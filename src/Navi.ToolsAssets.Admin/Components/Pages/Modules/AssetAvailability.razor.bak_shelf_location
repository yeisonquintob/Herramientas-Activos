@page "/asset-availability"
@rendermode InteractiveServer
@using Navi.ToolsAssets.Admin.Services.Auth
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject NaviAccessScopeService AccessScope
@inject WebAuthSessionService AuthSession

<PageTitle>Disponible y Ubicación de Herramientas - NAVI</PageTitle>

<PermissionGuard Permission="AssetAvailability.View" ModuleName="Disponible y Ubicación de Herramientas">

<section class="af-banner">
    <div>
        <span class="af-pill">ACTIVOS FIJOS</span>
        <h2>Disponible y Ubicación de Herramientas</h2>
        <p>Gestiona disponibilidad, sede, almacén, taller o ubicación interna de las herramientas.</p>
    </div>

    <div class="af-banner-side"><button class="btn btn-sm btn-outline-light" @onclick="LoadAsync">
            Actualizar
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="@messageClass">@message</div>
}

<section class="af-grid">
    <aside class="af-card">
        <h3>Gestionar ubicación</h3>

        <div class="mb-2 navi-search-field">
            <label class="form-label">Herramienta</label>
            <input class="form-control"
                   list="availability-tools-list"
                   value="@toolSearchText"
                   @oninput="OnToolSearchInput"
                   placeholder="Escriba código, nombre o serial..." />

            <datalist id="availability-tools-list">
                @foreach (var tool in ScopedTools.OrderBy(x => x.InternalCode))
                {
                    <option value="@FormatToolOption(tool)"></option>
                }
            </datalist>

            <small class="@GetToolSearchHintClass()">@GetToolSearchHint()</small>
        </div>

        <div class="mb-2 navi-search-field">
            <label class="form-label">Sede</label>
            <input class="form-control"
                   list="availability-branches-list"
                   value="@branchSearchText"
                   @oninput="OnBranchSearchInput"
                   placeholder="Escriba código o nombre de sede..." / disabled="@(!CanChangeAvailabilityLocation)">

            <datalist id="availability-branches-list">
                @foreach (var branch in branches.OrderBy(x => x.Code))
                {
                    <option value="@FormatBranchOption(branch)"></option>
                }
            </datalist>

            <small class="@GetBranchSearchHintClass()">@GetBranchSearchHint()</small>
        </div>

        <div class="mb-2 navi-search-field">
            <label class="form-label">Almacén / Taller / Ubicación</label>
            <input class="form-control"
                   list="availability-locations-list"
                   value="@locationSearchText"
                   @oninput="OnLocationSearchInput"
                   placeholder="Escriba almacén, taller o ubicación..." / disabled="@(!CanChangeAvailabilityLocation)">

            <datalist id="availability-locations-list">
                @foreach (var location in AvailableLocations.OrderBy(x => x.Code))
                {
                    <option value="@FormatLocationOption(location)"></option>
                }
            </datalist>

            <small class="@GetLocationSearchHintClass()">@GetLocationSearchHint()</small>
        </div>

        <div class="mb-2">
            <label class="form-label">Estado operativo</label>
            <InputSelect class="form-select" @bind-Value="form.OperationalStatus" disabled="@(!CanChangeAvailabilityStatus)">
                <option value="Available">Disponible</option>
                <option value="Assigned">Asignada</option>
                <option value="Loaned">Prestada</option>
                <option value="InMaintenance">En mantenimiento</option>
                <option value="Damaged">Dañada</option>
                <option value="NotSuitable">No apta</option>
                <option value="PendingValidation">Pendiente validación</option>
                <option value="NotLocated">No localizada</option>
                <option value="PendingDisposal">Pendiente baja</option>
                <option value="Disposed">Dada de baja</option>
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Observación</label>
            <InputTextArea class="form-control" @bind-Value="form.Observation" rows="3" />
        </div>

        <div class="d-grid gap-2">
            @if (!CanChangeAvailabilityLocation || !CanChangeAvailabilityStatus)
        {
            <div class="availability-permission-note">
                @if (!CanChangeAvailabilityLocation)
                {
                    <span>Ubicación bloqueada</span>
                }

                @if (!CanChangeAvailabilityStatus)
                {
                    <span>Estado bloqueado</span>
                }
            </div>
        }

        <button class="btn btn-primary" @onclick="SaveAsync" disabled="@(isSaving || !CanSaveAvailability || !form.ToolId.HasValue)">
                @(isSaving ? "Guardando..." : "Guardar cambios")
            </button>

            <button class="btn btn-outline-secondary" @onclick="ClearForm">
                Limpiar
            </button>
        </div>
    </aside>

    <section class="af-card">
        <div class="af-table-header">
            <div>
                <h3>Herramientas por disponibilidad</h3>
                <p>Selecciona una herramienta para modificar su ubicación.</p>
            </div>

            <div class="af-filters">
                <input class="form-control form-control-sm" placeholder="Buscar código, nombre, serial..." @bind="search" @bind:event="oninput" />

                <input class="form-control form-control-sm"
                       list="availability-filter-branches-list"
                       placeholder="Sede..."
                       @bind="selectedBranchCode"
                       @bind:event="oninput" />

                <datalist id="availability-filter-branches-list">
                    @foreach (var branch in branches.OrderBy(x => x.Code))
                    {
                        <option value="@branch.Code">@branch.Name</option>
                        <option value="@branch.Name">@branch.Code</option>
                    }
                </datalist>

                <select class="form-select form-select-sm" @bind="selectedStatus">
                    <option value="">Todos los estados</option>
                    <option value="Available">Disponible</option>
                    <option value="Assigned">Asignada</option>
                    <option value="Loaned">Prestada</option>
                    <option value="InMaintenance">En mantenimiento</option>
                    <option value="Damaged">Dañada</option>
                    <option value="NotLocated">No localizada</option>
                </select>
            </div>
        </div>

        @if (isLoading)
        {
            <p>Cargando herramientas...</p>
        }
        else
        {
            <table class="table table-hover align-middle af-table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Activo</th>
                        <th>Sede</th>
                        <th>Ubicación</th>
                        <th>Responsable</th>
                        <th>Estado</th>
                        <th class="text-end">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tool in FilteredTools)
                    {
                        <tr>
                            <td><strong>@tool.InternalCode</strong></td>
                            <td>
                                <div>@tool.Name</div>
                                <small class="text-muted">@tool.SerialNumber</small>
                            </td>
                            <td>@Show(tool.BranchCode)</td>
                            <td>@Show(tool.LocationName)</td>
                            <td>@Show(tool.ResponsiblePersonName)</td>
                            <td><span class="@GetStatusBadge(tool.OperationalStatus)">@GetStatusLabel(tool.OperationalStatus)</span></td>
                            <td class="text-end">
                                <button class="avail-action avail-action-primary" @onclick="() => SelectTool(tool)">
                                    Gestionar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</section>

</PermissionGuard>

