@rendermode InteractiveServer
@implements IDisposable
@using System.Text.Json
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.JSInterop
@using Navi.ToolsAssets.Admin.Services.Auth
@inject WebAuthSessionService AuthSession
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

@code {
    private const string StorageKey = "navi-auth-session";
    private bool initialized;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await RestoreSessionAsync();
        await RefreshCurrentRolePermissionsAsync();

        initialized = true;
        CheckCurrentRoute();
    }

    private async Task RestoreSessionAsync()
    {
        if (AuthSession.IsAuthenticated)
        {
            return;
        }

        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);

            if (string.IsNullOrWhiteSpace(json))
            {
                return;
            }

            var user = JsonSerializer.Deserialize<AuthSessionUser>(
                json,
                new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

            if (user is not null && !string.IsNullOrWhiteSpace(user.UserName))
            {
                AuthSession.Login(user);
            }
        }
        catch
        {
            try
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey);
            }
            catch
            {
                // Ignorar error JS.
            }
        }
    }

    private async Task RefreshCurrentRolePermissionsAsync()
    {
        if (!AuthSession.IsAuthenticated || AuthSession.RoleId is null)
        {
            return;
        }

        try
        {
            var api = HttpClientFactory.CreateClient("NaviApi");
            var roles = await api.GetFromJsonAsync<List<RoleRefreshDto>>("api/settings/roles") ?? new();

            var role = roles.FirstOrDefault(x => x.Id == AuthSession.RoleId.Value);

            if (role is null)
            {
                return;
            }

            var current = AuthSession.CurrentUser;

            if (current is null)
            {
                return;
            }

            current.RoleCode = role.Code;
            current.RoleName = role.Name;
            current.Permissions = ParsePermissions(role.Permissions).ToList();

            AuthSession.Login(current);

            var json = JsonSerializer.Serialize(current);
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
        }
        catch
        {
            // Si no se puede refrescar, se conserva la sesión actual.
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (!initialized)
        {
            return;
        }

        CheckCurrentRoute();
    }

    private void CheckCurrentRoute()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri)
            .Split('?', '#')[0]
            .Trim('/')
            .ToLowerInvariant();

        if (path == "login" || path == "access-denied")
        {
            return;
        }

        var requiredPermissions = GetRequiredPermissions(path);

        if (requiredPermissions.Length == 0)
        {
            return;
        }

        if (!AuthSession.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (!HasAnyRequiredPermission(requiredPermissions))
        {
            var startRoute = NaviPermissionRouteService.GetStartRoute(AuthSession);

            if ((string.IsNullOrWhiteSpace(path) || path == "dashboard") &&
                !string.Equals(startRoute, "/dashboard", StringComparison.OrdinalIgnoreCase) &&
                !string.Equals(startRoute, "/access-denied", StringComparison.OrdinalIgnoreCase))
            {
                Navigation.NavigateTo(startRoute, forceLoad: true);
                return;
            }

            Navigation.NavigateTo("/access-denied", forceLoad: true);
        }
    }

    private bool HasAnyRequiredPermission(string[] permissions)
    {
        foreach (var permission in permissions)
        {
            if (AuthSession.HasPermission(permission))
            {
                return true;
            }
        }

        return false;
    }

    private static string[] GetRequiredPermissions(string path)
    {
        if (string.IsNullOrWhiteSpace(path) || path == "dashboard")
        {
            return new[] { "Dashboard.View" };
        }

        if (path == "tools")
        {
            return new[] { "Tools.View" };
        }

        if (path.StartsWith("tools/") && path.Contains("/technical-life-record/edit"))
        {
            return new[] { "TechnicalLifeRecord.Edit" };
        }

        if (path.StartsWith("tools/") && path.Contains("/technical-life-record-view"))
        {
            return new[] { "ToolDetail.LifeRecord.Open", "TechnicalLifeRecord.View" };
        }

        if (path.StartsWith("tools/") && path.Contains("/life-record-view"))
        {
            return new[] { "ToolDetail.LifeRecord.Open", "TechnicalLifeRecord.View" };
        }

        if (path.StartsWith("tools/") && path.Contains("/technical-life-record"))
        {
            return new[] { "TechnicalLifeRecord.View", "ToolDetail.LifeRecord.Open" };
        }

        if (path.StartsWith("tools/") && path.Contains("/accessories"))
        {
            return new[] { "TechnicalLifeRecord.Accessories", "TechnicalLifeRecord.Edit" };
        }

        if (path.StartsWith("tools/") && path.Contains("/safe-practices"))
        {
            return new[] { "TechnicalLifeRecord.SafePractices", "TechnicalLifeRecord.Edit", "SafePractices.Manage" };
        }

        if (path.StartsWith("tools/") && path.Contains("/maintenance-schedule"))
        {
            return new[]
            {
                "MaintenancePlans.View",
                "MaintenancePlans.Create",
                "MaintenancePlans.Edit",
                "MaintenancePlans.Delete",
                "TechnicalLifeRecord.Maintenance",
                "TechnicalLifeRecord.Edit"
            };
        }

        if (path.StartsWith("tools/") && path.Contains("/documents"))
        {
            return new[] { "TechnicalLifeRecord.Documents", "Documents.View" };
        }

        if (path.StartsWith("tools/") && path.Contains("/life-cycle"))
        {
            return new[] { "TechnicalLifeRecord.View", "ToolDetail.LifeRecord.Open" };
        }

        if (path.StartsWith("tools/"))
        {
            return new[] { "ToolDetail.View" };
        }

        if (path == "asset-availability")
        {
            return new[] { "AssetAvailability.View" };
        }

        if (path == "asset-assignment")
        {
            return new[] { "AssetAssignment.View" };
        }

        if (path == "asset-assignment-history")
        {
            return new[] { "AssetAssignment.History" };
        }

        if (path == "technical-life-records")
        {
            return new[] { "TechnicalLifeRecord.View" };
        }

        if (path == "documents")
        {
            return new[] { "Documents.View" };
        }

        if (path == "reports")
        {
            return new[] { "Reports.View" };
        }

        if (path == "physical-counts")
        {
            return new[] { "PhysicalCounts.View" };
        }

        if (path == "reconciliation")
        {
            return new[] { "Reconciliation.View" };
        }

        if (path == "maintenance")
        {
            return new[] { "Maintenance.View", "Purchases.View" };
        }

        if (path == "maintenance-request")
        {
            return new[] { "Maintenance.Request" };
        }

        if (path == "maintenance-plans")
        {
            return new[] { "MaintenancePlans.View", "Maintenance.View" };
        }

        if (path == "mro-purchases" || path == "purchases/mro")
        {
            return new[] { "Purchases.Request" };
        }

        if (path == "approvals")
        {
            return new[] { "Purchases.Approve" };
        }

        if (path == "settings/users")
        {
            return new[] { "Security.Users" };
        }

        if (path == "settings/roles")
        {
            return new[] { "Security.Roles" };
        }

        if (path.StartsWith("settings/"))
        {
            return new[] { "Settings.View" };
        }

        if (path == "settings")
        {
            return new[] { "Settings.View" };
        }

        return Array.Empty<string>();
    }

    private static IEnumerable<string> ParsePermissions(string? permissions)
    {
        if (string.IsNullOrWhiteSpace(permissions))
        {
            return Array.Empty<string>();
        }

        if (permissions.Equals("ALL", StringComparison.OrdinalIgnoreCase))
        {
            return Array.Empty<string>();
        }

        return permissions
            .Split(new[] { ',', ';', '|', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase);
    }

    private sealed class RoleRefreshDto
    {
        public Guid Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Permissions { get; set; }
        public bool IsActive { get; set; }
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
