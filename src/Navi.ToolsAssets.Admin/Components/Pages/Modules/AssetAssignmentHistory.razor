@code {
    [SupplyParameterFromQuery(Name = "responsiblePersonId")]
    public Guid? ResponsiblePersonId { get; set; }

    [SupplyParameterFromQuery(Name = "q")]
    public string? Query { get; set; }

    private HttpClient Api => HttpClientFactory.CreateClient("NaviApi");

    private List<ResponsibleItem> responsibles = new();
    private List<AssignmentHistoryItem> historyItems = new();

    private bool isLoading;
    private string selectedResponsibleId = string.Empty;
    private string selectedBranchCode = string.Empty;
    private string search = string.Empty;
    private HashSet<string> selectedStatuses = new(StringComparer.OrdinalIgnoreCase);

    private readonly (string Value, string Text)[] StatusOptions =
    {
        ("Available", "Disponible"),
        ("Assigned", "Asignada"),
        ("Loaned", "Prestada"),
        ("InMaintenance", "Mantenimiento"),
        ("Damaged", "Dañada"),
        ("NotSuitable", "No apta"),
        ("PendingValidation", "Pendiente validación"),
        ("NotLocated", "No localizada"),
        ("Disposed", "Baja")
    };

    private IEnumerable<ResponsibleItem> VisibleResponsibles =>
        responsibles.OrderBy(x => x.FullName);

    private IEnumerable<string> BranchOptions =>
        historyItems
            .Where(x => AccessScope.CanSeeBranch(x.CurrentBranchCode))
            .Select(x => x.CurrentBranchCode)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Select(x => x!)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x);

    private IEnumerable<AssignmentHistoryItem> VisibleHistory =>
        historyItems
            .Where(x => AccessScope.CanSeeBranch(x.CurrentBranchCode));

    private IEnumerable<AssignmentHistoryItem> FilteredHistory =>
        VisibleHistory
            .Where(MatchesResponsibleFilter)
            .Where(MatchesBranchFilter)
            .Where(MatchesStatusFilter)
            .Where(MatchesSearchFilter)
            .OrderByDescending(x => x.AssignedAt);

    private int VisibleBranchCount =>
        VisibleHistory
            .Select(x => x.CurrentBranchCode)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count();

    private string ScopeLabel =>
        AccessScope.IsAllBranchScope() || AccessScope.IsAdminRole()
            ? "Todas las sedes"
            : AuthSession.BranchCode;

    private string SelectedResponsibleLabel
    {
        get
        {
            if (string.IsNullOrWhiteSpace(selectedResponsibleId))
            {
                return "Todos";
            }

            var selected = responsibles.FirstOrDefault(x => x.Id.ToString() == selectedResponsibleId);
            return selected?.FullName ?? "Seleccionado";
        }
    }

    private string SelectedStatusLabel =>
        selectedStatuses.Count == 0
            ? "Todos"
            : selectedStatuses.Count == 1
                ? StatusOptions.FirstOrDefault(x => selectedStatuses.Contains(x.Value)).Text ?? "1"
                : $"{selectedStatuses.Count} seleccionados";

    protected override async Task OnInitializedAsync()
    {
        search = Query ?? string.Empty;

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        responsibles = await Api.GetFromJsonAsync<List<ResponsibleItem>>("api/settings/responsibles") ?? new();

        if (ResponsiblePersonId.HasValue)
        {
            selectedResponsibleId = ResponsiblePersonId.Value.ToString();
        }
        else if (string.IsNullOrWhiteSpace(selectedResponsibleId) && AuthSession.ResponsiblePersonId.HasValue)
        {
            selectedResponsibleId = AuthSession.ResponsiblePersonId.Value.ToString();
        }

        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        isLoading = true;

        try
        {
            var endpoint = string.IsNullOrWhiteSpace(selectedResponsibleId)
                ? "api/tools/assignment-history"
                : $"api/tools/assignment-history?responsiblePersonId={Uri.EscapeDataString(selectedResponsibleId)}";

            historyItems = await Api.GetFromJsonAsync<List<AssignmentHistoryItem>>(endpoint) ?? new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ClearFilters()
    {
        search = string.Empty;
        selectedBranchCode = string.Empty;
        selectedStatuses.Clear();

        selectedResponsibleId = AuthSession.ResponsiblePersonId.HasValue
            ? AuthSession.ResponsiblePersonId.Value.ToString()
            : string.Empty;

        await LoadHistoryAsync();
    }

    private void ToggleStatus(string status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return;
        }

        if (!selectedStatuses.Add(status))
        {
            selectedStatuses.Remove(status);
        }
    }

    private void ClearStatusFilter()
    {
        selectedStatuses.Clear();
    }

    private bool MatchesResponsibleFilter(AssignmentHistoryItem item)
    {
        if (string.IsNullOrWhiteSpace(selectedResponsibleId))
        {
            return true;
        }

        return item.CurrentResponsiblePersonId.HasValue &&
               item.CurrentResponsiblePersonId.Value.ToString().Equals(selectedResponsibleId, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesBranchFilter(AssignmentHistoryItem item)
    {
        if (string.IsNullOrWhiteSpace(selectedBranchCode))
        {
            return true;
        }

        return SameNormalized(item.CurrentBranchCode, selectedBranchCode);
    }

    private bool MatchesStatusFilter(AssignmentHistoryItem item)
    {
        return selectedStatuses.Count == 0 ||
               selectedStatuses.Contains(item.CurrentStatus ?? string.Empty);
    }

    private bool MatchesSearchFilter(AssignmentHistoryItem item)
    {
        if (string.IsNullOrWhiteSpace(search))
        {
            return true;
        }

        return ContainsText(item.ToolInternalCode, search) ||
               ContainsText(item.ToolName, search) ||
               ContainsText(item.ToolSerialNumber, search) ||
               ContainsText(item.Detail, search) ||
               ContainsText(item.ReturnDetail, search) ||
               ContainsText(item.CurrentResponsibleName, search) ||
               ContainsText(item.CurrentBranchCode, search) ||
               ContainsText(item.CurrentLocationName, search) ||
               ContainsText(GetStatusLabel(item.CurrentStatus ?? string.Empty), search);
    }

    private void GoBackToAssignment()
    {
        NavigationManager.NavigateTo("/asset-assignment");
    }

    private static bool ContainsText(string? value, string expected)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               !string.IsNullOrWhiteSpace(expected) &&
               Normalize(value).Contains(Normalize(expected), StringComparison.OrdinalIgnoreCase);
    }

    private static bool SameNormalized(string? left, string? right)
    {
        var a = Normalize(left);
        var b = Normalize(right);

        return !string.IsNullOrWhiteSpace(a)
            && !string.IsNullOrWhiteSpace(b)
            && string.Equals(a, b, StringComparison.OrdinalIgnoreCase);
    }

    private static string Normalize(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value
            .Trim()
            .ToUpperInvariant()
            .Replace("Á", "A")
            .Replace("É", "E")
            .Replace("Í", "I")
            .Replace("Ó", "O")
            .Replace("Ú", "U")
            .Replace("Ü", "U")
            .Replace("Ñ", "N");
    }

    private static string Show(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string ShowDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("dd/MM/yyyy") : "—";
    }

    private static string GetStatusLabel(string status) => status switch
    {
        "Available" => "Disponible",
        "Assigned" => "Asignada",
        "Loaned" => "Prestada",
        "InMaintenance" => "En mantenimiento",
        "Damaged" => "Dañada",
        "NotSuitable" => "No apta",
        "NotLocated" => "No localizada",
        "PendingValidation" => "Pendiente validación",
        "Disposed" => "Baja",
        _ => Show(status)
    };

    private static string GetStatusBadge(string status) => status switch
    {
        "Available" => "badge bg-success",
        "Assigned" => "badge bg-warning text-dark",
        "Loaned" => "badge bg-info text-dark",
        "InMaintenance" => "badge bg-primary",
        "Damaged" => "badge bg-danger",
        "NotSuitable" => "badge bg-danger",
        "NotLocated" => "badge bg-dark",
        "PendingValidation" => "badge bg-secondary",
        "Disposed" => "badge bg-dark",
        _ => "badge bg-secondary"
    };

    private sealed class ResponsibleItem
    {
        public Guid Id { get; set; }
        public string FullName { get; set; } = string.Empty;
    }

    private sealed class AssignmentHistoryItem
    {
        public Guid Id { get; set; }
        public Guid ToolAssetId { get; set; }
        public string ToolInternalCode { get; set; } = string.Empty;
        public string ToolName { get; set; } = string.Empty;
        public string? ToolSerialNumber { get; set; }
        public string? CurrentBranchCode { get; set; }
        public string? CurrentLocationName { get; set; }
        public Guid? CurrentResponsiblePersonId { get; set; }
        public string? CurrentResponsibleName { get; set; }
        public string? CurrentStatus { get; set; }
        public DateTime? AssignedAt { get; set; }
        public DateTime? ReturnedAt { get; set; }
        public string? ReturnDetail { get; set; }
        public string? Detail { get; set; }
    }
}
