@page "/"
@page "/dashboard"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components
@using Navi.ToolsAssets.Admin.Components.Shared
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Dashboard - NAVI</PageTitle>

<PermissionGuard Permission="Dashboard.View" ModuleName="Dashboard">

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (isLoading && dashboard is null)
{
    <div class="alert alert-info">Cargando dashboard...</div>
}
else if (dashboard is not null)
{
    <section class="dash-board">
        <section class="dash-hero">
            <div>
                <span>Estado</span>
                <p>Control operativo de herramientas, activos, responsables, diferencias, mantenimientos y hojas de vida.</p>
            </div>

            <div class="dash-hero-actions">
                <strong>En progreso</strong>
                <button type="button" @onclick="LoadDashboardAsync" disabled="@isLoading">
                    @(isLoading ? "Actualizando..." : "Actualizar")
                </button>
            </div>
        </section>

        <section class="dash-kpis">
            <article class="purple">
                <span>PARTICIPANTES</span>
                <strong>@dashboard.Summary.ActiveResponsibles</strong>
                <small>Usuario / responsable</small>
            </article>

            <article class="cyan">
                <span>EN PROCESO</span>
                <strong>@GetInProcess()</strong>
                <small>Inventario activo</small>
            </article>

            <article class="green">
                <span>FINALIZADOS</span>
                <strong>@dashboard.Summary.WithLifeRecord</strong>
                <small>Con hoja de vida</small>
            </article>

            <article class="yellow">
                <span>PENDIENTES</span>
                <strong>@GetPendingTotal()</strong>
                <small>Herramientas por validar</small>
            </article>

            <article class="red">
                <span>DIFERENCIAS</span>
                <strong>@GetDifferences()</strong>
                <small>Conciliación</small>
            </article>

            <article class="purple">
                <span>AVANCE</span>
                <strong>@GetAdvancePercent()%</strong>
                <small>@dashboard.Summary.WithLifeRecord de @dashboard.Summary.TotalTools</small>
            </article>
        </section>

        <section class="dash-layout">
            <article class="dash-card dash-local">
                <h3>Local de herramientas</h3>

                <div class="dash-local-list">
                    <div>
                        <span>
                            <b class="dash-svg green">@GetMiniIcon("total")</b>
                            Total herramientas
                        </span>
                        <strong>@dashboard.Summary.TotalTools</strong>
                    </div>

                    <div>
                        <span>
                            <b class="dash-svg green">@GetMiniIcon("check")</b>
                            Disponibles
                        </span>
                        <strong>@dashboard.Summary.AvailableTools</strong>
                    </div>

                    <div>
                        <span>
                            <b class="dash-svg blue">@GetMiniIcon("user")</b>
                            Asignadas
                        </span>
                        <strong>@dashboard.Summary.AssignedTools</strong>
                    </div>

                    <div>
                        <span>
                            <b class="dash-svg cyan">@GetMiniIcon("tool")</b>
                            En mantenimiento
                        </span>
                        <strong>@dashboard.Summary.InMaintenanceTools</strong>
                    </div>

                    <div>
                        <span>
                            <b class="dash-svg yellow">@GetMiniIcon("clock")</b>
                            Pendientes validación
                        </span>
                        <strong>@dashboard.Summary.PendingValidationTools</strong>
                    </div>

                    <div>
                        <span>
                            <b class="dash-svg red">@GetMiniIcon("close")</b>
                            Desactivadas / baja
                        </span>
                        <strong>@dashboard.Summary.DisposedTools</strong>
                    </div>
                </div>
            </article>

            <article class="dash-card dash-maintenance">
                <div class="dash-card-head">
                    <h3>Mantenimientos realizados</h3>

                    <div class="dash-tabs">
                        <span>Por mes</span>
                        <span>Por día</span>
                    </div>
                </div>

                <div class="dash-maintenance-grid">
                    <div>
                        <span>Por mes</span>
                        <strong>@dashboard.MaintenanceSummary.ThisMonth</strong>
                    </div>

                    <div>
                        <span>Por día</span>
                        <strong>@dashboard.MaintenanceSummary.Today</strong>
                    </div>

                    <div>
                        <span>En proceso</span>
                        <strong>@dashboard.Summary.InMaintenanceTools</strong>
                    </div>

                    <div>
                        <span>Pendientes</span>
                        <strong>@dashboard.Summary.RequiresMaintenance</strong>
                    </div>
                </div>
            </article>

            <section class="dash-middle-stack">
                <article class="dash-card dash-vs">
                    <h3>Herramientas vs activos</h3>

                    <div class="dash-vs-grid">
                        <div>
                            <span>Herramientas</span>
                            <strong>@dashboard.Summary.ToolsOnly</strong>
                        </div>

                        <div>
                            <span>Activos fijos</span>
                            <strong>@dashboard.Summary.FixedAssets</strong>
                        </div>
                    </div>
                </article>

                <article class="dash-card dash-mini">
                    <h3>Mantenimientos por día</h3>

                    <div class="dash-mini-metrics">
                        <div>
                            <strong>@dashboard.MaintenanceSummary.ThisMonth</strong>
                            <span>Por mes</span>
                        </div>

                        <div>
                            <strong>@dashboard.MaintenanceSummary.Today</strong>
                            <span>Por día</span>
                        </div>

                        <div>
                            <strong>@dashboard.Summary.RequiresMaintenance</strong>
                            <span>Pendientes</span>
                        </div>
                    </div>
                </article>

                <article class="dash-card dash-mini dash-physical">
                    <h3>Toma física</h3>
                    <p>Acciones rápidas para gestión de toma física y conciliación.</p>

                    <div class="dash-actions">
                        <a href="/physical-counts">Volver</a>
                        <a href="/physical-counts">Generar participantes</a>
                        <a href="/physical-counts">Activar toma</a>
                        <a href="/reconciliation">Conciliar</a>
                    </div>
                </article>
            </section>

            <section class="dash-charts-zone">
                <article class="dash-card dash-chart">
                    <h3>Distribución de activos fijos</h3>

                    <div class="dash-chart-content">
                        <div class="dash-donut xl" style="@GetToolsVsAssetsDonut()">
                            <div>
                                <strong>@dashboard.Summary.TotalTools</strong>
                                <span>Total</span>
                            </div>
                        </div>

                        <div class="dash-legend">
                            <div><i class="purple"></i><span>Herramientas</span><strong>@dashboard.Summary.ToolsOnly</strong><small>@GetPercentLabel(dashboard.Summary.ToolsOnly, dashboard.Summary.TotalTools)</small></div>
                            <div><i class="blue"></i><span>Activos fijos</span><strong>@dashboard.Summary.FixedAssets</strong><small>@GetPercentLabel(dashboard.Summary.FixedAssets, dashboard.Summary.TotalTools)</small></div>
                            <div><i class="orange"></i><span>Sin código AF</span><strong>@dashboard.Summary.ToolsWithoutFixedAssetCode</strong><small>@GetPercentLabel(dashboard.Summary.ToolsWithoutFixedAssetCode, dashboard.Summary.TotalTools)</small></div>
                        </div>
                    </div>
                </article>

                <article class="dash-card dash-chart">
                    <h3>Herramientas por sede</h3>

                    <div class="dash-branch-bars">
                        @foreach (var item in GetBranchChartItems())
                        {
                            <div>
                                <strong style="@GetBranchBarStyle(item.Branch.Total, item.Index)"></strong>
                                <span>@item.Branch.BranchCode</span>
                                <small>@item.Branch.Total</small>
                            </div>
                        }
                    </div>
                </article>

                <article class="dash-card dash-chart">
                    <h3>Herramientas por mes</h3>

                    <div class="dash-chart-content">
                        <div class="dash-donut md" style="@GetMaintenanceDonut()">
                            <div>
                                <strong>@GetMaintenanceTotalForChart()</strong>
                                <span>Total</span>
                            </div>
                        </div>

                        <div class="dash-legend compact">
                            <div><i class="blue"></i><span>Asignada</span><strong>@dashboard.Summary.AssignedTools</strong></div>
                            <div><i class="orange"></i><span>Disponible</span><strong>@dashboard.Summary.AvailableTools</strong></div>
                            <div><i class="red"></i><span>Pendientes</span><strong>@dashboard.Summary.PendingValidationTools</strong></div>
                            <div><i class="purple"></i><span>Técnico</span><strong>@dashboard.Summary.InMaintenanceTools</strong></div>
                            <div><i class="gray"></i><span>Otras</span><strong>@GetOtherMaintenance()</strong></div>
                        </div>
                    </div>
                </article>

                <article class="dash-card dash-chart">
                    <h3>Hojas de vida</h3>

                    <div class="dash-chart-content">
                        <div class="dash-donut md" style="@GetLifeRecordDonut()">
                            <div>
                                <strong>@dashboard.Summary.WithLifeRecord</strong>
                                <span>Con HV</span>
                            </div>
                        </div>

                        <div class="dash-legend compact">
                            <div><i class="purple"></i><span>Con hoja</span><strong>@dashboard.Summary.WithLifeRecord</strong></div>
                            <div><i class="orange"></i><span>Sin hoja</span><strong>@dashboard.Summary.WithoutLifeRecord</strong></div>
                            <div><i class="red"></i><span>Datos incompletos</span><strong>@dashboard.LifeRecordCoverage.MissingTechnicalData</strong></div>
                            <div><i class="blue"></i><span>Activos fijos</span><strong>@dashboard.Summary.FixedAssets</strong></div>
                            <div><i class="gray"></i><span>Otras</span><strong>@GetOtherLifeRecords()</strong></div>
                        </div>
                    </div>
                </article>
            </section>

            <article class="dash-card dash-table-card">
                <h3>Resumen por sede / responsable</h3>

                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Sede</th>
                            <th>Asignadas</th>
                            <th>Válidas</th>
                            <th>Diferencias</th>
                            <th>Avance</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in dashboard.ToolsByBranch.Take(7))
                        {
                            var assigned = GetBranchAssigned(item.Total);
                            var valid = GetBranchValidated(item.Total);
                            var difference = GetBranchDifferences(item.Total);
                            var percent = GetBranchAdvance(item.Total);

                            <tr>
                                <td>
                                    <div class="dash-branch-name">
                                        <strong>@item.BranchCode</strong>
                                        <span>@item.BranchName</span>
                                    </div>
                                </td>

                                <td>@assigned</td>
                                <td>@valid</td>

                                <td>
                                    <span class="dash-difference">@difference</span>
                                </td>

                                <td>
                                    <div class="dash-progress">
                                        <span style="@($"width:{percent}%")"></span>
                                    </div>
                                    <small>@percent%</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </article>

            <section class="dash-bottom-columns">
                <article class="dash-card dash-column">
                    <h3>Pendientes</h3>

                    <div class="dash-column-list">
                        @foreach (var item in GetPendingItems().Take(6))
                        {
                            <div>
                                <strong>@item.Title</strong>
                                <span>@item.Description</span>
                                <small>@item.Value</small>
                            </div>
                        }
                    </div>
                </article>

                <article class="dash-card dash-column">
                    <h3>Históricos</h3>

                    @if (dashboard.RecentActivity.Any())
                    {
                        <div class="dash-column-list">
                            @foreach (var item in dashboard.RecentActivity.Take(6))
                            {
                                <div>
                                    <strong>@item.Title</strong>
                                    <span>@Display(item.Description)</span>
                                    <small>@item.RegisteredAt.ToString("dd/MM/yyyy HH:mm") · @Display(item.User)</small>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="dash-column-list">
                            <div>
                                <strong>Sin historial reciente</strong>
                                <span>No hay eventos recientes para mostrar.</span>
                                <small>Dashboard operativo</small>
                            </div>
                        </div>
                    }
                </article>
            </section>
        </section>
    </section>
}

</PermissionGuard>

<style>
    .dash-board {
        display: grid;
        gap: .65rem;
        padding-bottom: 1rem;
    }

    .dash-hero {
        background:
            radial-gradient(circle at top right, rgba(208, 32, 224, .32), transparent 34%),
            linear-gradient(135deg, #060009 0%, #250030 45%, #8a0b99 100%);
        color: #fff;
        border-radius: .85rem;
        padding: .78rem 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .8rem;
        box-shadow: 0 .65rem 1.3rem rgba(75, 0, 92, .20);
    }

    .dash-hero span {
        display: block;
        color: #fff;
        font-size: .82rem;
        font-weight: 950;
    }

    .dash-hero p {
        margin: .12rem 0 0;
        color: rgba(255,255,255,.86);
        font-size: .86rem;
        font-weight: 700;
    }

    .dash-hero-actions {
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .dash-hero-actions strong,
    .dash-hero-actions button {
        border-radius: .55rem;
        color: #fff;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        padding: .43rem .65rem;
        font-size: .76rem;
        font-weight: 950;
        white-space: nowrap;
    }

    .dash-kpis {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: .5rem;
    }

    .dash-kpis article {
        background: #fff;
        border-radius: .65rem;
        border: 1px solid #eadff0;
        border-left: 4px solid #7b0d8e;
        padding: .55rem .65rem;
        box-shadow: 0 .25rem .65rem rgba(75,0,92,.055);
    }

    .dash-kpis article.cyan { border-left-color: #2186d9; }
    .dash-kpis article.green { border-left-color: #16a34a; }
    .dash-kpis article.yellow { border-left-color: #f0a224; }
    .dash-kpis article.red { border-left-color: #b4232e; }

    .dash-kpis span {
        display: block;
        color: #1f1427;
        font-size: .62rem;
        font-weight: 950;
    }

    .dash-kpis strong {
        display: block;
        color: #060009;
        font-size: 1.48rem;
        font-weight: 950;
        line-height: 1;
    }

    .dash-kpis small {
        color: #55445f;
        font-size: .64rem;
        font-weight: 750;
    }

    .dash-layout {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr 1.14fr 1.14fr;
        grid-template-areas:
            "local maintenance middle charts charts"
            "table table table charts charts"
            "bottom bottom bottom bottom bottom";
        gap: .65rem;
        align-items: stretch;
    }

    .dash-card {
        background: #fff;
        border: 1px solid #eadff0;
        border-radius: .82rem;
        padding: .72rem;
        box-shadow: 0 .28rem .75rem rgba(75,0,92,.055);
        min-height: 132px;
    }

    .dash-card h3 {
        margin: 0 0 .5rem;
        color: #100018;
        font-size: .92rem;
        font-weight: 950;
    }

    .dash-local {
        grid-area: local;
    }

    .dash-maintenance {
        grid-area: maintenance;
    }

    .dash-middle-stack {
        grid-area: middle;
        display: grid;
        grid-template-rows: 1fr .86fr .96fr;
        gap: .65rem;
    }

    .dash-charts-zone {
        grid-area: charts;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        grid-auto-rows: 1fr;
        gap: .65rem;
    }

    .dash-table-card {
        grid-area: table;
        min-height: 286px;
    }

    .dash-bottom-columns {
        grid-area: bottom;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .65rem;
    }

    .dash-local-list {
        display: grid;
        gap: .26rem;
    }

    .dash-local-list div {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: .55rem;
        align-items: center;
        font-size: .76rem;
    }

    .dash-local-list span {
        display: flex;
        align-items: center;
        gap: .45rem;
        color: #24102e;
        font-weight: 820;
    }

    .dash-local-list strong {
        color: #0d0013;
        font-weight: 950;
    }

    .dash-svg {
        width: 20px;
        height: 20px;
        display: inline-grid;
        place-items: center;
        border-radius: 50%;
        border: 1px solid currentColor;
        background: #fff;
        flex: 0 0 auto;
    }

    .dash-svg svg {
        width: 13px;
        height: 13px;
        stroke: currentColor;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        fill: none;
        display: block;
    }

    .dash-svg.green { color: #16a34a; }
    .dash-svg.blue { color: #2186d9; }
    .dash-svg.cyan { color: #0ea5e9; }
    .dash-svg.yellow { color: #f0a224; }
    .dash-svg.red { color: #b4232e; }

    .dash-card-head {
        display: flex;
        justify-content: space-between;
        gap: .5rem;
        align-items: center;
        margin-bottom: .3rem;
    }

    .dash-tabs {
        display: flex;
        gap: .25rem;
    }

    .dash-tabs span {
        background: #7b0d8e;
        color: #fff;
        border-radius: .45rem;
        padding: .25rem .5rem;
        font-size: .68rem;
        font-weight: 950;
    }

    .dash-tabs span + span {
        background: #f7eef9;
        color: #32103d;
        border: 1px solid #eadff0;
    }

    .dash-maintenance-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: .45rem;
        height: calc(100% - 1.8rem);
        align-content: center;
    }

    .dash-maintenance-grid div,
    .dash-vs-grid div {
        text-align: center;
        border-radius: .65rem;
        border: 1px solid #eadff0;
        background: #fbf6fd;
        padding: .5rem;
    }

    .dash-maintenance-grid span,
    .dash-vs-grid span {
        display: block;
        color: #5b4666;
        font-size: .68rem;
        font-weight: 850;
    }

    .dash-maintenance-grid strong {
        display: block;
        color: #0c0012;
        font-size: 1.2rem;
        font-weight: 950;
        line-height: 1;
        margin-top: .15rem;
    }

    .dash-vs-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: .45rem;
    }

    .dash-vs-grid strong {
        display: block;
        color: #060009;
        font-size: 1.75rem;
        font-weight: 950;
        line-height: 1;
        margin-top: .22rem;
    }

    .dash-mini {
        min-height: unset;
    }

    .dash-mini-metrics {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .4rem;
        align-items: center;
    }

    .dash-mini-metrics div {
        text-align: center;
        border-right: 1px solid #eadff0;
    }

    .dash-mini-metrics div:last-child {
        border-right: 0;
    }

    .dash-mini-metrics strong {
        display: block;
        color: #0a0010;
        font-size: 1.25rem;
        font-weight: 950;
        line-height: 1;
    }

    .dash-mini-metrics span {
        color: #55445f;
        font-size: .66rem;
        font-weight: 850;
    }

    .dash-physical p {
        color: #5d4a67;
        font-size: .72rem;
        margin: 0 0 .45rem;
    }

    .dash-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
    }

    .dash-actions a {
        text-decoration: none;
        border-radius: .45rem;
        padding: .34rem .5rem;
        color: #fff;
        background: linear-gradient(135deg, #7b0d8e, #4b005c);
        font-size: .66rem;
        font-weight: 900;
    }

    .dash-chart {
        min-height: 210px;
        display: grid;
        grid-template-rows: auto 1fr;
    }

    .dash-chart-content {
        display: grid;
        grid-template-columns: 124px 1fr;
        align-items: center;
        gap: .55rem;
    }

    .dash-donut {
        border-radius: 50%;
        position: relative;
        display: grid;
        place-items: center;
        box-shadow:
            inset 0 0 0 1px rgba(75,0,92,.12),
            0 .25rem .6rem rgba(75,0,92,.08);
    }

    .dash-donut.xl {
        width: 116px;
        height: 116px;
    }

    .dash-donut.md {
        width: 104px;
        height: 104px;
    }

    .dash-donut::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        background: #fff;
        box-shadow: inset 0 0 0 1px #eadff0;
    }

    .dash-donut.xl::after {
        inset: 25px;
    }

    .dash-donut.md::after {
        inset: 22px;
    }

    .dash-donut div {
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .dash-donut strong {
        display: block;
        color: #07000d;
        font-size: 1.15rem;
        font-weight: 950;
        line-height: 1;
    }

    .dash-donut span {
        display: block;
        color: #5d4a67;
        font-size: .56rem;
        font-weight: 850;
        margin-top: .18rem;
    }

    .dash-legend {
        display: grid;
        gap: .28rem;
        font-size: .69rem;
    }

    .dash-legend.compact {
        font-size: .66rem;
        gap: .2rem;
    }

    .dash-legend div {
        display: grid;
        grid-template-columns: 9px 1fr auto auto;
        gap: .3rem;
        align-items: center;
    }

    .dash-legend.compact div {
        grid-template-columns: 9px 1fr auto;
    }

    .dash-legend i {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .dash-legend .purple { background: #7b0d8e; }
    .dash-legend .blue { background: #2186d9; }
    .dash-legend .orange { background: #f0a224; }
    .dash-legend .red { background: #b4232e; }
    .dash-legend .gray { background: #64748b; }

    .dash-legend span {
        color: #2a1734;
        font-weight: 800;
    }

    .dash-legend strong {
        color: #0a0010;
        font-weight: 950;
    }

    .dash-legend small {
        color: #66536f;
        font-weight: 850;
    }

    .dash-branch-bars {
        height: 150px;
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: .48rem;
        align-items: end;
        border-left: 1px solid #eadff0;
        border-bottom: 1px solid #eadff0;
        padding: .25rem .3rem 0;
    }

    .dash-branch-bars div {
        height: 100%;
        display: grid;
        align-items: end;
        text-align: center;
    }

    .dash-branch-bars strong {
        display: block;
        min-height: 8px;
        border-radius: .36rem .36rem 0 0;
    }

    .dash-branch-bars span {
