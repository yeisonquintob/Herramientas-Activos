:root {
    --navi-purple: #4b005c;
    --navi-purple-2: #7b0d8e;
    --navi-bg: #f6f1f8;
    --navi-card: #ffffff;
    --navi-text: #25112f;
    --navi-muted: #756a7f;
    --navi-border: #eadff0;
}

* {
    box-sizing: border-box;
}

html,
body {
    margin: 0;
    min-height: 100%;
    font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--navi-bg);
    color: var(--navi-text);
}

a {
    color: inherit;
}

.mobile-shell {
    min-height: 100vh;
    background:
        radial-gradient(circle at top right, rgba(123, 13, 142, .22), transparent 34%),
        linear-gradient(180deg, #fbf7fc 0%, #f1e8f5 100%);
}

.mobile-main {
    min-height: 100vh;
    padding-bottom: 92px;
}

.mobile-page {
    width: min(560px, 100%);
    margin: 0 auto;
    padding: 1rem;
}

.mobile-login-page {
    min-height: 100vh;
    display: grid;
    align-content: center;
    gap: 1.2rem;
    padding: 1.25rem;
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.24), transparent 28%),
        linear-gradient(135deg, #16001d 0%, #4b005c 58%, #7b0d8e 100%);
    color: white;
}

.mobile-login-brand {
    text-align: center;
}

.mobile-brand-mark {
    width: 70px;
    height: 70px;
    margin: 0 auto .8rem;
    border-radius: 1.1rem;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #8f1bb1, #3b0048);
    color: #fff;
    font-size: 2.1rem;
    font-weight: 950;
    box-shadow: 0 1rem 2rem rgba(0,0,0,.25);
}

.mobile-login-brand h1,
.mobile-login-card h2,
.mobile-hero h1 {
    margin: 0;
    font-weight: 950;
    letter-spacing: -.04rem;
}

.mobile-login-brand p,
.mobile-login-card p,
.mobile-hero p {
    margin: .35rem 0 0;
    color: rgba(255,255,255,.78);
    font-weight: 700;
}

.mobile-login-card,
.mobile-form-card,
.mobile-panel,
.mobile-kpi-card,
.mobile-action-card,
.mobile-tool-card,
.mobile-empty,
.mobile-loading {
    background: var(--navi-card);
    border: 1px solid var(--navi-border);
    border-radius: 1.15rem;
    box-shadow: 0 1rem 2.4rem rgba(75, 0, 92, .10);
}

.mobile-login-card {
    color: var(--navi-text);
    padding: 1.25rem;
}

.mobile-login-card p {
    color: var(--navi-muted);
    margin-bottom: 1rem;
}

.mobile-pill {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: .2rem .62rem;
    border-radius: 999px;
    background: rgba(123, 13, 142, .10);
    color: var(--navi-purple);
    font-size: .68rem;
    font-weight: 950;
    letter-spacing: .05rem;
}

.mobile-login-page .mobile-pill {
    background: rgba(75, 0, 92, .10);
}

.mobile-login-card label,
.mobile-form-card label {
    display: block;
    color: #2f1938;
    font-size: .8rem;
    font-weight: 950;
    margin-top: .85rem;
}

.mobile-input,
.mobile-search {
    width: 100%;
    min-height: 46px;
    margin-top: .38rem;
    border: 1px solid #dfd4e7;
    border-radius: .75rem;
    padding: .7rem .85rem;
    background: #fff;
    color: var(--navi-text);
    font-size: .92rem;
    outline: none;
}

.mobile-input:focus,
.mobile-search:focus {
    border-color: var(--navi-purple-2);
    box-shadow: 0 0 0 .18rem rgba(123, 13, 142, .12);
}

.mobile-textarea {
    min-height: 130px;
    resize: vertical;
}

.mobile-primary-button {
    width: 100%;
    min-height: 48px;
    margin-top: 1rem;
    border: 0;
    border-radius: .85rem;
    background: linear-gradient(135deg, var(--navi-purple-2), var(--navi-purple));
    color: #fff;
    font-size: .93rem;
    font-weight: 950;
    box-shadow: 0 .8rem 1.5rem rgba(75, 0, 92, .22);
}

.mobile-primary-button:disabled {
    opacity: .7;
}

.mobile-alert,
.mobile-success {
    margin: .85rem 0;
    padding: .8rem .9rem;
    border-radius: .85rem;
    font-size: .82rem;
    font-weight: 850;
    line-height: 1.35;
}

.mobile-alert {
    color: #9f1239;
    background: #fff1f2;
    border: 1px solid #fecdd3;
}

.mobile-success {
    color: #166534;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
}

.mobile-hero {
    padding: 1.15rem;
    border-radius: 1.25rem;
    color: #fff;
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.18), transparent 34%),
        linear-gradient(135deg, #15001b 0%, #4b005c 58%, #7b0d8e 100%);
    box-shadow: 0 1rem 2.2rem rgba(75, 0, 92, .22);
}

.mobile-hero.compact {
    padding: 1rem;
}

.mobile-hero .mobile-pill {
    color: #fff;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.16);
    margin-bottom: .55rem;
}

.mobile-kpi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .65rem;
    margin: .85rem 0;
}

.mobile-kpi-card {
    padding: .85rem;
}

.mobile-kpi-card span {
    display: block;
    color: var(--navi-muted);
    font-size: .68rem;
    font-weight: 900;
}

.mobile-kpi-card strong {
    display: block;
    color: var(--navi-purple);
    font-size: 1.7rem;
    font-weight: 950;
    line-height: 1;
    margin: .35rem 0;
}

.mobile-kpi-card small {
    display: block;
    color: #8b8092;
    font-size: .65rem;
    font-weight: 700;
}

.mobile-kpi-card.warning strong {
    color: #b45309;
}

.mobile-kpi-card.ok strong {
    color: #15803d;
}

.mobile-action-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .75rem;
    margin: .85rem 0;
}

.mobile-action-card {
    border: 1px solid var(--navi-border);
    text-align: left;
    padding: 1rem;
    color: var(--navi-text);
}

.mobile-action-card span {
    display: inline-flex;
    padding: .2rem .55rem;
    border-radius: 999px;
    background: rgba(123, 13, 142, .10);
    color: var(--navi-purple);
    font-size: .68rem;
    font-weight: 950;
}

.mobile-action-card strong,
.mobile-tool-card strong,
.mobile-selected-tool strong {
    display: block;
    margin-top: .45rem;
    font-size: .95rem;
    font-weight: 950;
}

.mobile-action-card small,
.mobile-tool-card small {
    display: block;
    margin-top: .2rem;
    color: var(--navi-muted);
    font-size: .75rem;
    font-weight: 700;
}

.mobile-panel {
    padding: 1rem;
    margin-top: .9rem;
}

.mobile-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: .75rem;
    margin-bottom: .75rem;
}

.mobile-panel-head h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 950;
}

.mobile-panel-head button,
.mobile-tool-card button,
.mobile-card-actions button {
    border: 1px solid var(--navi-purple);
    background: #fff;
    color: var(--navi-purple);
    border-radius: .7rem;
    padding: .48rem .7rem;
    font-size: .72rem;
    font-weight: 950;
}

.mobile-tool-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: .75rem;
    padding: .85rem;
    margin-top: .65rem;
}

.mobile-tool-card.big {
    align-items: flex-start;
}

.mobile-tool-card span,
.mobile-selected-tool span {
    display: block;
    color: var(--navi-purple);
    font-size: .72rem;
    font-weight: 950;
}

.mobile-list {
    margin-top: .8rem;
}

.mobile-card-actions {
    display: grid;
    justify-items: end;
    gap: .55rem;
    min-width: 108px;
}

.mobile-status {
    display: inline-flex;
    padding: .25rem .55rem;
    border-radius: 999px;
    background: #fef3c7;
    color: #92400e;
    font-size: .65rem;
    font-style: normal;
    font-weight: 950;
}

.mobile-status.ok {
    background: #dcfce7;
    color: #166534;
}

.mobile-status.danger {
    background: #fee2e2;
    color: #991b1b;
}

.mobile-search {
    margin-top: .85rem;
}

.mobile-form-card {
    padding: 1rem;
    margin-top: .85rem;
}

.mobile-selected-tool {
    border: 1px solid var(--navi-border);
    background: #fbf7fc;
    border-radius: .85rem;
    padding: .85rem;
}

.mobile-check-row {
    display: flex !important;
    align-items: center;
    gap: .55rem;
}

.mobile-check-row input {
    width: 18px;
    height: 18px;
}

.mobile-empty,
.mobile-loading {
    padding: 1rem;
    text-align: center;
    color: var(--navi-muted);
    font-weight: 750;
}

.mobile-empty strong {
    display: block;
    color: var(--navi-text);
    font-weight: 950;
}

.mobile-empty span {
    display: block;
    margin-top: .25rem;
}

.mobile-empty.compact {
    box-shadow: none;
    background: #fbf7fc;
}

.mobile-bottom-nav {
    position: fixed;
    left: 50%;
    bottom: .75rem;
    transform: translateX(-50%);
    width: min(520px, calc(100% - 1.5rem));
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: .35rem;
    padding: .45rem;
    border-radius: 1.1rem;
    background: rgba(255,255,255,.94);
    border: 1px solid var(--navi-border);
    box-shadow: 0 1rem 2rem rgba(75,0,92,.18);
    backdrop-filter: blur(16px);
    z-index: 50;
}

.mobile-bottom-nav a,
.mobile-bottom-nav button {
    border: 0;
    background: transparent;
    text-decoration: none;
    display: grid;
    place-items: center;
    gap: .15rem;
    padding: .45rem .2rem;
    border-radius: .8rem;
    color: var(--navi-muted);
    font-family: inherit;
}

.mobile-bottom-nav a.active {
    background: linear-gradient(135deg, var(--navi-purple-2), var(--navi-purple));
    color: #fff;
}

.mobile-bottom-nav span {
    font-size: .62rem;
    font-weight: 950;
}

.mobile-bottom-nav strong {
    font-size: .68rem;
    font-weight: 950;
}

@media (max-width: 420px) {
    .mobile-kpi-grid {
        grid-template-columns: 1fr;
    }

    .mobile-action-grid {
        grid-template-columns: 1fr;
    }

    .mobile-tool-card {
        flex-direction: column;
        align-items: flex-start;
    }

    .mobile-card-actions {
        width: 100%;
        justify-items: stretch;
    }

    .mobile-card-actions button,
    .mobile-tool-card button {
        width: 100%;
    }
}

/* ============================================================
   Ajustes MVP móvil - navegación y cierre de sesión
   ============================================================ */

.mobile-hero-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    margin-bottom: .65rem;
}

.mobile-logout-button {
    border: 1px solid rgba(255,255,255,.55);
    background: rgba(255,255,255,.10);
    color: #ffffff;
    border-radius: 999px;
    padding: .42rem .7rem;
    font-size: .72rem;
    font-weight: 950;
}

.mobile-logout-button:active {
    transform: scale(.98);
}

.mobile-action-card {
    text-decoration: none;
    display: block;
}

.mobile-action-card:active {
    transform: scale(.985);
}

.mobile-mini-link {
    border: 1px solid var(--navi-purple);
    background: #fff;
    color: var(--navi-purple);
    border-radius: .7rem;
    padding: .48rem .7rem;
    font-size: .72rem;
    font-weight: 950;
    text-decoration: none;
    white-space: nowrap;
}

.mobile-bottom-nav {
    display: grid !important;
    visibility: visible !important;
}

.mobile-bottom-nav button {
    cursor: pointer;
}
