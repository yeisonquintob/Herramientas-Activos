    }

    .maintenance-kpi-card.warning { border-left-color: #ffc107; }
    .maintenance-kpi-card.success { border-left-color: #198754; }
    .maintenance-kpi-card.danger { border-left-color: #dc3545; }

    .maintenance-kpi-card span {
        display: block;
        color: #526071;
        font-size: .68rem;
        font-weight: 950;
        text-transform: uppercase;
    }

    .maintenance-kpi-card strong {
        display: block;
        font-size: 1.35rem;
        font-weight: 950;
        color: #06111f;
    }

    .maintenance-kpi-card small {
        color: #657083;
    }

    .maintenance-layout {
        display: grid;
        grid-template-columns: 390px 1fr;
        gap: .85rem;
    }

    .maintenance-card {
        background: white;
        border: 1px solid #dfe3e8;
        border-radius: .95rem;
        padding: .85rem;
        box-shadow: 0 .35rem .9rem rgba(0,0,0,.04);
    }

    .maintenance-card-title {
        display: flex;
        justify-content: space-between;
        gap: .75rem;
        align-items: flex-start;
        margin-bottom: .7rem;
    }

    .maintenance-card-title h3 {
        margin: 0;
