@page "/login"
@rendermode InteractiveServer

@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.JSInterop
@using Navi.ToolsAssets.Admin.Services.Auth

@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject WebAuthSessionService AuthSession
@inject IJSRuntime JS

<PageTitle>Ingreso - NAVI Herramientas y AF</PageTitle>

<div class="login-shell">
    <header class="login-topbar">
        <div class="login-brand">
            <div class="login-brand-icon">N</div>

            <div>
                <h1>NAVI Herramientas y AF</h1>
                <p>Consola de administración</p>
            </div>
        </div>

        <div class="login-brand-right">
            <span class="login-divider"></span>
            <strong>Herramientas y AF</strong>
        </div>
    </header>

    <main class="login-main">
        <section class="login-card">
            <div class="login-card-icon">N</div>

            <h2>Bienvenido</h2>

            <p class="login-subtitle">
                Ingresa tus credenciales para acceder<br />
                a la consola de administración.
            </p>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="login-alert">@errorMessage</div>
            }

            <EditForm Model="loginModel" OnValidSubmit="LoginAsync">
                <div class="login-field">
                    <label>Documento / usuario</label>

                    <div class="login-input-wrap">
                        <span class="login-input-icon" aria-hidden="true">&#128100;</span>

                        <InputText class="login-input"
                                   @bind-Value="loginModel.UserName"
                                   placeholder="Ingresa tu documento o usuario" />
                    </div>
                </div>

                <div class="login-field">
                    <label>Contraseña</label>

                    <div class="login-input-wrap">
                        <span class="login-input-icon" aria-hidden="true">&#128274;</span>

                        <InputText class="login-input"
                                   type="@passwordInputType"
                                   @bind-Value="loginModel.Password"
                                   placeholder="Ingresa tu contraseña" />

                        <button type="button" class="login-eye" @onclick="TogglePassword">
                            @((MarkupString)(showPassword ? "&#128065;" : "&#128065;"))
                        </button>
                    </div>
                </div>

                <button class="login-submit" type="submit" disabled="@isLoading">
                    @(isLoading ? "Ingresando..." : "Ingresar")
                </button>
            </EditForm>
        </section>
    </main>

    <footer class="login-footer">
        Navitrans 40 años <span>•</span> Soluciones que impulsan tu operación
    </footer>

    <div class="login-bg-letter">N</div>
    <div class="login-bg-lines"></div>
    <div class="login-bg-dots"></div>
</div>

@code {
    private const string StorageKey = "navi-auth-session";

    private LoginFormModel loginModel = new();
    private bool isLoading;
    private bool showPassword;
    private string? errorMessage;

    private string passwordInputType => showPassword ? "text" : "password";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (AuthSession.IsAuthenticated)
        {
            Navigation.NavigateTo("/dashboard", forceLoad: true);
            return;
        }

        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);

            if (!string.IsNullOrWhiteSpace(json))
            {
                var user = JsonSerializer.Deserialize<AuthSessionUser>(
                    json,
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                if (user is not null && !string.IsNullOrWhiteSpace(user.UserName))
                {
                    AuthSession.Login(user);
                    Navigation.NavigateTo("/dashboard", forceLoad: true);
                }
            }
        }
        catch
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey);
        }
    }

    private async Task LoginAsync()
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(loginModel.UserName) ||
            string.IsNullOrWhiteSpace(loginModel.Password))
        {
            errorMessage = "Debe ingresar documento/usuario y contraseña.";
            return;
        }

        isLoading = true;

        try
        {
            var api = HttpClientFactory.CreateClient("NaviApi");

            var response = await api.PostAsJsonAsync("api/auth/login", new
            {
                userName = loginModel.UserName,
                password = loginModel.Password
            });

            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();

                errorMessage = string.IsNullOrWhiteSpace(error)
                    ? "Usuario o contraseña inválidos."
                    : error;

                return;
            }

            var user = await response.Content.ReadFromJsonAsync<AuthSessionUser>();

            if (user is null)
            {
                errorMessage = "No se recibió la información de sesión.";
                return;
            }

            AuthSession.Login(user);

            var json = JsonSerializer.Serialize(user);
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);

            Navigation.NavigateTo("/dashboard", forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo iniciar sesión: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void TogglePassword()
    {
        showPassword = !showPassword;
    }

    private sealed class LoginFormModel
    {
        public string? UserName { get; set; }
        public string? Password { get; set; }
    }
}

<style>
    .login-shell {
        min-height: 100vh;
        position: relative;
        overflow: hidden;
        color: #ffffff;
        display: grid;
        grid-template-rows: auto 1fr auto;
        padding: 2.5rem 3rem;
        background:
            radial-gradient(circle at 48% 44%, rgba(157, 37, 174, .48), transparent 24%),
            radial-gradient(circle at 80% 38%, rgba(118, 0, 136, .42), transparent 26%),
            linear-gradient(135deg, #120016 0%, #24002e 42%, #5b006a 100%);
    }

    .login-topbar {
        position: relative;
        z-index: 5;
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
    }

    .login-brand {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .login-brand-icon,
    .login-card-icon {
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, #8b1fc2, #4b005c);
        color: white;
        font-weight: 950;
        box-shadow: 0 1rem 2rem rgba(0, 0, 0, .26);
    }

    .login-brand-icon {
        width: 62px;
        height: 62px;
        border-radius: .9rem;
        font-size: 1.85rem;
    }

    .login-brand h1 {
        margin: 0;
        color: white;
        font-size: 1.95rem;
        font-weight: 950;
        letter-spacing: -.04rem;
    }

    .login-brand p {
        margin: .2rem 0 0;
        color: rgba(255, 255, 255, .68);
        font-size: 1rem;
        font-weight: 700;
    }

    .login-brand-right {
        display: flex;
        align-items: center;
        gap: 1rem;
        color: rgba(255, 255, 255, .72);
        font-size: 1.05rem;
        padding-top: .4rem;
    }

    .login-divider {
        display: block;
        width: 1px;
        height: 38px;
        background: rgba(255, 255, 255, .45);
    }

    .login-main {
        position: relative;
        z-index: 5;
        display: grid;
        place-items: center;
        padding: 2rem 0 1rem;
    }

    .login-card {
        width: min(460px, 100%);
        background: rgba(255, 255, 255, .98);
        color: #2d1236;
        border: 1px solid rgba(255, 255, 255, .75);
        border-radius: 1.25rem;
        padding: 2rem 2.05rem 1.9rem;
        text-align: center;
        box-shadow:
            0 2rem 4.5rem rgba(0, 0, 0, .34),
            inset 0 1px 0 rgba(255, 255, 255, .95);
        backdrop-filter: blur(14px);
    }

    .login-card-icon {
        width: 68px;
        height: 68px;
        border-radius: .85rem;
        margin: 0 auto 1rem;
        font-size: 2rem;
    }

    .login-card h2 {
        margin: 0;
        color: #3a0046;
        font-size: 1.55rem;
        font-weight: 950;
        letter-spacing: -.02rem;
    }

    .login-subtitle {
        margin: .5rem 0 1.55rem;
        color: #6c6473;
        font-size: .92rem;
        font-weight: 650;
        line-height: 1.45;
    }

    .login-alert {
        text-align: left;
        margin-bottom: .95rem;
        background: #fff1f2;
        color: #9f1239;
        border: 1px solid #fecdd3;
        border-radius: .75rem;
        padding: .75rem .85rem;
        font-weight: 850;
        font-size: .78rem;
        line-height: 1.35;
    }

    .login-field {
        text-align: left;
        margin-bottom: 1rem;
    }

    .login-field label {
        display: block;
        color: #2f1938;
        font-size: .78rem;
        font-weight: 950;
        margin-bottom: .38rem;
    }

    .login-input-wrap {
        display: flex;
        align-items: center;
        gap: .55rem;
        min-height: 44px;
        border: 1px solid #d9dee8;
        background: #fff;
        border-radius: .55rem;
        padding: 0 .75rem;
        transition: border-color .15s ease, box-shadow .15s ease;
    }

    .login-input-wrap:focus-within {
        border-color: #8a1296;
        box-shadow: 0 0 0 .18rem rgba(138, 18, 150, .12);
    }

    .login-input-icon {
        width: 26px;
        min-width: 26px;
        height: 26px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #7a118f;
        font-size: 1rem;
        font-weight: 950;
        line-height: 1;
        opacity: .85;
    }

    .login-input {
        flex: 1;
        border: 0;
        outline: 0;
        min-height: 42px;
        font-size: .86rem;
        color: #24142c;
        background: transparent;
    }

    .login-input::placeholder {
        color: #9aa1ad;
    }

    .login-eye {
        width: 28px;
        min-width: 28px;
        height: 28px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        background: transparent;
        color: #7a118f;
        font-size: .95rem;
        font-weight: 950;
        cursor: pointer;
        padding: .2rem;
        line-height: 1;
        opacity: .85;
    }

    .login-eye:hover {
        opacity: 1;
    }

    .login-submit {
        width: 100%;
        min-height: 46px;
        margin-top: .35rem;
        border: 0;
        border-radius: .55rem;
        background: linear-gradient(135deg, #8d14a8, #4d005e);
        color: #fff;
        font-size: .9rem;
        font-weight: 950;
        box-shadow: 0 .75rem 1.35rem rgba(99, 0, 113, .25);
        transition: transform .12s ease, box-shadow .12s ease, opacity .12s ease;
    }

    .login-submit:hover {
        transform: translateY(-1px);
        box-shadow: 0 .95rem 1.6rem rgba(99, 0, 113, .32);
    }

    .login-submit:disabled {
        opacity: .72;
        cursor: not-allowed;
        transform: none;
    }

    .login-footer {
        position: relative;
        z-index: 5;
        text-align: center;
        color: rgba(255, 255, 255, .78);
        font-size: .86rem;
        font-weight: 650;
    }

    .login-footer span {
        margin: 0 .65rem;
    }

    .login-bg-letter {
        position: absolute;
        z-index: 1;
        right: -5rem;
        bottom: -13rem;
        font-size: 36rem;
        line-height: 1;
        font-weight: 950;
        color: transparent;
        -webkit-text-stroke: 2px rgba(255, 255, 255, .12);
        text-stroke: 2px rgba(255, 255, 255, .12);
        user-select: none;
        pointer-events: none;
    }

    .login-bg-lines {
        position: absolute;
        z-index: 2;
        right: 7%;
        top: 25%;
        width: 360px;
        height: 420px;
        border: 2px solid rgba(255, 255, 255, .13);
        border-left-color: rgba(255, 255, 255, .24);
        border-radius: 7rem 0 0 7rem;
        transform: skewX(-28deg);
        opacity: .75;
        pointer-events: none;
    }

    .login-bg-dots {
        position: absolute;
        z-index: 2;
        right: 4%;
        top: 15%;
        width: 180px;
        height: 180px;
        opacity: .20;
        background-image: radial-gradient(rgba(255, 255, 255, .85) 1px, transparent 1px);
        background-size: 18px 18px;
        pointer-events: none;
    }

    @@media (max-width: 900px) {
        .login-shell {
            padding: 1.35rem;
        }

        .login-topbar {
            flex-direction: column;
        }

        .login-brand-right {
            display: none;
        }

        .login-brand h1 {
            font-size: 1.45rem;
        }

        .login-brand-icon {
            width: 52px;
            height: 52px;
            font-size: 1.55rem;
        }

        .login-card {
            padding: 1.55rem;
        }

        .login-bg-letter,
        .login-bg-lines,
        .login-bg-dots {
            display: none;
        }
    }
</style>

