@page "/mobile/assignment"

@using Microsoft.AspNetCore.Components
@using Navi.ToolsAssets.MobilePwa.Models

@inject NaviMobileApiClient Api
@inject MobileAuthSessionService Auth
@inject NavigationManager Navigation

<PageTitle>Asignar AF móvil - NAVI Herramientas y AF</PageTitle>

<section class="mobile-page mobile-assignment-page">
    @if (isLoading)
    {
        <div class="mobile-loading">Cargando asignaciones móviles...</div>
    }
    else if (!Auth.IsAuthenticated)
    {
        <div class="mobile-empty">
            <strong>Sesión requerida</strong>
            <span>Debes iniciar sesión para usar asignaciones móviles.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoLogin">Ir al login</button>
        </div>
    }
    else
    {
        <header class="mobile-assignment-hero">
            <div class="mobile-assignment-hero-top">
                <span>ASIGNAR AF</span>
                <button type="button" @onclick="GoHome">Regresar</button>
            </div>

            <h1>Asignar móvil</h1>
            <p>Aprobaciones, nueva asignación, regreso a almacén, historial y activos.</p>
        </header>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="@messageClass">@message</div>
        }

        <section class="mobile-assignment-kpis">
            <article>
                <strong>@PendingRequests.Count()</strong>
                <span>Pendientes</span>
            </article>

            <article>
                <strong>@ApprovedOrDeliveredCount</strong>
                <span>Aprobadas</span>
            </article>

            <article>
                <strong>@FilteredTools.Count()</strong>
                <span>Activos</span>
            </article>
        </section>

        <section class="mobile-assignment-card">
            <div class="mobile-assignment-card-head">
                <div>
                    <strong>Aprobaciones</strong>
                    <span>Solicitudes pendientes para aprobar o denegar</span>
                </div>

                <button type="button" @onclick="ReloadAsync">Actualizar</button>
            </div>

            @if (!PendingRequests.Any())
            {
                <div class="mobile-assignment-empty">No hay solicitudes pendientes.</div>
            }
            else
            {
                <div class="mobile-approval-list">
                    @foreach (var request in PendingRequests.Take(10))
                    {
                        var item = request.Items.FirstOrDefault();

                        <article>
                            <div class="mobile-approval-info">
                                <span>@request.LoanNumber</span>
                                <strong>@Display(item?.ToolInternalCode) - @Display(item?.ToolName)</strong>
                                <small>Solicita: @Display(request.CreatedBy) · @ShowDate(request.RequestedAt)</small>
                            </div>

                            <div class="mobile-approval-actions">
                                <button class="approve" type="button" disabled="@isSaving" @onclick="() => ApproveAsync(request)">
                                    Aprobar
                                </button>

                                <button class="deny" type="button" disabled="@isSaving" @onclick="() => DenyAsync(request)">
                                    Denegar
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="mobile-assignment-card">
            <div class="mobile-collapse-head">
                <div>
                    <strong>Nueva asignación</strong>
                    <span>Asignar a responsable o regresar a almacén/taller</span>
                </div>

                <button type="button" @onclick="ToggleNewAssignment">
                    @(showNewAssignment ? "Ocultar" : "Expandir")
                </button>
            </div>

            @if (showNewAssignment)
            {
                <div class="mobile-assignment-user">
                    <span>Usuario actual</span>
                    <strong>@CurrentResponsibleLabel</strong>
                </div>

                <label class="mobile-field">
                    <span>Buscar activo</span>
                    <input value="@assignmentSearch"
                           @oninput="OnAssignmentSearchChanged"
                           placeholder="Código, nombre, serial o sede..." />
                </label>

                @if (ShowAssignmentSearchResults)
                {
                    <div class="mobile-request-results">
                        @if (!AssignmentTools.Any())
                        {
                            <div class="mobile-assignment-empty">No se encontraron activos.</div>
                        }
                        else
                        {
                            @foreach (var tool in AssignmentTools.Take(8))
                            {
                                var selected = assignmentForm.ToolId == tool.Id;

                                <button type="button"
                                        class="mobile-request-result @(selected ? "selected" : "")"
                                        @onclick="() => SelectAssignmentTool(tool)">
                                    <span>
                                        <strong>@tool.InternalCode</strong>
                                        <small>@tool.Name</small>
                                        <small>@Display(tool.BranchCode) · @Display(tool.LocationName)</small>
                                    </span>

                                    <em class="@GetToolStateClass(tool)">
                                        @GetStatusLabel(tool.OperationalStatus)
                                    </em>
                                </button>
                            }
                        }
                    </div>
                }

                @if (selectedAssignmentTool is not null)
                {
                    <div class="mobile-assignment-selected">
                        <span>@selectedAssignmentTool.InternalCode</span>
                        <strong>@selectedAssignmentTool.Name</strong>
                        <small>@Display(selectedAssignmentTool.BranchCode) · @Display(selectedAssignmentTool.LocationName)</small>
                    </div>
                }

                <label class="mobile-field">
                    <span>Tipo de movimiento</span>
                    <select value="@assignmentForm.AssignmentType" @onchange="OnAssignmentTypeChanged">
                        <option value="Responsible">Asignar a usuario/responsable</option>
                        <option value="Warehouse">Regresar a almacén/taller</option>
                    </select>
                </label>

                @if (assignmentForm.AssignmentType == "Responsible")
                {
                    <label class="mobile-field">
                        <span>Usuario / Responsable</span>
                        <select value="@AssignmentResponsibleText" @onchange="OnAssignmentResponsibleChanged">
                            <option value="">Seleccione responsable</option>
                            @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                            {
                                <option value="@responsible.Id">@responsible.FullName - @Display(responsible.Position)</option>
                            }
                        </select>
                    </label>
                }

                @if (assignmentForm.AssignmentType == "Warehouse")
                {
                    <label class="mobile-field">
                        <span>Sede destino</span>
                        <select value="@AssignmentBranchText" @onchange="OnAssignmentBranchChanged">
                            <option value="">Seleccione sede</option>
                            @foreach (var branch in branches.OrderBy(x => x.Code))
                            {
                                <option value="@branch.Id">@branch.Code - @branch.Name</option>
                            }
                        </select>
                    </label>

                    <label class="mobile-field">
                        <span>Almacén / taller destino</span>
                        <select value="@AssignmentLocationText" @onchange="OnAssignmentLocationChanged">
                            <option value="">Seleccione almacén/taller</option>
                            @foreach (var location in AvailableAssignmentLocations.OrderBy(x => x.Code))
                            {
                                <option value="@location.Id">@location.Code - @location.Name</option>
                            }
                        </select>
                    </label>
                }

                <label class="mobile-field">
                    <span>@(assignmentForm.AssignmentType == "Warehouse" ? "Fecha de regreso" : "Fecha de asignación")</span>
                    <input type="date"
                           value="@FormatDateInput(assignmentForm.AssignmentDate)"
                           @onchange="OnAssignmentDateChanged" />
                </label>

                <label class="mobile-field">
                    <span>Observación</span>
                    <textarea rows="2"
                              value="@assignmentForm.Observation"
                              @oninput="OnAssignmentObservationChanged"
                              placeholder="Observación del movimiento..."></textarea>
                </label>

                <button class="mobile-assignment-main-button" type="button" disabled="@isSaving" @onclick="SaveDirectAssignmentAsync">
                    @(isSaving ? "Guardando..." : assignmentForm.AssignmentType == "Warehouse" ? "Confirmar regreso" : "Confirmar asignación")
                </button>
            }
        </section>

        <section class="mobile-assignment-card">
            <div class="mobile-collapse-head">
                <div>
                    <strong>Historial de usuario</strong>
                    <span>Solicitudes, aprobaciones y movimientos por usuario</span>
                </div>

                <button type="button" @onclick="ToggleHistory">
                    @(showHistory ? "Ocultar" : "Expandir")
                </button>
            </div>

            @if (showHistory)
            {
                <div class="mobile-assignment-filters">
                    <input value="@historyResponsibleSearch"
                           @oninput="OnHistoryResponsibleSearchChanged"
                           placeholder="Buscar usuario responsable..." />

                    @if (ShowHistoryResponsibleResults)
                    {
                        <div class="mobile-person-results">
                            @foreach (var responsible in HistoryResponsibleResults.Take(8))
                            {
                                <button type="button"
                                        class="mobile-person-result"
                                        @onclick="() => SelectHistoryResponsible(responsible)">
                                    <span>
                                        <strong>@responsible.FullName</strong>
                                        <small>@Display(responsible.Position) · @Display(responsible.BranchCode)</small>
                                    </span>
                                </button>
                            }
                        </div>
                    }

                    @if (selectedHistoryResponsible is not null)
                    {
                        <div class="mobile-selected-person-card">
                            <span>Responsable seleccionado</span>
                            <strong>@selectedHistoryResponsible.FullName</strong>
                            <small>@Display(selectedHistoryResponsible.Position) · @Display(selectedHistoryResponsible.BranchCode)</small>
                        </div>
                    }

                    <input value="@historySearch"
                           @oninput="OnHistorySearchChanged"
                           placeholder="Buscar préstamo, activo o usuario..." />
                </div>

                @if (!FilteredHistory.Any())
                {
                    <div class="mobile-assignment-empty">No hay historial para los filtros seleccionados.</div>
                }
                else
                {
                    <div class="mobile-history-list">
                        @foreach (var request in FilteredHistory.Take(12))
                        {
                            var item = request.Items.FirstOrDefault();

                            <article>
                                <div>
                                    <span>@request.LoanNumber</span>
                                    <strong>@Display(item?.ToolInternalCode) - @Display(item?.ToolName)</strong>
                                    <small>@GetLoanStatusLabel(request.Status) · @ShowDate(request.CreatedAt)</small>
                                    <small>Usuario: @Display(request.CreatedBy)</small>
                                </div>

                                <em class="@GetLoanStatusClass(request.Status)">
                                    @GetLoanStatusLabel(request.Status)
                                </em>
                            </article>
                        }
                    </div>
                }
            }
        </section>

        <section class="mobile-assignment-card">
            <div class="mobile-assignment-card-head">
                <div>
                    <strong>Herramientas / activos</strong>
                    <span>Consulta activos, solicita préstamo o reporta daño</span>
                </div>
            </div>

            <div class="mobile-assignment-filters">
                <input value="@toolSearch"
                       @oninput="OnToolSearchChanged"
                       placeholder="Buscar código, nombre, sede o ubicación..." />

                <select value="@toolStatus" @onchange="OnToolStatusChanged">
                    <option value="">Todos los estados</option>
                    <option value="Available">Disponible</option>
                    <option value="Assigned">Asignada</option>
                    <option value="Loaned">Prestada</option>
                    <option value="InMaintenance">Mantenimiento</option>
                    <option value="Damaged">Dañada</option>
                </select>
            </div>

            @if (!FilteredTools.Any())
            {
                <div class="mobile-assignment-empty">No hay activos para mostrar.</div>
            }
            else
            {
                <div class="mobile-assignment-tools">
                    @foreach (var tool in FilteredTools.Take(80))
                    {
                        <article>
                            <div class="mobile-assignment-tool-head">
                                <div>
                                    <span>@tool.InternalCode</span>
                                    <strong>@tool.Name</strong>
                                </div>

                                <em class="@GetToolStateClass(tool)">
                                    @GetStatusLabel(tool.OperationalStatus)
                                </em>
                            </div>

                            <div class="mobile-assignment-tool-grid">
                                <div>
                                    <span>Sede</span>
                                    <strong>@Display(tool.BranchCode)</strong>
                                </div>

                                <div>
                                    <span>Ubicación</span>
                                    <strong>@Display(tool.LocationName)</strong>
                                </div>

                                <div>
                                    <span>Responsable</span>
                                    <strong>@Display(tool.ResponsiblePersonName)</strong>
                                </div>

                                <div>
                                    <span>Físico</span>
                                    <strong>@Display(tool.PhysicalStatus)</strong>
                                </div>
                            </div>

                            <div class="mobile-assignment-tool-actions">
                                <a href="@GetDetailUrl(tool.Id)">Detalle</a>
                                <a href="@GetLifeRecordUrl(tool.Id)">Hoja vida</a>
                                <button type="button" @onclick="() => SelectAssignmentTool(tool)">Asignar</button>
                                <a class="danger" href="@GetDamageUrl(tool.Id)">Daño</a>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</section>

@code {
    private bool isLoading = true;
    private bool isSaving;
    private bool showNewAssignment = true;
    private bool showHistory;
    private string? message;
    private string messageClass = "mobile-alert";

    private string assignmentSearch = string.Empty;
    private string historySearch = string.Empty;
    private string historyResponsibleId = string.Empty;
    private string historyResponsibleSearch = string.Empty;
    private string toolSearch = string.Empty;
    private string toolStatus = string.Empty;

    private List<MobileAvailabilityToolDto> tools = new();
    private List<MobileLoanRequestDto> loanRequests = new();
    private List<MobileResponsibleDto> responsibles = new();
    private List<MobileBranchDto> branches = new();
    private List<MobileLocationDto> locations = new();

    private MobileDirectAssignmentForm assignmentForm = new();

    private string CurrentResponsibleLabel =>
        !string.IsNullOrWhiteSpace(Auth.CurrentUser?.ResponsiblePersonName)
            ? Auth.CurrentUser!.ResponsiblePersonName!
            : Auth.CurrentUser?.DisplayName ?? Auth.CurrentUser?.UserName ?? "Usuario móvil";

    private string AssignmentResponsibleText => assignmentForm.ResponsiblePersonId?.ToString() ?? string.Empty;
    private string AssignmentBranchText => assignmentForm.BranchId?.ToString() ?? string.Empty;
    private string AssignmentLocationText => assignmentForm.LocationId?.ToString() ?? string.Empty;

    private MobileAvailabilityToolDto? selectedAssignmentTool =>
        assignmentForm.ToolId.HasValue
            ? tools.FirstOrDefault(x => x.Id == assignmentForm.ToolId.Value)
            : null;

    private bool ShowAssignmentSearchResults =>
        !string.IsNullOrWhiteSpace(assignmentSearch) &&
        selectedAssignmentTool is null;

    private IEnumerable<MobileLocationDto> AvailableAssignmentLocations =>
        assignmentForm.BranchId.HasValue
            ? locations.Where(x => x.BranchId == assignmentForm.BranchId.Value)
            : locations;

    private IEnumerable<MobileLoanRequestDto> PendingRequests =>
        loanRequests
            .Where(x => IsPendingStatus(x.Status))
            .Where(x => x.Items.Any(i => !i.Returned))
            .OrderByDescending(x => x.CreatedAt);

    private int ApprovedOrDeliveredCount =>
        loanRequests.Count(x =>
            x.Status.Equals("Approved", StringComparison.OrdinalIgnoreCase) ||
            x.Status.Equals("Delivered", StringComparison.OrdinalIgnoreCase));

    private IEnumerable<MobileAvailabilityToolDto> AssignmentTools =>
        tools
            .Where(x => string.IsNullOrWhiteSpace(assignmentSearch) ||
                        ContainsText(x.InternalCode, assignmentSearch) ||
                        ContainsText(x.Name, assignmentSearch) ||
                        ContainsText(x.SerialNumber, assignmentSearch) ||
                        ContainsText(x.BranchCode, assignmentSearch) ||
                        ContainsText(x.LocationName, assignmentSearch))
            .OrderByDescending(x => ContainsStatus(x.OperationalStatus, "Available"))
            .ThenBy(x => x.InternalCode);

    private IEnumerable<MobileLoanRequestDto> FilteredHistory =>
        loanRequests
            .Where(x => !IsPendingStatus(x.Status))
            .Where(x => string.IsNullOrWhiteSpace(historyResponsibleId) ||
                        (x.RequestedByPersonId.HasValue && x.RequestedByPersonId.Value.ToString() == historyResponsibleId))
            .Where(x => string.IsNullOrWhiteSpace(historySearch) ||
                        ContainsText(x.LoanNumber, historySearch) ||
                        ContainsText(x.CreatedBy, historySearch) ||
                        x.Items.Any(i => ContainsText(i.ToolInternalCode, historySearch) || ContainsText(i.ToolName, historySearch)))
            .OrderByDescending(x => x.CreatedAt);

    private IEnumerable<MobileAvailabilityToolDto> FilteredTools =>
        tools
            .Where(x => string.IsNullOrWhiteSpace(toolSearch) ||
                        ContainsText(x.InternalCode, toolSearch) ||
                        ContainsText(x.Name, toolSearch) ||
                        ContainsText(x.BranchCode, toolSearch) ||
                        ContainsText(x.LocationName, toolSearch) ||
                        ContainsText(x.ResponsiblePersonName, toolSearch))
            .Where(x => string.IsNullOrWhiteSpace(toolStatus) ||
                        x.OperationalStatus.Equals(toolStatus, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => FindPendingRequestForTool(x.Id) is not null)
            .ThenByDescending(x => ContainsStatus(x.OperationalStatus, "Available"))
            .ThenBy(x => x.InternalCode);

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsAuthenticated)
        {
            isLoading = false;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            message = null;

            tools = await Api.GetAvailabilityToolsAsync();
            loanRequests = await Api.GetLoanRequestsAsync();
            responsibles = await Api.GetResponsiblesAsync();
            branches = await Api.GetBranchesAsync();
            locations = await Api.GetLocationsAsync();
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo cargar asignar móvil: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private void ToggleNewAssignment()
    {
        showNewAssignment = !showNewAssignment;
    }

    private void ToggleHistory()
    {
        showHistory = !showHistory;
    }

    private void SelectAssignmentTool(MobileAvailabilityToolDto tool)
    {
        assignmentForm.ToolId = tool.Id;
        assignmentForm.BranchId = tool.BranchId;
        assignmentForm.LocationId = tool.LocationId;
        assignmentForm.ResponsiblePersonId = tool.ResponsiblePersonId;
        assignmentForm.AssignmentDate = DateTime.Today;
        assignmentForm.Observation = assignmentForm.AssignmentType == "Warehouse"
            ? $"Regreso del activo {tool.InternalCode} a almacén/taller."
            : $"Asignación del activo {tool.InternalCode}.";

        assignmentSearch = $"{tool.InternalCode} - {tool.Name}";
        showNewAssignment = true;
    }

    private void OnAssignmentSearchChanged(ChangeEventArgs args)
    {
        assignmentSearch = args.Value?.ToString() ?? string.Empty;

        if (selectedAssignmentTool is not null &&
            !assignmentSearch.Equals($"{selectedAssignmentTool.InternalCode} - {selectedAssignmentTool.Name}", StringComparison.OrdinalIgnoreCase))
        {
            assignmentForm.ToolId = null;
        }
    }

    private void OnAssignmentTypeChanged(ChangeEventArgs args)
    {
        assignmentForm.AssignmentType = args.Value?.ToString() ?? "Responsible";

        if (assignmentForm.AssignmentType == "Warehouse")
        {
            assignmentForm.ResponsiblePersonId = null;
        }
    }

    private void OnAssignmentResponsibleChanged(ChangeEventArgs args)
    {
        assignmentForm.ResponsiblePersonId = ParseGuid(args.Value?.ToString());
    }

    private void OnAssignmentBranchChanged(ChangeEventArgs args)
    {
        assignmentForm.BranchId = ParseGuid(args.Value?.ToString());

        if (assignmentForm.LocationId.HasValue &&
            !locations.Any(x => x.Id == assignmentForm.LocationId.Value && x.BranchId == assignmentForm.BranchId))
        {
            assignmentForm.LocationId = null;
        }
    }

    private void OnAssignmentLocationChanged(ChangeEventArgs args)
    {
        assignmentForm.LocationId = ParseGuid(args.Value?.ToString());
    }

    private void OnAssignmentDateChanged(ChangeEventArgs args)
    {
        if (DateTime.TryParse(args.Value?.ToString(), out var value))
        {
            assignmentForm.AssignmentDate = value;
        }
    }

    private void OnAssignmentObservationChanged(ChangeEventArgs args)
    {
        assignmentForm.Observation = args.Value?.ToString();
    }

    private void OnHistorySearchChanged(ChangeEventArgs args)
    {
        historySearch = args.Value?.ToString() ?? string.Empty;
    }

    private void OnHistoryResponsibleChanged(ChangeEventArgs args)
    {
        historyResponsibleId = args.Value?.ToString() ?? string.Empty;
    }

    private void OnToolSearchChanged(ChangeEventArgs args)
    {
        toolSearch = args.Value?.ToString() ?? string.Empty;
    }

    private void OnToolStatusChanged(ChangeEventArgs args)
    {
        toolStatus = args.Value?.ToString() ?? string.Empty;
    }

    private async Task SaveDirectAssignmentAsync()
    {
        if (assignmentForm.ToolId is null)
        {
            ShowError("Debe seleccionar un activo fijo.");
            return;
        }

        if (assignmentForm.AssignmentType == "Responsible" && assignmentForm.ResponsiblePersonId is null)
        {
            ShowError("Debe seleccionar un responsable.");
            return;
        }

        if (assignmentForm.AssignmentType == "Warehouse" && (assignmentForm.BranchId is null || assignmentForm.LocationId is null))
        {
            ShowError("Debe seleccionar sede y almacén/taller destino.");
            return;
        }

        try
        {
            isSaving = true;

            await Api.AssignFixedAssetAsync(assignmentForm.ToolId.Value, new MobileDirectAssignmentRequest
            {
                AssignmentType = assignmentForm.AssignmentType,
                ResponsiblePersonId = assignmentForm.ResponsiblePersonId,
                BranchId = assignmentForm.BranchId,
                LocationId = assignmentForm.LocationId,
                AssignmentDate = assignmentForm.AssignmentDate,
                Observation = assignmentForm.Observation,
                ChangedBy = Auth.CurrentUser?.UserName ?? "mobile"
            });

            ShowSuccess(assignmentForm.AssignmentType == "Warehouse"
                ? "Activo regresado correctamente a almacén/taller."
                : "Asignación confirmada correctamente.");

            assignmentForm = new MobileDirectAssignmentForm();
            assignmentSearch = string.Empty;

            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo guardar el movimiento: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task ApproveAsync(MobileLoanRequestDto request)
    {
        try
        {
            isSaving = true;

            await Api.ApproveAndAssignLoanAsync(request.Id, new MobileLoanActionDto
            {
                ActionBy = Auth.CurrentUser?.UserName,
                Notes = $"Solicitud {request.LoanNumber} aprobada desde app móvil.",
                Condition = "Aprobado y asignado desde app móvil."
            });

            ShowSuccess($"Solicitud {request.LoanNumber} aprobada y asignada correctamente.");

            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo aprobar: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DenyAsync(MobileLoanRequestDto request)
    {
        try
        {
            isSaving = true;

            await Api.RejectLoanRequestAsync(request.Id, new MobileLoanActionDto
            {
                ActionBy = Auth.CurrentUser?.UserName,
                Notes = $"Solicitud {request.LoanNumber} denegada desde app móvil.",
                Condition = "Solicitud denegada desde app móvil."
            });

            ShowSuccess($"Solicitud {request.LoanNumber} denegada correctamente.");

            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo denegar: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private LoanRequestItemLite? FindPendingRequestForTool(Guid toolId)
    {
        var request = PendingRequests.FirstOrDefault(x =>
            x.Items.Any(i => i.ToolAssetId == toolId && !i.Returned));

        if (request is null)
        {
            return null;
        }

        return new LoanRequestItemLite(request.Id, request.LoanNumber);
    }

    private void GoHome()
    {
        Navigation.NavigateTo("/");
    }

    private void GoLogin()
    {
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private static Guid? ParseGuid(string? value)
    {
        return Guid.TryParse(value, out var id) ? id : null;
    }

    private static bool IsPendingStatus(string? status)
    {
        return status is not null &&
               (status.Equals("Draft", StringComparison.OrdinalIgnoreCase) ||
                status.Equals("Requested", StringComparison.OrdinalIgnoreCase) ||
                status.Equals("PendingApproval", StringComparison.OrdinalIgnoreCase));
    }

    private static bool ContainsStatus(string? value, string expected)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               value.Contains(expected, StringComparison.OrdinalIgnoreCase);
    }

    private static bool ContainsText(string? value, string expected)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               !string.IsNullOrWhiteSpace(expected) &&
               Normalize(value).Contains(Normalize(expected), StringComparison.OrdinalIgnoreCase);
    }

    private static string Normalize(string value)
    {
        return value
            .Trim()
            .ToUpperInvariant()
            .Replace("Á", "A")
            .Replace("É", "E")
            .Replace("Í", "I")
            .Replace("Ó", "O")
            .Replace("Ú", "U")
            .Replace("Ü", "U")
            .Replace("Ñ", "N");
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Sin dato" : value;
    }

    private static string ShowDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToLocalTime().ToString("dd/MM/yyyy") : "Sin fecha";
    }

    private static string FormatDateInput(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("yyyy-MM-dd") : string.Empty;
    }

    private static string GetStatusLabel(string? status)
    {
        return status switch
        {
            "Available" => "Disponible",
            "Assigned" => "Asignada",
            "Loaned" => "Prestada",
            "InMaintenance" => "En mantenimiento",
            "Damaged" => "Dañada",
            "NotSuitable" => "No apta",
            "PendingValidation" => "Pendiente validación",
            "NotLocated" => "No localizada",
            "Disposed" => "Baja",
            _ => Display(status)
        };
    }

    private static string GetLoanStatusLabel(string? status)
    {
        return status switch
        {
            "Draft" => "Borrador",
            "Requested" => "Solicitada",
            "PendingApproval" => "Pendiente",
            "Approved" => "Aprobada",
            "Delivered" => "Asignada",
            "Returned" => "Devuelta",
            "Rejected" => "Denegada",
            "Cancelled" => "Cancelada",
            _ => Display(status)
        };
    }

    private static string GetToolStateClass(MobileAvailabilityToolDto tool)
    {
        return tool.OperationalStatus switch
        {
            "Available" => "mobile-state ok",
            "Assigned" => "mobile-state assigned",
            "Loaned" => "mobile-state assigned",
            "InMaintenance" => "mobile-state warning",
            "Damaged" => "mobile-state danger",
            "NotSuitable" => "mobile-state danger",
            "NotLocated" => "mobile-state dark",
            _ => "mobile-state neutral"
        };
    }

    private static string GetLoanStatusClass(string? status)
    {
        return status switch
        {
            "Approved" => "mobile-state ok",
            "Delivered" => "mobile-state ok",
            "Returned" => "mobile-state neutral",
            "Rejected" => "mobile-state danger",
            "Cancelled" => "mobile-state dark",
            _ => "mobile-state warning"
        };
    }

    private static string GetDetailUrl(Guid id)
    {
        return "/tools/" + id;
    }

    private static string GetLifeRecordUrl(Guid id)
    {
        return "/tools/" + id + "/life-record";
    }

    private static string GetDamageUrl(Guid id)
