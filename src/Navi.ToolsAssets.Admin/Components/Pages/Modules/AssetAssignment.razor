    private Guid? ReadGuidProperty(object? item, string propertyName)
    {
        if (item is null || string.IsNullOrWhiteSpace(propertyName))
        {
            return null;
        }

        var flags = System.Reflection.BindingFlags.Instance
            | System.Reflection.BindingFlags.Public
            | System.Reflection.BindingFlags.NonPublic
            | System.Reflection.BindingFlags.IgnoreCase;

        var property = item.GetType().GetProperty(propertyName, flags);
        var value = property?.GetValue(item);

        if (value is Guid guidValue && guidValue != Guid.Empty)
        {
            return guidValue;
        }

        if (value is string stringValue && Guid.TryParse(stringValue, out var parsedGuid) && parsedGuid != Guid.Empty)
        {
            return parsedGuid;
        }

        return null;
    }


















