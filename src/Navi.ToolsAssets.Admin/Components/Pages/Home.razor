        font-size: .9rem;
    }

    .dash-hero-side {
        min-width: 210px;
        display: grid;
        gap: .65rem;
    }

    .dash-hero-box {
        background: rgba(255,255,255,.12);
        border-radius: .65rem;
        padding: .55rem .75rem;
        text-align: right;
    }

    .dash-hero-box span {
        display: block;
        color: #ffdd57;
        font-size: .73rem;
        font-weight: 900;
    }

    .dash-hero-box strong {
        color: #fff;
        font-size: .82rem;
    }

    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(8, minmax(125px, 1fr));
        gap: .65rem;
        margin-bottom: 1rem;
    }

    .kpi-card {
        background: #fff;
        border: 1px solid #dfe3e8;
        border-left: 4px solid #4b005c;
