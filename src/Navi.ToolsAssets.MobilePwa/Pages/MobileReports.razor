    private string BuildCsvDataUrl()
    {
        if (!CanExportReports)
        {
            return "#";
        }

        var csv = new StringBuilder();

        csv.AppendLine(string.Join(",", CurrentHeaders.Select(Csv)));

        foreach (var row in FilteredRows)
        {
            csv.AppendLine(string.Join(",", row.Cells.Select(x => Csv(x.Value))));
        }

        return "data:text/csv;charset=utf-8," + Uri.EscapeDataString(csv.ToString());
    }

    private bool IsAssetVisibleByScope(MobileToolDto tool)
    {
        if (CanSeeAllBranches)
        {
            return true;
        }

        return Same(tool.BranchCode, UserBranchCode) ||
               Same(tool.BranchName, Auth.CurrentUser?.BranchName) ||
               Same(tool.ResponsiblePersonName, Auth.CurrentUser?.ResponsiblePersonName) ||
               Same(tool.ResponsiblePersonName, Auth.CurrentUser?.DisplayName) ||
               Same(tool.ResponsiblePersonName, Auth.CurrentUser?.UserName) ||
               (tool.ResponsiblePersonId.HasValue &&
                Auth.CurrentUser?.ResponsiblePersonId.HasValue == true &&
                tool.ResponsiblePersonId.Value == Auth.CurrentUser.ResponsiblePersonId.Value);
    }

    private bool IsRowVisibleByScope(ReportRow row)
    {
        return CanSeeAllBranches ||
               string.IsNullOrWhiteSpace(row.BranchCode) ||
               Same(row.BranchCode, UserBranchCode);
    }

