@code {
    [Parameter] public Guid Id { get; set; }

    private ReportedItemsBoard? board;
    private List<ParticipantItem> participants = new();
    private ReportedItemForm form = new();
    private bool isLoading;
    private bool showForm;
    private string? errorMessage;
    private string? successMessage;
    private string? searchText;

    private IEnumerable<ReportedItemDto> FilteredItems
    {
        get
        {
            var items = board?.Items ?? new();

            if (string.IsNullOrWhiteSpace(searchText))
            {
                return items;
            }

            var term = searchText.Trim();

            return items.Where(x =>
                Contains(x.ReportedCode, term) ||
                Contains(x.ReportedName, term) ||
                Contains(x.SerialNumber, term) ||
                Contains(x.AssetTypeName, term) ||
                Contains(x.CategoryName, term) ||
                Contains(x.ResponsibleName, term) ||
                Contains(x.FoundLocation, term) ||
                Contains(x.ReportTypeLabel, term));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var api = CreateApiClient();

            board = await api.GetFromJsonAsync<ReportedItemsBoard>($"api/physical-counts/{Id}/reported-items-board");

            var participantBoard = await api.GetFromJsonAsync<ParticipantBoard>($"api/physical-counts/{Id}/participants-board");
            participants = participantBoard?.Participants ?? new();

            if (board is not null && string.IsNullOrWhiteSpace(form.BranchCode))
            {
                form.BranchCode = board.BranchCode;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error cargando registros reportados: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private HttpClient CreateApiClient()
    {
        var api = HttpClientFactory.CreateClient("NaviApi");

        if (api.BaseAddress is null)
        {
            api.BaseAddress = new Uri("http://localhost:5218/");
        }

        return api;
    }

    private void ToggleForm()
    {
        showForm = !showForm;

        if (showForm && board is not null)
        {
            form.BranchCode = board.BranchCode;
            form.ReportType = "ExtraNotListed";
            form.RequiresUserClarification = true;
        }
    }

    private void ClearForm()
    {
        form = new ReportedItemForm
        {
            ReportType = "ExtraNotListed",
            BranchCode = board?.BranchCode,
            RequiresUserClarification = true
        };
    }

    private async Task SaveAsync()
    {
        errorMessage = null;
        successMessage = null;

        if (form.ParticipantId is null || form.ParticipantId == Guid.Empty)
        {
            errorMessage = "Debe seleccionar el participante o usuario que reporta.";
            return;
        }

        if (string.IsNullOrWhiteSpace(form.ReportedName) && string.IsNullOrWhiteSpace(form.ReportedCode))
        {
            errorMessage = "Debe ingresar al menos el nombre o código del activo/herramienta reportada.";
            return;
        }

        try
        {
            var api = CreateApiClient();

            var response = await api.PostAsJsonAsync(
                $"api/physical-counts/participants/{form.ParticipantId}/reported-items",
                form);

            if (!response.IsSuccessStatusCode)
            {
                var detail = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo guardar el registro reportado. {detail}";
                return;
            }

            successMessage = "Registro reportado guardado correctamente.";
            ClearForm();
            showForm = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error guardando registro reportado: {ex.Message}";
        }
    }



    private Task ViewCreatedToolAsync(Guid toolAssetId)
    {
        NavigationManager.NavigateTo($"/tools/{toolAssetId}");
        return Task.CompletedTask;
    }

    private async Task VoidCreatedInventoryAssetAsync(Guid id)
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            var api = CreateApiClient();

            var response = await api.PatchAsJsonAsync(
                $"api/physical-counts/reported-items/{id}/void-created-tool-asset",
                new
                {
                    ActionBy = "admin",
                    Observation = "Activo anulado desde conciliación porque el reporte no procede."
                });

            if (!response.IsSuccessStatusCode)
            {
                var detail = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo anular el activo creado. {detail}";
                return;
            }

            successMessage = "Activo creado anulado correctamente. El registro queda rechazado y conserva trazabilidad.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error anulando activo creado: {ex.Message}";
        }
    }
    private async Task CreateInventoryAssetAsync(Guid id)
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            var api = CreateApiClient();

            var response = await api.PostAsJsonAsync(
                $"api/physical-counts/reported-items/{id}/create-tool-asset",
                new
                {
                    ActionBy = "admin",
                    CreateMissingCatalogs = true,
                    Observation = "Activo creado en Inventario de AF desde registro reportado en toma física."
                });

            if (!response.IsSuccessStatusCode)
            {
                var detail = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo crear el activo en Inventario de AF. {detail}";
                return;
            }

            var created = await response.Content.ReadFromJsonAsync<CreatedInventoryAssetResponse>();

            successMessage = created is null
                ? "Activo creado correctamente en Inventario de AF."
                : $"Activo creado correctamente en Inventario de AF: {created.InternalCode} - {created.Name}";

            await LoadAsync();

            if (created is not null && created.ToolAssetId != Guid.Empty)
            {
                NavigationManager.NavigateTo($"/tools/{created.ToolAssetId}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creando activo en Inventario de AF: {ex.Message}";
        }
    }

    private async Task ResolveClarificationAsync(Guid id)
    {
        await PatchAsync(
            $"api/physical-counts/reported-items/{id}/resolve-clarification",
            "Aclaración recibida del usuario. Registro disponible nuevamente para revisión.",
            "Registro marcado como aclarado.");
    }
    private async Task RequestClarificationAsync(Guid id)
    {
        await PatchAsync(
            $"api/physical-counts/reported-items/{id}/request-clarification",
            "Se requiere contactar al usuario para ampliar información del registro reportado.",
            "Registro marcado para aclaración.");
    }

    private async Task ApproveCreationAsync(Guid id)
    {
        await PatchAsync(
            $"api/physical-counts/reported-items/{id}/approve-creation",
            "Registro aprobado para creación en Inventario de AF.",
            "Registro aprobado para creación.");
    }

    private async Task ReconcileAsync(Guid id)
    {
        await PatchAsync(
            $"api/physical-counts/reported-items/{id}/reconcile",
            "Registro conciliado manualmente desde administración.",
            "Registro conciliado.");
    }

    private async Task RejectAsync(Guid id)
    {
        await PatchAsync(
            $"api/physical-counts/reported-items/{id}/reject",
            "Reporte rechazado en conciliación.",
            "Registro rechazado.");
    }

    private async Task PatchAsync(string url, string observation, string okMessage)
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            var api = CreateApiClient();

            var response = await api.PatchAsJsonAsync(url, new
            {
                ActionBy = "admin",
                Observation = observation
            });

            if (!response.IsSuccessStatusCode)
            {
                var detail = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo completar la acción. {detail}";
                return;
            }

            successMessage = okMessage;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error ejecutando acción: {ex.Message}";
        }
    }

