@page "/physical-counts/{Id:guid}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Components.Security
@using Navi.ToolsAssets.Admin.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject WebAuthSessionService AuthSession
@inject NavigationManager NavigationManager

<PageTitle>Detalle Toma Física</PageTitle>

<PermissionGuard Permission="PhysicalCounts.View" ModuleName="Detalle de Toma Física">

<section class="pc-hero">
    <div>
        <span class="pc-pill">TOMA FÍSICA · CONTROL POR USUARIO</span>
        <h2>@(board?.CountNumber ?? "Toma física")</h2>
        <p>
            Controla quién realizó inventario, quién no lo realizó, herramientas pendientes, diferencias y cierre de la toma.
        </p>
    </div>

    <div class="pc-side">
        <div class="pc-status-box">
            <span>Estado</span>
            <strong>@(board?.StatusLabel ?? "Cargando")</strong>
        </div>

        <button class="pc-outline-btn" type="button" @onclick="LoadAsync">
            Actualizar
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading && board is null)
{
    <div class="pc-empty">Cargando toma física...</div>
}
else if (board is not null)
{
    <section class="pc-kpi-grid">
        <article class="pc-kpi">
            <span>Participantes</span>
            <strong>@board.Summary.TotalParticipants</strong>
            <small>Usuarios / responsables</small>
        </article>

        <article class="pc-kpi info">
            <span>En proceso</span>
            <strong>@board.Summary.InProgress</strong>
            <small>Inventario iniciado</small>
        </article>

        <article class="pc-kpi success">
            <span>Finalizados</span>
            <strong>@board.Summary.Finished</strong>
            <small>Sin pendientes</small>
        </article>

        <article class="pc-kpi warning">
            <span>Pendientes</span>
            <strong>@board.Summary.TotalPending</strong>
            <small>Herramientas por validar</small>
        </article>

        <article class="pc-kpi danger">
            <span>Diferencias</span>
            <strong>@(board.Summary.DifferentItems + board.Summary.MissingItems + board.Summary.DamagedItems + board.Summary.ExtraItems)</strong>
            <small>Conciliación</small>
        </article>

        <article class="pc-kpi purple">
            <span>Avance</span>
            <strong>@board.Summary.Progress%</strong>
            <small>@board.Summary.TotalCounted de @board.Summary.TotalExpected</small>
        </article>
    </section>

    <section class="pc-actions-card">
        <div>
            <h3>Acciones de la toma física</h3>
            <p>Genera participantes según los responsables de activos, activa la toma y ciérrala cuando todos terminen.</p>
        </div>

        <div class="pc-actions">
            <button class="btn btn-outline-primary" type="button" @onclick="GenerateParticipantsAsync">
                Generar participantes
            </button>

            <button class="btn btn-success" type="button" @onclick="ActivateAsync">
                Activar toma
            </button>

            <button class="btn btn-dark" type="button" @onclick="CloseAsync">
                Cerrar toma
            </button>

            <button class="btn btn-outline-secondary" type="button" @onclick="GoBack">
                Volver
            </button>
        </div>
    </section>

    <section class="pc-card">
        <div class="pc-card-title">
            <div>
                <h3>Participantes de la toma</h3>
                <p>Estado individual: no iniciada, en proceso, finalizada, finalizada con diferencias o vencida.</p>
            </div>

            <input class="form-control pc-search"
                   placeholder="Buscar usuario, área, cargo..."
                   @bind="searchText"
                   @bind:event="oninput" />
        </div>

        @if (!FilteredParticipants.Any())
        {
            <div class="pc-empty">
                No hay participantes generados. Usa el botón <strong>Generar participantes</strong>.
            </div>
        }
        else
        {
            <div class="pc-table-wrapper">
                <table class="pc-table">
                    <thead>
                        <tr>
                            <th>Usuario / responsable</th>
                            <th>Estado</th>
                            <th>Asignadas</th>
                            <th>Validadas</th>
                            <th>Pendientes</th>
                            <th>Diferencias</th>
                            <th>Avance</th>
                            <th>Fechas</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var participant in FilteredParticipants)
                        {
                            <tr>
                                <td>
                                    <strong>@participant.DisplayName</strong>
                                    <small>@participant.UserName</small>
                                    <small>@participant.Area @participant.Position</small>
                                </td>

                                <td>
                                    <span class="@GetParticipantStatusClass(participant.Status)">
                                        @participant.StatusLabel
                                    </span>
                                </td>

                                <td>@participant.ExpectedItems</td>
                                <td>@participant.CountedItems</td>
                                <td>@participant.PendingItems</td>

                                <td>
                                    <small>Faltantes: @participant.MissingItems</small>
                                    <small>Diferentes: @participant.DifferentItems</small>
                                    <small>Dañadas: @participant.DamagedItems</small>
                                    <small>Sobrantes: @participant.ExtraItems</small>
                                </td>

                                <td>
                                    <div class="pc-progress">
                                        <div style="width:@participant.Progress%"></div>
                                    </div>
                                    <small>@participant.Progress%</small>
                                </td>

                                <td>
                                    <small>Inicio: @FormatDate(participant.StartedAt)</small>
                                    <small>Finalizó: @FormatDate(participant.FinishedAt)</small>
                                    <small>Última: @FormatDate(participant.LastActivityAt)</small>
                                </td>

                                <td>
                                    <div class="row-actions">
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => StartParticipantAsync(participant.Id)">
                                            Iniciar
                                        </button>

                                        <button class="btn btn-sm btn-outline-success" @onclick="() => FinishParticipantAsync(participant.Id)">
                                            Finalizar
                                        </button>

                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => LoadPendingToolsAsync(participant.Id)">
                                            Pendientes
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    @if (selectedPending is not null)
    {
        <section class="pc-card">
            <div class="pc-card-title">
                <div>
                    <h3>Pendientes de @(selectedPending?.DisplayName ?? "Usuario seleccionado")</h3>
                    <p>Herramientas o activos que aún no han sido validados por este participante.</p>
                </div>

                <button class="btn btn-sm btn-outline-secondary" @onclick="() => selectedPending = null">
                    Cerrar
                </button>
            </div>

            @if (!selectedPending.Tools.Any())
            {
                <div class="pc-empty">Este participante no tiene herramientas pendientes.</div>
            }
            else
            {
                <div class="pc-table-wrapper">
                    <table class="pc-table">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Activo / herramienta</th>
                                <th>Sede</th>
                                <th>Ubicación</th>
                                <th>Responsable</th>
                                <th>Estado operativo</th>
                                <th>Estado físico</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tool in selectedPending.Tools)
                            {
                                <tr>
                                    <td><strong>@tool.InternalCode</strong></td>
                                    <td>@tool.Name</td>
                                    <td>@tool.BranchCode</td>
                                    <td>@tool.LocationName</td>
                                    <td>@tool.ResponsibleName</td>
                                    <td>@tool.OperationalStatus</td>
                                    <td>@tool.PhysicalStatus</td>
                                <td>
                                    <div class="pc-pending-actions">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="@($"/physical-counts/{Id}/participants/{GetSelectedPendingParticipantId()}/pending-tools/{GetPendingToolId(tool)}")">
                                            Detalle / Reportar
                                        </a>

                                        <a class="btn btn-sm btn-outline-danger"
                                           href="@($"/physical-counts/{Id}/participants/{GetSelectedPendingParticipantId()}/pending-tools/{GetPendingToolId(tool)}?mode=reject")">
                                            Rechazar
                                        </a>
                                    </div>
                                </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

        <section class="pc-card">
                <div class="pc-card-title">
            <div class="pc-reported-section-header pc-reported-section-header--top">
                <div>
                    <h3>
                        @if (selectedPending is null)
                        {
                            <span>Registros reportados por usuario</span>
                        }
                        else
                        {
                            <span>Registros reportados de @(selectedPending?.DisplayName ?? "Usuario seleccionado")</span>
                        }
                    </h3>
                    <p>
                        @if (selectedPending is null)
                        {
                            <span>Seleccione un participante en la tabla superior y presione Pendientes para ver solo sus registros.</span>
                        }
                        else
                        {
                            <span>Solo se muestran los registros de este usuario: herramientas validadas, rechazadas, no encontradas o no listadas.</span>
                        }
                    </p>
                </div>

                <div class="pc-reported-section-actions pc-reported-section-actions--right">
                    <a class="pc-reported-inline-btn" href="@($"/physical-counts/{Id}/reported-items")">
                        Ir a conciliación global
                    </a>
                </div>
            </div>
        </div>
<div class="pc-user-progress">
                <article>
                    <span>Usuario</span>
                    <strong>@(selectedPending?.DisplayName ?? "Usuario seleccionado")</strong>
                    <small>Participante seleccionado</small>
                </article>

                <article>
                    <span>Esperados</span>
                    <strong>@(selectedPending?.ExpectedItems ?? 0)</strong>
                    <small>Asignados en sistema</small>
                </article>

                <article>
                    <span>Pendientes</span>
                    <strong>@(selectedPending?.PendingItems ?? 0)</strong>
                    <small>Sin validar</small>
                </article>

                <article>
                    <span>Reportados</span>
                    <strong>@SelectedParticipantReportedItems.Count()</strong>
                    <small>Registros del usuario</small>
                </article>
            </div>

            @if (!SelectedParticipantReportedItems.Any())
            {
                <div class="pc-empty">
                    Este usuario aún no tiene registros reportados. Cuando use Detalle / Reportar o Rechazar, aparecerán aquí.
                </div>
            }
            else
            {
                <div class="pc-table-wrapper">
                    <table class="pc-table">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Activo / reporte</th>
                                <th>Tipo</th>
                                <th>Proceso</th>
                                <th>Ubicación encontrada</th>
                                <th>Observación</th>
                                <th>Fecha</th>
                                <th>Registró</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in SelectedParticipantReportedItems)
                            {
                                <tr>
                                    <td>
                                        <strong>@Display(item.ToolInternalCode ?? item.ReportedCode)</strong>
                                    </td>

                                    <td>
                                        <strong>@Display(item.ToolName ?? item.ReportedName)</strong>
                                        @if (!string.IsNullOrWhiteSpace(item.SerialNumber))
                                        {
                                            <small>Serial: @item.SerialNumber</small>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(item.Brand) || !string.IsNullOrWhiteSpace(item.Model))
                                        {
                                            <small>@Display(item.Brand) @Display(item.Model)</small>
                                        }
                                    </td>

                                    <td>
                                        <span class="@GetReconciliationStatusClass(item.ReconciliationStatus)">
                                            @Display(item.ReportTypeLabel ?? item.ReportType)
                                        </span>
                                    </td>

                                    <td>
                                        <span class="@GetReconciliationStatusClass(item.ReconciliationStatus)">
                                            @GetUserProcessLabel(item)
                                        </span>
                                        <small>@Display(item.ReconciliationStatusLabel)</small>
                                    </td>

                                    <td>@Display(item.FoundLocation)</td>

                                    <td>@Display(item.Observation)</td>

                                    <td>@FormatDate(item.ReportedAt)</td>

                                    <td>@Display(item.ReportedBy ?? item.ParticipantName)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        }
    </section>
}


            <section class="pc-card pc-add-report-card">
                <div class="pc-card-title">
            <div class="pc-reported-section-header pc-reported-section-header--top">
                <div>
                    <h3>Agregar registro reportado</h3>
                    <p>
                        Registra un activo o herramienta que el usuario reportó físicamente y que no aparece en su inventario esperado.
                        Luego se valida en la vista de conciliación global.
                    </p>
                </div>

                <div class="pc-reported-section-actions pc-reported-section-actions--right">
                    @if (selectedPending is not null)
                    {
                        <button type="button"
                                class="pc-reported-inline-btn"
                                @onclick="ToggleQuickReportForm">
                            @(showQuickReportForm ? "Ocultar formulario" : "Mostrar formulario")
                        </button>
                    }
                </div>
            </div>
        </div>
@if (selectedPending is null)
        {
            <div class="pc-empty">
                Seleccione primero un participante usando el botón Pendientes. El registro reportado se asociará únicamente a ese usuario.
            </div>
        }
        else
        {
            <div class="pc-selected-user-banner">
                <strong>Usuario que reporta:</strong>
                <span>@(selectedPending?.DisplayName ?? "Usuario seleccionado")</span>
            </div>

            @if (!showQuickReportForm)
            {
                <div class="pc-empty">
                    El formulario está oculto. Presione <strong>Mostrar formulario</strong> para agregar un nuevo registro reportado para este usuario.
                </div>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(quickReportError))
                {
                    <div class="pc-alert pc-alert-danger">@quickReportError</div>
                }

                @if (!string.IsNullOrWhiteSpace(quickReportSuccess))
                {
                    <div class="pc-alert pc-alert-success">@quickReportSuccess</div>
                }

                <EditForm Model="quickReportedItem" OnValidSubmit="SaveQuickReportedItemAsync">
                    <div class="pc-report-form-grid">
                        <label>
                            Tipo de reporte *
                            <select @bind="quickReportedItem.ReportType">
                                <option value="ExtraNotListed">Herramienta / activo no listado</option>
                            </select>
                        </label>

                        <label>
                            Tipo de activo *
                            <select @bind="quickReportedItem.AssetTypeName">
                                <option value="Herramienta">Herramienta</option>
                                <option value="Activo fijo">Activo fijo</option>
                                <option value="Equipo">Equipo</option>
                            </select>
                        </label>

                        <label>
                            Código / placa visible *
                            <input @bind="quickReportedItem.ReportedCode" placeholder="Ej: AGU-NO-SIS-001..." />
                        </label>

                        <label>
                            Nombre del activo / herramienta *
                            <input @bind="quickReportedItem.ReportedName" placeholder="Ej: Taladro, gato, escáner..." />
                        </label>

                        <label>
                            Categoría *
                            <input @bind="quickReportedItem.CategoryName" placeholder="Ej: Eléctrica, hidráulica, cómputo..." />
                        </label>

                        <label>
                            Sede *
                            <input @bind="quickReportedItem.BranchCode" />
                        </label>

                        <label>
                            Ubicación encontrada *
                            <input @bind="quickReportedItem.FoundLocation" placeholder="Ej: Taller principal, almacén..." />
                        </label>

                        <label>
                            Estado físico *
                            <select @bind="quickReportedItem.PhysicalStatus">
                                <option value="">Seleccione...</option>
                                <option value="Bueno">Bueno</option>
                                <option value="Regular">Regular</option>
                                <option value="Dañado">Dañado</option>
                                <option value="No operativo">No operativo</option>
                            </select>
                        </label>

                        <label>
                            Serial
                            <input @bind="quickReportedItem.SerialNumber" />
                        </label>

                        <label>
                            Marca
                            <input @bind="quickReportedItem.Brand" />
                        </label>

                        <label>
                            Modelo
                            <input @bind="quickReportedItem.Model" />
                        </label>

                        <label>
                            Estado operativo
                            <input @bind="quickReportedItem.OperationalStatus" placeholder="Operativo / No operativo" />
                        </label>
                    </div>

                    <label class="pc-report-full">
                        Observación *
                        <textarea @bind="quickReportedItem.Observation" rows="4" placeholder="Describa lo que reportó el usuario y cualquier detalle para conciliación."></textarea>
                    </label>

                    <label class="pc-check-row">
                        <input type="checkbox" @bind="quickReportedItem.RequiresUserClarification" />
                        Requiere llamar/contactar al usuario para aclaración
                    </label>

                    <div class="pc-form-actions">
                        <button type="submit" class="pc-primary-btn" disabled="@isSavingQuickReport">
                            @(isSavingQuickReport ? "Guardando..." : "Guardar registro reportado")
                        </button>

                        <button type="button" class="pc-secondary-btn" @onclick="ResetQuickReportedItemForm" disabled="@isSavingQuickReport">
                            Limpiar
                        </button>
                    </div>
                </EditForm>
            }
        }
    </section>

            
        }
    

</PermissionGuard>

<style>
    .pc-hero {
        margin-bottom: .8rem;
        padding: 1rem 1.15rem;
        border-radius: 1rem;
        background: radial-gradient(circle at top right, rgba(255,255,255,.16), transparent 34%),
            linear-gradient(135deg, #100015 0%, #4b005c 58%, #7b0d8e 100%);
        color: white;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        box-shadow: 0 .65rem 1.5rem rgba(75,0,92,.22);
    }

    .pc-pill {
        display: inline-flex;
        padding: .18rem .6rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.35);
        background: rgba(255,255,255,.10);
        font-size: .68rem;
        font-weight: 950;
    }

    .pc-hero h2 {
        margin: .45rem 0 .2rem;
        font-size: 1.55rem;
        font-weight: 950;
    }

    .pc-hero p {
        margin: 0;
        color: rgba(255,255,255,.88);
    }

    .pc-side {
        min-width: 190px;
        display: flex;
        flex-direction: column;
        gap: .5rem;
        align-items: flex-end;
    }

    .pc-status-box {
        width: 190px;
        padding: .65rem .85rem;
        border-radius: .85rem;
        background: rgba(255,255,255,.12);
        text-align: right;
    }

    .pc-status-box span {
        display: block;
        color: #ffdd57;
        font-size: .72rem;
        font-weight: 950;
    }

    .pc-outline-btn {
        width: 190px;
        min-height: 34px;
        border-radius: .55rem;
        border: 1px solid rgba(255,255,255,.7);
        background: rgba(255,255,255,.06);
        color: white;
        font-weight: 950;
    }

    .pc-kpi-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(130px, 1fr));
        gap: .55rem;
        margin-bottom: .75rem;
    }

    .pc-kpi {
        border: 1px solid #dfe3e8;
        border-left: 4px solid #0d6efd;
        border-radius: .75rem;
        padding: .62rem;
        background: white;
    }

    .pc-kpi.success { border-left-color: #198754; }
    .pc-kpi.warning { border-left-color: #ffc107; }
    .pc-kpi.info { border-left-color: #0dcaf0; }
    .pc-kpi.danger { border-left-color: #dc3545; }
    .pc-kpi.purple { border-left-color: #7b0d8e; }

    .pc-kpi span {
        display: block;
        color: #526071;
        font-size: .65rem;
        font-weight: 950;
        text-transform: uppercase;
    }

    .pc-kpi strong {
        display: block;
        font-size: 1.25rem;
        font-weight: 950;
        color: #06111f;
    }

    .pc-card,
    .pc-actions-card {
        background: white;
        border: 1px solid #dfe3e8;
        border-radius: .95rem;
        padding: .9rem;
        margin-bottom: .8rem;
        box-shadow: 0 .35rem .9rem rgba(0,0,0,.04);
    }

    .pc-actions-card {
        display: flex;
        justify-content: space-between;
        gap: .75rem;
        align-items: center;
    }

    .pc-actions-card h3,
    .pc-card-title h3 {
        margin: 0;
        font-size: 1rem;
        font-weight: 950;
    }

    .pc-actions-card p,
    .pc-card-title p {
        margin: .1rem 0 0;
        color: #657083;
        font-size: .78rem;
    }

    .pc-actions {
        display: flex;
        gap: .4rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .pc-card-title {
        display: flex;
        justify-content: space-between;
        gap: .75rem;
        align-items: flex-start;
        margin-bottom: .7rem;
    }

    .pc-search {
        max-width: 360px;
    }

    .pc-table-wrapper {
        width: 100%;
        overflow-x: auto;
    }

    .pc-table {
        width: 100%;
        min-width: 1050px;
        table-layout: fixed;
        border-collapse: collapse;
        font-size: .72rem;
    }

    .pc-table th {
        border-bottom: 1px solid #17111c;
        padding: .42rem .35rem;
        font-size: .63rem;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .pc-table td {
        border-bottom: 1px solid #e5e8ef;
        padding: .45rem .35rem;
        vertical-align: middle;
    }

    .pc-table td strong,
    .pc-table td small {
        display: block;
        line-height: 1.2;
    }

    .pc-table td small {
        color: #657083;
        font-size: .64rem;
    }

    .pc-status {
        display: inline-flex;
        border-radius: 999px;
        padding: .18rem .42rem;
        font-size: .65rem;
        font-weight: 950;
        white-space: nowrap;
    }

    .pc-status.pending { background: #f8f9fa; color: #495057; }
    .pc-status.progress { background: #cff4fc; color: #055160; }
    .pc-status.done { background: #d1e7dd; color: #0f5132; }
    .pc-status.diff { background: #fff3cd; color: #7a5200; }
    .pc-status.expired { background: #f8d7da; color: #842029; }

    .pc-progress {
        height: 8px;
        border-radius: 999px;
        background: #e9ecef;
        overflow: hidden;
    }

    .pc-progress div {
        height: 100%;
        border-radius: 999px;
        background: #7b0d8e;
    }

    .row-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .28rem;
    }

    .row-actions .btn {
        font-size: .68rem;
        padding: .22rem .42rem;
        min-height: 27px;
    }

    .pc-empty {
        padding: .9rem;
        border-radius: .75rem;
        background: #f8fafc;
        color: #526071;
        font-weight: 850;
    }

    @@media (max-width: 1200px) {
        .pc-kpi-grid {
