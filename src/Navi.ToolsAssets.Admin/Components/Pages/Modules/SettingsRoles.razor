@page "/settings/roles"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject WebAuthSessionService AuthSession

<PageTitle>Roles y permisos - NAVI</PageTitle>

<section class="navi-module-hero">
    <div>
        <span class="navi-module-pill">SEGURIDAD · MATRIZ DE ACCIÓN · PERMISOS</span>
        <h2>Roles y permisos</h2>
        <p>Define qué puede ver, crear, editar, aprobar, rechazar, reportar, exportar o administrar cada rol del sistema NAVI.</p>
    </div>

    <div class="navi-module-hero-actions">
        <div class="navi-module-hero-counter">
            <span>Roles</span>
            <strong>@roles.Count</strong>
        </div>

        <a class="navi-module-hero-btn" href="/settings">
            Volver a Configuración
        </a>
    </div>
</section>

<section class="rolesx-kpis">
    <article>
        <span>Permisos definidos</span>
        <strong>@AllPermissions.Count</strong>
        <small>Matriz funcional</small>
    </article>

    <article class="success">
        <span>Plantillas</span>
        <strong>@roleTemplates.Count</strong>
        <small>Perfiles rápidos</small>
    </article>

    <article class="warning">
        <span>Seleccionados</span>
        <strong>@selectedPermissions.Count</strong>
        <small>Rol actual</small>
    </article>

    <article class="purple">
        <span>Modo</span>
        <strong>@(CanManageRoles ? "Edición" : "Consulta")</strong>
        <small>@(CanManageRoles ? "Puede modificar" : "Solo lectura")</small>
    </article>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="@messageClass rolesx-message">@message</div>
}

<section class="rolesx-workspace">
    <aside class="rolesx-card rolesx-left">
        <div class="rolesx-card-title">
            <div>
                <h3>@(editingId is null ? "Crear rol" : "Editar rol")</h3>
                <p>Información base del perfil.</p>
            </div>
        </div>

        <EditForm Model="formModel" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="rolesx-form-grid">
                <div>
                    <label>Código del rol</label>
                    <InputText class="form-control"
                               @bind-Value="formModel.Code"
                               placeholder="TECNICO, HERRAMIENT, COORD_TALLER"
                               disabled="@(!CanManageRoles)" />
                </div>

                <div>
                    <label>Nombre</label>
                    <InputText class="form-control"
                               @bind-Value="formModel.Name"
                               placeholder="Técnico, Herramientero, Coordinador"
                               disabled="@(!CanManageRoles)" />
                </div>

                <div class="span-2">
                    <label>Descripción</label>
                    <InputTextArea class="form-control"
                                   @bind-Value="formModel.Description"
                                   rows="3"
                                   placeholder="Describe el alcance del rol dentro del proceso."
                                   disabled="@(!CanManageRoles)" />
                </div>

                <div class="rolesx-check-row span-2">
                    <InputCheckbox class="form-check-input"
                                   @bind-Value="formModel.IsActive"
                                   disabled="@(!CanManageRoles)" />
                    <label>Rol activo</label>
                </div>
            </div>

            <div class="rolesx-actions">
                @if (CanManageRoles)
                {
                    <button type="submit">Guardar matriz del rol</button>
                }
                else
                {
                    <span class="rolesx-denied">Solo consulta</span>
                }

                <button type="button" class="secondary" @onclick="ClearForm">Limpiar</button>
            </div>
        </EditForm>

        <div class="rolesx-separator"></div>

        <div class="rolesx-card-title compact">
            <div>
                <h3>Plantillas por cargo</h3>
                <p>Selecciona un perfil y ajusta permisos antes de guardar.</p>
            </div>
        </div>

        <div class="rolesx-template-list">
            @foreach (var template in roleTemplates)
            {
                <button type="button"
                        class="@GetTemplateClass(template.Code)"
                        @onclick="() => SelectProfile(template.Code)"
                        disabled="@(!CanManageRoles)">
                    <span>@template.Icon</span>

                    <div>
                        <strong>@template.Name</strong>
                        <small>@template.Scope</small>
                    </div>

                    <em>@template.Permissions.Count</em>
                </button>
            }
        </div>
        <div class="rolesx-separator"></div>

        <section class="rolesx-left-summary">

        <div class="rolesx-card-title compact">
            <div>
                <h3>Resumen del rol</h3>
                <p>Qué puede y qué no puede hacer.</p>
            </div>
        </div>

        <div class="rolesx-current-role">
            <span>@GetSelectedTemplateIcon()</span>
            <div>
                <strong>@(string.IsNullOrWhiteSpace(formModel.Name) ? "Rol sin seleccionar" : formModel.Name)</strong>
                <small>@(string.IsNullOrWhiteSpace(formModel.Code) ? "Código pendiente" : formModel.Code)</small>
            </div>
        </div>

        <div class="rolesx-summary-grid">
            <div>
                <span>Ver</span>
                <strong>@CountByKind("View")</strong>
            </div>

            <div>
                <span>Crear</span>
                <strong>@CountByKind("Create", "Request")</strong>
            </div>

            <div>
                <span>Editar</span>
                <strong>@CountByKind("Edit", "Manage", "Execute", "Assign", "Return")</strong>
            </div>

            <div>
                <span>Aprobar</span>
                <strong>@CountByKind("Approve", "Close")</strong>
            </div>
        </div>

        <div class="rolesx-separator"></div>

        <div class="rolesx-card-title compact">
            <div>
                <h3>Reglas recomendadas</h3>
                <p>Base para aplicar seguridad real.</p>
            </div>
        </div>

        <div class="rolesx-rules">
            @foreach (var rule in CurrentRoleRules)
            {
                <div>
                    <span>@rule.Icon</span>
                    <strong>@rule.Title</strong>
                    <small>@rule.Description</small>
                </div>
            }
        </div>

        <div class="rolesx-separator"></div>

        <div class="rolesx-card-title compact">
            <div>
                <h3>Permisos seleccionados</h3>
                <p>@selectedPermissions.Count permiso(s) en el rol actual.</p>
            </div>
        </div>

        <div class="rolesx-selected-list">
            @if (selectedPermissions.Count == 0)
            {
                <div class="rolesx-empty small">Sin permisos seleccionados.</div>
            }
            else
            {
                @foreach (var permission in selectedPermissions.OrderBy(x => x))
                {
                    <span>@permission</span>
                }
            }
        </div>
        </section>

    </aside>

    <main class="rolesx-main">
        <article class="rolesx-card">
            <div class="rolesx-card-title">
                <div>
                    <h3>Matriz de acción por módulo</h3>
                    <p>Permisos separados por ver, crear, editar, aprobar, rechazar, reportar, exportar y administrar.</p>
                </div>

                <div class="rolesx-tools">
                    <input class="form-control"
                           placeholder="Buscar permiso, módulo o acción..."
                           @bind="permissionSearch"
                           @bind:event="oninput" />

                    <div class="rolesx-tool-actions">
                        <button type="button" class="soft" @onclick="ExpandAllPermissionGroups">Mostrar todo</button>
                        <button type="button" class="soft" @onclick="CollapseAllPermissionGroups">Ocultar todo</button>
                        <button type="button" @onclick="SelectAdminProfile" disabled="@(!CanManageRoles)">Todo</button>
                        <button type="button" class="danger-light" @onclick="ClearPermissions" disabled="@(!CanManageRoles)">Quitar</button>
                    </div>
                </div>
            </div>

            <div class="rolesx-legend">
                <span><b class="view"></b> Ver / consultar</span>
                <span><b class="create"></b> Crear / solicitar</span>
                <span><b class="edit"></b> Editar / gestionar</span>
                <span><b class="approve"></b> Aprobar / cerrar</span>
                <span><b class="danger"></b> Eliminar / rechazar</span>
                <span><b class="mobile"></b> Móvil / técnico</span>
            </div>

            <div class="rolesx-matrix">
                @foreach (var group in FilteredPermissionGroups)
                {
                    <section class="@(IsGroupCollapsed(group) ? "rolesx-permission-group collapsed" : "rolesx-permission-group")">
                        <header>
                            <div>
                                <span>@group.Area</span>
                                <strong>@group.Title</strong>
                                <small>@group.Permissions.Count permiso(s)</small>
                            </div>

                            <button type="button"
                                    class="rolesx-collapse-btn"
                                    @onclick="() => TogglePermissionGroup(group)">
                                @(IsGroupCollapsed(group) ? "Ver" : "Ocultar")
                            </button>
                        </header>

                        @if (!IsGroupCollapsed(group))
                        {
                            <div class="rolesx-permission-list">
                                @foreach (var permission in group.Permissions)
                                {
                                    <label class="@GetPermissionClass(permission)">
                                        <input type="checkbox"
                                               checked="@IsPermissionSelected(permission.Code)"
                                               disabled="@(!CanManageRoles)"
                                               @onchange="args => TogglePermission(permission.Code, args.Value)" />

                                        <span>
                                            <strong>@permission.Name</strong>
                                            <small>@permission.Code</small>
                                        </span>

                                        <em>@permission.Scope</em>
                                    </label>
                                }
                            </div>
                        }
                    </section>
                }
            </div>
        </article>

        <article class="rolesx-card rolesx-role-table">
            <div class="rolesx-card-title">
                <div>
                    <h3>Roles registrados</h3>
                    <p>Perfiles guardados en base de datos y permisos activos por rol.</p>
                </div>

                <button class="rolesx-light-btn" type="button" @onclick="LoadAsync">Actualizar</button>
            </div>

            @if (isLoading)
            {
                <div class="rolesx-empty">Cargando roles...</div>
            }
            else if (roles.Count == 0)
            {
                <div class="rolesx-empty">No hay roles registrados.</div>
            }
            else
            {
                <div class="rolesx-table-wrapper">
                    <table class="rolesx-table">
                        <thead>
                            <tr>
                                <th>Rol</th>
                                <th>Perfil detectado</th>
                                <th>Permisos</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var role in roles.OrderBy(x => x.Code))
                            {
                                <tr>
                                    <td>
                                        <strong>@role.Code</strong>
                                        <small>@role.Name</small>
                                    </td>

                                    <td>
                                        <span class="rolesx-profile-pill">@GetRoleProfileName(role)</span>
                                        <small>@role.Description</small>
                                    </td>

                                    <td>
                                        <div class="rolesx-permission-count">
                                            <strong>@GetRolePermissionCount(role)</strong>
                                            <small>@GetRolePermissionPreview(role)</small>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="@(role.IsActive ? "rolesx-status active" : "rolesx-status inactive")">
                                            @(role.IsActive ? "Activo" : "Inactivo")
                                        </span>
                                    </td>

                                    <td>
                                        <div class="rolesx-row-actions">
                                            <button type="button" @onclick="() => Edit(role)" disabled="@(!CanManageRoles)">
                                                Editar
                                            </button>

                                            <button type="button" class="danger" @onclick="() => DeleteAsync(role.Id)" disabled="@(!CanManageRoles)">
                                                Eliminar
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>
    </main>


</section>

<style>
    .rolesx-hero {
        margin-bottom: .7rem;
        padding: .95rem 1.1rem;
        border-radius: 1rem;
        background: linear-gradient(105deg, #050507 0%, #07070b 34%, #120017 58%, #350040 78%, #710083 100%);
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 .55rem 1.2rem rgba(75,0,92,.18);
    }

    .rolesx-pill {
        display: inline-flex;
        padding: .18rem .62rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.35);
        background: rgba(255,255,255,.10);
        font-size: .68rem;
        font-weight: 950;
    }

    .rolesx-hero h2 {
        margin: .34rem 0 .14rem;
        font-size: 1.75rem;
        font-weight: 950;
        line-height: 1.05;
    }

    .rolesx-hero p {
        margin: 0;
        color: rgba(255,255,255,.88);
        font-size: .88rem;
    }

    .rolesx-hero-actions {
        display: grid;
        gap: .45rem;
        width: 190px;
    }

    .rolesx-hero-counter {
        border: 1px solid rgba(255,255,255,.18);
        border-radius: .72rem;
        background: rgba(255,255,255,.10);
        padding: .45rem .7rem;
        text-align: right;
    }

    .rolesx-hero-counter span,
    .rolesx-hero-counter strong {
        display: block;
        line-height: 1.08;
    }

    .rolesx-hero-counter span {
        color: #ffdd57;
        font-size: .66rem;
        font-weight: 950;
        text-transform: uppercase;
    }

    .rolesx-hero-counter strong {
        color: #fff;
        font-size: 1.25rem;
        font-weight: 950;
    }

    .rolesx-hero-btn {
        min-height: 34px;
        border-radius: .55rem;
        border: 1px solid rgba(255,255,255,.70);
        background: rgba(255,255,255,.06);
        color: #fff;
        font-size: .76rem;
        font-weight: 950;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .rolesx-kpis {
        display: grid;
        grid-template-columns: repeat(4, minmax(130px, 1fr));
        gap: .45rem;
        margin-bottom: .65rem;
    }

    .rolesx-kpis article,
    .rolesx-card {
        background: #fff;
        border: 1px solid #eadff0;
        border-radius: .9rem;
        box-shadow: 0 .25rem .75rem rgba(75,0,92,.045);
    }

    .rolesx-kpis article {
        border-left: 4px solid #2186d9;
        padding: .55rem;
    }

    .rolesx-kpis article.success { border-left-color: #198754; }
    .rolesx-kpis article.warning { border-left-color: #ffc107; }
    .rolesx-kpis article.purple { border-left-color: #7b0d8e; }

    .rolesx-kpis span {
        display: block;
        color: #526071;
        font-size: .62rem;
        font-weight: 950;
        text-transform: uppercase;
    }

    .rolesx-kpis strong {
        display: block;
        color: #06111f;
        font-size: 1.25rem;
        font-weight: 950;
        line-height: 1;
    }

    .rolesx-kpis small {
        color: #657083;
        font-size: .62rem;
    }

    .rolesx-message {
        border-radius: .65rem;
        margin-bottom: .65rem;
        font-size: .76rem;
        font-weight: 850;
    }

    .rolesx-workspace {
        display: grid;
        grid-template-columns: 345px minmax(0, 1fr);
        gap: .65rem;
        align-items: start;
    }

    .rolesx-card {
        padding: .82rem;
    }

    .rolesx-left {
        position: sticky;
        top: .7rem;
        max-height: calc(100vh - 1.4rem);
        overflow-y: auto;
    }

    .rolesx-main {
        display: grid;
        gap: .65rem;
        min-width: 0;
    }

    .rolesx-card-title {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: .75rem;
        margin-bottom: .62rem;
    }

    .rolesx-card-title.compact {
        display: block;
        margin-bottom: .45rem;
    }

    .rolesx-card-title h3 {
        margin: 0;
        color: #100018;
        font-size: 1rem;
        font-weight: 950;
    }

    .rolesx-card-title p {
        margin: .08rem 0 0;
        color: #657083;
        font-size: .72rem;
        line-height: 1.25;
    }

    .rolesx-form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .5rem;
    }

    .rolesx-form-grid .span-2 {
        grid-column: span 2;
    }

    .rolesx-form-grid label,
    .rolesx-check-row label {
        color: #24102e;
        font-size: .68rem;
        font-weight: 950;
        margin-bottom: .18rem;
    }

    .rolesx-check-row {
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .rolesx-actions {
        display: flex;
        gap: .4rem;
        margin-top: .65rem;
        flex-wrap: wrap;
    }

    .rolesx-actions button,
    .rolesx-tools button,
    .rolesx-light-btn,
    .rolesx-row-actions button {
        min-height: 30px;
        border-radius: .48rem;
        font-size: .66rem;
        font-weight: 950;
        padding: .28rem .65rem;
        border: 1px solid #2563eb;
        background: #eff6ff;
        color: #1d4ed8;
    }

    .rolesx-actions button:first-child {
        border: 0;
        color: #fff;
        background: linear-gradient(135deg, #7b0d8e, #4b005c);
    }

    .rolesx-actions button.secondary {
        border: 1px solid #cbd5e1;
        background: #f8fafc;
        color: #334155;
    }

    .rolesx-denied {
        display: inline-flex;
        align-items: center;
        min-height: 30px;
        padding: .28rem .65rem;
        border-radius: .48rem;
        background: #fff3cd;
        color: #7a5200;
        font-size: .66rem;
        font-weight: 950;
    }

    .rolesx-separator {
        height: 1px;
        background: #eadff0;
        margin: .75rem 0 .6rem;
    }

    .rolesx-template-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: .28rem;
    }

    .rolesx-template-list button {
        min-height: 42px;
        border: 1px solid #eadff0;
        background: #fbf8ff;
        border-radius: .58rem;
        display: grid;
        grid-template-columns: 28px minmax(0, 1fr) 30px;
        gap: .36rem;
        align-items: center;
        text-align: left;
        padding: .34rem .38rem;
    }

    .rolesx-template-list button.active {
        border-color: #7b0d8e;
        background: linear-gradient(135deg, rgba(123,13,142,.12), rgba(33,134,217,.08));
    }

    .rolesx-template-list span,
    .rolesx-current-role > span,
    .rolesx-rules span {
        width: 28px;
        height: 28px;
        border-radius: .5rem;
        display: grid;
        place-items: center;
        color: #fff;
        background: linear-gradient(145deg, #7b0d8e, #4b005c);
        font-size: .78rem;
    }

    .rolesx-template-list strong,
    .rolesx-template-list small {
        color: #657083;
        font-size: .54rem;
        margin-top: .06rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .rolesx-template-list strong {
        color: #100018;
        font-size: .64rem;
        font-weight: 950;
    }

    .rolesx-template-list small {
        color: #657083;
        font-size: .58rem;
        margin-top: .08rem;
    }

    .rolesx-template-list em {
        font-style: normal;
        font-size: .62rem;
        font-weight: 950;
        color: #4b005c;
        text-align: right;
    }

    .rolesx-tools {
        display: grid;
        grid-template-columns: minmax(260px, 1fr) auto;
        gap: .45rem;
        align-items: center;
        min-width: 540px;
    }

    .rolesx-tool-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: .3rem;
    }

    .rolesx-tool-actions button {
        min-height: 30px;
        border-radius: .48rem;
        font-size: .62rem;
        font-weight: 950;
        padding: .24rem .55rem;
        border: 1px solid #2563eb;
        background: #eff6ff;
        color: #1d4ed8;
        white-space: nowrap;
    }

    .rolesx-tool-actions button.soft {
        border-color: #d8b7e4;
        background: #fbf4ff;
        color: #4b005c;
    }

    .rolesx-tool-actions button.danger-light {
        border-color: #f5c2c7;
        background: #fff5f5;
        color: #b42318;
    }

    .rolesx-legend {
        display: flex;
        flex-wrap: wrap;
        gap: .35rem;
        margin-bottom: .6rem;
    }

    .rolesx-legend span {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        border: 1px solid #edf1f5;
        background: #fbf8ff;
        border-radius: 999px;
        padding: .18rem .45rem;
        font-size: .58rem;
        font-weight: 850;
        color: #526071;
    }

    .rolesx-legend b {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        display: inline-block;
        background: #2186d9;
    }

    .rolesx-legend b.create { background: #198754; }
    .rolesx-legend b.edit { background: #7b0d8e; }
    .rolesx-legend b.approve { background: #fd7e14; }
    .rolesx-legend b.danger { background: #dc3545; }
    .rolesx-legend b.mobile { background: #0dcaf0; }

    .rolesx-matrix {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: .55rem;
    }

    .rolesx-permission-group {
        border: 1px solid #e5e8ef;
        border-radius: .78rem;
        overflow: hidden;
        background: #fff;
    }

    .rolesx-permission-group header {
        padding: .44rem .5rem;
        background: linear-gradient(135deg, #fbf4fd 0%, #ffffff 100%);
        border-bottom: 1px solid #edf1f5;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .5rem;
    }

    .rolesx-collapse-btn {
        min-width: 58px;
        min-height: 25px;
        border-radius: 999px;
        border: 1px solid #d8b7e4;
        background: #ffffff;
        color: #4b005c;
        font-size: .56rem;
        font-weight: 950;
        padding: .12rem .45rem;
        white-space: nowrap;
    }

    .rolesx-permission-group.collapsed {
        opacity: .96;
    }

    .rolesx-permission-group.collapsed header {
        border-bottom: 0;
    }

    .rolesx-permission-group header span,
    .rolesx-permission-group header strong,
    .rolesx-permission-group header small {
        display: block;
        line-height: 1.08;
    }

    .rolesx-permission-group header span {
        color: #4b005c;
        font-size: .58rem;
        font-weight: 950;
