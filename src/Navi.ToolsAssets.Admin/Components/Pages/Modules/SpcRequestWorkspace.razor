@rendermode InteractiveServer
@using System.Text
@using System.Text.Json
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Navi.ToolsAssets.Admin.Components.Security
@using Navi.ToolsAssets.Admin.Services.Auth
@inject WebAuthSessionService AuthSession
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject IServiceProvider ServiceProvider

<PermissionGuard Permission="@PermissionName" ModuleName="@ModuleName">

<section class="spc-hero navi-standard-hero">
    <div class="spc-hero-copy">
        <span class="spc-pill">@HeroPill</span>
        <h2>@PageTitleText</h2>
        <p>@PageSubtitle</p>
    </div>

    <div class="spc-hero-actions">
        <div class="spc-hero-status">
            <span>Solicitudes registradas</span>
            <strong>@(storedRequests.Count + registeredItems.Count)</strong>
        </div>

        <button type="button" class="spc-hero-btn" @onclick="LoadAsync">
            Actualizar
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="spc-shell">
    <div class="spc-column">
        <article class="spc-card">
            <div class="spc-card-title">
                <div>
                    <h3>@HeaderTitle</h3>
                    <p>@HeaderSubtitle</p>
                </div>
            </div>

            <div class="spc-grid two">
                <div class="form-group">
                    <label>Nombre de la solicitud</label>
                    <InputText class="form-control" @bind-Value="header.RequestName" disabled="@(!CanEditRequest)" />
                </div>

                <div class="form-group">
                    <label>Sede</label>
                    <InputSelect class="form-select" @bind-Value="header.BranchIdText" disabled="@(!CanEditRequest)">
                        <option value="">Seleccione sede</option>
                        @foreach (var branch in branches)
                        {
                            <option value="@branch.Id">@branch.Code - @branch.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Solicitante</label>
                    <InputText class="form-control" @bind-Value="header.RequestedBy" readonly />
                </div>

                <div class="form-group">
                    <label>Responsable que aprueba</label>
                    <InputText class="form-control" @bind-Value="header.Approver" disabled="@(!CanEditRequest)" />
                </div>

                @if (IsMaintenance)
                {
                    <div class="form-group">
                        <label>Tipo mantenimiento</label>
                        <InputSelect class="form-select" @bind-Value="header.RequestType" disabled="@(!CanEditRequest)">
                            <option value="Correctivo">Correctivo</option>
                            <option value="Preventivo">Preventivo</option>
                            <option value="Calibración">Calibración</option>
                            <option value="Garantía">Garantía</option>
                            <option value="Seguridad/SSTA">Seguridad/SSTA</option>
                        </InputSelect>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label>Tipo solicitud</label>
                        <InputSelect class="form-select" @bind-Value="header.RequestType" disabled="@(!CanEditRequest)">
                            <option value="SPC">SPC</option>
                            <option value="Activo fijo">Activo fijo</option>
                            <option value="Herramienta">Herramienta</option>
                            <option value="Equipo">Equipo</option>
                            <option value="Kit de herramientas">Kit de herramientas</option>
                        </InputSelect>
                    </div>
                }

                <div class="form-group">
                    <label>Prioridad</label>
                    <InputSelect class="form-select" @bind-Value="header.Priority" disabled="@(!CanEditRequest)">
                        <option value="Baja">Baja</option>
                        <option value="Media">Media</option>
                        <option value="Alta">Alta</option>
                        <option value="Crítica">Crítica</option>
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Fecha requerida</label>
                    <InputDate class="form-control" @bind-Value="header.RequiredAt" disabled="@(!CanEditRequest)" />
                </div>

                <div class="form-group">
                    <label>Ubicación / área</label>
                    <InputText class="form-control" @bind-Value="header.Location" disabled="@(!CanEditRequest)" />
                </div>

                <div class="form-group full">
                    <label>Descripción general de la necesidad</label>
                    <InputTextArea class="form-control" @bind-Value="header.NeedDescription" rows="2" disabled="@(!CanEditRequest)" />
                </div>
            </div>
        </article>

        <article class="spc-card">
            <div class="spc-card-title">
                <div>
                    <h3>@LinesTitle</h3>
                    <p>Agrega una herramienta principal o varias herramientas que hagan parte del kit solicitado.</p>
                </div>
            </div>

            <div class="spc-grid two">
                <div class="form-group">
                    <label>Foto / evidencia</label>
                    <InputFile class="form-control" OnChange="OnImageSelected" accept="image/*" disabled="@(!CanEditRequest)" />
                    @if (!string.IsNullOrWhiteSpace(lineForm.ImageReference))
                    {
                        <small class="photo-file-name">@lineForm.ImageReference</small>
                    }
                    @if (!string.IsNullOrWhiteSpace(lineForm.ImagePreview))
                    {
                        <img class="photo-preview" src="@lineForm.ImagePreview" alt="Vista previa" />
                    }
                </div>

                <div class="form-group">
                    <label>Información técnica / serial</label>
                    <InputText class="form-control" @bind-Value="lineForm.TechnicalOrSerial" disabled="@(!CanEditRequest)" />
                </div>

                <div class="form-group">
                    <label>Nombre herramienta / equipo</label>
                    <InputText class="form-control" @bind-Value="lineForm.ToolName" disabled="@(!CanEditRequest)" />
                </div>

                @if (IsMaintenance)
                {
                    <div class="form-group">
                        <label>Estado / criticidad</label>
                        <InputSelect class="form-select" @bind-Value="lineForm.Criticality" disabled="@(!CanEditRequest)">
                            <option value="Normal">Normal</option>
                            <option value="Alta">Alta</option>
                            <option value="Crítica">Crítica</option>
                        </InputSelect>
                    </div>
                }
                else
                {
                    <div class="form-group">
                        <label>Cantidad</label>
                        <InputNumber class="form-control" @bind-Value="lineForm.Quantity" disabled="@(!CanEditRequest)" />
                    </div>
                }

                <div class="form-group full">
                    <label>Detalles</label>
                    <InputTextArea class="form-control" @bind-Value="lineForm.Details" rows="2" disabled="@(!CanEditRequest)" />
                </div>

                <div class="form-group full">
                    <label>Novedades / falla / observación</label>
                    <InputTextArea class="form-control" @bind-Value="lineForm.Novelty" rows="2" disabled="@(!CanEditRequest)" />
                </div>
            </div>

            <div class="spc-actions">
                <button type="button" class="btn btn-primary" @onclick="AddLine" disabled="@(!CanCreateOrConfirmRequest)">
                    @(editingLineId.HasValue ? "Actualizar herramienta" : "Agregar herramienta")
                </button>

                <button type="button" class="btn btn-outline-secondary" @onclick="ClearLine">
                    Limpiar línea
                </button>
            </div>

            @if (!currentLines.Any())
            {
                <div class="spc-empty">No hay herramientas agregadas.</div>
            }
            else
            {
                <div class="spc-table-wrap">
                    <table class="spc-table">
                        <thead>
                            <tr>
                                <th>Usar</th>
                                <th>Herramienta</th>
                                <th>Técnico / serial</th>
                                <th>@(IsMaintenance ? "Criticidad" : "Cant.")</th>
                                <th>Detalles / novedades</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in currentLines)
                            {
                                <tr>
                                    <td><InputCheckbox @bind-Value="item.Selected" disabled="@(!CanEditRequest)" /></td>
                                    <td>
                                        <strong>@item.ToolName</strong>
                                        @if (!string.IsNullOrWhiteSpace(item.ImagePreview))
                                        {
                                            <img class="photo-thumb" src="@item.ImagePreview" alt="Foto herramienta" />
                                        }
                                        <small>@item.ImageReference</small>
                                    </td>
                                    <td>@item.TechnicalOrSerial</td>
                                    <td>@(IsMaintenance ? item.Criticality : item.Quantity)</td>
                                    <td>
                                        <small>@item.Details</small>
                                        <small>@item.Novelty</small>
                                    </td>
                                    <td>
                                        <div class="row-actions">
                                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => EditLine(item.Id)">Editar</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(item.Id)">Quitar</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="spc-card spc-request-state-card">
            <div class="spc-card-title">
                <div>
                    <h3>Estado de la solicitud</h3>
                    <p>Guarda el borrador o confirma la solicitud. Al guardar se limpia el formulario y queda abajo en solicitudes registradas.</p>
                </div>
            </div>

            <div class="spc-state-box">
                <span>Estado actual</span>
                <strong>@RequestVisualState</strong>
            </div>

            <div class="spc-actions">
                <button type="button" class="btn btn-outline-primary" @onclick="SaveDraftAsync">
                    Guardar como borrador
                </button>

                <button type="button" class="btn btn-primary" @onclick="ConfirmRequestAsync" disabled="@(!CanCreateOrConfirmRequest)">
                    Confirmar solicitud
                </button>
            </div>
        </article>
    </div>

    <div class="spc-column">
        <article class="spc-card">
            <div class="spc-card-title">
                <div>
                    <h3>@QuotationTitle</h3>
                    <p>Solo se habilita cuando una solicitud confirmada entra a Realizar cotización.</p>
                </div>
            </div>

            @if (!CanQuote)
            {
                <div class="spc-locked">
                    Selecciona una solicitud confirmada en la parte inferior y presiona <strong>Realizar cotización</strong>.
                </div>
            }

            <div class="quote-header-box">
                <div>
                    <span>Solicitud</span>
                    <strong>@Display(header.RequestName)</strong>
                </div>
                <div>
                    <span>Sede</span>
                    <strong>@SelectedBranchLabel</strong>
                </div>
                <div>
                    <span>Estado</span>
                    <strong>@RequestVisualState</strong>
                </div>
            </div>

            <div class="spc-grid two">
                <div class="form-group">
                    <label>Proveedor</label>
                    <InputText class="form-control" @bind-Value="quoteForm.Provider" disabled="@(!CanQuote)" />
                </div>

                <div class="form-group">
                    <label>Herramienta cotizada</label>
                    <select class="form-select" @bind="quoteForm.LineIdText" disabled="@(!CanQuote)">
                        <option value="">Toda la solicitud / kit</option>
                        @foreach (var line in currentLines)
                        {
                            <option value="@line.Id">@line.ToolName</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Fecha cotización</label>
                    <InputDate class="form-control" @bind-Value="quoteForm.QuotationDate" disabled="@(!CanQuote)" />
                </div>

                <div class="form-group">
                    <label>Tiempo entrega / reparación</label>
                    <InputText class="form-control" @bind-Value="quoteForm.DeliveryTime" disabled="@(!CanQuote)" />
                </div>

                <div class="form-group">
                    <label>Precio antes de IVA</label>
                    <InputNumber class="form-control" @bind-Value="quoteForm.PriceBeforeVat" disabled="@(!CanQuote)" />
                </div>

                <div class="form-group full">
                    <label>Detalles adicionales de cotización</label>
                    <InputTextArea class="form-control" @bind-Value="quoteForm.AdditionalDetails" rows="2" disabled="@(!CanQuote)" />
                </div>
            </div>

            <div class="spc-actions">
                <button type="button" class="btn btn-primary" @onclick="AddQuotationAsync" disabled="@(!CanRegisterQuotation)">
                    @(editingQuoteId.HasValue ? "Actualizar cotización" : "Agregar cotización")
                </button>

                <button type="button" class="btn btn-outline-secondary" @onclick="ClearQuotation">
                    Limpiar cotización
                </button>
            </div>

            @if (!currentQuotes.Any())
            {
                <div class="spc-empty">No hay cotizaciones agregadas.</div>
            }
            else
            {
                <div class="spc-table-wrap">
                    <table class="spc-table">
                        <thead>
                            <tr>
                                <th>Usar</th>
                                <th>Proveedor</th>
                                <th>Herramienta</th>
                                <th>Fecha</th>
                                <th>Entrega</th>
                                <th>Precio sin IVA</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var quote in currentQuotes)
                            {
                                <tr>
                                    <td><InputCheckbox @bind-Value="quote.Selected" disabled="@(!CanQuote)" /></td>
                                    <td>
                                        <strong>@quote.Provider</strong>
                                        <small>@quote.AdditionalDetails</small>
                                    </td>
                                    <td>@GetLineName(quote.LineId)</td>
                                    <td>@FormatDate(quote.QuotationDate)</td>
                                    <td>@quote.DeliveryTime</td>
                                    <td>@FormatMoney(quote.PriceBeforeVat)</td>
                                    <td>
                                        <div class="row-actions">
                                            <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => EditQuotation(quote.Id)">Editar</button>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveQuotationAsync(quote.Id)">Quitar</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <article class="spc-card spc-final-card">
            <h3>@GenerateTitle</h3>
            <p>Solo se habilita cuando la solicitud está en cotización y tiene mínimo una cotización seleccionada.</p>

            <div class="spc-summary-grid">
                <div>
                    <span>Herramientas seleccionadas</span>
                    <strong>@SelectedLines.Count()</strong>
                </div>
                <div>
                    <span>Cotizaciones seleccionadas</span>
                    <strong>@SelectedQuotes.Count()</strong>
                </div>
                <div>
                    <span>Total antes de IVA</span>
                    <strong>@FormatMoney(SelectedQuotes.Sum(x => x.PriceBeforeVat ?? 0))</strong>
                </div>
            </div>

            <div class="spc-actions vertical">
                <button type="button" class="btn btn-success" @onclick="GenerateAsync" disabled="@(!CanGenerateFinalRequest)">
                    @(isSaving ? "Generando..." : GenerateButtonText)
                </button>

                @if (CanQuote && !SelectedQuotes.Any())
                {
                    <div class="spc-generate-warning">
                        Agrega y selecciona al menos una cotización para generar la solicitud.
                    </div>
                }
            </div>
        </article>
    </div>
</section>

<section class="spc-card spc-registered">
    <div class="spc-card-title">
        <div>
            <h3>Solicitudes registradas</h3>
            <p>Borradores, solicitudes confirmadas pendientes por cotizar y solicitudes generadas.</p>
        </div>
        <button type="button" class="btn btn-outline-primary btn-sm" @onclick="LoadAsync">Actualizar</button>
    </div>

    @if (isLoading)
    {
        <div class="spc-empty">Cargando solicitudes...</div>
    }
    else if (!storedRequests.Any() && !registeredItems.Any())
    {
        <div class="spc-empty">No hay solicitudes registradas.</div>
    }
    else
    {
        <div class="spc-table-wrap">
            <table class="spc-table">
                <thead>
                    <tr>
                        <th>Solicitud</th>
                        <th>Nombre</th>
                        <th>Tipo</th>
                        <th>Prioridad</th>
                        <th>Estado</th>
                        <th>Herramientas</th>
                        <th>Cotizaciones</th>
                        <th>Actualización</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in storedRequests.OrderByDescending(x => x.UpdatedAt))
                    {
                        <tr class="@GetStoredRowClass(item)">
                            <td><strong>@item.LocalNumber</strong></td>
                            <td>@Display(item.Header.RequestName)</td>
                            <td>@Display(item.Header.RequestType)</td>
                            <td>@Display(item.Header.Priority)</td>
                            <td><span class="@GetStoredStatusClass(item.Status)">@GetStoredStatusLabel(item.Status)</span></td>
                            <td>@item.Lines.Count</td>
                            <td>@item.Quotations.Count</td>
                            <td>@FormatDateTime(item.UpdatedAt)</td>
                            <td>
                                <div class="row-actions">
                                    @if (item.Status == LocalStatusDraft)
                                    {
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => LoadDraftForEdit(item.Id)">Editar</button>
                                        <button type="button" class="btn btn-sm btn-primary" @onclick="() => ConfirmStoredRequestAsync(item.Id)">Confirmar</button>
                                    }
                                    else if (item.Status == LocalStatusConfirmed)
                                    {
                                        <button type="button" class="btn btn-sm btn-warning" disabled="@(!CanRegisterQuotation)" @onclick="() => StartQuotationAsync(item.Id)">Realizar cotización</button>
                                    }
                                    else if (item.Status == LocalStatusQuoting)
                                    {
                                        <button type="button" class="btn btn-sm btn-warning" disabled="@(!CanRegisterQuotation)" @onclick="() => ContinueQuotation(item.Id)">Continuar cotización</button>
                                    }

                                    <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => DeleteLocalRequestAsync(item.Id)">Eliminar</button>
                                </div>
                            </td>
                        </tr>
                    }

                    @foreach (var item in registeredItems.OrderByDescending(x => x.CreatedAt).Take(20))
                    {
                        <tr>
                            <td><strong>@item.RequestNumber</strong></td>
                            <td>@item.Title</td>
                            <td>@item.Type</td>
                            <td>@item.Priority</td>
                            <td><span class="status-pill">@GetStatusLabel(item.Status)</span></td>
                            <td>—</td>
                            <td>—</td>
                            <td>@FormatDateTime(item.CreatedAt)</td>
                            <td><span class="text-muted">Generada</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

</PermissionGuard>

@code {

    private bool CanCreateOrConfirmRequest =>
        HasSpcPermission(IsPurchase ? "Purchases.Request" : "Maintenance.Request");

    private bool CanRegisterQuotation =>
        HasSpcPermission(IsPurchase ? "Purchases.Quote" : "Maintenance.Quote");

    private bool CanGenerateFinalRequest =>
        HasSpcPermission(IsPurchase ? "Purchases.Generate" : "Maintenance.Generate");

    private bool CanApproveRequest =>
        HasSpcPermission(IsPurchase ? "Purchases.Approve" : "Maintenance.Close");

    private bool CanRejectRequest =>
        HasSpcPermission(IsPurchase ? "Purchases.Reject" : "Maintenance.Reject");

    private bool HasSpcPermission(string permission)
    {
        try
        {
            var serviceType = AppDomain.CurrentDomain
                .GetAssemblies()
                .SelectMany(assembly =>
                {
                    try
                    {
                        return assembly.GetTypes();
                    }
                    catch
                    {
                        return Array.Empty<Type>();
                    }
                })
                .FirstOrDefault(type => type.Name == "WebAuthSessionService");

            if (serviceType is null)
            {
                return false;
            }

            var service = ServiceProvider.GetService(serviceType);

            if (service is null)
            {
                return false;
            }

            var method = serviceType.GetMethod("HasPermission", new[] { typeof(string) });

            if (method is null)
            {
                return false;
            }

            return method.Invoke(service, new object[] { permission }) is bool allowed && allowed;
        }
        catch
        {
            return false;
        }
    }


    [Parameter] public string Kind { get; set; } = "purchase";

    private const string LocalStatusDraft = "Draft";
    private const string LocalStatusConfirmed = "Confirmed";
    private const string LocalStatusQuoting = "Quoting";

    private readonly JsonSerializerOptions jsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = false
    };

    private readonly RequestHeader header = new();
    private readonly RequestLineForm lineForm = new();
    private readonly QuotationForm quoteForm = new();

    private List<RequestLineItem> currentLines = new();
    private List<QuotationItem> currentQuotes = new();
    private List<StoredRequest> storedRequests = new();
    private List<ApiRegisteredItem> registeredItems = new();
    private List<BranchOption> branches = new();

    private Guid? activeStoredRequestId;
    private Guid? editingLineId;
    private Guid? editingQuoteId;

    private string currentStatus = "New";
    private bool isLoading;
    private bool isSaving;
    private bool localLoaded;
    private string? successMessage;
    private string? errorMessage;

    private bool IsPurchase => Kind.Equals("purchase", StringComparison.OrdinalIgnoreCase);
    private bool IsMaintenance => !IsPurchase;

    private string StorageKey => IsPurchase ? "navi-spc-purchase-workspace-v2" : "navi-maintenance-request-workspace-v2";
private string PermissionName => IsPurchase ? "Purchases.Request" : "Maintenance.Request";
    private string RequestPermissionName => IsPurchase ? "Purchases.Request" : "Maintenance.Request";
    private string ModuleName => IsPurchase ? "Solicitar Compra Herramientas y AF" : "Solicitar Mantenimiento";
    private string HeroPill => IsPurchase ? "SPC · SOLICITUD DE COMPRA" : "MANTENIMIENTO · HERRAMIENTAS · EQUIPOS";
    private string PageTitleText => IsPurchase ? "Solicitud de compra Herramientas y AF" : "Solicitud de mantenimiento";
    private string PageSubtitle => IsPurchase
        ? "Crea un borrador o confirma la solicitud. Después cotiza y genera la solicitud final."
        : "Crea un borrador o confirma el mantenimiento. Después cotiza y genera la solicitud final.";
    private string HeaderTitle => IsPurchase ? "Encabezado de compra" : "Encabezado de mantenimiento";
    private string HeaderSubtitle => IsPurchase
        ? "Información mínima de la solicitud SPC."
        : "Información mínima de la solicitud de mantenimiento.";
    private string LinesTitle => IsPurchase ? "Herramientas / activos solicitados" : "Herramientas / equipos a intervenir";
    private string QuotationTitle => IsPurchase ? "Cotización de compra" : "Cotización de mantenimiento";
    private string GenerateTitle => IsPurchase ? "Generar solicitud de compra" : "Generar solicitud de mantenimiento";
    private string GenerateButtonText => IsPurchase ? "Generar solicitud de compra" : "Generar solicitud de mantenimiento";

    private bool CanRequest =>
        AuthSession.HasPermission(RequestPermissionName);

    private bool CanEditRequest => CanRequest && (currentStatus == "New" || currentStatus == LocalStatusDraft);
    private bool CanQuote => CanRequest && currentStatus == LocalStatusQuoting && activeStoredRequestId.HasValue;
    private bool CanSaveAsDraft => CanEditRequest && SelectedLines.Any();
    private bool CanConfirmRequest => CanEditRequest && SelectedLines.Any();
    private bool CanGenerateRequest => CanQuote && SelectedQuotes.Any();

    private IEnumerable<RequestLineItem> SelectedLines => currentLines.Where(x => x.Selected);
    private IEnumerable<QuotationItem> SelectedQuotes => currentQuotes.Where(x => x.Selected);

    private string RequestVisualState => currentStatus switch
    {
        LocalStatusDraft => "Estado borrador",
        LocalStatusConfirmed => "Solicitud confirmada",
        LocalStatusQuoting => "Cotizando",
        _ => "Nueva solicitud"
    };

    private string SelectedBranchLabel
    {
        get
        {
            var branch = branches.FirstOrDefault(x => x.Id.ToString() == header.BranchIdText);
            return branch is null ? "Sin sede" : $"{branch.Code} - {branch.Name}";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        ResetHeaderDefaults();
        await LoadBranchesAsync();
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || localLoaded)
        {
            return;
        }

        await LoadLocalStateAsync();
        localLoaded = true;
        StateHasChanged();
    }

    private void ResetHeaderDefaults()
    {
        header.RequestedBy = string.IsNullOrWhiteSpace(AuthSession.UserName) ? "admin" : AuthSession.UserName;
        header.Priority = "Media";
        header.RequestType = IsPurchase ? "SPC" : "Correctivo";

        if (AuthSession.BranchId.HasValue)
        {
            header.BranchIdText = AuthSession.BranchId.Value.ToString();
        }
    }

