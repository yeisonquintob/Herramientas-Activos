    private void NewRequest()
    {
        ClearWorkspace(keepBranchAndRequester: true);
        successMessage = "Formulario listo para una nueva solicitud.";
    }

    private void ClearWorkspace(bool keepBranchAndRequester)
    {
        var currentRequester = header.RequestedBy;
        var currentBranch = header.BranchIdText;

        activeStoredRequestId = null;
        editingLineId = null;
        editingQuoteId = null;
        currentStatus = "New";
        currentLines = new();
        currentQuotes = new();
        ClearLine();
        ClearQuotation();

        header.Clear();
        ResetHeaderDefaults();

        if (keepBranchAndRequester)
        {
            if (!string.IsNullOrWhiteSpace(currentRequester))
            {
                header.RequestedBy = currentRequester;
            }

            if (!string.IsNullOrWhiteSpace(currentBranch))
            {
                header.BranchIdText = currentBranch;
            }
        }
    }

    private void OnSearchChanged(ChangeEventArgs args) => searchText = args.Value?.ToString() ?? string.Empty;
    private void OnBranchFilterChanged(ChangeEventArgs args) => selectedBranchCode = args.Value?.ToString() ?? string.Empty;
    private void OnBottomStatusChanged(ChangeEventArgs args) => selectedBottomStatus = args.Value?.ToString() ?? string.Empty;

    private void ClearTopFilters()
    {
        searchText = string.Empty;
        selectedBranchCode = string.Empty;
    }

    private void ClearBottomStatus()
    {
        selectedBottomStatus = string.Empty;
    }

    private bool MatchesLocalScope(StoredRequest item)
    {
        var branch = BranchByIdText(item.Header.BranchIdText);

        if (!string.IsNullOrWhiteSpace(selectedBranchCode))
        {
            return branch is not null && SameNormalized(branch.Code, selectedBranchCode);
        }

        if (branch is null)
        {
            return UserCanSeeAllBranches();
        }

        return UserCanSeeAllBranches() ||
               SameNormalized(branch.Code, Auth.CurrentUser?.BranchCode) ||
               SameNormalized(branch.Name, Auth.CurrentUser?.BranchName);
    }

    private bool MatchesApiScope(ApiRegisteredItem item)
    {
        if (!string.IsNullOrWhiteSpace(selectedBranchCode))
        {
            return SameNormalized(item.BranchCode, selectedBranchCode);
        }

        return UserCanSeeAllBranches() ||
               SameNormalized(item.BranchCode, Auth.CurrentUser?.BranchCode) ||
               SameNormalized(item.BranchName, Auth.CurrentUser?.BranchName);
    }

    private bool MatchesLocalSearch(StoredRequest item)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
        }

        return ContainsText(item.LocalNumber, searchText) ||
               ContainsText(item.Status, searchText) ||
               ContainsText(GetStoredStatusLabel(item.Status), searchText) ||
               ContainsText(item.Header.RequestName, searchText) ||
               ContainsText(item.Header.RequestType, searchText) ||
               item.Lines.Any(x => ContainsText(x.ToolName, searchText) || ContainsText(x.TechnicalOrSerial, searchText) || ContainsText(x.Novelty, searchText));
    }

    private bool MatchesApiSearch(ApiRegisteredItem item)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
        }

        return ContainsText(item.RequestNumber, searchText) ||
               ContainsText(item.Title, searchText) ||
               ContainsText(item.Status, searchText) ||
               ContainsText(StatusLabel(item.Status), searchText) ||
               ContainsText(item.RequestedBy, searchText) ||
               ContainsText(item.BranchCode, searchText);
    }

    private bool MatchesBottomStatus(StoredRequest item)
    {
        return string.IsNullOrWhiteSpace(selectedBottomStatus) ||
               string.Equals(item.Status, selectedBottomStatus, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesApiBottomStatus(ApiRegisteredItem item)
    {
        return string.IsNullOrWhiteSpace(selectedBottomStatus) ||
               string.Equals(item.Status, selectedBottomStatus, StringComparison.OrdinalIgnoreCase);
    }

    private MobileBranchDto? BranchByIdText(string? value)
    {
        if (!Guid.TryParse(value, out var branchId))
        {
            return null;
        }

        return branches.FirstOrDefault(x => x.Id == branchId);
    }

    private bool IsVisibleBranch(MobileBranchDto branch)
    {
        if (UserCanSeeAllBranches())
        {
            return true;
        }

        return SameNormalized(branch.Code, Auth.CurrentUser?.BranchCode) ||
               SameNormalized(branch.Name, Auth.CurrentUser?.BranchName);
    }

    private bool UserCanSeeAllBranches()
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(user.BranchCode) ||
               SameNormalized(user.BranchCode, "TODAS") ||
               SameNormalized(user.BranchCode, "ALL") ||
               SameNormalized(user.BranchName, "TODAS") ||
               SameNormalized(user.BranchName, "ALL") ||
               SameNormalized(user.BranchName, "Todas las sedes");
    }

    private bool Has(string permission) => Auth.HasPermission(permission);

    private bool HasAny(params string[] permissions) => permissions.Any(Has);

    private bool IsOpenStatus(string? status)
    {
        return status is "Draft" or "Confirmed" or "Quoting" or "InReview" or "Approved" or "Scheduled" or "InExecution";
    }

    private string BuildSummary(List<RequestLineItem> lines, List<QuotationItem> quotes)
    {
        var sb = new System.Text.StringBuilder();

        sb.AppendLine("ENCABEZADO");
        sb.AppendLine($"Solicitud: {Display(header.RequestName)}");
        sb.AppendLine($"Tipo: {Display(header.RequestType)}");
        sb.AppendLine($"Sede: {SelectedBranchLabel}");
        sb.AppendLine($"Solicitante: {Display(header.RequestedBy)}");
        sb.AppendLine($"Responsable aprueba: {Display(header.Approver)}");
        sb.AppendLine($"Prioridad: {Display(header.Priority)}");
        sb.AppendLine($"Fecha requerida: {DateLabel(header.RequiredAt)}");
        sb.AppendLine($"Ubicación/área: {Display(header.Location)}");
        sb.AppendLine($"Necesidad: {Display(header.NeedDescription)}");
        sb.AppendLine();

        sb.AppendLine("HERRAMIENTAS / EQUIPOS");
        foreach (var line in lines)
        {
            sb.AppendLine($"- {line.ToolName} | Técnico/Serial: {Display(line.TechnicalOrSerial)} | Criticidad: {Display(line.Criticality)}");
            sb.AppendLine($"  Foto/evidencia: {Display(line.ImageReference)}");
            sb.AppendLine($"  Detalles: {Display(line.Details)}");
            sb.AppendLine($"  Novedades: {Display(line.Novelty)}");
        }

        sb.AppendLine();
        sb.AppendLine("COTIZACIONES");
        foreach (var quote in quotes)
        {
            sb.AppendLine($"- Proveedor: {quote.Provider} | Equipo: {GetLineName(quote.LineId)} | Fecha: {DateLabel(quote.QuotationDate)} | Entrega: {Display(quote.DeliveryTime)} | Precio sin IVA: {MoneyLabel(quote.PriceBeforeVat)}");
            sb.AppendLine($"  Detalles: {Display(quote.AdditionalDetails)}");
        }

        return sb.ToString();
    }

    private string GetLineName(Guid? id)
    {
        if (!id.HasValue)
        {
            return "Toda la solicitud / kit";
        }

        return currentLines.FirstOrDefault(x => x.Id == id.Value)?.ToolName ?? "Equipo no encontrado";
    }

    private string BuildLocalNumber(string status, DateTime date)
    {
        var suffix = status == LocalStatusConfirmed ? "CONF" : "DRAFT";
        return $"BOR-MANT-{suffix}-{date:yyyyMMddHHmmss}";
    }

    private string GetStoredStatusLabel(string status)
    {
        return status switch
        {
            LocalStatusDraft => "Borrador",
            LocalStatusConfirmed => "Confirmada / pendiente por cotizar",
            LocalStatusQuoting => "Cotizando",
            _ => StatusLabel(status)
        };
    }

    private string GetStoredRowClass(StoredRequest item)
    {
        return item.Status switch
        {
            LocalStatusDraft => "draft-row",
            LocalStatusConfirmed => "confirmed-row",
            LocalStatusQuoting => "quoting-row",
            _ => string.Empty
        };
    }

