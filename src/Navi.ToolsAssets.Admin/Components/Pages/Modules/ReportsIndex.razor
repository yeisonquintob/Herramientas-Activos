@page "/reports"
@rendermode InteractiveServer
@inherits ReportsIndexBase

<PageTitle>Reportes - NAVI</PageTitle>

<section class="reports-hero">
    <div>
        <span class="reports-pill">REPORTES · INDICADORES · EXPORTACIÓN</span>
        <h2>Centro de reportes</h2>
        <p>Consulta reportes ejecutivos y operativos de inventario, documentos, mantenimiento, compras, toma física y conciliación.</p>
    </div>

    <div class="reports-hero-actions">
        <button type="button" class="reports-hero-btn" @onclick="LoadAsync" disabled="@isLoading">
            @(isLoading ? "Actualizando..." : "Actualizar")
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="@messageClass reports-message">@message</div>
}

<section class="reports-kpis">
    <article>
        <span>Inventario</span>
        <strong>@assets.Count</strong>
        <small>Activos / herramientas</small>
    </article>

    <article class="success">
        <span>Documentos</span>
        <strong>@documents.Count</strong>
        <small>Soportes cargados</small>
    </article>

    <article class="warning">
        <span>Mantenimientos</span>
        <strong>@TotalMaintenance</strong>
        <small>Registros y solicitudes</small>
    </article>

    <article class="purple">
        <span>Tomas físicas</span>
        <strong>@physicalCounts.Count</strong>
        <small>Campañas creadas</small>
    </article>
</section>

<section class="reports-workspace">
    <aside class="reports-card reports-left">
        <div class="reports-card-title compact">
            <div>
                <h3>Reportes</h3>
                <p>Selecciona el informe a consultar.</p>
            </div>
        </div>

        <div class="reports-menu">
            @foreach (var item in Reports)
            {
                <button type="button"
                        class="@GetReportClass(item.Code)"
                        @onclick="() => SelectReport(item.Code)">
                    <span>@item.Icon</span>

                    <div>
                        <strong>@item.Title</strong>
                        <small>@item.Description</small>
                    </div>
                </button>
            }
        </div>
    </aside>

    <main class="reports-main">
        <article class="reports-card">
            <div class="reports-card-title">
                <div>
                    <h3>@SelectedReport.Title</h3>
                    <p>@SelectedReport.LongDescription</p>
                </div>

                <span class="reports-selected-pill">@SelectedReport.Area</span>
            </div>

            <div class="reports-filters">
                <div>
                    <label>Buscar</label>
                    <input class="form-control"
                           placeholder="Buscar código, nombre, sede, responsable, estado..."
                           @bind="searchText"
                           @bind:event="oninput" />
                </div>

                <div>
                    <label>Sede</label>
                    <select class="form-select" @bind="branchFilter">
                        <option value="">Todas las sedes</option>
                        @foreach (var branch in BranchOptions)
                        {
                            <option value="@branch">@branch</option>
                        }
                    </select>
                </div>

                <div>
                    <label>Periodo</label>
                    <select class="form-select" @bind="periodFilter">
                        <option value="all">Todo</option>
                        <option value="today">Hoy</option>
                        <option value="7">Últimos 7 días</option>
                        <option value="30">Últimos 30 días</option>
                        <option value="90">Últimos 90 días</option>
                    </select>
                </div>

                <div>
                    <label>Estado</label>
                    <select class="form-select" @bind="statusFilter">
                        <option value="">Todos</option>
                        @foreach (var status in StatusOptions)
                        {
                            <option value="@status">@status</option>
                        }
                    </select>
                </div>
            </div>
        </article>

        <section class="reports-summary-grid">
            @foreach (var item in SelectedSummary)
            {
                <article class="@item.CssClass">
                    <span>@item.Label</span>
                    <strong>@item.Value</strong>
                    <small>@item.Description</small>
                </article>
            }
        </section>

        <article class="reports-card">
            <div class="reports-card-title">
                <div>
                    <h3>Resultado del reporte</h3>
                    <p>@FilteredRows.Count registro(s) según filtros aplicados.</p>
                </div>

                <div class="reports-actions">
                    <button type="button" @onclick="ClearFilters">Limpiar filtros</button>
                </div>
            </div>

            @if (isLoading)
            {
                <div class="reports-empty">Cargando información del reporte...</div>
            }
            else if (FilteredRows.Count == 0)
            {
                <div class="reports-empty">No hay registros para el reporte y filtros seleccionados.</div>
            }
            else
            {
                <div class="reports-table-wrapper">
                    <table class="reports-table">
                        <thead>
                            <tr>
                                @foreach (var header in CurrentHeaders)
                                {
                                    <th>@header</th>
                                }
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var row in FilteredRows)
                            {
                                <tr>
                                    @foreach (var cell in row.Cells)
                                    {
                                        <td>
                                            @if (cell.IsBadge)
                                            {
                                                <span class="@GetBadgeClass(cell.Value)">@cell.Value</span>
                                            }
                                            else
                                            {
                                                @cell.Value
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>
    </main>

    <aside class="reports-card reports-right">
        <div class="reports-card-title compact">
            <div>
                <h3>Resumen</h3>
                <p>Lectura rápida del reporte actual.</p>
            </div>
        </div>

        <div class="reports-resume-list">
            @foreach (var item in SelectedInsights)
            {
                <div>
                    <span>@item.Icon</span>
                    <strong>@item.Title</strong>
                    <small>@item.Detail</small>
                </div>
            }
        </div>

        <div class="reports-left-separator"></div>

        <div class="reports-card-title compact">
            <div>
                <h3>Exportación</h3>
                <p>El CSV conserva el reporte y filtros seleccionados.</p>
            </div>
        </div>

        <div class="reports-export-box">
            <strong>@SelectedReport.Title</strong>
            <small>@FilteredRows.Count registro(s)</small>

            @if (CanExportReports)
            {
                <a href="@BuildCsvDataUrl()" download="@($"{SelectedReport.FileName}.csv")">
                    Descargar reporte
                </a>
            }
            else
            {
                <button type="button" class="reports-disabled-export" disabled>
                    Exportación restringida
                </button>
            }
        </div>

        <div class="reports-left-separator"></div>

        <div class="reports-card-title compact">
            <div>
                <h3>Histórico</h3>
                <p>Últimas acciones de reportería.</p>
            </div>
        </div>

        <div class="reports-history">
            @foreach (var item in History.Take(8))
            {
                <div>
                    <strong>@item.Title</strong>
                    <small>@item.Date.ToString("dd/MM/yyyy HH:mm") · @item.User</small>
                </div>
            }
        </div>
    </aside>
</section>

<style>
    .reports-hero {
        margin-bottom: .7rem;
        padding: .95rem 1.1rem;
        border-radius: 1rem;
        background: linear-gradient(105deg, #050507 0%, #07070b 34%, #120017 58%, #350040 78%, #710083 100%);
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 .55rem 1.2rem rgba(75,0,92,.18);
    }

    .reports-pill {
        display: inline-flex;
        padding: .18rem .62rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.35);
        background: rgba(255,255,255,.10);
        font-size: .68rem;
        font-weight: 950;
    }

    .reports-hero h2 {
        margin: .34rem 0 .14rem;
        font-size: 1.75rem;
        font-weight: 950;
        line-height: 1.05;
    }

    .reports-hero p {
        margin: 0;
        color: rgba(255,255,255,.88);
        font-size: .88rem;
    }

    .reports-hero-actions {
        width: 190px;
        display: grid;
        gap: .42rem;
    }

    .reports-hero-btn {
        width: 190px;
        min-height: 36px;
        border-radius: .6rem;
        border: 1px solid rgba(255,255,255,.70);
        background: rgba(255,255,255,.08);
        color: white;
        font-weight: 950;
        font-size: .76rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .reports-message {
        margin-bottom: .65rem;
        border-radius: .65rem;
        font-size: .74rem;
        font-weight: 800;
    }

    .reports-kpis {
        display: grid;
        grid-template-columns: repeat(4, minmax(130px, 1fr));
        gap: .45rem;
        margin-bottom: .65rem;
    }

    .reports-kpis article,
    .reports-card,
    .reports-summary-grid article {
        background: #fff;
        border: 1px solid #eadff0;
        border-radius: .9rem;
        box-shadow: 0 .25rem .75rem rgba(75,0,92,.045);
    }

    .reports-kpis article,
    .reports-summary-grid article {
        border-left: 4px solid #2186d9;
        padding: .55rem;
    }

    .reports-kpis article.success,
    .reports-summary-grid article.success {
        border-left-color: #198754;
    }

    .reports-kpis article.warning,
    .reports-summary-grid article.warning {
        border-left-color: #ffc107;
    }

    .reports-kpis article.purple,
    .reports-summary-grid article.purple {
        border-left-color: #7b0d8e;
    }

    .reports-kpis span,
    .reports-summary-grid span {
        display: block;
        color: #526071;
        font-size: .62rem;
        font-weight: 950;
        text-transform: uppercase;
    }

    .reports-kpis strong,
    .reports-summary-grid strong {
        display: block;
        color: #06111f;
        font-size: 1.35rem;
        font-weight: 950;
        line-height: 1;
    }

    .reports-kpis small,
    .reports-summary-grid small {
        color: #657083;
        font-size: .62rem;
    }

    .reports-workspace {
        display: grid;
        grid-template-columns: 270px minmax(0, 1fr) 275px;
        gap: .65rem;
        align-items: start;
    }

    .reports-card {
        padding: .82rem;
    }

    .reports-left,
    .reports-right {
        position: sticky;
        top: .7rem;
        max-height: calc(100vh - 1.4rem);
        overflow-y: auto;
        padding: .62rem;
    }

    .reports-main {
        display: grid;
        gap: .65rem;
        min-width: 0;
    }

    .reports-card-title {
        display: flex;
        justify-content: space-between;
        gap: .75rem;
        margin-bottom: .62rem;
    }

    .reports-card-title.compact {
        display: block;
        margin-bottom: .38rem;
    }

    .reports-card-title h3 {
        margin: 0;
        color: #100018;
        font-size: 1rem;
        font-weight: 950;
    }

    .reports-card-title p {
        margin: .08rem 0 0;
        color: #657083;
        font-size: .74rem;
    }

    .reports-menu {
        display: grid;
        gap: .38rem;
    }

    .reports-menu button {
        width: 100%;
        min-height: 64px;
        display: grid;
        grid-template-columns: 36px minmax(0, 1fr);
        gap: .42rem;
        align-items: center;
        border: 1px solid #eadff0;
        background: #fbf8ff;
        border-radius: .7rem;
        padding: .45rem;
        text-align: left;
        cursor: pointer;
    }

    .reports-menu button.active {
        border-color: #7b0d8e;
        background: linear-gradient(135deg, rgba(123,13,142,.12), rgba(33,134,217,.08));
    }

    .reports-menu span,
    .reports-resume-list span {
        grid-column: 1;
        grid-row: 1 / span 2;
        width: 28px;
        height: 28px;
        border-radius: .5rem;
        display: grid;
        place-items: center;
        background: linear-gradient(145deg, #7b0d8e, #4b005c);
        color: white;
        font-size: .82rem;
    }

    .reports-menu strong,
    .reports-menu small {
        display: block;
        line-height: 1.08;
    }

    .reports-menu strong {
        color: #100018;
        font-size: .72rem;
        font-weight: 950;
    }

    .reports-menu small {
        color: #657083;
        font-size: .6rem;
        margin-top: .12rem;
        font-weight: 760;
    }

    .reports-selected-pill,
    .reports-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        padding: .15rem .55rem;
        background: #fbf4ff;
        border: 1px solid #eadff0;
        color: #4b005c;
        font-size: .62rem;
        font-weight: 950;
        white-space: nowrap;
    }

    .reports-badge.ok {
        background: #d1e7dd;
        color: #0f5132;
        border-color: #badbcc;
    }

    .reports-badge.warn {
        background: #fff3cd;
        color: #7a5200;
        border-color: #ffecb5;
    }

    .reports-badge.danger {
        background: #f8d7da;
        color: #842029;
        border-color: #f5c2c7;
    }

    .reports-filters {
        display: grid;
        grid-template-columns: minmax(240px, 1fr) 150px 150px 150px;
        gap: .5rem;
        align-items: end;
    }

    .reports-filters label {
        display: block;
        color: #24102e;
        font-size: .68rem;
        font-weight: 950;
        margin-bottom: .18rem;
    }

    .reports-summary-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(130px, 1fr));
        gap: .45rem;
    }

    .reports-actions {
        display: flex;
        gap: .35rem;
        flex-wrap: wrap;
    }

    .reports-actions button,
    .reports-actions a {
        min-height: 30px;
        border-radius: .48rem;
        border: 1px solid #2563eb;
        color: #1d4ed8;
        background: #eff6ff;
        font-size: .65rem;
        font-weight: 950;
        padding: .25rem .65rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .reports-empty {
        border: 1px dashed #d8c8e3;
        background: #fbf8ff;
        color: #55445f;
        border-radius: .75rem;
        padding: .85rem;
        font-weight: 850;
        font-size: .76rem;
    }

    .reports-table-wrapper {
        overflow-x: auto;
    }

    .reports-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .72rem;
    }

    .reports-table th {
        border-bottom: 1px solid #17111c;
        padding: .42rem .35rem;
        font-size: .63rem;
        text-transform: uppercase;
        white-space: nowrap;
    }

    .reports-table td {
        border-bottom: 1px solid #e5e8ef;
        padding: .45rem .35rem;
        vertical-align: top;
        white-space: normal;
        line-height: 1.18;
    }

    .reports-resume-list,
    .reports-history {
        display: grid;
        gap: .38rem;
    }

    .reports-resume-list div {
        min-height: 46px;
        display: grid;
        grid-template-columns: 30px minmax(0, 1fr);
        grid-template-rows: auto auto;
        gap: .12rem .42rem;
        align-items: center;
        border: 1px solid #eadff0;
        background: #fbf8ff;
        border-radius: .62rem;
        padding: .38rem .45rem;
        overflow: hidden;
    }

    .reports-resume-list strong,
    .reports-resume-list small,
    .reports-history strong,
    .reports-history small {
        display: block;
        min-width: 0;
        max-width: 100%;
        line-height: 1.05;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .reports-resume-list strong,
    .reports-history strong {
        color: #100018;
        font-size: .72rem;
        font-weight: 950;
    }

    .reports-resume-list strong {
        grid-column: 2;
        grid-row: 1;
        color: #100018;
        font-size: .66rem;
        font-weight: 950;
    }

    .reports-resume-list small {
        grid-column: 2;
        grid-row: 2;
        color: #657083;
        font-size: .56rem;
        font-weight: 760;
        margin-top: 0;
    }

    .reports-history small {
        color: #657083;
        font-size: .58rem;
        margin-top: .1rem;
    }

    .reports-left-separator {
        height: 1px;
        background: #eadff0;
        margin: .55rem 0 .45rem;
    }

    .reports-export-box {
        border: 1px solid #eadff0;
        background: #fbf8ff;
        border-radius: .62rem;
        padding: .48rem;
        display: grid;
        gap: .25rem;
    }

    .reports-export-box strong,
    .reports-export-box small {
        display: block;
        line-height: 1.12;
    }

    .reports-export-box strong {
        color: #100018;
        font-size: .82rem;
        font-weight: 950;
    }

    .reports-export-box small {
        color: #657083;
        font-size: .65rem;
    }

    .reports-export-box a {
        min-height: 28px;
        border-radius: .45rem;
        color: #fff;
        background: linear-gradient(135deg, #7b0d8e, #4b005c);
        text-decoration: none;
        font-weight: 950;
        font-size: .62rem;
        display: inline-flex;
        justify-content: center;
        align-items: center;
    }

    .reports-history div {
        border-top: 1px solid #eadff0;
        padding: .45rem 0;
    }

    @@media (max-width: 1500px) {
        .reports-workspace {
            grid-template-columns: 260px minmax(0, 1fr);
        }

        .reports-right {
            grid-column: 1 / -1;
            position: static;
            max-height: none;
        }

        .reports-resume-list {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }

    @@media (max-width: 1050px) {
        .reports-workspace,
        .reports-kpis,
        .reports-summary-grid,
        .reports-filters {
            grid-template-columns: 1fr;
        }

        .reports-left,
        .reports-right {
            position: static;
            max-height: none;
        }

        .reports-card-title,
        .reports-hero {
            flex-direction: column;
            align-items: flex-start;
        }

        .reports-resume-list {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 650px) {
        .reports-resume-list {
            grid-template-columns: 1fr;
        }
    }

    .reports-disabled-export {
        width: 100%;
        border: 1px solid #cbd5e1;
        background: #f8fafc;
        color: #94a3b8;
        border-radius: .65rem;
        padding: .48rem .7rem;
        font-weight: 900;
        cursor: not-allowed;
        opacity: .75;
    }
</style>
