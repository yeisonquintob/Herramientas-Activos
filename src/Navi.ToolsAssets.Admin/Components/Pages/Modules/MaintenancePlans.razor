@page "/maintenance-plans"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Components.Security
@using Navi.ToolsAssets.Admin.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject WebAuthSessionService AuthSession

<PageTitle>Planes de Mantenimiento</PageTitle>

<PermissionGuard Permission="MaintenancePlans.View" ModuleName="Planes de Mantenimiento">

<section class="plans-hero">
    <div>
        <span class="plans-pill">OPERACIONES · PLANES · COSTOS</span>
        <h2>Planes de mantenimiento</h2>
        <p>Controla vencimientos, cobertura, solicitudes pendientes, cronograma y relación con solicitudes de mantenimiento.</p>
    </div>

    <div class="plans-hero-actions">
        @if (CanRequestMaintenance)
        {
        @if (CanRequestMaintenance)
        {
            <a class="plans-hero-btn" href="/maintenance-request">Solicitar</a>
        }
        }
        <button class="plans-hero-btn" type="button" @onclick="LoadAsync">
            Actualizar
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
<section class="plans-board">
    <article class="plans-card plan-distribution">
        <div class="plans-card-title">
            <div>
                <h3>Distribución del plan</h3>
                <p>Lectura rápida del estado de mantenimiento por activo.</p>
            </div>
        </div>

        <div class="plans-donut-row">
            <div class="plans-donut" style="@GetPlanDonutStyle()">
                <div>
                    <strong>@plans.Count</strong>
                    <span>Total</span>
                </div>
            </div>

            <div class="plans-legend">
                <div><i class="green"></i><span>Al día</span><strong>@plans.Count(x => x.PlanStatus == "OnTime")</strong><small>@GetPercentLabel(plans.Count(x => x.PlanStatus == "OnTime"), plans.Count)</small></div>
                <div><i class="orange"></i><span>Por vencer</span><strong>@plans.Count(x => x.PlanStatus == "DueSoon")</strong><small>@GetPercentLabel(plans.Count(x => x.PlanStatus == "DueSoon"), plans.Count)</small></div>
                <div><i class="red"></i><span>Vencido</span><strong>@plans.Count(x => x.PlanStatus == "Overdue")</strong><small>@GetPercentLabel(plans.Count(x => x.PlanStatus == "Overdue"), plans.Count)</small></div>
            </div>
        </div>
    </article>

    <article class="plans-card plans-kpis-panel">
        <div class="plans-card-title">
            <div>
                <h3>Indicadores del plan</h3>
                <p>Resumen operativo del cronograma y solicitudes pendientes.</p>
            </div>
        </div>

        <section class="plans-kpis plans-kpis-inline">
    <article>
        <span>Total activos</span>
        <strong>@plans.Count</strong>
        <small>Con seguimiento</small>
    </article>

    <article class="success">
        <span>Al día</span>
        <strong>@plans.Count(x => x.PlanStatus == "OnTime")</strong>
        <small>Sin vencimiento</small>
    </article>

    <article class="warning">
        <span>Por vencer</span>
        <strong>@plans.Count(x => x.PlanStatus == "DueSoon")</strong>
        <small>Próximos 30 días</small>
    </article>

    <article class="danger">
        <span>Vencidos</span>
        <strong>@plans.Count(x => x.PlanStatus == "Overdue")</strong>
        <small>Requieren atención</small>
    </article>

    <article class="purple">
        <span>Solicitudes</span>
        <strong>@plans.Sum(x => x.PendingRequests)</strong>
        <small>Pendientes abiertas</small>
    </article>

    <article class="info">
        <span>Completados</span>
        <strong>@plans.Sum(x => x.CompletedMaintenances)</strong>
        <small>Registros cerrados</small>
    </article>

        </section>
    </article>

</section>

<section class="plans-card">
    <div class="plans-card-title">
        <div>
            <h3>Tablero de planes</h3>
            <p>Consulta el cronograma por activo. Las acciones visibles dependen de la matriz de permisos.</p>
        </div>

        <div class="plans-filters">
            <select class="form-select" @bind="selectedStatus">
                <option value="">Todos los estados</option>
                <option value="OnTime">Al día</option>
                <option value="DueSoon">Por vencer</option>
                <option value="Overdue">Vencido</option>
            </select>

            <input class="form-control"
                   placeholder="Buscar código, activo, sede, responsable..."
                   @bind="searchText"
                   @bind:event="oninput" />
        </div>
    </div>

    @if (isLoading)
    {
        <div class="plans-empty">Cargando planes...</div>
    }
    else if (!FilteredPlans.Any())
    {
        <div class="plans-empty">No hay planes con los filtros aplicados.</div>
    }
    else
    {
        <div class="plans-table-wrapper">
            <table class="plans-table">
                <thead>
                    <tr>
                        <th>Activo</th>
                        <th>Sede / ubicación</th>
                        <th>Responsable</th>
                        <th>Periodicidad</th>
                        <th>Último mantenimiento</th>
                        <th>Próximo mantenimiento</th>
                        <th>Estado</th>
                        <th>Indicadores</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in FilteredPlans)
                    {
                        <tr>
                            <td>
                                <strong>@item.InternalCode</strong>
                                <small>@item.Name</small>
                            </td>

                            <td>
                                <strong>@(item.BranchCode ?? "—")</strong>
                                <small>@(item.LocationName ?? item.BranchName ?? "Sin ubicación")</small>
                            </td>

                            <td>@(item.ResponsibleName ?? "—")</td>

                            <td>
                                <strong>@item.PeriodMonths mes(es)</strong>
                                <small>Periodicidad base</small>
                            </td>

                            <td>
                                <strong>@FormatDate(item.LastMaintenanceAt)</strong>
                                <small>@(item.LastMaintenanceNumber ?? "Sin registro previo")</small>
                                <small>@(item.LastProvider ?? "Sin proveedor")</small>
                            </td>

                            <td>
                                <strong>@FormatDate(item.NextMaintenanceAt)</strong>
                                <small>@GetDaysText(item.DaysRemaining)</small>
                            </td>

                            <td>
                                <span class="@GetPlanClass(item.PlanStatus)">
                                    @GetPlanLabel(item.PlanStatus)
                                </span>
                            </td>

                            <td>
                                <small>Total: @item.TotalMaintenances</small>
                                <small>Completados: @item.CompletedMaintenances</small>
                                <small>Programados: @item.ScheduledMaintenances</small>
                                <small>Solicitudes abiertas: @item.PendingRequests</small>
                            </td>

                            <td>
                                <div class="plans-actions">
    @if (CanOpenLifeRecord)
    {
        <a class="plans-action neutral" href="@($"/tools/{item.ToolAssetId}/technical-life-record")">
            Hoja de vida
        </a>
    }

    @if (CanOpenMaintenanceSchedule)
    {
        <a class="plans-action primary" href="@($"/tools/{item.ToolAssetId}/maintenance-schedule")">
            Cronograma
        </a>
    }

    @if (CanRequestMaintenance)
    {
        <a class="plans-action success" href="/maintenance-request">
            Solicitar
        </a>
    }
</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

</PermissionGuard>

