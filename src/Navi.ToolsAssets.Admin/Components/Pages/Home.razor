@code {
    private bool isLoading;
    private string? errorMessage;
    private ExecutiveDashboard? dashboard;
    private string maintenanceTab = "month";

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            var client = HttpClientFactory.CreateClient("NaviApi");
            dashboard = await client.GetFromJsonAsync<ExecutiveDashboard>("api/dashboard/executive");
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo cargar el dashboard. Valida que la API esté activa en http://localhost:5218. Detalle: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetMaintenanceTab(string value)
    {
        maintenanceTab = value;
    }

    private string GetMaintenanceTabClass(string value)
    {
        return maintenanceTab == value ? "active" : string.Empty;
    }

    private int GetSelectedMaintenanceValue()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return maintenanceTab == "day"
            ? dashboard.MaintenanceSummary.Today
            : dashboard.MaintenanceSummary.ThisMonth;
    }

    private int GetInProcess()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return dashboard.Summary.AssignedTools + dashboard.Summary.LoanedTools + dashboard.Summary.InMaintenanceTools;
    }

    private int GetPendingTotal()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return dashboard.Summary.PendingValidationTools + dashboard.Summary.WithoutLifeRecord;
    }

    private int GetDifferences()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return dashboard.Summary.DamagedTools + dashboard.Summary.NotLocatedTools + dashboard.Summary.PendingValidationTools;
    }

    private int GetAdvancePercent()
    {
        if (dashboard is null || dashboard.Summary.TotalTools <= 0)
        {
            return 0;
        }

        return Math.Min(100, Math.Max(0, (int)Math.Round((decimal)dashboard.Summary.WithLifeRecord / dashboard.Summary.TotalTools * 100)));
    }

    private int GetToolsVsAssetsTotal()
    {
        if (dashboard is null)
        {
            return 1;
        }

        return Math.Max(1, dashboard.Summary.ToolsOnly + dashboard.Summary.FixedAssets + dashboard.Summary.ToolsWithoutFixedAssetCode);
    }

    private int GetStatusDonutTotal()
    {
        if (dashboard is null)
        {
            return 1;
        }

        return Math.Max(
            1,
            dashboard.Summary.AssignedTools
            + dashboard.Summary.AvailableTools
            + dashboard.Summary.PendingValidationTools
            + dashboard.Summary.InMaintenanceTools
            + GetOtherStatusTools());
    }

    private int GetLifeRecordDonutTotal()
    {
        if (dashboard is null)
        {
            return 1;
        }

        return Math.Max(
            1,
            dashboard.Summary.WithLifeRecord
            + dashboard.Summary.WithoutLifeRecord
            + dashboard.LifeRecordCoverage.MissingTechnicalData
            + dashboard.Summary.FixedAssets
            + GetOtherLifeRecords());
    }

    private int GetOtherStatusTools()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return Math.Max(
            0,
            dashboard.Summary.TotalTools
            - dashboard.Summary.AssignedTools
            - dashboard.Summary.AvailableTools
            - dashboard.Summary.PendingValidationTools
            - dashboard.Summary.InMaintenanceTools);
    }

    private int GetOtherLifeRecords()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return Math.Max(
            0,
            dashboard.Summary.TotalTools
            - dashboard.Summary.WithLifeRecord
            - dashboard.Summary.WithoutLifeRecord
            - dashboard.LifeRecordCoverage.MissingTechnicalData);
    }

    private int GetBranchAssigned(int total)
    {
        return Math.Max(0, total);
    }

    private int GetBranchPending(int total)
    {
        return Math.Max(0, (int)Math.Round(total * 0.08m));
    }

    private int GetBranchDifferences(int total)
    {
        if (dashboard is null || dashboard.Summary.TotalTools <= 0)
        {
            return 0;
        }

        var totalDiff = GetDifferences();

        return Math.Max(0, (int)Math.Round((decimal)total / dashboard.Summary.TotalTools * totalDiff));
    }

    private int GetBranchValidated(int total)
    {
        var pending = GetBranchPending(total);
        var diff = GetBranchDifferences(total);

        return Math.Max(0, total - pending - diff);
    }

    private int GetBranchAdvance(int total)
    {
        if (total <= 0)
        {
            return 0;
        }

        var valid = GetBranchValidated(total);

        return Math.Min(100, Math.Max(0, (int)Math.Round((decimal)valid / total * 100)));
    }

    private int GetMaxBranch()
    {
        if (dashboard is null || dashboard.ToolsByBranch.Count == 0)
        {
            return 1;
        }

        return Math.Max(1, dashboard.ToolsByBranch.Max(x => x.Total));
    }

    private IEnumerable<BranchChartItem> GetBranchChartItems()
    {
        if (dashboard is null)
        {
            return Enumerable.Empty<BranchChartItem>();
        }

        return dashboard.ToolsByBranch.Take(8).Select((branch, index) => new BranchChartItem(branch, index));
    }

    private string GetBranchBarStyle(int value, int index)
    {
        var percent = GetPercent(value, GetMaxBranch());

        var colors = new[]
        {
            "#7b0d8e",
            "#2186d9",
            "#f0a224",
            "#16a34a",
            "#b4232e",
            "#0ea5e9",
            "#8b5cf6",
            "#64748b"
        };

        var color = colors[index % colors.Length];

        return $"height:{percent}%; background:{color};";
    }

    private static int GetPercent(int value, int max)
    {
        if (value <= 0 || max <= 0)
        {
            return 0;
        }

        return Math.Max(5, (int)Math.Round((decimal)value / max * 100));
    }

    private string GetToolsVsAssetsDonut()
    {
        if (dashboard is null)
        {
            return "background: conic-gradient(#eadff0 0 100%);";
        }

        return BuildDonut(
            new DashboardSegment(dashboard.Summary.ToolsOnly, "#7b0d8e"),
            new DashboardSegment(dashboard.Summary.FixedAssets, "#2186d9"),
            new DashboardSegment(dashboard.Summary.ToolsWithoutFixedAssetCode, "#f0a224"));
    }

    private string GetStatusDonut()
    {
        if (dashboard is null)
        {
            return "background: conic-gradient(#eadff0 0 100%);";
        }

        return BuildDonut(
            new DashboardSegment(dashboard.Summary.AssignedTools, "#7b0d8e"),
            new DashboardSegment(dashboard.Summary.AvailableTools, "#2186d9"),
            new DashboardSegment(dashboard.Summary.PendingValidationTools, "#f0a224"),
            new DashboardSegment(dashboard.Summary.InMaintenanceTools, "#b4232e"),
            new DashboardSegment(GetOtherStatusTools(), "#64748b"));
    }

    private string GetLifeRecordDonut()
    {
        if (dashboard is null)
        {
            return "background: conic-gradient(#eadff0 0 100%);";
        }

        return BuildDonut(
            new DashboardSegment(dashboard.Summary.WithLifeRecord, "#7b0d8e"),
            new DashboardSegment(dashboard.Summary.WithoutLifeRecord, "#2186d9"),
            new DashboardSegment(dashboard.LifeRecordCoverage.MissingTechnicalData, "#f0a224"),
            new DashboardSegment(dashboard.Summary.FixedAssets, "#b4232e"),
            new DashboardSegment(GetOtherLifeRecords(), "#64748b"));
    }

    private static string BuildDonut(params DashboardSegment[] segments)
    {
        var validSegments = segments
            .Where(x => x.Value > 0)
            .ToList();

        var total = validSegments.Sum(x => x.Value);

        if (total <= 0)
        {
            return "background: conic-gradient(#eadff0 0 100%);";
        }

        var parts = new List<string>();
        decimal start = 0;

        for (var i = 0; i < validSegments.Count; i++)
        {
            var segment = validSegments[i];
            var percent = Math.Round((decimal)segment.Value / total * 100, 2);
            var end = i == validSegments.Count - 1 ? 100 : Math.Min(100, start + percent);

            parts.Add($"{segment.Color} {CssNumber(start)}% {CssNumber(end)}%");
            start = end;
        }

        return $"background: conic-gradient({string.Join(", ", parts)});";
    }

    private static string CssNumber(decimal value)
    {
        return value.ToString("0.##", CultureInfo.InvariantCulture);
    }

    private static string GetPercentLabel(int value, int total)
    {
        if (value <= 0 || total <= 0)
        {
            return "0%";
        }

        return $"{Math.Round((decimal)value / total * 100, 1)}%";
    }

    private static string GetProgressStyle(int percent)
    {
        return $"width:{Math.Min(100, Math.Max(0, percent))}%";
    }

    private string GetPendingPanelTitle()
    {
        if (dashboard is null || dashboard.ToolsByBranch.Count == 0)
        {
            return "Pendientes";
        }

        var branch = dashboard.ToolsByBranch
            .OrderByDescending(x => GetBranchPending(x.Total) + GetBranchDifferences(x.Total))
            .First();

        return $"Pendientes de {branch.BranchName}";
    }

    private static string ShortName(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "Sin sede";
        }

        return value.Length <= 12 ? value : value[..12];
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "—" : value;
    }

    private static string FormatDateTime(DateTime value)
    {
        return value.ToString("dd/MM/yyyy HH:mm");
    }

    private static string GetActivityIcon(string? eventType)
    {
        if (string.IsNullOrWhiteSpace(eventType))
        {
            return "📌";
        }

        var value = eventType.ToLowerInvariant();

        if (value.Contains("maintenance"))
        {
            return "🛠️";
        }

        if (value.Contains("assignment"))
        {
            return "🔁";
        }

        if (value.Contains("document"))
        {
            return "📄";
        }

        if (value.Contains("purchase"))
        {
            return "🛒";
        }

        if (value.Contains("physical") || value.Contains("count"))
        {
            return "📦";
        }

        return "📌";
    }

