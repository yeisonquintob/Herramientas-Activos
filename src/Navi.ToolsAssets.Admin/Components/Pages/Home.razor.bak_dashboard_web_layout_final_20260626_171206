@code {
    private bool isLoading;
    private string? errorMessage;
    private ExecutiveDashboard? dashboard;

    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;

            var client = HttpClientFactory.CreateClient("NaviApi");
            dashboard = await client.GetFromJsonAsync<ExecutiveDashboard>("api/dashboard/executive");
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo cargar el dashboard. Valida que la API esté activa en http://localhost:5218. Detalle: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private int GetInProcess()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return dashboard.Summary.AssignedTools + dashboard.Summary.LoanedTools + dashboard.Summary.InMaintenanceTools;
    }

    private int GetPendingTotal()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return dashboard.Summary.PendingValidationTools + dashboard.Summary.WithoutLifeRecord;
    }

    private int GetDifferences()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return dashboard.Summary.DamagedTools + dashboard.Summary.NotLocatedTools + dashboard.Summary.PendingValidationTools;
    }

    private int GetAdvancePercent()
    {
        if (dashboard is null || dashboard.Summary.TotalTools <= 0)
        {
            return 0;
        }

        return Math.Min(100, Math.Max(0, (int)Math.Round((decimal)dashboard.Summary.WithLifeRecord / dashboard.Summary.TotalTools * 100)));
    }

    private int GetOtherMaintenance()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return Math.Max(0, dashboard.MaintenanceSummary.Total - dashboard.MaintenanceSummary.ThisMonth - dashboard.MaintenanceSummary.Today);
    }

    private int GetMaintenanceTotalForChart()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return dashboard.Summary.AssignedTools + dashboard.Summary.AvailableTools + dashboard.Summary.PendingValidationTools + dashboard.Summary.InMaintenanceTools;
    }

    private int GetOtherLifeRecords()
    {
        if (dashboard is null)
        {
            return 0;
        }

        return Math.Max(0, dashboard.Summary.TotalTools - dashboard.Summary.WithLifeRecord - dashboard.Summary.WithoutLifeRecord);
    }

    private int GetBranchAssigned(int total)
    {
        return Math.Max(0, total);
    }

    private int GetBranchValidated(int total)
    {
        var pending = GetBranchPending(total);
        var diff = GetBranchDifferences(total);

        return Math.Max(0, total - pending - diff);
    }

    private int GetBranchPending(int total)
    {
        return Math.Max(0, (int)Math.Round(total * 0.08m));
    }

    private int GetBranchDifferences(int total)
    {
        if (dashboard is null || dashboard.Summary.TotalTools <= 0)
        {
            return 0;
        }

        var totalDiff = GetDifferences();

        return Math.Max(0, (int)Math.Round((decimal)total / dashboard.Summary.TotalTools * totalDiff));
    }

    private int GetBranchAdvance(int total)
    {
        if (total <= 0)
        {
            return 0;
        }

        var valid = GetBranchValidated(total);

        return Math.Min(100, Math.Max(0, (int)Math.Round((decimal)valid / total * 100)));
    }

    private int GetMaxBranch()
    {
        if (dashboard is null || dashboard.ToolsByBranch.Count == 0)
        {
            return 1;
        }

        return Math.Max(1, dashboard.ToolsByBranch.Max(x => x.Total));
    }

    private IEnumerable<BranchChartItem> GetBranchChartItems()
    {
        if (dashboard is null)
        {
            return Enumerable.Empty<BranchChartItem>();
        }

        return dashboard.ToolsByBranch.Take(8).Select((branch, index) => new BranchChartItem(branch, index));
    }

    private string GetBranchBarStyle(int value, int index)
    {
        var percent = GetPercent(value, GetMaxBranch());

        var colors = new[]
        {
            "#7b0d8e",
            "#2186d9",
            "#f0a224",
            "#16a34a",
            "#b4232e",
            "#0ea5e9",
            "#8b5cf6",
            "#64748b"
        };

        var color = colors[index % colors.Length];

        return $"height:{percent}%; background:{color};";
    }

    private static int GetPercent(int value, int max)
    {
        if (value <= 0 || max <= 0)
        {
            return 0;
        }

        return Math.Max(5, (int)Math.Round((decimal)value / max * 100));
    }

    private string GetToolsVsAssetsDonut()
    {
        if (dashboard is null)
        {
            return "background:#eee;";
        }

        return GetDonutStyle(
            dashboard.Summary.ToolsOnly,
            dashboard.Summary.FixedAssets,
            dashboard.Summary.ToolsWithoutFixedAssetCode);
    }

    private string GetLifeRecordDonut()
    {
        if (dashboard is null)
        {
            return "background:#eee;";
        }

        return GetDonutStyle(
            dashboard.Summary.WithLifeRecord,
            dashboard.Summary.WithoutLifeRecord,
            dashboard.LifeRecordCoverage.MissingTechnicalData);
    }

    private string GetMaintenanceDonut()
    {
        if (dashboard is null)
        {
            return "background:#eee;";
        }

        var assigned = dashboard.Summary.AssignedTools;
        var available = dashboard.Summary.AvailableTools;
        var pending = dashboard.Summary.PendingValidationTools + dashboard.Summary.InMaintenanceTools;

        return GetDonutStyle(assigned, available, pending);
    }

    private static string GetDonutStyle(int first, int second, int third)
    {
        var total = Math.Max(1, first + second + third);
        var p1 = Math.Round((decimal)first / total * 100, 2);
        var p2 = Math.Round((decimal)second / total * 100, 2);
        var p12 = p1 + p2;

        return $"background: conic-gradient(#7b0d8e 0 {p1}%, #2186d9 {p1}% {p12}%, #f0a224 {p12}% 100%);";
    }

    private static string GetPercentLabel(int value, int total)
    {
        if (value <= 0 || total <= 0)
        {
            return "0%";
        }

        return $"{Math.Round((decimal)value / total * 100, 1)}%";
    }

    private IEnumerable<PendingDashboardItem> GetPendingItems()
    {
        if (dashboard is null)
        {
            return Enumerable.Empty<PendingDashboardItem>();
        }

        var items = new List<PendingDashboardItem>
        {
            new("Pendientes validación", "Herramientas pendientes por validar", dashboard.Summary.PendingValidationTools.ToString()),
            new("Sin hoja de vida", "Activos sin hoja de vida técnica", dashboard.Summary.WithoutLifeRecord.ToString()),
            new("Requieren mantenimiento", "Activos marcados para mantenimiento", dashboard.Summary.RequiresMaintenance.ToString()),
            new("Datos incompletos", "Hojas de vida con datos técnicos faltantes", dashboard.LifeRecordCoverage.MissingTechnicalData.ToString())
        };

        foreach (var branch in dashboard.ToolsByBranch.Take(4))
        {
            items.Add(new(
                $"Pendiente {branch.BranchCode}",
                branch.BranchName,
                GetBranchPending(branch.Total).ToString()));
        }

        return items;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Sin dato" : value;
    }

    private static MarkupString GetMiniIcon(string key)
    {
        var svg = key switch
        {
            "total" => "<svg viewBox='0 0 24 24'><path d='M4 7l8-4 8 4-8 4-8-4z'/><path d='M4 7v10l8 4 8-4V7'/></svg>",
            "check" => "<svg viewBox='0 0 24 24'><path d='M5 12l4 4L19 6'/></svg>",
            "user" => "<svg viewBox='0 0 24 24'><circle cx='12' cy='8' r='4'/><path d='M4 21c1.5-4 14.5-4 16 0'/></svg>",
            "tool" => "<svg viewBox='0 0 24 24'><path d='M14 6l4 4'/><path d='M4 20l6-6'/><path d='M11 5a5 5 0 0 0 6 6l-7 7a3 3 0 0 1-4-4l7-7z'/></svg>",
            "clock" => "<svg viewBox='0 0 24 24'><circle cx='12' cy='12' r='8'/><path d='M12 8v5l3 2'/></svg>",
            "close" => "<svg viewBox='0 0 24 24'><circle cx='12' cy='12' r='8'/><path d='M9 9l6 6'/><path d='M15 9l-6 6'/></svg>",
            _ => "<svg viewBox='0 0 24 24'><path d='M5 5h14v14H5z'/></svg>"
        };

        return new MarkupString(svg);
    }

