    private static string GetRequestAvailabilityClass(ToolItem tool, LoanRequestItem? pending)
    {
        if (pending is not null)
        {
            return "request-status request-status-pending";
        }

        return tool.OperationalStatus switch
        {
            "Available" => "request-status request-status-available",
            "Assigned" => "request-status request-status-assigned",
            "Loaned" => "request-status request-status-loaned",
            "InMaintenance" => "request-status request-status-maintenance",
            "Damaged" => "request-status request-status-danger",
            "NotLocated" => "request-status request-status-danger",
            "PendingValidation" => "request-status request-status-warning",
            _ => "request-status request-status-neutral"
        };
    }
    private async Task SubmitSelfAssignmentRequestAsync()
    {
        if (!CanRequestAssignment)
        {
            ShowError("No tienes permiso para solicitar asignación de herramientas.");
            return;
        }

        if (requestForm.ToolId is null)
        {
            ShowError("Debe seleccionar una herramienta para solicitar asignación.");
            return;
        }

        var requesterId = CurrentRequesterPersonId;

        var tool = tools.FirstOrDefault(x => x.Id == requestForm.ToolId);

        if (tool is null)
        {
            ShowError("No se encontró la herramienta seleccionada.");
            return;
        }

        if (string.IsNullOrWhiteSpace(tool.BranchCode))
        {
            ShowError("La herramienta no tiene sede asociada para generar la solicitud.");
            return;
        }

        var pending = FindPendingRequestForTool(tool.Id);

        if (pending is not null)
        {
            ShowError($"La herramienta ya tiene una solicitud pendiente: {pending.LoanNumber}.");
            return;
        }

        isSaving = true;
        ShowSuccess("Registrando solicitud de asignación...");

        var requesterName = AuthSession.ResponsiblePersonName;

        if (string.IsNullOrWhiteSpace(requesterName))
        {
            requesterName = AuthSession.DisplayName;
        }

        if (string.IsNullOrWhiteSpace(requesterName))
        {
            requesterName = AuthSession.UserName;
        }

        var request = new
        {
            branchCode = tool.BranchCode,
            requestedByPersonId = requesterId,
            toolInternalCodes = new[] { tool.InternalCode },
            expectedReturnAt = requestForm.ExpectedReturnAt,
            deliveryCondition = "Solicitud de asignación desde Asignar Herramientas y AF web.",
            notes = string.IsNullOrWhiteSpace(requestForm.Notes)
                ? $"Solicitud de asignación del activo {tool.InternalCode} para {requesterName}."
                : requestForm.Notes,
            requestedBy = AuthSession.AuditUser
        };

        try
        {
            var response = await Api.PostAsJsonAsync("api/loans/request", request);

            if (!response.IsSuccessStatusCode)
            {
                var apiError = await response.Content.ReadAsStringAsync();
                ShowError(string.IsNullOrWhiteSpace(apiError)
                    ? "No se pudo crear la solicitud de asignación."
                    : apiError);
                return;
            }

            var created = await response.Content.ReadFromJsonAsync<LoanRequestItem>();

            ShowSuccess(created is null
                ? "Solicitud de asignación creada correctamente. Queda pendiente de aprobación."
                : $"Solicitud {created.LoanNumber} creada correctamente. Queda pendiente de aprobación.");

            requestForm = new AssignmentRequestForm();
            requestSearch = string.Empty;

            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Error creando solicitud: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task RejectRequestAsync(LoanRequestItem? request)
    {

        if (!CanDenyAssignmentRequest)
        {
            ShowError("No tienes permiso para denegar solicitudes de asignación.");
            return;
        }

        if (request is null)
        {
            ShowError("La herramienta no tiene solicitud pendiente para denegar.");
            return;
        }

        isSaving = true;

        var body = new
        {
            actionBy = AuthSession.AuditUser,
            notes = $"Solicitud {request.LoanNumber} denegada desde Asignar Herramientas y AF web.",
            condition = "Solicitud denegada por herramentero."
        };

        try
        {
            var response = await Api.PatchAsJsonAsync($"api/loans/{request.Id}/reject", body);

            if (!response.IsSuccessStatusCode)
            {
                ShowError(await response.Content.ReadAsStringAsync());
                return;
            }

            ShowSuccess($"Solicitud {request.LoanNumber} denegada correctamente.");

            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Error denegando solicitud: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }
    private async Task ApproveRequestAsync(LoanRequestItem? request)
    {

        if (!CanApproveAssignmentRequest)
        {
            ShowError("No tienes permiso para aprobar solicitudes de asignación.");
            return;
        }

        if (request is null)
        {
            ShowError("La herramienta no tiene solicitud pendiente para aprobar.");
            return;
        }

        isSaving = true;

        var body = new
        {
            actionBy = AuthSession.AuditUser,
            notes = $"Solicitud {request.LoanNumber} aprobada desde Asignar Herramientas y AF web.",
            condition = "Aprobado y asignado por herramentero."
        };

        try
        {
            var response = await Api.PatchAsJsonAsync($"api/loans/{request.Id}/approve-assign", body);

            if (!response.IsSuccessStatusCode)
            {
                ShowError(await response.Content.ReadAsStringAsync());
                return;
            }

            ShowSuccess($"Solicitud {request.LoanNumber} aprobada y activo asignado correctamente.");

            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Error aprobando solicitud: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private LoanRequestItem? FindPendingRequestForTool(Guid toolId)
    {
        return PendingLoanRequests.FirstOrDefault(x =>
            x.Items.Any(i => i.ToolAssetId == toolId && !i.Returned));
    }

    private void ClearForm()
    {
        form = new AssignmentForm();
        assignmentToolSearchText = string.Empty;
        assignmentResponsibleSearchText = string.Empty;
        assignmentBranchSearchText = string.Empty;
        assignmentLocationSearchText = string.Empty;
    }

    
    private void OnAssignmentToolSearchInput(ChangeEventArgs args)
    {
        assignmentToolSearchText = args?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(assignmentToolSearchText))
        {
            form.ToolId = null;
            return;
        }

        var tool = ResolveTool(assignmentToolSearchText);

        if (tool is not null)
        {
            form.ToolId = tool.Id;
            LoadSelectedTool();
        }
    }

    private void OnAssignmentResponsibleSearchInput(ChangeEventArgs args)
    {
        assignmentResponsibleSearchText = args?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(assignmentResponsibleSearchText))
        {
            form.ResponsiblePersonId = null;
            return;
        }

        var responsible = ResolveResponsible(assignmentResponsibleSearchText);

        if (responsible is not null)
        {
            form.ResponsiblePersonId = responsible.Id;
            assignmentResponsibleSearchText = FormatResponsibleOption(responsible);
        }
    }

    private void OnAssignmentBranchSearchInput(ChangeEventArgs args)
    {
        assignmentBranchSearchText = args?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(assignmentBranchSearchText))
        {
            form.BranchId = null;
            form.LocationId = null;
            assignmentLocationSearchText = string.Empty;
            return;
        }

        var branch = ResolveBranch(assignmentBranchSearchText);

        if (branch is not null)
        {
            form.BranchId = branch.Id;
            assignmentBranchSearchText = FormatBranchOption(branch);
            OnBranchChanged();
        }
    }

    private void OnAssignmentLocationSearchInput(ChangeEventArgs args)
    {
        assignmentLocationSearchText = args?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(assignmentLocationSearchText))
        {
            form.LocationId = null;
            return;
        }

        var location = ResolveLocation(assignmentLocationSearchText);

        if (location is not null)
        {
            form.LocationId = location.Id;
            assignmentLocationSearchText = FormatLocationOption(location);
        }
    }

    private void OnHistoryResponsibleSearchInput(ChangeEventArgs args)
    {
        historyResponsibleSearchText = args?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(historyResponsibleSearchText) ||
            historyResponsibleSearchText.Equals("Todos los usuarios", StringComparison.OrdinalIgnoreCase))
        {
            historyResponsibleId = string.Empty;
            return;
        }

        var responsible = ResolveResponsible(historyResponsibleSearchText);

        if (responsible is not null)
        {
            historyResponsibleId = responsible.Id.ToString();
            historyResponsibleSearchText = FormatResponsibleOption(responsible);
        }
    }

    
    private ToolItem? ResolveTool(string value)
    {
        return tools.FirstOrDefault(x =>
            string.Equals(FormatToolOption(x), value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals($"{x.InternalCode} - {x.Name}", value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.InternalCode, value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Name, value, StringComparison.OrdinalIgnoreCase));
    }

    private BranchItem? ResolveBranch(string value)
    {
        return branches.FirstOrDefault(x =>
            string.Equals(FormatBranchOption(x), value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Code, value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Name, value, StringComparison.OrdinalIgnoreCase));
    }

    private LocationItem? ResolveLocation(string value)
    {
        return AvailableLocations.FirstOrDefault(x =>
            string.Equals(FormatLocationOption(x), value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Code, value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Name, value, StringComparison.OrdinalIgnoreCase));
    }

    private static string FormatToolOption(ToolItem tool)
    {
        var serial = string.IsNullOrWhiteSpace(tool.SerialNumber) ? "Sin serial" : tool.SerialNumber;
        var branch = string.IsNullOrWhiteSpace(tool.BranchCode) ? "Sin sede" : tool.BranchCode;
        return $"{tool.InternalCode} - {tool.Name} · {branch} · {serial}";
    }

    private static string FormatLocationOption(LocationItem location)
    {
        return $"{location.Code} - {location.Name}";
    }

