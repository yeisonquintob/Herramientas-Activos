@page "/mobile/assignment"

@using Microsoft.AspNetCore.Components
@using Navi.ToolsAssets.MobilePwa.Models

@inject NaviMobileApiClient Api
@inject MobileAuthSessionService Auth
@inject NavigationManager Navigation

<PageTitle>Asignación y préstamos móvil - NAVI Herramientas y AF</PageTitle>

<section class="mobile-page mobile-assignment-page">
    @if (isLoading)
    {
        <div class="mobile-loading">Cargando asignaciones móviles...</div>
    }
    else if (!Auth.IsAuthenticated)
    {
        <div class="mobile-empty">
            <strong>Sesión requerida</strong>
            <span>Debes iniciar sesión para usar asignaciones móviles.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoLogin">Ir al login</button>
        </div>
    }
    else if (!CanUseAssignmentModule)
    {
        <div class="mobile-empty">
            <strong>Sin permiso</strong>
            <span>Tu usuario no tiene permisos de asignación, préstamo ni historial.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoHome">Volver</button>
        </div>
    }
    else
    {
        <header class="mobile-assignment-hero">
            <div class="mobile-assignment-hero-top">
                <span>ASIGNACIÓN Y PRÉSTAMOS</span>
                <button type="button" @onclick="GoHome">Regresar</button>
            </div>

            <h1>Asignación y préstamos</h1>
            <p>@GetScopeText()</p>
        </header>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="@messageClass">@message</div>
        }

        <section class="mobile-assignment-kpis">
            <article>
                <strong>@PendingRequests.Count()</strong>
                <span>Pendientes visibles</span>
            </article>

            <article>
                <strong>@ApprovedOrDeliveredCount</strong>
                <span>Aprobadas</span>
            </article>

            <article>
                <strong>@ScopedTools.Count()</strong>
                <span>Activos sede</span>
            </article>
        </section>

        @if (CanRequestLoan)
        {
            <section class="mobile-assignment-card">
                <div class="mobile-assignment-card-head">
                    <div>
                        <strong>Solicitud de préstamo</strong>
                        <span>El solicitante será @CurrentResponsibleLabel</span>
                    </div>

                    <button type="button" @onclick="ClearLoanRequest">Limpiar</button>
                </div>

                <label class="mobile-field">
                    <span>Buscar activo para solicitar</span>
                    <input value="@loanSearch"
                           @oninput="OnLoanSearchChanged"
                           placeholder="Código, nombre, serial, sede o ubicación..." />
                </label>

                @if (ShowLoanSearchResults)
                {
                    <div class="mobile-request-results">
                        @if (!LoanRequestTools.Any())
                        {
                            <div class="mobile-assignment-empty">No se encontraron activos dentro de tu sede.</div>
                        }
                        else
                        {
                            @foreach (var tool in LoanRequestTools.Take(8))
                            {
                                var selected = loanForm.ToolId == tool.Id;

                                <button type="button"
                                        class="mobile-request-result @(selected ? "selected" : "")"
                                        @onclick="() => SelectLoanTool(tool)">
                                    <span>
                                        <strong>@tool.InternalCode</strong>
                                        <small>@tool.Name</small>
                                        <small>@Display(tool.BranchCode) · @Display(tool.LocationName)</small>
                                    </span>

                                    <em class="@GetToolStateClass(tool)">
                                        @GetStatusLabel(tool.OperationalStatus)
                                    </em>
                                </button>
                            }
                        }
                    </div>
                }

                @if (selectedLoanTool is not null)
                {
                    <div class="mobile-assignment-selected">
                        <span>@selectedLoanTool.InternalCode</span>
                        <strong>@selectedLoanTool.Name</strong>
                        <small>@Display(selectedLoanTool.BranchCode) · @Display(selectedLoanTool.LocationName)</small>
                    </div>
                }

                <label class="mobile-field">
                    <span>Fecha estimada devolución</span>
                    <input type="date"
                           value="@FormatDateInput(loanForm.ExpectedReturnAt)"
                           @onchange="OnLoanExpectedReturnChanged" />
                </label>

                <label class="mobile-field">
                    <span>Observación</span>
                    <textarea rows="2"
                              value="@loanForm.Notes"
                              @oninput="OnLoanNotesChanged"
                              placeholder="Indique para qué requiere la herramienta..."></textarea>
                </label>

                <button class="mobile-assignment-main-button"
                        type="button"
                        disabled="@isSaving"
                        @onclick="SubmitLoanRequestAsync">
                    @(isSaving ? "Enviando..." : "Enviar solicitud de préstamo")
                </button>
            </section>
        }

        @if (CanApproveAssignmentRequest || CanDenyAssignmentRequest)
        {
            <section class="mobile-assignment-card">
                <div class="mobile-assignment-card-head">
                    <div>
                        <strong>Aprobaciones</strong>
                        <span>Solo visible para roles con permiso de aprobar o denegar</span>
                    </div>

                    <button type="button" @onclick="ReloadAsync">Actualizar</button>
                </div>

                @if (!PendingRequests.Any())
                {
                    <div class="mobile-assignment-empty">No hay solicitudes pendientes visibles.</div>
                }
                else
                {
                    <div class="mobile-approval-list">
                        @foreach (var request in PendingRequests.Take(10))
                        {
                            var item = request.Items.FirstOrDefault();

                            <article>
                                <div class="mobile-approval-info">
                                    <span>@request.LoanNumber</span>
                                    <strong>@Display(item?.ToolInternalCode) - @Display(item?.ToolName)</strong>
                                    <small>Solicita: @Display(GetRequesterName(request)) · @ShowDate(request.RequestedAt)</small>
                                </div>

                                <div class="mobile-approval-actions mobile-approval-actions-top">
                                    @if (CanApproveAssignmentRequest)
                                    {
                                        <button class="approve" type="button" disabled="@isSaving" @onclick="() => ApproveAsync(request)">
                                            Aprobar
                                        </button>
                                    }

                                    @if (CanDenyAssignmentRequest)
                                    {
                                        <button class="deny" type="button" disabled="@isSaving" @onclick="() => DenyAsync(request)">
                                            Denegar
                                        </button>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
            </section>
        }

        @if (CanDirectAssign || CanReturnAssignment)
        {
            <section class="mobile-assignment-card">
                <div class="mobile-collapse-head">
                    <div>
                        <strong>Nueva asignación / regreso</strong>
                        <span>Solo roles con permiso de asignar o devolver</span>
                    </div>

                    <button type="button" @onclick="ToggleNewAssignment">
                        @(showNewAssignment ? "Ocultar" : "Expandir")
                    </button>
                </div>

                @if (showNewAssignment)
                {
                    <label class="mobile-field">
                        <span>Buscar activo</span>
                        <input value="@assignmentSearch"
                               @oninput="OnAssignmentSearchChanged"
                               placeholder="Código, nombre, serial o sede..." />
                    </label>

                    @if (ShowAssignmentSearchResults)
                    {
                        <div class="mobile-request-results">
                            @if (!AssignmentTools.Any())
                            {
                                <div class="mobile-assignment-empty">No se encontraron activos.</div>
                            }
                            else
                            {
                                @foreach (var tool in AssignmentTools.Take(8))
                                {
                                    var selected = assignmentForm.ToolId == tool.Id;

                                    <button type="button"
                                            class="mobile-request-result @(selected ? "selected" : "")"
                                            @onclick="() => SelectAssignmentTool(tool)">
                                        <span>
                                            <strong>@tool.InternalCode</strong>
                                            <small>@tool.Name</small>
                                            <small>@Display(tool.BranchCode) · @Display(tool.LocationName)</small>
                                        </span>

                                        <em class="@GetToolStateClass(tool)">
                                            @GetStatusLabel(tool.OperationalStatus)
                                        </em>
                                    </button>
                                }
                            }
                        </div>
                    }

                    @if (selectedAssignmentTool is not null)
                    {
                        <div class="mobile-assignment-selected">
                            <span>@selectedAssignmentTool.InternalCode</span>
                            <strong>@selectedAssignmentTool.Name</strong>
                            <small>@Display(selectedAssignmentTool.BranchCode) · @Display(selectedAssignmentTool.LocationName)</small>
                        </div>
                    }

                    <label class="mobile-field">
                        <span>Tipo de movimiento</span>
                        <select value="@assignmentForm.AssignmentType" @onchange="OnAssignmentTypeChanged">
                            @if (CanDirectAssign)
                            {
                                <option value="Responsible">Asignar a usuario/responsable</option>
                            }

                            @if (CanReturnAssignment)
                            {
                                <option value="Warehouse">Regresar a almacén/taller</option>
                            }
                        </select>
                    </label>

                    @if (assignmentForm.AssignmentType == "Responsible" && CanDirectAssign)
                    {
                        <label class="mobile-field">
                            <span>Usuario / Responsable</span>
                            <select value="@AssignmentResponsibleText" @onchange="OnAssignmentResponsibleChanged">
                                <option value="">Seleccione responsable</option>
                                @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                                {
                                    <option value="@responsible.Id">@responsible.FullName - @Display(responsible.Position)</option>
                                }
                            </select>
                        </label>
                    }

                    @if (assignmentForm.AssignmentType == "Warehouse" && CanReturnAssignment)
                    {
                        <label class="mobile-field">
                            <span>Sede destino</span>
                            <select value="@AssignmentBranchText" @onchange="OnAssignmentBranchChanged" disabled="@(!UserCanSeeAllBranches())">
                                <option value="">Seleccione sede</option>
                                @foreach (var branch in branches.OrderBy(x => x.Code))
                                {
                                    <option value="@branch.Id">@branch.Code - @branch.Name</option>
                                }
                            </select>
                        </label>

                        <label class="mobile-field">
                            <span>Almacén / taller destino</span>
                            <select value="@AssignmentLocationText" @onchange="OnAssignmentLocationChanged">
                                <option value="">Seleccione almacén/taller</option>
                                @foreach (var location in AvailableAssignmentLocations.OrderBy(x => x.Code))
                                {
                                    <option value="@location.Id">@location.Code - @location.Name</option>
                                }
                            </select>
                        </label>
                    }

                    <label class="mobile-field">
                        <span>@(assignmentForm.AssignmentType == "Warehouse" ? "Fecha de regreso" : "Fecha de asignación")</span>
                        <input type="date"
                               value="@FormatDateInput(assignmentForm.AssignmentDate)"
                               @onchange="OnAssignmentDateChanged" />
                    </label>

                    <label class="mobile-field">
                        <span>Observación</span>
                        <textarea rows="2"
                                  value="@assignmentForm.Observation"
                                  @oninput="OnAssignmentObservationChanged"
                                  placeholder="Observación del movimiento..."></textarea>
                    </label>

                    <button class="mobile-assignment-main-button" type="button" disabled="@isSaving" @onclick="SaveDirectAssignmentAsync">
                        @(isSaving ? "Guardando..." : assignmentForm.AssignmentType == "Warehouse" ? "Confirmar regreso" : "Confirmar asignación")
                    </button>
                }
            </section>
        }

        @if (CanViewAssignmentHistory)
        {
            <section class="mobile-assignment-card">
                <div class="mobile-collapse-head">
                    <div>
                        <strong>Historial</strong>
                        <span>Movimientos visibles según sede y permisos</span>
                    </div>

                    <button type="button" @onclick="ToggleHistory">
                        @(showHistory ? "Ocultar" : "Expandir")
                    </button>
                </div>

                @if (showHistory)
                {
                    <div class="mobile-assignment-filters">
                        <input value="@historySearch"
                               @oninput="OnHistorySearchChanged"
                               placeholder="Buscar préstamo, activo o usuario..." />
                    </div>

                    @if (!FilteredHistory.Any())
                    {
                        <div class="mobile-assignment-empty">No hay historial para los filtros seleccionados.</div>
                    }
                    else
                    {
                        <div class="mobile-history-list">
                            @foreach (var request in FilteredHistory.Take(12))
                            {
                                var item = request.Items.FirstOrDefault();

                                <article>
                                    <div>
                                        <span>@request.LoanNumber</span>
                                        <strong>@Display(item?.ToolInternalCode) - @Display(item?.ToolName)</strong>
                                        <small>@GetLoanStatusLabel(request.Status) · @ShowDate(request.CreatedAt)</small>
                                        <small>Usuario: @Display(GetRequesterName(request))</small>
                                    </div>

                                    <em class="@GetLoanStatusClass(request.Status)">
                                        @GetLoanStatusLabel(request.Status)
                                    </em>
                                </article>
                            }
                        </div>
                    }
                }
            </section>
        }

        <section class="mobile-assignment-card">
            <div class="mobile-assignment-card-head">
                <div>
                    <strong>Herramientas / activos visibles</strong>
                    <span>Consulta activos de la sede, solicita préstamo o reporta daño según permiso</span>
                </div>
            </div>

            <div class="mobile-assignment-filters">
                <input value="@toolSearch"
                       @oninput="OnToolSearchChanged"
                       placeholder="Buscar código, nombre, sede o ubicación..." />

                <div class="mobile-assignment-status-multi">
                    <div class="mobile-assignment-status-head">
                        <strong>Estado</strong>
                        <button type="button" @onclick="ClearToolStatuses">Limpiar</button>
                    </div>

                    <div class="mobile-assignment-status-options">
                        @foreach (var status in ToolStatusFilterOptions)
                        {
                            var selected = selectedToolStatuses.Contains(status.Value);

                            <button type="button"
                                    class="@(selected ? "selected" : "")"
                                    @onclick="() => ToggleToolStatus(status.Value)">
                                @status.Text
                            </button>
                        }
                    </div>
                </div>
            </div>

            @if (!FilteredTools.Any())
            {
                <div class="mobile-assignment-empty">No hay activos para mostrar.</div>
            }
            else
            {
                <div class="mobile-assignment-tools">
                    @foreach (var tool in FilteredTools.Take(80))
                    {
                        <article>
                            <div class="mobile-assignment-tool-head">
                                <div>
                                    <span>@tool.InternalCode</span>
                                    <strong>@tool.Name</strong>
                                </div>

                                <em class="@GetToolStateClass(tool)">
                                    @GetStatusLabel(tool.OperationalStatus)
                                </em>
                            </div>

                            <div class="mobile-assignment-tool-grid">
                                <div>
                                    <span>Sede</span>
                                    <strong>@Display(tool.BranchCode)</strong>
                                </div>

                                <div>
                                    <span>Ubicación</span>
                                    <strong>@Display(tool.LocationName)</strong>
                                </div>

                                <div>
                                    <span>Responsable</span>
                                    <strong>@Display(tool.ResponsiblePersonName)</strong>
                                </div>

                                <div>
                                    <span>Físico</span>
                                    <strong>@Display(tool.PhysicalStatus)</strong>
                                </div>
                            </div>

                            <div class="mobile-assignment-tool-actions">
                                @if (CanViewToolDetail)
                                {
                                    <a href="@GetDetailUrl(tool.Id)">Detalle</a>
                                }

                                @if (CanViewLifeRecord)
                                {
                                    <a href="@GetLifeRecordUrl(tool.Id)">Hoja vida</a>
                                }

                                @if (CanDirectAssign || CanReturnAssignment)
                                {
                                    <button type="button" @onclick="() => SelectAssignmentTool(tool)">Asignar</button>
                                }

                                @if (CanRequestLoan)
                                {
                                    <button type="button" @onclick="() => RequestLoanForToolAsync(tool)">Solicitar</button>
                                }

                                @if (CanReportDamage)
                                {
                                    <a class="danger" href="@GetDamageUrl(tool.Id)">Daño</a>
                                }
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }
</section>

@code {
    private bool isLoading = true;
    private bool isSaving;
    private bool showNewAssignment;
    private bool showHistory;
    private string? message;
    private string messageClass = "mobile-alert";

    private string loanSearch = string.Empty;
    private string assignmentSearch = string.Empty;
    private string historySearch = string.Empty;
    private string toolSearch = string.Empty;
    private string toolStatus = string.Empty;
    private HashSet<string> selectedToolStatuses = new(StringComparer.OrdinalIgnoreCase);

    private readonly (string Value, string Text)[] ToolStatusFilterOptions =
    {
        ("Available", "Disponible"),
        ("Assigned", "Asignada"),
        ("Loaned", "Prestada"),
        ("InMaintenance", "Mantenimiento"),
        ("Damaged", "Dañada"),
        ("NotSuitable", "No apta"),
        ("PendingValidation", "Pendiente validación"),
        ("NotLocated", "No localizada"),
        ("Disposed", "Baja")
    };

    private List<MobileAvailabilityToolDto> tools = new();
    private List<MobileLoanRequestDto> loanRequests = new();
    private List<MobileResponsibleDto> responsibles = new();
    private List<MobileBranchDto> branches = new();
    private List<MobileLocationDto> locations = new();

    private MobileLoanRequestForm loanForm = new();
    private MobileDirectAssignmentForm assignmentForm = new();

    private bool CanRequestLoan => HasAny("Mobile.Loans.Request", "AssetAssignment.Request");
    private bool CanDirectAssign => HasPermission("AssetAssignment.Assign");
    private bool CanReturnAssignment => HasPermission("AssetAssignment.Return");
    private bool CanApproveAssignmentRequest => HasPermission("AssetAssignment.Approve");
    private bool CanDenyAssignmentRequest => HasPermission("AssetAssignment.Deny");
    private bool CanViewAssignmentHistory => HasPermission("AssetAssignment.History");
    private bool CanViewToolDetail => HasAny("ToolDetail.View", "Tools.View", "Mobile.Tools.View");
    private bool CanViewLifeRecord => HasAny("TechnicalLifeRecord.View", "ToolDetail.LifeRecord.Open");
    private bool CanReportDamage => HasAny("Mobile.Damage.Report", "Damages.Create");

    private bool CanUseAssignmentModule =>
        HasPermission("AssetAssignment.View") ||
        CanRequestLoan ||
        CanDirectAssign ||
        CanReturnAssignment ||
        CanApproveAssignmentRequest ||
        CanDenyAssignmentRequest ||
        CanViewAssignmentHistory;

    private string CurrentResponsibleLabel =>
        !string.IsNullOrWhiteSpace(Auth.CurrentUser?.ResponsiblePersonName)
            ? Auth.CurrentUser!.ResponsiblePersonName!
            : Auth.CurrentUser?.DisplayName ?? Auth.CurrentUser?.UserName ?? "Usuario móvil";

    private string AssignmentResponsibleText => assignmentForm.ResponsiblePersonId?.ToString() ?? string.Empty;
    private string AssignmentBranchText => assignmentForm.BranchId?.ToString() ?? string.Empty;
    private string AssignmentLocationText => assignmentForm.LocationId?.ToString() ?? string.Empty;

    private IEnumerable<MobileAvailabilityToolDto> ScopedTools =>
        tools
            .Where(IsSameBranch)
            .OrderBy(x => x.BranchCode)
            .ThenBy(x => x.InternalCode);

    private MobileAvailabilityToolDto? selectedLoanTool =>
        loanForm.ToolId.HasValue
            ? ScopedTools.FirstOrDefault(x => x.Id == loanForm.ToolId.Value)
            : null;

    private MobileAvailabilityToolDto? selectedAssignmentTool =>
        assignmentForm.ToolId.HasValue
            ? ScopedTools.FirstOrDefault(x => x.Id == assignmentForm.ToolId.Value)
            : null;

    private bool ShowLoanSearchResults =>
        CanRequestLoan &&
        !string.IsNullOrWhiteSpace(loanSearch) &&
        selectedLoanTool is null;

    private bool ShowAssignmentSearchResults =>
        (CanDirectAssign || CanReturnAssignment) &&
        !string.IsNullOrWhiteSpace(assignmentSearch) &&
        selectedAssignmentTool is null;

    private IEnumerable<MobileAvailabilityToolDto> LoanRequestTools =>
        ScopedTools
            .Where(IsToolAvailableForLoan)
            .Where(x => string.IsNullOrWhiteSpace(loanSearch) ||
                        ContainsText(x.InternalCode, loanSearch) ||
                        ContainsText(x.Name, loanSearch) ||
                        ContainsText(x.SerialNumber, loanSearch) ||
                        ContainsText(x.BranchCode, loanSearch) ||
                        ContainsText(x.LocationName, loanSearch))
            .OrderByDescending(x => ContainsStatus(x.OperationalStatus, "Available"))
            .ThenBy(x => x.InternalCode);

    private IEnumerable<MobileAvailabilityToolDto> AssignmentTools =>
        ScopedTools
            .Where(x => string.IsNullOrWhiteSpace(assignmentSearch) ||
                        ContainsText(x.InternalCode, assignmentSearch) ||
                        ContainsText(x.Name, assignmentSearch) ||
                        ContainsText(x.SerialNumber, assignmentSearch) ||
                        ContainsText(x.BranchCode, assignmentSearch) ||
                        ContainsText(x.LocationName, assignmentSearch))
            .OrderByDescending(x => ContainsStatus(x.OperationalStatus, "Available"))
            .ThenBy(x => x.InternalCode);

    private IEnumerable<MobileLocationDto> AvailableAssignmentLocations =>
        assignmentForm.BranchId.HasValue
            ? locations.Where(x => x.BranchId == assignmentForm.BranchId.Value)
            : locations;

    private IEnumerable<MobileLoanRequestDto> PendingRequests =>
        loanRequests
            .Where(x => CanApproveAssignmentRequest || CanDenyAssignmentRequest)
            .Where(x => IsPendingStatus(x.Status))
            .Where(x => x.Items.Any(i => !i.Returned))
            .Where(RequestInVisibleScope)
            .OrderByDescending(x => x.CreatedAt);

    private int ApprovedOrDeliveredCount =>
        loanRequests.Count(x =>
            RequestInVisibleScope(x) &&
            (
                x.Status.Equals("Approved", StringComparison.OrdinalIgnoreCase) ||
                x.Status.Equals("Delivered", StringComparison.OrdinalIgnoreCase)
            ));

    private int VisibleHistoryTotal =>
        loanRequests
            .Where(x => CanViewAssignmentHistory)
            .Where(x => !IsPendingStatus(x.Status))
            .Where(RequestInVisibleScope)
            .Count();

    private IEnumerable<MobileLoanRequestDto> FilteredHistory =>
        loanRequests
            .Where(x => CanViewAssignmentHistory)
            .Where(x => !IsPendingStatus(x.Status))
            .Where(RequestInVisibleScope)
            .Where(x => string.IsNullOrWhiteSpace(historySearch) ||
                        ContainsText(x.LoanNumber, historySearch) ||
                        ContainsText(x.CreatedBy, historySearch) ||
                        x.Items.Any(i => ContainsText(i.ToolInternalCode, historySearch) || ContainsText(i.ToolName, historySearch)))
            .OrderByDescending(x => x.CreatedAt);

    private IEnumerable<MobileAvailabilityToolDto> FilteredTools =>
        ScopedTools
            .Where(x => string.IsNullOrWhiteSpace(toolSearch) ||
                        ContainsText(x.InternalCode, toolSearch) ||
                        ContainsText(x.Name, toolSearch) ||
                        ContainsText(x.BranchCode, toolSearch) ||
                        ContainsText(x.LocationName, toolSearch) ||
                        ContainsText(x.ResponsiblePersonName, toolSearch))
            .Where(x => selectedToolStatuses.Count == 0 ||
                        selectedToolStatuses.Contains(x.OperationalStatus ?? string.Empty))
            .OrderByDescending(x => FindPendingRequestForTool(x.Id) is not null)
            .ThenByDescending(x => ContainsStatus(x.OperationalStatus, "Available"))
            .ThenBy(x => x.InternalCode);

    private void ToggleToolStatus(string status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return;
        }

        if (!selectedToolStatuses.Add(status))
        {
            selectedToolStatuses.Remove(status);
        }
    }

    private void ClearToolStatuses()
    {
        selectedToolStatuses.Clear();
    }

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsAuthenticated)
        {
            isLoading = false;
            return;
        }

        var refreshedUser = await Api.RefreshCurrentSessionAsync();

        if (refreshedUser is null || !Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (!CanUseAssignmentModule)
        {
            isLoading = false;
            return;
        }

        await LoadAsync();
    }


    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            message = null;

            tools = await Api.GetAvailabilityToolsAsync();
            loanRequests = await Api.GetLoanRequestsAsync();

            responsibles = (await Api.GetResponsiblesAsync())
                .OrderBy(x => x.FullName)
                .ToList();

            branches = (await Api.GetBranchesAsync())
                .Where(IsVisibleBranch)
                .OrderBy(x => x.Code)
                .ToList();

            locations = (await Api.GetLocationsAsync())
                .Where(IsVisibleLocation)
                .OrderBy(x => x.Code)
                .ToList();

            if (!CanDirectAssign && CanReturnAssignment)
            {
                assignmentForm.AssignmentType = "Warehouse";
            }
            else
            {
                assignmentForm.AssignmentType = "Responsible";
            }

            showNewAssignment = CanDirectAssign || CanReturnAssignment;
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo cargar asignación móvil: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ReloadAsync()
    {
        await LoadAsync();
    }

    private void ToggleNewAssignment()
    {
        if (!CanDirectAssign && !CanReturnAssignment)
        {
            ShowError("No tienes permiso para crear asignaciones o regresos.");
            return;
        }

        showNewAssignment = !showNewAssignment;
    }

    private void ToggleHistory()
    {
        if (!CanViewAssignmentHistory)
        {
