@code {
    private const string StorageKey = "navi-auth-session";

    private readonly LoginForm loginModel = new();
    private bool isLoading;
    private string? errorMessage;
    private string? infoMessage;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (AuthSession.IsAuthenticated)
        {
            Navigation.NavigateTo(GetHomeUrl(AuthSession.Permissions), forceLoad: true);
            return;
        }

        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);

            if (string.IsNullOrWhiteSpace(json))
            {
                return;
            }

            var user = JsonSerializer.Deserialize<AuthSessionUser>(
                json,
                new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

            if (user is not null && !string.IsNullOrWhiteSpace(user.UserName))
            {
                AuthSession.Login(user);
                Navigation.NavigateTo(GetHomeUrl(user.Permissions), forceLoad: true);
            }
        }
        catch
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey);
        }
    }

    private async Task LoginAsync()
    {
        isLoading = true;
        errorMessage = null;
        infoMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("NaviApi");

            var response = await client.PostAsJsonAsync("api/auth/login", new
            {
                userName = loginModel.UserName,
                password = loginModel.Password
            });

            if (!response.IsSuccessStatusCode)
            {
                var apiError = await response.Content.ReadFromJsonAsync<ApiError>();
                errorMessage = apiError?.Message ?? "No fue posible iniciar sesión.";
                return;
            }

            var sessionUser = await response.Content.ReadFromJsonAsync<AuthSessionUser>();

            if (sessionUser is null)
            {
                errorMessage = "La API no devolvió información de sesión.";
                return;
            }

            AuthSession.Login(sessionUser);

            var sessionJson = JsonSerializer.Serialize(sessionUser);
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, sessionJson);

            Navigation.NavigateTo(GetHomeUrl(sessionUser.Permissions), forceLoad: true);
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo conectar con la API. Valida que esté activa en http://localhost:5218. Detalle: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string GetHomeUrl(IEnumerable<string>? permissions)
    {
        var list = permissions?.ToList() ?? new();

        if (list.Contains("Dashboard.View", StringComparer.OrdinalIgnoreCase))
        {
            return "/dashboard";
        }

        if (list.Contains("Tools.View", StringComparer.OrdinalIgnoreCase))
        {
            return "/tools";
        }

        if (list.Contains("AssetAssignment.History", StringComparer.OrdinalIgnoreCase))
        {
            return "/asset-assignment-history";
        }

        if (list.Contains("TechnicalLifeRecord.View", StringComparer.OrdinalIgnoreCase))
        {
            return "/technical-life-records";
        }

        if (list.Contains("Documents.View", StringComparer.OrdinalIgnoreCase))
        {
            return "/documents";
        }

        return "/access-denied";
    }

    private void UseDemo(string userName)
    {
        loginModel.UserName = userName;
        loginModel.Password = "123456";
        errorMessage = null;
        infoMessage = $"Usuario demo seleccionado: {userName}. Presiona Ingresar.";
    }

    private sealed class LoginForm
    {
        [Required(ErrorMessage = "El usuario es obligatorio.")]
        public string UserName { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria.")]
        public string Password { get; set; } = string.Empty;
    }

    private sealed class ApiError
    {
        public string? Message { get; set; }
    }
}
