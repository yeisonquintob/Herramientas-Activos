        public void CopyFrom(RequestHeader source)
        {
            RequestName = source.RequestName;
            BranchIdText = source.BranchIdText;
            RequestedBy = source.RequestedBy;
            Approver = source.Approver;
            RequestType = source.RequestType;
            Priority = source.Priority;
            RequiredAt = source.RequiredAt;
            Location = source.Location;
            NeedDescription = source.NeedDescription;
