                </div>

                <div>
                    <span>Código reportado</span>
                    <strong>@DisplaySourceValue(reportedSource.ReportedCode)</strong>
                </div>

                <div>
                    <span>Nombre reportado</span>
                    <strong>@DisplaySourceValue(reportedSource.ReportedName)</strong>
                </div>

                <div>
                    <span>Ubicación encontrada</span>
                    <strong>@DisplaySourceValue(reportedSource.FoundLocation)</strong>
                </div>

                <div>
                    <span>Estado conciliación</span>
                    <strong>@DisplaySourceValue(reportedSource.ReconciliationStatus)</strong>
                    <small>@DisplaySourceValue(reportedSource.ReconciliationObservation)</small>
                </div>

                <div class="source-full">
                    <span>Observación del reporte</span>
                    <strong>@DisplaySourceValue(reportedSource.Observation)</strong>
                </div>
