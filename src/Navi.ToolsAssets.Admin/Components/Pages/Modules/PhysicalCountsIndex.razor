@page "/physical-counts"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Components.Security
@using Navi.ToolsAssets.Admin.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject WebAuthSessionService AuthSession
@inject NavigationManager NavigationManager

<PageTitle>Tomas Físicas</PageTitle>

<PermissionGuard Permission="PhysicalCounts.View" ModuleName="Tomas Físicas">

<section class="tf-hero">
    <div>
        <span class="tf-pill">INVENTARIO · TOMA FÍSICA</span>
        <h2>Tomas físicas</h2>
        <p>Programa campañas, habilita inventario por sede y controla el avance por usuario desde escritorio y móvil.</p>
    </div>

    <div class="tf-side">
        <div class="tf-status-box">
            <span>Total</span>
            <strong>@counts.Count</strong>
        </div>

        <button class="tf-outline-btn" type="button" @onclick="LoadAsync">
            Actualizar
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="tf-layout">
    @if (CanCreatePhysicalCount)
    {
        <article class="tf-form-card">
                <h3>Programar toma física</h3>
                <p>Crea una campaña por sede. Luego, en el detalle, generas participantes y activas la toma.</p>
        
                <div class="form-grid">
                    <div class="form-group">
                        <label>Sede</label>
                        <select class="form-select" @bind="newCount.BranchCode">
                            <option value="">Seleccione...</option>
                            @foreach (var branch in branches)
                            {
                                <option value="@branch.Code">@branch.Code - @branch.Name</option>
                            }
                        </select>
                    </div>
        
                    <div class="form-group">
                        <label>Responsable / creador</label>
                        <input class="form-control" @bind="newCount.ResponsibleBy" />
                    </div>
        
                    <div class="form-group full">
                        <label>Notas / alcance</label>
                        <textarea class="form-control" rows="3" @bind="newCount.Notes"></textarea>
                    </div>
                </div>
        
                <button class="btn btn-success w-100 mt-2" @onclick="CreateAsync">
                    Crear toma física
                </button>
            </article>
    }
    else
    {
        <article class="tf-form-card">
            <h3>Programar toma física</h3>
            <p>Tu rol no tiene permiso para crear campañas. Solo puedes consultar tus tomas y tus pendientes.</p>
            <div class="tf-empty">Permiso requerido para crear: PhysicalCounts.Create</div>
        </article>
    }

    <article class="tf-list-card">
        <div class="tf-card-title">
            <div>
                <h3>Campañas registradas</h3>
                <p>Ingresa a cada toma para ver usuarios, avance, pendientes y conciliación.</p>
            </div>

            <input class="form-control tf-search"
                   placeholder="Buscar toma, sede, responsable..."
                   @bind="searchText"
                   @bind:event="oninput" />
        </div>

        @if (isLoading)
        {
            <div class="tf-empty">Cargando tomas físicas...</div>
        }
        else if (!FilteredCounts.Any())
        {
            <div class="tf-empty">No hay tomas físicas registradas.</div>
        }
        else
        {
            <div class="tf-table-wrapper">
                <table class="tf-table">
                    <thead>
                        <tr>
                            <th>Toma</th>
                            <th>Sede</th>
                            <th>Estado</th>
                            <th>Fecha inicio</th>
                            <th>Fecha cierre</th>
                            <th>Responsable</th>
                            <th>Herramientas</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredCounts)
                        {
                            <tr>
                                <td>
                                    <strong>@item.CountNumber</strong>
                                    <small>@item.Notes</small>
                                </td>

                                <td>
                                    <strong>@item.BranchCode</strong>
                                    <small>@item.BranchName</small>
                                </td>

                                <td>
                                    <span class="@GetStatusClass(item.Status)">
                                        @item.StatusLabel
                                    </span>
                                </td>

                                <td>@FormatDate(item.StartedAt)</td>
                                <td>@FormatDate(item.FinishedAt)</td>
                                <td>@item.ResponsibleBy</td>

                                <td>
                                    <small>Total: @item.TotalItems</small>
                                    <small>Encontradas: @item.FoundItems</small>
                                    <small>Faltantes: @item.MissingItems</small>
                                </td>

                                <td>
                                    <div class="row-actions">
                                        <a class="tf-action tf-action-primary" href="@($"/physical-counts/{item.Id}")">
                                            Detalle
                                        </a>

                                        <button class="tf-action tf-action-success" disabled="@(!CanStartPhysicalCount)" @onclick="() => StartAsync(item.Id)">
                                            Iniciar
                                        </button>

                                        <button class="tf-action tf-action-neutral" disabled="@(!CanClosePhysicalCount)" @onclick="() => CompleteAsync(item.Id)">
                                            Cerrar
                                        </button>

                                        <button class="tf-action tf-action-danger" disabled="@(!CanCancelPhysicalCount)" @onclick="() => CancelAsync(item.Id)">
                                            Cancelar
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>
</section>

</PermissionGuard>

