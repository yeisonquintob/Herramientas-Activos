    private IEnumerable<LocationItem> AvailableLocations =>
        form.BranchId is null
            ? locations
            : locations.Where(x => x.BranchId == form.BranchId);

    private IEnumerable<BranchItem> BranchFilterOptions =>
        IsAllBranchScope()
            ? branches.OrderBy(x => x.Code)
            : branches
                .Where(x => string.Equals(x.Code, AuthSession.BranchCode, StringComparison.OrdinalIgnoreCase) ||
                            (AuthSession.BranchId.HasValue && x.Id == AuthSession.BranchId))
                .OrderBy(x => x.Code);

    private IEnumerable<ToolItem> ScopedTools =>
        AccessScope.FilterTools(
            tools,
            x => x.BranchCode,
            x => x.ResponsiblePersonName);
private IEnumerable<ToolItem> FilteredTools =>
        ScopedTools
            .Where(MatchesSearchFilter)
            .Where(MatchesBranchFilter)
            .Where(MatchesResponsibleFilter)
            .OrderByDescending(x => FindPendingRequestForTool(x.Id) is not null)
            .ThenBy(x => x.InternalCode);

    private IEnumerable<ToolItem> RequestTools =>
        ScopedTools
            .Where(x => string.IsNullOrWhiteSpace(requestSearch) ||
                        x.InternalCode.Contains(requestSearch, StringComparison.OrdinalIgnoreCase) ||
                        x.Name.Contains(requestSearch, StringComparison.OrdinalIgnoreCase) ||
                        (x.SerialNumber ?? string.Empty).Contains(requestSearch, StringComparison.OrdinalIgnoreCase) ||
                        (x.BranchCode ?? string.Empty).Contains(requestSearch, StringComparison.OrdinalIgnoreCase) ||
                        (x.LocationName ?? string.Empty).Contains(requestSearch, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(x => x.OperationalStatus.Equals("Available", StringComparison.OrdinalIgnoreCase))
            .ThenBy(x => FindPendingRequestForTool(x.Id) is not null)
            .ThenBy(x => x.InternalCode)
            .Take(80);

    private ToolItem? SelectedRequestTool =>
        requestForm.ToolId.HasValue
            ? tools.FirstOrDefault(x => x.Id == requestForm.ToolId)
            : null;

    private IEnumerable<LoanRequestItem> PendingLoanRequests =>
        loanRequests
            .Where(x => IsPendingStatus(x.Status))
            .Where(x => x.Items.Any(i => !i.Returned))
            .OrderByDescending(x => x.RequestedAt);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;

        try
        {
            tools = await Api.GetFromJsonAsync<List<ToolItem>>("api/tools/assignment-board") ?? new();
            responsibles = await Api.GetFromJsonAsync<List<ResponsibleItem>>("api/settings/responsibles") ?? new();
            branches = await Api.GetFromJsonAsync<List<BranchItem>>("api/settings/branches") ?? new();
            locations = await Api.GetFromJsonAsync<List<LocationItem>>("api/settings/warehouses") ?? new();
            loanRequests = await Api.GetFromJsonAsync<List<LoanRequestItem>>("api/loans") ?? new();
            users = await Api.GetFromJsonAsync<List<UserItem>>("api/settings/users") ?? new();

            if (!branchFilterInitialized)
            {
                ApplyDefaultBranchFilter();
                branchFilterInitialized = true;
            }
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo cargar la información: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    
    private bool MatchesSearchFilter(ToolItem tool)
    {
        return string.IsNullOrWhiteSpace(search) ||
               Contains(tool.InternalCode, search) ||
               Contains(tool.Name, search) ||
               Contains(tool.SerialNumber, search) ||
               Contains(tool.BranchCode, search) ||
               Contains(tool.LocationName, search) ||
               Contains(tool.ResponsiblePersonName, search);
    }

    private bool IsAllBranchScope()
    {
        return string.IsNullOrWhiteSpace(AuthSession.BranchCode) ||
               AuthSession.BranchCode.Equals("TODAS", StringComparison.OrdinalIgnoreCase) ||
               AuthSession.BranchCode.Equals("ALL", StringComparison.OrdinalIgnoreCase);
    }

    private void ApplyDefaultBranchFilter()
    {
        if (IsAllBranchScope())
        {
            selectedBranchCode = string.Empty;
            selectedBranchSearchText = "Todas las sedes";
            return;
        }

        var branch = branches.FirstOrDefault(x =>
            string.Equals(x.Code, AuthSession.BranchCode, StringComparison.OrdinalIgnoreCase) ||
            (AuthSession.BranchId.HasValue && x.Id == AuthSession.BranchId));

        selectedBranchCode = branch?.Code ?? AuthSession.BranchCode;
        selectedBranchSearchText = branch is null
            ? AuthSession.BranchCode
            : FormatBranchOption(branch);
    }

    private void OnTableBranchSearchInput(ChangeEventArgs args)
    {
        selectedBranchSearchText = args?.ToString() ?? string.Empty;

        if (IsAllBranchScope() &&
            (string.IsNullOrWhiteSpace(selectedBranchSearchText) ||
             selectedBranchSearchText.Equals("Todas las sedes", StringComparison.OrdinalIgnoreCase)))
        {
            selectedBranchCode = string.Empty;
            selectedBranchSearchText = "Todas las sedes";
            return;
        }

        if (!IsAllBranchScope() && string.IsNullOrWhiteSpace(selectedBranchSearchText))
        {
            ApplyDefaultBranchFilter();
            return;
        }

        var branch = ResolveBranchFilterOption(selectedBranchSearchText);

        if (branch is not null)
        {
            selectedBranchCode = branch.Code;
            selectedBranchSearchText = FormatBranchOption(branch);
            return;
        }

        selectedBranchCode = selectedBranchSearchText;
    }

    private void OnTableResponsibleSearchInput(ChangeEventArgs args)
    {
        selectedResponsibleSearchText = args?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(selectedResponsibleSearchText) ||
            selectedResponsibleSearchText.Equals("Todos los usuarios", StringComparison.OrdinalIgnoreCase))
        {
            selectedResponsibleId = string.Empty;
            selectedResponsibleSearchText = "Todos los usuarios";
            return;
        }

        if (selectedResponsibleSearchText.Equals("Sin responsable", StringComparison.OrdinalIgnoreCase))
        {
            selectedResponsibleId = "SIN_RESPONSABLE";
            return;
        }

        var responsible = ResolveResponsible(selectedResponsibleSearchText);

        if (responsible is not null)
        {
            selectedResponsibleId = responsible.Id.ToString();
            selectedResponsibleSearchText = FormatResponsibleOption(responsible);
            return;
        }

        selectedResponsibleId = string.Empty;
    }

    private BranchItem? ResolveBranchFilterOption(string value)
    {
        return BranchFilterOptions.FirstOrDefault(x =>
            string.Equals(FormatBranchOption(x), value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Code, value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Name, value, StringComparison.OrdinalIgnoreCase));
    }

    private ResponsibleItem? ResolveResponsible(string value)
    {
        return responsibles.FirstOrDefault(x =>
            string.Equals(FormatResponsibleOption(x), value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.FullName, value, StringComparison.OrdinalIgnoreCase) ||
            Contains(x.FullName, value) ||
            Contains(x.Position, value));
    }

    private bool MatchesBranchFilter(ToolItem tool)
    {
        if (!IsAllBranchScope() &&
            !string.Equals(tool.BranchCode, AuthSession.BranchCode, StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        var value = selectedBranchCode;

        if (string.IsNullOrWhiteSpace(value) &&
            !selectedBranchSearchText.Equals("Todas las sedes", StringComparison.OrdinalIgnoreCase))
        {
            value = selectedBranchSearchText;
        }

        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        var branch = branches.FirstOrDefault(x =>
            string.Equals(x.Code, tool.BranchCode, StringComparison.OrdinalIgnoreCase));

        return Contains(tool.BranchCode, value) ||
               Contains(branch?.Name, value) ||
               Contains(branch is null ? null : FormatBranchOption(branch), value);
    }

    private bool MatchesResponsibleFilter(ToolItem tool)
    {
        if (string.IsNullOrWhiteSpace(selectedResponsibleId) &&
            (string.IsNullOrWhiteSpace(selectedResponsibleSearchText) ||
             selectedResponsibleSearchText.Equals("Todos los usuarios", StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }

        if (selectedResponsibleId == "SIN_RESPONSABLE" ||
            selectedResponsibleSearchText.Contains("sin responsable", StringComparison.OrdinalIgnoreCase))
        {
            return tool.ResponsiblePersonId is null;
        }

        if (!string.IsNullOrWhiteSpace(selectedResponsibleId) &&
            tool.ResponsiblePersonId.HasValue &&
            tool.ResponsiblePersonId.ToString() == selectedResponsibleId)
        {
            return true;
        }

        return Contains(tool.ResponsiblePersonName, selectedResponsibleSearchText) ||
               Contains(tool.ResponsiblePosition, selectedResponsibleSearchText);
    }

    private static string FormatBranchOption(BranchItem branch)
    {
        return $"{branch.Code} - {branch.Name}";
    }

    private static string FormatResponsibleOption(ResponsibleItem responsible)
    {
        return string.IsNullOrWhiteSpace(responsible.Position)
            ? responsible.FullName
            : $"{responsible.FullName} - {responsible.Position}";
    }

    private static bool Contains(string? source, string value)
    {
        return !string.IsNullOrWhiteSpace(source)
            && source.Contains(value, StringComparison.OrdinalIgnoreCase);
    }


    private string GetMovementTitle()
    {
        return form.AssignmentType == "Warehouse" ? "Regresar activo fijo" : "Nueva asignación";
    }

    private void OpenHistory()
    {

        if (!CanViewAssignmentHistory)
        {
            ShowError("No tienes permiso para ver historial de asignaciones.");
            return;
        }

        var query = new List<string>();

        if (!string.IsNullOrWhiteSpace(historyResponsibleId))
        {
            query.Add($"responsiblePersonId={Uri.EscapeDataString(historyResponsibleId)}");
        }

        if (!string.IsNullOrWhiteSpace(historySearch))
        {
            query.Add($"q={Uri.EscapeDataString(historySearch)}");
        }

        var url = query.Any()
            ? $"/asset-assignment-history?{string.Join("&", query)}"
            : "/asset-assignment-history";

        NavigationManager.NavigateTo(url);
    }

    private void LoadSelectedTool()
    {
        var tool = tools.FirstOrDefault(x => x.Id == form.ToolId);

        if (tool is not null)
        {
            form.BranchId = tool.BranchId;
            form.LocationId = tool.LocationId;
            form.ResponsiblePersonId = tool.ResponsiblePersonId;

            assignmentToolSearchText = FormatToolOption(tool);

            var responsible = responsibles.FirstOrDefault(x => x.Id == tool.ResponsiblePersonId);
            assignmentResponsibleSearchText = responsible is null
                ? tool.ResponsiblePersonName ?? string.Empty
                : FormatResponsibleOption(responsible);

            var branch = branches.FirstOrDefault(x => x.Id == tool.BranchId);
            assignmentBranchSearchText = branch is null
                ? tool.BranchCode ?? string.Empty
                : FormatBranchOption(branch);

            var location = locations.FirstOrDefault(x => x.Id == tool.LocationId);
            assignmentLocationSearchText = location is null
                ? tool.LocationName ?? string.Empty
                : FormatLocationOption(location);
        }
    }

    private void SelectForAssignment(ToolItem tool)
    {

        if (!CanAssignAsset)
        {
            ShowError("No tienes permiso para realizar asignación directa.");
            return;
        }

        if (!CanDirectAssign)
        {
            ShowError("No tienes permiso para realizar asignación directa.");
            return;
        }

        form.ToolId = tool.Id;
        form.AssignmentType = "Responsible";
        form.BranchId = tool.BranchId;
        form.LocationId = tool.LocationId;
        form.ResponsiblePersonId = tool.ResponsiblePersonId;
        form.AssignmentDate = DateTime.Today;
        form.Observation = $"Asignación del activo {tool.InternalCode}.";

        LoadSelectedTool();
    }

    private void SelectForReturn(ToolItem tool)
    {

        if (!CanReturnAsset)
        {
            ShowError("No tienes permiso para regresar activos al taller o almacén.");
            return;
        }

        if (!CanReturnAssignment)
        {
            ShowError("No tienes permiso para regresar activos al taller o almacén.");
            return;
        }

        form.ToolId = tool.Id;
        form.AssignmentType = "Warehouse";
        form.BranchId = tool.BranchId;
        form.LocationId = tool.LocationId;
        form.ResponsiblePersonId = null;
        form.AssignmentDate = DateTime.Today;
        form.Observation = $"Regreso de activo fijo {tool.InternalCode} a almacén/taller.";

        LoadSelectedTool();
        assignmentResponsibleSearchText = string.Empty;
    }

    private void OnBranchChanged()
    {
        if (form.LocationId.HasValue &&
            !locations.Any(x => x.Id == form.LocationId && x.BranchId == form.BranchId))
        {
            form.LocationId = null;
        }
    }

    private async Task SaveAsync()
    {

        if (form.AssignmentType == "Responsible" && !CanAssignAsset)
        {
            ShowError("No tienes permiso para confirmar asignaciones directas.");
            return;
        }

        if (form.AssignmentType == "Warehouse" && !CanReturnAsset)
        {
            ShowError("No tienes permiso para regresar activos al taller o almacén.");
            return;
        }

        if (form.ToolId is null)
        {
            ShowError("Debe seleccionar un activo fijo.");
            return;
        }

        if (form.AssignmentType == "Responsible" && form.ResponsiblePersonId is null)
        {
            ShowError("Debe seleccionar un responsable.");
            return;
        }

        if (form.AssignmentType == "Warehouse" && (form.BranchId is null || form.LocationId is null))
        {
            ShowError("Debe seleccionar sede y almacén/taller destino.");
            return;
        }

        isSaving = true;

        var request = new
        {
            assignmentType = form.AssignmentType,
            responsiblePersonId = form.ResponsiblePersonId,
            branchId = form.BranchId,
            locationId = form.LocationId,
            assignmentDate = form.AssignmentDate,
            observation = form.Observation,
            changedBy = AuthSession.AuditUser
        };

        try
        {
            var response = await Api.PatchAsJsonAsync($"api/tools/{form.ToolId}/assign-fixed-asset", request);

            if (!response.IsSuccessStatusCode)
            {
                ShowError(await response.Content.ReadAsStringAsync());
                return;
            }

            ShowSuccess(form.AssignmentType == "Warehouse"
                ? "Activo fijo regresado correctamente."
                : "Asignación confirmada correctamente.");

            ClearForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Error guardando movimiento: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

