@page "/"
@page "/dashboard"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Components.Shared
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Dashboard - NAVI</PageTitle>

<PermissionGuard Permission="Dashboard.View" ModuleName="Dashboard">

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (isLoading && dashboard is null)
{
    <div class="alert alert-info">Cargando dashboard...</div>
}
else if (dashboard is not null)
{
    <section class="dash-web">
        <section class="dash-hero">
            <div>
                <span>Estado</span>
                <p>Control operativo de herramientas, activos, responsables, diferencias, mantenimientos y hojas de vida.</p>
            </div>

            <div class="dash-hero-actions">
                <strong>En progreso</strong>
                <button type="button" @onclick="LoadDashboardAsync" disabled="@isLoading">
                    @(isLoading ? "Actualizando..." : "Actualizar")
                </button>
            </div>
        </section>

        <section class="dash-kpis">
            <article>
                <span>PARTICIPANTES</span>
                <strong>@dashboard.Summary.ActiveResponsibles</strong>
                <small>Usuario / responsable</small>
            </article>

            <article>
                <span>EN PROCESO</span>
                <strong>@GetInProcess()</strong>
                <small>Inventario activo</small>
            </article>

            <article>
                <span>FINALIZADOS</span>
                <strong>@dashboard.Summary.WithLifeRecord</strong>
                <small>Con hoja de vida</small>
            </article>

            <article>
                <span>PENDIENTES</span>
                <strong>@GetPendingTotal()</strong>
                <small>Herramientas por validar</small>
            </article>

            <article>
                <span>DIFERENCIAS</span>
                <strong>@GetDifferences()</strong>
                <small>Conciliación</small>
            </article>

            <article>
                <span>AVANCE</span>
                <strong>@GetAdvancePercent()%</strong>
                <small>@dashboard.Summary.WithLifeRecord de @dashboard.Summary.TotalTools</small>
            </article>
        </section>

        <section class="dash-main-grid">
            <article class="dash-card dash-local">
                <h3>Local de herramientas</h3>

                <div class="dash-list">
                    <div>
                        <span><b class="dash-code">IC-TOT</b>Total herramientas</span>
                        <strong>@dashboard.Summary.TotalTools</strong>
                    </div>

                    <div>
                        <span><b class="dash-code green">IC-DSP</b>Disponibles</span>
                        <strong>@dashboard.Summary.AvailableTools</strong>
                    </div>

                    <div>
                        <span><b class="dash-code blue">IC-ASG</b>Asignadas</span>
                        <strong>@dashboard.Summary.AssignedTools</strong>
                    </div>

                    <div>
                        <span><b class="dash-code cyan">IC-MNT</b>En mantenimiento</span>
                        <strong>@dashboard.Summary.InMaintenanceTools</strong>
                    </div>

                    <div>
                        <span><b class="dash-code yellow">IC-PEN</b>Pendientes validación</span>
                        <strong>@dashboard.Summary.PendingValidationTools</strong>
                    </div>

                    <div>
                        <span><b class="dash-code red">IC-DES</b>Desactivadas / baja</span>
                        <strong>@dashboard.Summary.DisposedTools</strong>
                    </div>
                </div>
            </article>

            <article class="dash-card">
                <div class="dash-card-head">
                    <h3>Mantenimientos realizados</h3>

                    <div class="dash-tabs">
                        <span>Por mes</span>
                        <span class="secondary">Por día</span>
                    </div>
                </div>

                <div class="dash-list">
                    <div><span><b class="dash-code purple">IC-MES</b>Por mes</span><strong>@dashboard.MaintenanceSummary.ThisMonth</strong></div>
                    <div><span><b class="dash-code blue">IC-DIA</b>Por día</span><strong>@dashboard.MaintenanceSummary.Today</strong></div>
                    <div><span><b class="dash-code yellow">IC-PRO</b>En proceso</span><strong>@dashboard.Summary.InMaintenanceTools</strong></div>
                    <div><span><b class="dash-code red">IC-PEN</b>Pendientes</span><strong>@dashboard.Summary.RequiresMaintenance</strong></div>
                    <div><span><b class="dash-code gray">IC-OTH</b>Otras</span><strong>@GetOtherMaintenance()</strong></div>
                </div>
            </article>

            <article class="dash-card dash-metric-card">
                <h3>Herramientas vs activos</h3>

                <div class="dash-metric-dual">
                    <div>
                        <span>Herramientas</span>
                        <strong>@dashboard.Summary.ToolsOnly</strong>
                    </div>

                    <div>
                        <span>Activos fijos</span>
                        <strong>@dashboard.Summary.FixedAssets</strong>
                    </div>
                </div>
            </article>

            <article class="dash-card">
                <h3>Distribución de activos fijos</h3>

                <div class="dash-donut-layout">
                    <div class="dash-donut big" style="@GetToolsVsAssetsDonut()">
                        <div class="dash-donut-center">
                            <strong>@dashboard.Summary.TotalTools</strong>
                            <span>Total</span>
                        </div>
                    </div>

                    <div class="dash-legend">
                        <div>
                            <i class="purple"></i>
                            <span>Herramientas</span>
                            <strong>@dashboard.Summary.ToolsOnly</strong>
                            <small>@GetPercentLabel(dashboard.Summary.ToolsOnly, dashboard.Summary.TotalTools)</small>
                        </div>

                        <div>
                            <i class="blue"></i>
                            <span>Activos fijos</span>
                            <strong>@dashboard.Summary.FixedAssets</strong>
                            <small>@GetPercentLabel(dashboard.Summary.FixedAssets, dashboard.Summary.TotalTools)</small>
                        </div>

                        <div>
                            <i class="orange"></i>
                            <span>Sin código AF</span>
                            <strong>@dashboard.Summary.ToolsWithoutFixedAssetCode</strong>
                            <small>@GetPercentLabel(dashboard.Summary.ToolsWithoutFixedAssetCode, dashboard.Summary.TotalTools)</small>
                        </div>
                    </div>
                </div>
            </article>

            <article class="dash-card">
                <h3>Herramientas por sede</h3>

                <div class="dash-branch-chart">
                    @foreach (var item in dashboard.ToolsByBranch.Take(8).Select((value, index) => new { value, index }))
                    {
                        <div>
                            <strong style="@GetBranchBarStyle(item.value.Total, item.index)"></strong>
                            <span>@item.value.BranchCode</span>
                            <small>@item.value.Total</small>
                        </div>
                    }
                </div>
            </article>

            <article class="dash-card dash-table-card">
                <h3>Resumen por sede / responsable</h3>

                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Sede</th>
                            <th>Asignadas</th>
                            <th>Válidas</th>
                            <th>Diferencias</th>
                            <th>Avance</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in dashboard.ToolsByBranch.Take(10))
                        {
                            var assigned = GetBranchAssigned(item.Total);
                            var valid = GetBranchValidated(item.Total);
                            var difference = GetBranchDifferences(item.Total);
                            var percent = GetBranchAdvance(item.Total);

                            <tr>
                                <td>
                                    <strong>@item.BranchCode</strong>
                                    <small>@item.BranchName</small>
                                </td>
                                <td>@assigned</td>
                                <td>@valid</td>
                                <td>
                                    <span class="dash-difference">@difference</span>
                                </td>
                                <td>
                                    <div class="dash-progress">
                                        <span style="@($"width:{percent}%")"></span>
                                    </div>
                                    <small>@percent%</small>
                                </td>
                                <td>
                                    <div class="dash-row-actions">
                                        <a href="/physical-counts">Iniciar</a>
                                        <a href="/physical-counts">Finalizar</a>
                                        <a href="/physical-counts">Pendientes</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </article>

            <article class="dash-card dash-small-chart">
                <h3>Herramientas por mes</h3>

                <div class="dash-donut-layout compact">
                    <div class="dash-donut small blue" style="@GetMaintenanceDonut()">
                        <div class="dash-donut-center">
                            <strong>@dashboard.MaintenanceSummary.Total</strong>
                            <span>Total</span>
                        </div>
                    </div>

                    <div class="dash-legend compact">
                        @if (dashboard.MaintenanceByMonth.Any())
                        {
                            @foreach (var item in dashboard.MaintenanceByMonth.Take(5))
                            {
                                <div>
                                    <i class="blue"></i>
                                    <span>@item.Label</span>
                                    <strong>@item.Count</strong>
                                </div>
                            }
                        }
                        else
                        {
                            <div><i class="blue"></i><span>Asignada</span><strong>@dashboard.Summary.AssignedTools</strong></div>
                            <div><i class="orange"></i><span>Disponible</span><strong>@dashboard.Summary.AvailableTools</strong></div>
                            <div><i class="red"></i><span>Pendientes</span><strong>@dashboard.Summary.PendingValidationTools</strong></div>
                        }
                    </div>
                </div>
            </article>

            <article class="dash-card dash-small-chart">
                <h3>Hojas de vida</h3>

                <div class="dash-donut-layout compact">
                    <div class="dash-donut small orange" style="@GetLifeRecordDonut()">
                        <div class="dash-donut-center">
                            <strong>@dashboard.Summary.WithLifeRecord</strong>
                            <span>Con HV</span>
                        </div>
                    </div>

                    <div class="dash-legend compact">
                        <div><i class="purple"></i><span>Asignada</span><strong>@dashboard.Summary.AssignedTools</strong></div>
                        <div><i class="blue"></i><span>Disponible</span><strong>@dashboard.Summary.AvailableTools</strong></div>
                        <div><i class="orange"></i><span>Herramienta</span><strong>@dashboard.Summary.ToolsOnly</strong></div>
                        <div><i class="cyan"></i><span>MED</span><strong>@dashboard.Summary.InMaintenanceTools</strong></div>
                        <div><i class="gray"></i><span>CALL</span><strong>@dashboard.Summary.LoanedTools</strong></div>
                        <div><i class="red"></i><span>Pendientes</span><strong>@dashboard.Summary.WithoutLifeRecord</strong></div>
                        <div><i class="light"></i><span>Otras</span><strong>@dashboard.LifeRecordCoverage.MissingTechnicalData</strong></div>
                    </div>
                </div>
            </article>

            <article class="dash-card dash-maintenance-day">
                <h3>Mantenimientos por día</h3>

                <div>
                    <strong>@dashboard.MaintenanceSummary.ThisMonth</strong>
                    <span>Por mes</span>
                </div>

                <div>
                    <strong>@dashboard.MaintenanceSummary.Today</strong>
                    <span>Por día</span>
                </div>

                <div>
                    <strong>@dashboard.Summary.RequiresMaintenance</strong>
                    <span>Pendientes</span>
                </div>
            </article>

            <article class="dash-card dash-physical-card">
                <h3>Toma física</h3>
                <p>Acciones rápidas para gestión de toma física y conciliación.</p>

                <div class="dash-actions">
                    <a href="/physical-counts">Volver</a>
                    <a href="/physical-counts">Generar participantes</a>
                    <a href="/physical-counts">Activar toma</a>
                    <a href="/reconciliation">Conciliar</a>
                </div>
            </article>

            <article class="dash-card dash-history-card">
                <h3>Historial reciente</h3>

                @if (dashboard.RecentActivity.Any())
                {
                    <div class="dash-history">
                        @foreach (var item in dashboard.RecentActivity.Take(6))
                        {
                            <div>
                                <strong>@item.Title</strong>
                                <span>@Display(item.Description)</span>
                                <small>@item.RegisteredAt.ToString("dd/MM/yyyy HH:mm") · @Display(item.User)</small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="dash-history empty">
                        <div>
                            <strong>Sin historial reciente</strong>
                            <span>No hay eventos recientes para mostrar.</span>
                            <small>Dashboard operativo</small>
                        </div>
                    </div>
                }
            </article>
        </section>
    </section>
}

</PermissionGuard>

<style>
    .dash-web {
        display: grid;
        gap: .65rem;
        padding-bottom: 1rem;
    }

    .dash-hero {
        background:
            radial-gradient(circle at top right, rgba(208, 32, 224, .32), transparent 34%),
            linear-gradient(135deg, #060009 0%, #250030 45%, #8a0b99 100%);
        color: #fff;
        border-radius: .85rem;
        padding: .78rem 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .8rem;
        box-shadow: 0 .65rem 1.3rem rgba(75, 0, 92, .20);
    }

    .dash-hero span {
        display: block;
        color: #fff;
        font-size: .82rem;
        font-weight: 950;
    }

    .dash-hero p {
        margin: .12rem 0 0;
        color: rgba(255,255,255,.86);
        font-size: .86rem;
        font-weight: 700;
    }

    .dash-hero-actions {
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .dash-hero-actions strong,
    .dash-hero-actions button {
        border-radius: .55rem;
        color: #fff;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        padding: .43rem .65rem;
        font-size: .76rem;
        font-weight: 950;
        white-space: nowrap;
    }

    .dash-kpis {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: .5rem;
    }

    .dash-kpis article {
        background: #fff;
        border-radius: .65rem;
        border: 1px solid #eadff0;
        border-left: 4px solid #7b0d8e;
        padding: .55rem .65rem;
        box-shadow: 0 .25rem .65rem rgba(75,0,92,.055);
    }

    .dash-kpis article:nth-child(2) { border-left-color: #2186d9; }
    .dash-kpis article:nth-child(3) { border-left-color: #16a34a; }
    .dash-kpis article:nth-child(4) { border-left-color: #f0a224; }
    .dash-kpis article:nth-child(5) { border-left-color: #b4232e; }
    .dash-kpis article:nth-child(6) { border-left-color: #7b0d8e; }

    .dash-kpis span {
        display: block;
        color: #1f1427;
        font-size: .62rem;
        font-weight: 950;
    }

    .dash-kpis strong {
        display: block;
        color: #060009;
        font-size: 1.48rem;
        font-weight: 950;
        line-height: 1;
    }

    .dash-kpis small {
        color: #55445f;
        font-size: .64rem;
        font-weight: 750;
    }

    .dash-main-grid {
        display: grid;
        grid-template-columns: 1.05fr 1fr 1fr 1fr 1fr;
        gap: .65rem;
        align-items: stretch;
    }

    .dash-card {
        background: #fff;
        border: 1px solid #eadff0;
        border-radius: .82rem;
        padding: .72rem;
        box-shadow: 0 .28rem .75rem rgba(75,0,92,.055);
        min-height: 132px;
    }

    .dash-card h3 {
        margin: 0 0 .5rem;
        color: #100018;
        font-size: .92rem;
        font-weight: 950;
    }

    .dash-list {
        display: grid;
        gap: .24rem;
    }

    .dash-list div {
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: center;
        gap: .6rem;
        font-size: .76rem;
    }

    .dash-list span {
        color: #22112b;
        display: flex;
        align-items: center;
        gap: .35rem;
    }

    .dash-list strong {
        color: #0d0013;
        font-weight: 950;
    }

    .dash-code {
        min-width: 44px;
        height: 18px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        color: #7b0d8e;
        background: #f8eafa;
        border: 1px solid #ead4f2;
        font-size: .52rem;
        font-weight: 950;
        letter-spacing: -.02rem;
    }

    .dash-code.green { color: #118243; background: #ecfdf3; border-color: #bbf7d0; }
    .dash-code.blue { color: #176fb8; background: #eef6ff; border-color: #bfdbfe; }
    .dash-code.cyan { color: #0e7490; background: #ecfeff; border-color: #a5f3fc; }
    .dash-code.yellow { color: #a16207; background: #fff8e1; border-color: #fde68a; }
    .dash-code.red { color: #a11524; background: #fff0f1; border-color: #fecdd3; }
    .dash-code.purple { color: #7b0d8e; background: #f8eafa; border-color: #ead4f2; }
    .dash-code.gray { color: #475569; background: #f8fafc; border-color: #e2e8f0; }

    .dash-card-head {
        display: flex;
        justify-content: space-between;
        gap: .5rem;
        align-items: center;
        margin-bottom: .2rem;
    }

    .dash-tabs {
        display: flex;
        gap: .25rem;
    }

    .dash-tabs span {
        background: #7b0d8e;
        color: #fff;
        border-radius: .45rem;
        padding: .25rem .5rem;
        font-size: .68rem;
        font-weight: 950;
    }

    .dash-tabs .secondary {
        background: #f7eef9;
        color: #32103d;
        border: 1px solid #eadff0;
    }

    .dash-metric-dual {
        height: calc(100% - 1.6rem);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .55rem;
        align-items: center;
    }

    .dash-metric-dual div {
        text-align: center;
        border-radius: .7rem;
        background: #fbf6fd;
        border: 1px solid #eadff0;
        padding: .6rem;
    }

    .dash-metric-dual span {
        display: block;
        color: #564260;
        font-size: .72rem;
        font-weight: 850;
    }

    .dash-metric-dual strong {
        display: block;
        color: #060009;
        font-size: 2rem;
        font-weight: 950;
        line-height: 1;
        margin-top: .2rem;
    }

    .dash-donut-layout {
        display: grid;
        grid-template-columns: 128px 1fr;
        align-items: center;
        gap: .65rem;
    }

    .dash-donut-layout.compact {
        grid-template-columns: 110px 1fr;
    }

    .dash-donut {
        border-radius: 50%;
        position: relative;
        display: grid;
        place-items: center;
        box-shadow: inset 0 0 0 1px rgba(75,0,92,.09);
    }

    .dash-donut.big {
        width: 120px;
        height: 120px;
    }

    .dash-donut.small {
        width: 96px;
        height: 96px;
    }

    .dash-donut::after {
        content: "";
        position: absolute;
        inset: 25px;
        border-radius: 50%;
        background: #fff;
        box-shadow: inset 0 0 0 1px #eadff0;
    }

    .dash-donut.small::after {
        inset: 21px;
    }

    .dash-donut-center {
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .dash-donut-center strong {
        display: block;
        color: #07000d;
        font-size: 1.25rem;
        font-weight: 950;
        line-height: 1;
    }

    .dash-donut-center span {
        display: block;
        margin-top: .2rem;
        color: #5d4a67;
        font-size: .58rem;
        font-weight: 850;
    }

    .dash-legend {
        display: grid;
        gap: .32rem;
        font-size: .72rem;
    }

    .dash-legend.compact {
        font-size: .68rem;
        gap: .24rem;
    }

    .dash-legend div {
        display: grid;
        grid-template-columns: 9px 1fr auto auto;
        align-items: center;
        gap: .32rem;
    }

    .dash-legend.compact div {
        grid-template-columns: 9px 1fr auto;
    }

    .dash-legend i {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .dash-legend .purple { background: #7b0d8e; }
    .dash-legend .blue { background: #2186d9; }
    .dash-legend .orange { background: #f0a224; }
    .dash-legend .red { background: #b4232e; }
    .dash-legend .cyan { background: #0ea5e9; }
    .dash-legend .gray { background: #64748b; }
    .dash-legend .light { background: #c4b5fd; }

    .dash-legend span {
        color: #2a1734;
        font-weight: 800;
    }

    .dash-legend strong {
        color: #0a0010;
        font-weight: 950;
    }

    .dash-legend small {
        color: #66536f;
        font-weight: 850;
    }

    .dash-branch-chart {
        height: 122px;
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: .42rem;
        align-items: end;
        border-left: 1px solid #eadff0;
        border-bottom: 1px solid #eadff0;
        padding: .2rem .25rem 0;
    }

    .dash-branch-chart div {
        height: 100%;
        display: grid;
        align-items: end;
        text-align: center;
    }

    .dash-branch-chart strong {
        display: block;
        min-height: 8px;
        border-radius: .35rem .35rem 0 0;
    }

    .dash-branch-chart span {
        display: block;
        margin-top: .18rem;
        color: #50405a;
        font-size: .58rem;
        font-weight: 850;
    }

    .dash-branch-chart small {
        display: block;
        color: #6b5a73;
        font-size: .54rem;
        font-weight: 800;
    }

    .dash-table-card {
        grid-column: span 3;
        min-height: 304px;
    }

    .dash-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .72rem;
    }

    .dash-table th {
        color: #160020;
        border-bottom: 1px solid #d9cce3;
        padding: .32rem;
        font-size: .68rem;
        text-align: left;
    }

    .dash-table td {
        border-bottom: 1px solid #f0e7f5;
        padding: .35rem .32rem;
        vertical-align: middle;
    }

    .dash-table td strong {
        display: block;
        color: #0a0010;
    }

    .dash-table td small {
        color: #5c4a66;
    }

    .dash-difference {
        min-width: 34px;
        display: inline-flex;
        justify-content: center;
        border: 1px solid rgba(180, 35, 46, .35);
        color: #9f1239;
        background: #fff1f2;
        border-radius: .35rem;
        padding: .16rem .3rem;
        font-weight: 950;
    }

    .dash-progress {
        height: 8px;
        border-radius: 999px;
        background: #ffffff;
        border: 1px solid #eadff0;
        overflow: hidden;
    }

    .dash-progress span {
        display: block;
        height: 100%;
        background: linear-gradient(90deg, #7b0d8e 0%, #2186d9 100%);
    }

    .dash-row-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .24rem;
    }

    .dash-row-actions a {
        color: #076678;
        border: 1px solid #9dd9e5;
        background: #f0fdff;
        text-decoration: none;
        border-radius: .35rem;
        padding: .16rem .3rem;
        font-size: .62rem;
