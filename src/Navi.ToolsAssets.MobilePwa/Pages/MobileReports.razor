    private static string Csv(string? value)
    {
        var safe = (value ?? string.Empty).Replace("\"", "\"\"");
        return "\"" + safe + "\"";
    }

    private static string GetBadgeClass(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "mrep-badge";
        }

        if (Contains(value, "cerr") ||
            Contains(value, "final") ||
            Contains(value, "vigente") ||
            Contains(value, "completo") ||
            Contains(value, "ok") ||
            Contains(value, "concili") ||
            Contains(value, "datos") ||
            Contains(value, "disponible") ||
            Contains(value, "assigned") ||
            Contains(value, "asignado"))
        {
            return "mrep-badge ok";
        }

        if (Contains(value, "cancel") ||
            Contains(value, "rechaz") ||
            Contains(value, "baja") ||
            Contains(value, "dañ") ||
            Contains(value, "damaged"))
        {
            return "mrep-badge danger";
        }

        return "mrep-badge warn";
    }

    private static bool IsClosedStatus(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        return Contains(value, "closed") ||
               Contains(value, "cerr") ||
               Contains(value, "finish") ||
               Contains(value, "final") ||
               Contains(value, "complete") ||
               Contains(value, "cancel") ||
               Contains(value, "reject") ||
               Contains(value, "rechaz");
    }

    private static string GetDocumentCategory(DocumentViewItem item)
    {
        var fromDescription = TryGetDescriptionValue(item.Description, "Clasificación");

        if (!string.IsNullOrWhiteSpace(fromDescription))
        {
            return fromDescription;
        }

        return item.DocumentType switch
        {
            "TechnicalDocument" => "Ficha técnica",
            "MaintenanceSupport" => "Evidencia mantenimiento",
            "PhysicalCountEvidence" => "Toma física",
            "DeliveryAct" => "Acta",
            "ReturnAct" => "Acta",
            "Other" => "Factura",
            _ => "Ficha técnica"
        };
    }

    private static string GetDocumentDisplayName(DocumentViewItem item)
    {
        var fromDescription = TryGetDescriptionValue(item.Description, "Nombre");

        return string.IsNullOrWhiteSpace(fromDescription)
            ? item.FileName
            : fromDescription;
    }

    private static string? TryGetDescriptionValue(string? description, string key)
    {
        if (string.IsNullOrWhiteSpace(description))
        {
            return null;
        }

        var token = $"[{key}:";
        var start = description.IndexOf(token, StringComparison.OrdinalIgnoreCase);

        if (start < 0)
        {
            return null;
        }

        start += token.Length;
        var end = description.IndexOf(']', start);

        if (end < 0)
        {
            return null;
        }

        return description[start..end].Trim();
    }

    private static bool Contains(string? source, string value)
    {
        return !string.IsNullOrWhiteSpace(source)
            && source.Contains(value, StringComparison.OrdinalIgnoreCase);
    }

    private static bool Same(string? left, string? right)
    {
        return string.Equals(Normalize(left), Normalize(right), StringComparison.OrdinalIgnoreCase);
    }

    private static string Normalize(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value.Trim()
            .ToUpperInvariant()
            .Replace("Á", "A")
            .Replace("É", "E")
            .Replace("Í", "I")
            .Replace("Ó", "O")
            .Replace("Ú", "U")
            .Replace("Ü", "U")
            .Replace("Ñ", "N");
    }

    private static string Show(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "—" : value;
    }

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            : "—";
    }

    private static string FormatBytes(long value)
    {
        if (value >= 1024 * 1024)
        {
            return $"{value / 1024d / 1024d:0.00} MB";
        }

        if (value >= 1024)
        {
            return $"{value / 1024d:0.00} KB";
        }

        return $"{value} bytes";
    }

    private static string FormatMoney(decimal? value)
    {
        return value is null ? "$0" : $"${value.Value:N0}";
    }

