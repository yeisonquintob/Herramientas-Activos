@page "/asset-assignment"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@using Navi.ToolsAssets.Admin.Services.Auth
@inject NavigationManager NavigationManager
@inject WebAuthSessionService AuthSession

<PageTitle>Asignar AF - NAVI</PageTitle>

<PermissionGuard Permission="AssetAssignment.View" ModuleName="Asignar AF">

<section class="af-banner">
    <div>
        <span class="af-pill">ACTIVOS FIJOS</span>
        <h2>Asignar AF</h2>
        <p>Solicita, aprueba, asigna o regresa activos fijos con trazabilidad de préstamo y responsable.</p>
    </div>

    <div class="af-banner-side">
        <div class="af-status-box">
            <span>Activos</span>
            <strong>@FilteredTools.Count() visibles</strong>
        </div>

        <button class="btn btn-sm btn-outline-light" @onclick="LoadAsync">
            Actualizar
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="@messageClass">@message</div>
}

<section class="af-grid">
    <aside class="af-left-stack">
        <div class="af-card">
            <h3>@GetMovementTitle()</h3>

            <div class="mb-2">
                <label class="form-label">Activo fijo</label>
                <InputSelect class="form-select" @bind-Value="form.ToolId" @bind-Value:after="LoadSelectedTool">
                    <option value="">Seleccione activo</option>
                    @foreach (var tool in tools.OrderBy(x => x.InternalCode))
                    {
                        <option value="@tool.Id">@tool.InternalCode - @tool.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-2">
                <label class="form-label">Tipo de movimiento</label>
                <InputSelect class="form-select" @bind-Value="form.AssignmentType">
                    <option value="Responsible">Asignar a usuario/responsable</option>
                    <option value="Warehouse">Regresar a almacén/taller</option>
                </InputSelect>
            </div>

            @if (form.AssignmentType == "Responsible")
            {
                <div class="mb-2">
                    <label class="form-label">Usuario / Responsable</label>
                    <InputSelect class="form-select" @bind-Value="form.ResponsiblePersonId">
                        <option value="">Seleccione responsable</option>
                        @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                        {
                            <option value="@responsible.Id">@responsible.FullName - @responsible.Position</option>
                        }
                    </InputSelect>
                </div>
            }

            @if (form.AssignmentType == "Warehouse")
            {
                <div class="mb-2">
                    <label class="form-label">Sede destino</label>
                    <InputSelect class="form-select" @bind-Value="form.BranchId" @bind-Value:after="OnBranchChanged">
                        <option value="">Seleccione sede</option>
                        @foreach (var branch in branches.OrderBy(x => x.Code))
                        {
                            <option value="@branch.Id">@branch.Code - @branch.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="mb-2">
                    <label class="form-label">Almacén / Taller destino</label>
                    <InputSelect class="form-select" @bind-Value="form.LocationId">
                        <option value="">Seleccione almacén/taller</option>
                        @foreach (var location in AvailableLocations.OrderBy(x => x.Code))
                        {
                            <option value="@location.Id">@location.Code - @location.Name</option>
                        }
                    </InputSelect>
                </div>
            }

            <div class="mb-2">
                <label class="form-label">
                    @(form.AssignmentType == "Warehouse" ? "Fecha de regreso" : "Fecha de asignación")
                </label>
                <InputDate class="form-control" @bind-Value="form.AssignmentDate" />
            </div>

            <div class="mb-3">
                <label class="form-label">Observación</label>
                <InputTextArea class="form-control" @bind-Value="form.Observation" rows="3" />
            </div>

            <div class="d-grid gap-2">
                @if (form.AssignmentType == "Warehouse")
                {
                    <button class="assign-main assign-main-warning" @onclick="SaveAsync" disabled="@(isSaving || !CanReturnAsset)">
                        @(isSaving ? "Guardando..." : "Confirmar regreso")
                    </button>
                }
                else
                {
                    <button class="assign-main assign-main-primary" @onclick="SaveAsync" disabled="@(isSaving || !CanAssignAsset)">
                        @(isSaving ? "Guardando..." : "Confirmar asignación")
                    </button>
                }

                <button class="assign-main assign-main-neutral" @onclick="ClearForm">
                    Limpiar
                </button>
            </div>
        </div>

        <div class="af-card history-launch-card">
            <span class="history-pill">HISTORIAL</span>
            <h3>Historial por usuario</h3>
            <p>Consulta en una vista completa los activos asignados, entregados, regresados y sus detalles.</p>

            <div class="mb-2">
                <label class="form-label">Usuario / Responsable</label>
                <select class="form-select form-select-sm" @bind="historyResponsibleId">
                    <option value="">Todos los usuarios</option>
                    @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                    {
                        <option value="@responsible.Id">@responsible.FullName</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Buscar</label>
                <input class="form-control form-control-sm"
                       placeholder="Código, activo fijo, serial o detalle..."
                       @bind="historySearch"
                       @bind:event="oninput" />
            </div>

            <button class="btn-open-history" @onclick="OpenHistory">
                Abrir historial de asignaciones
            </button>
        </div>

        <div class="af-card request-card">
            <span class="history-pill request">SOLICITUD</span>
            <h3>Solicitud de asignación</h3>
            <p>Busca una herramienta y solicita que sea asignada a tu usuario. El herramentero la aprueba desde esta misma vista.</p>

            <div class="request-user">
                <span>Solicitante</span>
                <strong>@GetCurrentResponsibleLabel()</strong>
            </div>

            <div class="mb-2">
                <label class="form-label">Buscar herramienta</label>
                <input class="form-control form-control-sm"
                       placeholder="Escriba código, nombre o serial..."
                       @bind="requestSearch"
                       @bind:event="oninput" />
            </div>

            @if (!string.IsNullOrWhiteSpace(requestSearch))
            {
                <div class="request-results">
                    <div class="request-results-title">
                        <span>Resultados filtrados</span>
                        <strong>@RequestTools.Count()</strong>
                    </div>

                    @if (!RequestTools.Any())
                    {
                        <div class="request-result-empty">
                            No se encontraron herramientas con ese criterio.
                        </div>
                    }
                    else
                    {
                        @foreach (var tool in RequestTools.Take(7))
                        {
                            var pending = FindPendingRequestForTool(tool.Id);
                            var isSelected = requestForm.ToolId == tool.Id;

                            <button type="button"
                                    class="request-result-card @(isSelected ? "selected" : "")"
                                    @onclick="() => SelectRequestTool(tool)">
                                <span>
                                    <strong>@tool.InternalCode</strong>
                                    <small>@tool.Name</small>
                                    <small>@Show(tool.BranchCode) · @Show(tool.LocationName)</small>
                                </span>

                                <em class="@GetRequestAvailabilityClass(tool, pending)">
                                    @(pending is not null ? "Con solicitud" : GetStatusLabel(tool.OperationalStatus))
                                </em>
                            </button>
                        }
                    }
                </div>
            }

            <div class="mb-2">
                <label class="form-label">Herramienta / activo</label>
                <InputSelect class="form-select form-select-sm" @bind-Value="requestForm.ToolId">
                    <option value="">Seleccione activo</option>
                    @foreach (var tool in RequestTools)
                    {
                        <option value="@tool.Id">@tool.InternalCode - @tool.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-2">
                <label class="form-label">Fecha estimada de devolución</label>
                <InputDate class="form-control form-control-sm" @bind-Value="requestForm.ExpectedReturnAt" />
            </div>

            <div class="mb-3">
                <label class="form-label">Observación</label>
                <InputTextArea class="form-control form-control-sm" rows="2" @bind-Value="requestForm.Notes" />
            </div>

            <button class="btn-request-assignment"
                    @onclick="SubmitSelfAssignmentRequestAsync"
                    disabled="@(isSaving || AuthSession.ResponsiblePersonId is null)">
                Solicitud de asignación
            </button>
        </div>

        <div class="af-card pending-card">
            <span class="history-pill approve">APROBACIÓN</span>
            <h3>Solicitudes pendientes</h3>

            @if (!PendingLoanRequests.Any())
            {
                <div class="pending-empty">No hay solicitudes pendientes.</div>
            }
            else
            {
                <div class="pending-list">
                    @foreach (var request in PendingLoanRequests.Take(6))
                    {
                        var item = request.Items.FirstOrDefault();

                        <article>
                            <div>
                                <strong>@request.LoanNumber</strong>
                                <span>@Show(item?.ToolInternalCode) - @Show(item?.ToolName)</span>
                                <small>Solicita: @Show(request.CreatedBy) · @ShowDate(request.RequestedAt)</small>
                            </div>

                            <button @onclick="() => ApproveRequestAsync(request)"
                                    disabled="@(isSaving || !CanApproveAssignmentRequest)">
                                Aprobar
                            </button>
                        </article>
                    }
                </div>
            }
        </div>
    </aside>

    <section class="af-card">
        <div class="af-table-header">
            <div>
                <h3>Activos asignables</h3>
                <p>Consulta el estado actual, filtra por usuario y registra asignaciones, regresos o aprobaciones.</p>
            </div>

            <div class="af-filters">
                <input class="form-control form-control-sm" placeholder="Buscar código, nombre..." @bind="search" @bind:event="oninput" />

                <select class="form-select form-select-sm" @bind="selectedResponsibleId">
                    <option value="">Todos los usuarios</option>
                    <option value="SIN_RESPONSABLE">Sin responsable</option>
                    @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                    {
                        <option value="@responsible.Id">@responsible.FullName</option>
                    }
                </select>
            </div>
        </div>

        @if (isLoading)
        {
            <p>Cargando activos...</p>
        }
        else if (!FilteredTools.Any())
        {
            <div class="alert alert-info">No hay activos para los filtros seleccionados.</div>
        }
        else
        {
            <table class="table table-hover align-middle af-table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Activo</th>
                        <th>Sede</th>
                        <th>Ubicación</th>
                        <th>Usuario / Responsable</th>
                        <th>Estado</th>
                        <th>Solicitud</th>
                        <th>Fecha asignación</th>
                        <th>Fecha entrega</th>
                        <th class="text-end">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tool in FilteredTools)
                    {
                        var pending = FindPendingRequestForTool(tool.Id);

                        <tr>
                            <td><strong>@tool.InternalCode</strong></td>
                            <td>
                                <div>@tool.Name</div>
                                <small class="text-muted">@Show(tool.SerialNumber)</small>
                            </td>
                            <td>@Show(tool.BranchCode)</td>
                            <td>@Show(tool.LocationName)</td>
                            <td>
                                <div>@Show(tool.ResponsiblePersonName)</div>
                                <small class="text-muted">@Show(tool.ResponsiblePosition)</small>
                            </td>
                            <td><span class="@GetStatusBadge(tool.OperationalStatus)">@GetStatusLabel(tool.OperationalStatus)</span></td>
                            <td>
                                @if (pending is null)
                                {
                                    <span class="request-state empty">Sin solicitud</span>
                                }
                                else
                                {
                                    <span class="request-state pending">@pending.LoanNumber</span>
                                }
                            </td>
                            <td>@ShowDate(tool.LastAssignmentDate)</td>
                            <td>@ShowDate(tool.LastReturnDate)</td>
                            <td class="text-end">
                                <div class="assignment-actions">
                                    <button class="assign-action assign-action-primary" @onclick="() => SelectForAssignment(tool)">
                                        Asignar
                                    </button>

                                    <button class="assign-action assign-action-success"
                                            @onclick="() => ApproveRequestAsync(pending)"
                                            disabled="@(pending is null || !CanApproveAssignmentRequest || isSaving)">
                                        Aprobar
                                    </button>

                                    <button class="assign-action assign-action-warning" @onclick="() => SelectForReturn(tool)">
                                        Regresar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</section>

</PermissionGuard>

