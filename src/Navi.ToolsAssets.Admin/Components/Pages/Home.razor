@page "/"
@page "/dashboard"
@rendermode InteractiveServer

@using System.Globalization
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Components.Shared
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Dashboard - NAVI</PageTitle>

<PermissionGuard Permission="Dashboard.View" ModuleName="Dashboard">

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (isLoading && dashboard is null)
{
    <div class="alert alert-info">Cargando dashboard...</div>
}
else if (dashboard is not null)
{
    <section class="dash-board dash-board-v5">
        <section class="dash-hero">
            <div>
                <span>Estado</span>
                <h2>Dashboard</h2>
                <p>Control operativo de inventario, responsables, activos, mantenimientos, diferencias y cierre de toma física.</p>
            </div>

            <div class="dash-hero-actions">
                <strong>En progreso</strong>
                <button type="button" @onclick="LoadDashboardAsync" disabled="@isLoading">
                    @(isLoading ? "Actualizando..." : "Actualizar")
                </button>
            </div>
        </section>

        <section class="dash-kpis">
            <article class="purple">
                <span>Participantes</span>
                <strong>@dashboard.Summary.ActiveResponsibles</strong>
                <small>Usuario / responsable</small>
            </article>

            <article class="cyan">
                <span>En proceso</span>
                <strong>@GetInProcess()</strong>
                <small>Inventario activo</small>
            </article>

            <article class="green">
                <span>Finalizados</span>
                <strong>@dashboard.Summary.WithLifeRecord</strong>
                <small>Con hoja de vida</small>
            </article>

            <article class="yellow">
                <span>Pendientes</span>
                <strong>@GetPendingTotal()</strong>
                <small>Por validar</small>
            </article>

            <article class="red">
                <span>Diferencias</span>
                <strong>@GetDifferences()</strong>
                <small>Conciliación</small>
            </article>

            <article class="purple">
                <span>Avance</span>
                <strong>@GetAdvancePercent()%</strong>
                <small>@dashboard.Summary.WithLifeRecord de @dashboard.Summary.TotalTools</small>
            </article>
        </section>

        <section class="dash-layout">
            <section class="dash-main-left">
                <div class="dash-overview-grid">
                    <article class="dash-card dash-local">
                        <h3>Local de herramientas</h3>

                        <div class="dash-local-list">
                            <div><span><b class="mini-dot green">✓</b>Total herramientas</span><strong>@dashboard.Summary.TotalTools.ToString("N0")</strong></div>
                            <div><span><b class="mini-dot green">✓</b>Disponibles</span><strong>@dashboard.Summary.AvailableTools.ToString("N0")</strong></div>
                            <div><span><b class="mini-dot blue">↗</b>Asignadas</span><strong>@dashboard.Summary.AssignedTools.ToString("N0")</strong></div>
                            <div><span><b class="mini-dot cyan">⚙</b>En mantenimiento</span><strong>@dashboard.Summary.InMaintenanceTools.ToString("N0")</strong></div>
                            <div><span><b class="mini-dot yellow">!</b>Pendientes validación</span><strong>@dashboard.Summary.PendingValidationTools.ToString("N0")</strong></div>
                            <div><span><b class="mini-dot red">×</b>Desactivados / baja</span><strong>@dashboard.Summary.DisposedTools.ToString("N0")</strong></div>
                        </div>
                    </article>

                    <article class="dash-card dash-maintenance">
                        <div class="dash-card-head">
                            <h3>Mantenimientos realizados</h3>

                            <div class="dash-tabs">
                                <button type="button" class="@GetMaintenanceTabClass("month")" @onclick="@(() => SetMaintenanceTab("month"))">Por mes</button>
                                <button type="button" class="@GetMaintenanceTabClass("day")" @onclick="@(() => SetMaintenanceTab("day"))">Por día</button>
                            </div>
                        </div>

                        <div class="dash-maintenance-list">
                            <div><span>@(maintenanceTab == "month" ? "Por mes" : "Por día")</span><strong>@GetSelectedMaintenanceValue()</strong></div>
                            <div><span>En proceso</span><strong>@dashboard.Summary.InMaintenanceTools</strong></div>
                            <div><span>Pendientes</span><strong>@dashboard.Summary.RequiresMaintenance</strong></div>
                            <div><span>Otras</span><strong>@GetOtherStatusTools()</strong></div>
                        </div>
                    </article>

                    <article class="dash-card dash-vs">
                        <h3>Herramientas vs activos</h3>

                        <div class="dash-vs-content">
                            <div class="dash-donut md" style="@GetToolsVsAssetsDonut()">
                                <div>
                                    <strong>@GetToolsVsAssetsTotal().ToString("N0")</strong>
                                    <span>Total</span>
                                </div>
                            </div>

                            <div class="dash-legend compact">
                                <div><i class="purple"></i><span>Herramientas</span><strong>@dashboard.Summary.ToolsOnly</strong><small>@GetPercentLabel(dashboard.Summary.ToolsOnly, GetToolsVsAssetsTotal())</small></div>
                                <div><i class="blue"></i><span>Activos fijos</span><strong>@dashboard.Summary.FixedAssets</strong><small>@GetPercentLabel(dashboard.Summary.FixedAssets, GetToolsVsAssetsTotal())</small></div>
                                <div><i class="orange"></i><span>Sin código Herramientas y AF</span><strong>@dashboard.Summary.ToolsWithoutFixedAssetCode</strong><small>@GetPercentLabel(dashboard.Summary.ToolsWithoutFixedAssetCode, GetToolsVsAssetsTotal())</small></div>
                            </div>
                        </div>
                    </article>
                </div>

                <article class="dash-card dash-table-card">
                    <div class="dash-section-head">
                        <div>
                            <h3>Resumen por sede / responsable</h3>
                            <p>Seguimiento de asignaciones, validaciones, pendientes, diferencias y avance.</p>
                        </div>

                        <span>@dashboard.ToolsByBranch.Count sedes</span>
                    </div>

                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Usuario / Responsable</th>
                                <th>Asignadas</th>
                                <th>Validadas</th>
                                <th>Pendientes</th>
                                <th>Diferencias</th>
                                <th>Avance</th>
                                <th>Acción</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in dashboard.ToolsByBranch.Take(7))
                            {
                                var assigned = GetBranchAssigned(item.Total);
                                var valid = GetBranchValidated(item.Total);
                                var pending = GetBranchPending(item.Total);
                                var difference = GetBranchDifferences(item.Total);
                                var percent = GetBranchAdvance(item.Total);

                                <tr>
                                    <td>
                                        <div class="dash-branch-name">
                                            <strong>@item.BranchName</strong>
                                            <span>@item.BranchCode</span>
                                            <small>Responsable sede</small>
                                        </div>
                                    </td>

                                    <td>@assigned</td>
                                    <td>@valid</td>
                                    <td><span class="dash-pending">@pending</span></td>
                                    <td><span class="dash-difference">@difference</span></td>

                                    <td>
                                        <div class="dash-progress">
                                            <span style="@GetProgressStyle(percent)"></span>
                                        </div>
                                        <small>@percent%</small>
                                    </td>

                                    <td>
                                        <div class="dash-row-actions">
                                            <button type="button">Iniciar</button>
                                            <button type="button">Finalizar</button>
                                            <button type="button">Pendientes</button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <div class="dash-pending-panel">
                        <div>
                            <h3>@GetPendingPanelTitle()</h3>
                            <p>Herramientas o activos pendientes de validación por el participante.</p>
                        </div>

                        <button type="button">Cerrar</button>
                    </div>
                </article>
            </section>

            <section class="dash-main-right">
                <article class="dash-card dash-branch">
                    <div class="dash-section-head">
                        <div>
                            <h3>Herramientas por sede</h3>
                            <p>Distribución proporcional por sede.</p>
                        </div>

                        <span>Máx. @GetMaxBranch()</span>
                    </div>

                    <div class="dash-branch-chart">
                        <div class="dash-axis">
                            <span>100</span>
                            <span>75</span>
                            <span>50</span>
                            <span>25</span>
                            <span>0</span>
                        </div>

                        <div class="dash-branch-bars">
                            @foreach (var item in GetBranchChartItems())
                            {
                                <div class="dash-branch-bar-item" title="@($"{item.Branch.BranchCode} - {item.Branch.BranchName}: {item.Branch.Total}")">
                                    <strong style="@GetBranchBarStyle(item.Branch.Total, item.Index)">
                                        <em>@item.Branch.Total</em>
                                    </strong>
                                    <span>@item.Branch.BranchCode</span>
                                    <small>@ShortName(item.Branch.BranchName)</small>
                                </div>
                            }
                        </div>
                    </div>
                </article>

                <div class="dash-chart-grid">
                    <article class="dash-card dash-donut-card">
                        <h3>Distribución de activos fijos</h3>

                        <div class="dash-donut-row">
                            <div class="dash-donut lg" style="@GetToolsVsAssetsDonut()">
                                <div>
                                    <strong>@GetToolsVsAssetsTotal().ToString("N0")</strong>
                                    <span>Total</span>
                                </div>
                            </div>

                            <div class="dash-legend">
                                <div><i class="purple"></i><span>Herramientas</span><strong>@dashboard.Summary.ToolsOnly</strong><small>@GetPercentLabel(dashboard.Summary.ToolsOnly, GetToolsVsAssetsTotal())</small></div>
                                <div><i class="blue"></i><span>Activos fijos</span><strong>@dashboard.Summary.FixedAssets</strong><small>@GetPercentLabel(dashboard.Summary.FixedAssets, GetToolsVsAssetsTotal())</small></div>
                                <div><i class="orange"></i><span>Sin código Herramientas y AF</span><strong>@dashboard.Summary.ToolsWithoutFixedAssetCode</strong><small>@GetPercentLabel(dashboard.Summary.ToolsWithoutFixedAssetCode, GetToolsVsAssetsTotal())</small></div>
                            </div>
                        </div>
                    </article>

                    <article class="dash-card dash-donut-card">
                        <h3>Herramientas por mes</h3>

                        <div class="dash-donut-row">
                            <div class="dash-donut lg" style="@GetStatusDonut()">
                                <div>
                                    <strong>@GetStatusDonutTotal().ToString("N0")</strong>
                                    <span>Total</span>
                                </div>
                            </div>

                            <div class="dash-legend">
                                <div><i class="purple"></i><span>Asignada</span><strong>@dashboard.Summary.AssignedTools</strong><small>@GetPercentLabel(dashboard.Summary.AssignedTools, GetStatusDonutTotal())</small></div>
                                <div><i class="blue"></i><span>Disponible</span><strong>@dashboard.Summary.AvailableTools</strong><small>@GetPercentLabel(dashboard.Summary.AvailableTools, GetStatusDonutTotal())</small></div>
                                <div><i class="orange"></i><span>Pendientes</span><strong>@dashboard.Summary.PendingValidationTools</strong><small>@GetPercentLabel(dashboard.Summary.PendingValidationTools, GetStatusDonutTotal())</small></div>
                                <div><i class="red"></i><span>Técnico</span><strong>@dashboard.Summary.InMaintenanceTools</strong><small>@GetPercentLabel(dashboard.Summary.InMaintenanceTools, GetStatusDonutTotal())</small></div>
                                <div><i class="gray"></i><span>Otras</span><strong>@GetOtherStatusTools()</strong><small>@GetPercentLabel(GetOtherStatusTools(), GetStatusDonutTotal())</small></div>
                            </div>
                        </div>
                    </article>

                    <article class="dash-card dash-donut-card">
                        <h3>Hojas de vida</h3>

                        <div class="dash-donut-row">
                            <div class="dash-donut lg" style="@GetLifeRecordDonut()">
                                <div>
                                    <strong>@GetLifeRecordDonutTotal().ToString("N0")</strong>
                                    <span>Total</span>
                                </div>
                            </div>

                            <div class="dash-legend">
                                <div><i class="purple"></i><span>Con hoja</span><strong>@dashboard.Summary.WithLifeRecord</strong><small>@GetPercentLabel(dashboard.Summary.WithLifeRecord, GetLifeRecordDonutTotal())</small></div>
                                <div><i class="blue"></i><span>Sin hoja</span><strong>@dashboard.Summary.WithoutLifeRecord</strong><small>@GetPercentLabel(dashboard.Summary.WithoutLifeRecord, GetLifeRecordDonutTotal())</small></div>
                                <div><i class="orange"></i><span>Incompletos</span><strong>@dashboard.LifeRecordCoverage.MissingTechnicalData</strong><small>@GetPercentLabel(dashboard.LifeRecordCoverage.MissingTechnicalData, GetLifeRecordDonutTotal())</small></div>
                                <div><i class="red"></i><span>Activos fijos</span><strong>@dashboard.Summary.FixedAssets</strong><small>@GetPercentLabel(dashboard.Summary.FixedAssets, GetLifeRecordDonutTotal())</small></div>
                                <div><i class="gray"></i><span>Otras</span><strong>@GetOtherLifeRecords()</strong><small>@GetPercentLabel(GetOtherLifeRecords(), GetLifeRecordDonutTotal())</small></div>
                            </div>
                        </div>
                    </article>
                </div>

                <article class="dash-card dash-day">
                    <h3>Mantenimientos por día</h3>

                    <div class="dash-day-metrics">
                        <div><strong>@dashboard.MaintenanceSummary.ThisMonth</strong><span>Por mes</span></div>
                        <div><strong>@dashboard.MaintenanceSummary.Today</strong><span>Por día</span></div>
                        <div><strong>@dashboard.Summary.RequiresMaintenance</strong><span>Pendientes</span></div>
                    </div>

                    <div class="dash-physical-row">
                        <div>
                            <h3>Toma física</h3>
                            <p>Acciones rápidas para control y cierre.</p>
                        </div>

                        <div class="dash-actions">
                            <a href="/physical-counts">Volver</a>
                            <a href="/physical-counts">Generar participantes</a>
                            <a href="/physical-counts">Activar toma</a>
                            <a href="/reconciliation">Cerrar toma</a>
                        </div>
                    </div>
                </article>
            </section>
        </section>

        <section class="dash-card dash-history">
            <div class="dash-section-head">
                <div>
                    <h3>Histórico de procesos</h3>
                    <p>Últimos movimientos, desarrollos, validaciones y eventos registrados en NAVI.</p>
                </div>

                <span>@dashboard.RecentActivity.Count eventos</span>
            </div>

            @if (dashboard.RecentActivity.Any())
            {
                <div class="dash-history-list">
                    @foreach (var item in dashboard.RecentActivity.OrderByDescending(x => x.RegisteredAt).Take(8))
                    {
                        <article>
                            <div class="dash-history-icon">@GetActivityIcon(item.EventType)</div>
                            <div>
                                <strong>@item.Title</strong>
                                <p>@Display(item.Description)</p>
                                <small>@Display(item.ToolInternalCode) · @FormatDateTime(item.RegisteredAt) · @Display(item.User)</small>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <div class="dash-history-list">
                    <article>
                        <div class="dash-history-icon">📊</div>
                        <div>
                            <strong>Dashboard ejecutivo actualizado</strong>
                            <p>Se consolidaron indicadores, gráficos de porcentaje, barras por sede y resumen operativo.</p>
                            <small>NAVI · Desarrollo visual</small>
                        </div>
                    </article>

                    <article>
                        <div class="dash-history-icon">🧰</div>
                        <div>
                            <strong>Inventario y hoja de vida integrados</strong>
                            <p>Se agrupan activos, responsables, disponibilidad, mantenimientos y trazabilidad.</p>
                            <small>NAVI · Gestión de activos</small>
                        </div>
                    </article>

                    <article>
                        <div class="dash-history-icon">⚖️</div>
                        <div>
                            <strong>Conciliación y toma física</strong>
                            <p>Se habilita seguimiento de pendientes, diferencias, validaciones y cierre de toma.</p>
                            <small>NAVI · Control operativo</small>
                        </div>
                    </article>
                </div>
            }
        </section>
    </section>
}

</PermissionGuard>

<style>
    .dash-board-v5 {
        display: grid;
        gap: .48rem;
        padding-bottom: .8rem;
    }

    .dash-hero {
        color: #fff;
        border-radius: .85rem;
        padding: .68rem .95rem;
        min-height: 82px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .75rem;
        background: linear-gradient(105deg, #050507 0%, #07070b 34%, #120017 58%, #350040 78%, #710083 100%) !important;
        box-shadow: 0 .55rem 1.2rem rgba(75, 0, 92, .17);
    }

    .dash-hero span {
        display: inline-flex;
        width: fit-content;
        border: 1px solid rgba(255,255,255,.45);
        border-radius: 999px;
        padding: .15rem .55rem;
        font-size: .64rem;
        font-weight: 950;
        letter-spacing: .04rem;
        text-transform: uppercase;
    }

    .dash-hero h2 {
        margin: .18rem 0 .04rem;
        color: #fff;
        font-size: 1.2rem;
        font-weight: 950;
        line-height: 1.08;
    }

    .dash-hero p {
        margin: 0;
        color: rgba(255,255,255,.88);
        font-size: .82rem;
        font-weight: 650;
    }

    .dash-hero-actions {
        width: 150px;
        display: grid;
        gap: .36rem;
    }

    .dash-hero-actions strong,
    .dash-hero-actions button {
        min-height: 32px;
        border-radius: .55rem;
        color: #fff;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.34);
        padding: .32rem .55rem;
        font-size: .7rem;
        font-weight: 950;
        text-align: center;
    }

    .dash-kpis {
        display: grid;
        grid-template-columns: repeat(6, minmax(0, 1fr));
        gap: .4rem;
    }

    .dash-kpis article {
        background: #fff;
        border-radius: .56rem;
        border: 1px solid #eadff0;
        border-left: 4px solid #7b0d8e;
        padding: .42rem .5rem;
        min-height: 58px;
        box-shadow: 0 .18rem .5rem rgba(75,0,92,.045);
    }

    .dash-kpis article.cyan { border-left-color: #2186d9; }
    .dash-kpis article.green { border-left-color: #16a34a; }
    .dash-kpis article.yellow { border-left-color: #f0a224; }
    .dash-kpis article.red { border-left-color: #b4232e; }

    .dash-kpis span {
        display: block;
        color: #1f1427;
        font-size: .55rem;
        font-weight: 950;
        text-transform: uppercase;
    }

    .dash-kpis strong {
        display: block;
        color: #060009;
        font-size: 1.35rem;
        font-weight: 950;
        line-height: 1;
    }

    .dash-kpis small {
        color: #55445f;
        font-size: .58rem;
        font-weight: 760;
    }

    .dash-layout {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(0, .95fr);
        gap: .48rem;
        align-items: start;
    }

    .dash-main-left,
    .dash-main-right {
        display: grid;
        gap: .48rem;
        min-width: 0;
    }

    .dash-overview-grid {
        display: grid;
        grid-template-columns: .88fr .88fr 1.24fr;
        gap: .48rem;
    }

    .dash-card {
        background: #fff;
        border: 1px solid #eadff0;
        border-radius: .72rem;
        padding: .56rem;
        box-shadow: 0 .18rem .55rem rgba(75,0,92,.045);
        min-width: 0;
    }

    .dash-card h3 {
        margin: 0 0 .38rem;
        color: #100018;
        font-size: .86rem;
        font-weight: 950;
        line-height: 1.08;
    }

    .dash-section-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: .65rem;
        margin-bottom: .38rem;
    }

    .dash-section-head p {
        margin: .08rem 0 0;
        color: #66536f;
        font-size: .64rem;
        font-weight: 720;
    }

    .dash-section-head span {
        flex: 0 0 auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 25px;
        padding: .15rem .5rem;
        border-radius: .5rem;
        background: #fbf4ff;
        color: #4b005c;
        border: 1px solid #eadff0;
        font-size: .62rem;
        font-weight: 950;
    }

    .dash-local-list,
    .dash-maintenance-list {
        display: grid;
        gap: .15rem;
    }

    .dash-local-list div,
    .dash-maintenance-list div {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: .35rem;
        align-items: center;
        font-size: .68rem;
    }

    .dash-local-list span,
    .dash-maintenance-list span {
        display: flex;
        align-items: center;
        gap: .32rem;
        color: #24102e;
        font-weight: 820;
        min-width: 0;
    }

    .dash-local-list strong,
    .dash-maintenance-list strong {
        color: #0d0013;
        font-weight: 950;
    }

    .mini-dot {
        width: 17px;
        height: 17px;
        border-radius: 50%;
        display: inline-grid;
        place-items: center;
        border: 1px solid currentColor;
        font-size: .62rem;
        line-height: 1;
        background: #fff;
    }

    .mini-dot.green { color: #16a34a; }
    .mini-dot.blue { color: #2186d9; }
    .mini-dot.cyan { color: #0ea5e9; }
    .mini-dot.yellow { color: #f0a224; }
    .mini-dot.red { color: #b4232e; }

    .dash-card-head {
        display: flex;
        justify-content: space-between;
        gap: .45rem;
        align-items: flex-start;
        margin-bottom: .28rem;
    }

    .dash-tabs {
        display: flex;
        gap: .22rem;
        flex: 0 0 auto;
    }

    .dash-tabs button {
        border: 1px solid #eadff0;
        background: #f7eef9;
        color: #32103d;
        border-radius: .42rem;
        padding: .24rem .42rem;
        font-size: .62rem;
        font-weight: 950;
    }

    .dash-tabs button.active {
        background: #7b0d8e;
        color: #fff;
        border-color: #7b0d8e;
    }

    .dash-vs-content {
        display: grid;
        grid-template-columns: 92px minmax(0, 1fr);
        align-items: center;
        gap: .45rem;
    }

    .dash-chart-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .48rem;
    }

    .dash-chart-grid .dash-donut-card:first-child {
        grid-column: 1 / -1;
    }

    .dash-donut-row {
        display: grid;
        grid-template-columns: 112px minmax(0, 1fr);
        align-items: center;
        gap: .55rem;
    }

    .dash-donut {
        border-radius: 50%;
        position: relative;
        display: grid;
        place-items: center;
        box-shadow: inset 0 0 0 1px rgba(75,0,92,.12), 0 .2rem .5rem rgba(75,0,92,.08);
    }

    .dash-donut.md {
        width: 86px;
        height: 86px;
    }

    .dash-donut.lg {
        width: 104px;
        height: 104px;
    }

    .dash-donut::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        background: #fff;
        box-shadow: inset 0 0 0 1px #eadff0;
        inset: 24px;
    }

    .dash-donut.md::after {
        inset: 21px;
    }

    .dash-donut div {
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .dash-donut strong {
        display: block;
