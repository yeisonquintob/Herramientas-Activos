    private async Task ExecuteItemActionAsync(ConsultationItem item, string action, string localStatus, string okMessage)
    {
        successMessage = null;
        errorMessage = null;

        try
        {
            if (item.SourceKind == SourceKind.Api)
            {
                var baseUrl = item.Kind == RequestKind.Purchase
                    ? "api/purchase-requests"
                    : "api/maintenance-requests";

                if (!Guid.TryParse(item.Id, out var id))
                {
                    errorMessage = "El registro de API no tiene un Id válido.";
                    return;
                }

                await Api.SendJsonAsync(HttpMethod.Post, $"{baseUrl}/{id}/{action}", new
                {
                    comment = $"Acción {action} realizada desde app móvil - Consulta Compras y Mtto.",
                    scheduledAt = DateTime.UtcNow,
                    assignedTechnician = Auth.CurrentUser?.DisplayName ?? Auth.CurrentUser?.UserName
                });
            }
            else
            {
                await UpdateLocalStatusAsync(item, localStatus);
            }

            selectedItem = null;
            successMessage = okMessage;
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private async Task UpdateLocalStatusAsync(ConsultationItem item, string newStatus)
    {
        if (string.IsNullOrWhiteSpace(item.StorageKey))
        {
            return;
        }

        var script =
            "(function(storageKey, id, number, newStatus) {" +
            "  const raw = localStorage.getItem(storageKey);" +
            "  if (!raw) return false;" +
            "  let data = JSON.parse(raw);" +
            "  let updated = false;" +
            "  function txt(v) { return v === null || v === undefined ? '' : String(v); }" +
            "  function match(obj) {" +
            "    if (!obj || typeof obj !== 'object') return false;" +
            "    const values = [obj.id,obj.Id,obj.localNumber,obj.LocalNumber,obj.requestNumber,obj.RequestNumber,obj.number,obj.Number].filter(Boolean).map(txt);" +
            "    return values.includes(txt(id)) || values.includes(txt(number));" +
            "  }" +
            "  function touch(obj) {" +
            "    if (!obj || typeof obj !== 'object') return;" +
            "    if (match(obj)) {" +
            "      obj.Status = newStatus; obj.status = newStatus;" +
            "      obj.UpdatedAt = new Date().toISOString(); obj.updatedAt = obj.UpdatedAt;" +
            "      updated = true;" +
            "    }" +
            "    for (const key of Object.keys(obj)) {" +
            "      if (obj[key] && typeof obj[key] === 'object') {" +
            "        if (Array.isArray(obj[key])) obj[key].forEach(touch); else touch(obj[key]);" +
            "      }" +
            "    }" +
            "  }" +
            "  if (Array.isArray(data)) data.forEach(touch); else touch(data);" +
            "  if (updated) localStorage.setItem(storageKey, JSON.stringify(data));" +
            "  return updated;" +
            "})(arguments[0], arguments[1], arguments[2], arguments[3]);";

        await JS.InvokeAsync<bool>("eval", script, item.StorageKey, item.Id, item.Number, newStatus);
    }

    private IEnumerable<ConsultationItem> Deduplicate(IEnumerable<ConsultationItem> source)
    {
        return source
            .GroupBy(x => $"{x.Kind}:{NormalizeKey(x.Number)}:{NormalizeKey(x.Id)}")
            .Select(group =>
                group.OrderByDescending(x => x.SourceKind == SourceKind.Api)
                     .ThenByDescending(x => x.UpdatedAt ?? x.CreatedAt ?? DateTime.MinValue)
                     .First())
            .Where(x => !string.IsNullOrWhiteSpace(x.Number) || !string.IsNullOrWhiteSpace(x.AssetName))
            .ToList();
    }

    private bool MatchesSearch(ConsultationItem item)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
        }

        var value = searchText.Trim();

        return Contains(item.Number, value)
            || Contains(item.AssetName, value)
            || Contains(item.Description, value)
            || Contains(item.Provider, value)
            || Contains(item.RequestedBy, value)
            || Contains(item.PreparedBy, value)
            || Contains(item.Technician, value)
            || Contains(item.Branch, value);
    }

    private void ClearFilters()
    {
        typeFilter = "all";
        statusFilter = "all";
        searchText = string.Empty;

        branchFilterInitialized = false;
        ApplyDefaultBranchFilterIfNeeded();
    }


    private void ApplyDefaultBranchFilterIfNeeded()
    {
        if (branchFilterInitialized)
        {
            return;
        }

        branchFilterInitialized = true;

        var userBranchCode = Auth.CurrentUser?.BranchCode;

        if (IsAllBranchValue(userBranchCode))
        {
            selectedBranchCode = string.Empty;
            return;
        }

        if (!string.IsNullOrWhiteSpace(userBranchCode))
        {
            selectedBranchCode = userBranchCode;
            return;
        }

        if (Auth.CurrentUser?.BranchId is Guid branchId)
        {
            var branch = branches.FirstOrDefault(x => x.Id == branchId);

            if (branch is not null && !IsAllBranchValue(branch.Code))
            {
                selectedBranchCode = branch.Code;
                return;
            }
        }

        selectedBranchCode = string.Empty;
    }

    private bool MatchesBranchFilter(ConsultationItem item)
    {
        if (string.IsNullOrWhiteSpace(selectedBranchCode))
        {
            return true;
        }

        var selectedBranch = branches.FirstOrDefault(x =>
            Same(x.Code, selectedBranchCode) ||
            Same(x.Name, selectedBranchCode));

        if (selectedBranch is not null)
        {
            return Same(item.Branch, selectedBranch.Code) ||
                   Same(item.Branch, selectedBranch.Name) ||
                   Contains(item.Branch, selectedBranch.Code) ||
                   Contains(item.Branch, selectedBranch.Name);
        }

        return Same(item.Branch, selectedBranchCode) ||
               Contains(item.Branch, selectedBranchCode);
    }

    private bool UserCanSeeAllBranches()
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(user.BranchCode) ||
               Same(user.BranchCode, "TODAS") ||
               Same(user.BranchCode, "ALL") ||
               Same(user.BranchName, "TODAS") ||
               Same(user.BranchName, "ALL") ||
               Same(user.BranchName, "Todas las sedes");
    }

    private string ResolveBranchLabel(string? branchIdText)
    {
        if (Guid.TryParse(branchIdText, out var branchId))
        {
            var branch = branches.FirstOrDefault(x => x.Id == branchId);

            if (branch is not null)
            {
                return $"{branch.Code} - {branch.Name}";
            }
        }

        return Display(Auth.CurrentUser?.BranchName ?? Auth.CurrentUser?.BranchCode);
    }

