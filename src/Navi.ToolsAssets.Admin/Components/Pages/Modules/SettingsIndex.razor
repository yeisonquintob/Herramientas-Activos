@page "/settings"
@rendermode InteractiveServer
@using Navi.ToolsAssets.Admin.Services.Auth
@inject WebAuthSessionService AuthSession

<PageTitle>Configuración - NAVI Herramientas</PageTitle>

<PermissionGuard Permission="Settings.View" ModuleName="Configuración">
    <section class="navi-module-hero">
        <div>
            <span class="navi-module-pill">CONFIGURACIÓN · PARÁMETROS · CATÁLOGOS</span>
            <h2>Configuración</h2>
            <p>Administra sedes, zonas, talleres, ubicaciones, responsables, tipos de activos, documentos, mantenimientos, causales y parámetros base.</p>
        </div>

        <div class="navi-module-hero-actions">
            <button type="button" class="navi-module-hero-btn" onclick="window.location.reload()">
                Actualizar
            </button>
        </div>
    </section>

    <section class="settings-tech-grid">

        @foreach (var item in VisibleOptions)
        {
            <article class="settings-tech-card">
                <span>@item.Group</span>
                <h3>@item.Title</h3>
                <p>@item.Description</p>

                @if (CanOpenOption(item))
                {
                    <a class="btn btn-outline-primary w-100" href="@item.Url">
                        @(CanManageOption(item) ? "Gestionar" : "Consultar")
                    </a>
                }
                else
                {
                    <button class="btn btn-outline-secondary w-100" type="button" disabled>
                        Sin permiso
                    </button>
                }
            </article>
        }

    </section>
</PermissionGuard>

<style>
    .settings-tech-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(180px, 1fr));
        gap: 0.75rem;
        align-items: stretch;
        margin-top: 1rem;
    }

    .settings-tech-card {
        background: #ffffff;
        border: 1px solid #dfe3e8;
        border-radius: 0.75rem;
        padding: 0.85rem;
        min-height: 132px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 0 0.3rem 0.75rem rgba(0, 0, 0, 0.045);
    }

    .settings-tech-card:hover {
        border-color: #4b005c;
        box-shadow: 0 0.5rem 1.1rem rgba(75, 0, 92, 0.12);
        transform: translateY(-1px);
        transition: all 0.15s ease;
    }

    .settings-tech-card span {
        display: block;
        color: #637083;
        font-size: 0.68rem;
        font-weight: 950;
        letter-spacing: 0.05rem;
        text-transform: uppercase;
        margin-bottom: 0.45rem;
    }

    .settings-tech-card h3 {
        color: #111827;
        font-size: 0.98rem;
        font-weight: 950;
        margin: 0 0 0.3rem 0;
    }

    .settings-tech-card p {
        color: #5f5963;
        font-size: 0.78rem;
        line-height: 1.3;
        margin: 0 0 0.85rem 0;
    }

    .settings-tech-card .btn {
        height: 30px;
        padding: 0.25rem 0.6rem;
        font-size: 0.78rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 850;
    }

    @@media (max-width: 1500px) {
        .settings-tech-grid {
            grid-template-columns: repeat(4, minmax(180px, 1fr));
        }
    }

    @@media (max-width: 1100px) {
        .settings-tech-grid {
            grid-template-columns: repeat(2, minmax(180px, 1fr));
        }
    }

    @@media (max-width: 700px) {
        .settings-tech-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private bool IsAdmin =>
        string.Equals(AuthSession.RoleCode, "ADMIN", StringComparison.OrdinalIgnoreCase)
        || string.Equals(AuthSession.RoleCode, "SUPERADMIN", StringComparison.OrdinalIgnoreCase)
        || string.Equals(AuthSession.RoleName, "Administrador", StringComparison.OrdinalIgnoreCase)
        || string.Equals(AuthSession.RoleName, "Administrador NAVI", StringComparison.OrdinalIgnoreCase);

    private bool CanViewSettings => IsAdmin || AuthSession.HasPermission("Settings.View");
    private bool CanManageSettings => IsAdmin || AuthSession.HasPermission("Settings.Manage");
    private bool CanManageUsers => IsAdmin || AuthSession.HasPermission("Security.Users");
    private bool CanManageRoles => IsAdmin || AuthSession.HasPermission("Security.Roles");

    private IEnumerable<SettingsOption> VisibleOptions =>
        Options.Where(CanSeeOption);

    private bool CanSeeOption(SettingsOption item)
    {
        if (item.Code == "users")
        {
            return CanManageUsers;
        }

        if (item.Code == "roles")
        {
            return CanManageRoles;
        }

        return CanViewSettings;
    }

    private bool CanOpenOption(SettingsOption item)
    {
        if (item.Code == "users")
        {
            return CanManageUsers;
        }

        if (item.Code == "roles")
        {
            return CanManageRoles;
        }

        return CanViewSettings;
    }

    private bool CanManageOption(SettingsOption item)
    {
        if (item.Code == "users")
        {
            return CanManageUsers;
        }

        if (item.Code == "roles")
        {
            return CanManageRoles;
        }

        return CanManageSettings;
    }

    private static List<SettingsOption> Options { get; } = new()
    {
        new("users", "SEGURIDAD", "Usuarios", "Crear, editar, activar o bloquear usuarios del sistema.", "/settings/users"),
        new("roles", "SEGURIDAD", "Roles y permisos", "Configurar perfiles y permisos por módulo, acción, sede y zona.", "/settings/roles"),
        new("branches", "ORGANIZACIÓN", "Sedes", "Administrar sedes como AGU, Medellín, Bogotá u otras operaciones.", "/settings/branches"),
        new("zones", "ORGANIZACIÓN", "Zonas", "Agrupar sedes por regional, operación o zona administrativa.", "/settings/zones"),
        new("warehouses", "ORGANIZACIÓN", "Almacenes / Talleres", "Crear almacenes, talleres, bodegas, patios, oficinas y áreas técnicas.", "/settings/warehouses"),
        new("locations", "ORGANIZACIÓN", "Ubicaciones", "Definir estantes, bahías, puestos, zonas internas o ubicaciones físicas.", "/settings/locations"),
        new("responsibles", "RESPONSABLES", "Responsables", "Gestionar técnicos, herramienteros, jefes, coordinadores y responsables.", "/settings/responsibles"),
        new("asset-types", "ACTIVOS FIJOS", "Tipos de activo", "Herramientas, equipos de diagnóstico, computadores, medición y otros activos.", "/settings/asset-types"),
        new("categories", "ACTIVOS FIJOS", "Categorías", "Gato pluma, escáner, computador, herramienta manual, eléctrica o especial.", "/settings/categories"),
        new("statuses", "ACTIVOS FIJOS", "Estados", "Disponible, asignado, prestado, mantenimiento, dañado, baja o pendiente.", "/settings/statuses"),
        new("document-types", "DOCUMENTOS", "Tipos de documento", "Ficha técnica, garantía, foto, acta, factura, evidencia y soporte.", "/settings/document-types"),
        new("maintenance-types", "MANTENIMIENTO", "Tipos de mantenimiento", "Preventivo, correctivo, calibración, inspección y certificación.", "/settings/maintenance-types"),
        new("maintenance-plans", "MANTENIMIENTO", "Planes de mantenimiento", "Frecuencias, alertas, cronogramas y reglas por tipo de activo.", "/settings/maintenance-plans"),
        new("causes", "OPERACIÓN", "Causales", "Causales de daño, novedad, pérdida, baja, traslado o mantenimiento.", "/settings/causes"),
        new("system-parameters", "SISTEMA", "Parámetros", "Reglas globales, días de alerta, límites de archivo y parámetros generales.", "/settings/system-parameters")
    };

    private sealed record SettingsOption(
        string Code,
        string Group,
        string Title,
        string Description,
        string Url);
}
