@page "/"
@page "/dashboard"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components
@using Navi.ToolsAssets.Admin.Components.Shared
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Dashboard - NAVI</PageTitle>

<PermissionGuard Permission="Dashboard.View" ModuleName="Dashboard">

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (isLoading && dashboard is null)
{
    <div class="alert alert-info">Cargando dashboard...</div>
}
else if (dashboard is not null)
{
    <section class="dash-web-final">
        <section class="dash-hero-final">
            <div>
                <span>Estado</span>
                <p>Control operativo de herramientas, activos, responsables, diferencias, mantenimientos y hojas de vida.</p>
            </div>

            <div class="dash-hero-actions-final">
                <strong>En progreso</strong>
                <button type="button" @onclick="LoadDashboardAsync" disabled="@isLoading">
                    @(isLoading ? "Actualizando..." : "Actualizar")
                </button>
            </div>
        </section>

        <section class="dash-kpis-final">
            <article class="purple">
                <span>PARTICIPANTES</span>
                <strong>@dashboard.Summary.ActiveResponsibles</strong>
                <small>Usuario / responsable</small>
            </article>

            <article class="cyan">
                <span>EN PROCESO</span>
                <strong>@GetInProcess()</strong>
                <small>Inventario activo</small>
            </article>

            <article class="green">
                <span>FINALIZADOS</span>
                <strong>@dashboard.Summary.WithLifeRecord</strong>
                <small>Con hoja de vida</small>
            </article>

            <article class="yellow">
                <span>PENDIENTES</span>
                <strong>@GetPendingTotal()</strong>
                <small>Herramientas por validar</small>
            </article>

            <article class="red">
                <span>DIFERENCIAS</span>
                <strong>@GetDifferences()</strong>
                <small>Conciliación</small>
            </article>

            <article class="purple">
                <span>AVANCE</span>
                <strong>@GetAdvancePercent()%</strong>
                <small>@dashboard.Summary.WithLifeRecord de @dashboard.Summary.TotalTools</small>
            </article>
        </section>

        <section class="dash-main-grid-final">
            <article class="dash-card-final dash-local-final">
                <h3>Local de herramientas</h3>

                <div class="dash-local-list-final">
                    <div>
                        <span class="dash-local-label">
                            <b class="dash-svg-icon green">@GetMiniIcon("total")</b>
                            Total herramientas
                        </span>
                        <strong>@dashboard.Summary.TotalTools</strong>
                    </div>

                    <div>
                        <span class="dash-local-label">
                            <b class="dash-svg-icon green">@GetMiniIcon("check")</b>
                            Disponibles
                        </span>
                        <strong>@dashboard.Summary.AvailableTools</strong>
                    </div>

                    <div>
                        <span class="dash-local-label">
                            <b class="dash-svg-icon blue">@GetMiniIcon("user")</b>
                            Asignadas
                        </span>
                        <strong>@dashboard.Summary.AssignedTools</strong>
                    </div>

                    <div>
                        <span class="dash-local-label">
                            <b class="dash-svg-icon cyan">@GetMiniIcon("tool")</b>
                            En mantenimiento
                        </span>
                        <strong>@dashboard.Summary.InMaintenanceTools</strong>
                    </div>

                    <div>
                        <span class="dash-local-label">
                            <b class="dash-svg-icon yellow">@GetMiniIcon("clock")</b>
                            Pendientes validación
                        </span>
                        <strong>@dashboard.Summary.PendingValidationTools</strong>
                    </div>

                    <div>
                        <span class="dash-local-label">
                            <b class="dash-svg-icon red">@GetMiniIcon("close")</b>
                            Desactivadas / baja
                        </span>
                        <strong>@dashboard.Summary.DisposedTools</strong>
                    </div>
                </div>
            </article>

            <article class="dash-card-final dash-maintenance-summary-final">
                <div class="dash-card-head-final">
                    <h3>Mantenimientos realizados</h3>

                    <div class="dash-tabs-final">
                        <span>Por mes</span>
                        <span>Por día</span>
                    </div>
                </div>

                <div class="dash-maintenance-centered-final">
                    <div>
                        <span>Por mes</span>
                        <strong>@dashboard.MaintenanceSummary.ThisMonth</strong>
                    </div>

                    <div>
                        <span>Por día</span>
                        <strong>@dashboard.MaintenanceSummary.Today</strong>
                    </div>

                    <div>
                        <span>En proceso</span>
                        <strong>@dashboard.Summary.InMaintenanceTools</strong>
                    </div>

                    <div>
                        <span>Pendientes</span>
                        <strong>@dashboard.Summary.RequiresMaintenance</strong>
                    </div>
                </div>
            </article>

            <article class="dash-card-final dash-vs-final">
                <h3>Herramientas vs activos</h3>

                <div class="dash-vs-metrics-final">
                    <div>
                        <span>Herramientas</span>
                        <strong>@dashboard.Summary.ToolsOnly</strong>
                    </div>

                    <div>
                        <span>Activos fijos</span>
                        <strong>@dashboard.Summary.FixedAssets</strong>
                    </div>
                </div>
            </article>

            <article class="dash-card-final dash-chart-card-final">
                <h3>Distribución de activos fijos</h3>

                <div class="dash-chart-layout-final">
                    <div class="dash-donut-final xl" style="@GetToolsVsAssetsDonut()">
                        <div class="dash-donut-center-final">
                            <strong>@dashboard.Summary.TotalTools</strong>
                            <span>Total</span>
                        </div>
                    </div>

                    <div class="dash-legend-final">
                        <div>
                            <i class="purple"></i>
                            <span>Herramientas</span>
                            <strong>@dashboard.Summary.ToolsOnly</strong>
                            <small>@GetPercentLabel(dashboard.Summary.ToolsOnly, dashboard.Summary.TotalTools)</small>
                        </div>

                        <div>
                            <i class="blue"></i>
                            <span>Activos fijos</span>
                            <strong>@dashboard.Summary.FixedAssets</strong>
                            <small>@GetPercentLabel(dashboard.Summary.FixedAssets, dashboard.Summary.TotalTools)</small>
                        </div>

                        <div>
                            <i class="orange"></i>
                            <span>Sin código AF</span>
                            <strong>@dashboard.Summary.ToolsWithoutFixedAssetCode</strong>
                            <small>@GetPercentLabel(dashboard.Summary.ToolsWithoutFixedAssetCode, dashboard.Summary.TotalTools)</small>
                        </div>
                    </div>
                </div>
            </article>

            <article class="dash-card-final dash-chart-card-final">
                <h3>Herramientas por sede</h3>

                <div class="dash-branch-bars-final">
                    @foreach (var item in GetBranchChartItems())
                    {
                        <div>
                            <strong style="@GetBranchBarStyle(item.Branch.Total, item.Index)"></strong>
                            <span>@item.Branch.BranchCode</span>
                            <small>@item.Branch.Total</small>
                        </div>
                    }
                </div>
            </article>

            <article class="dash-card-final dash-table-card-final">
                <h3>Resumen por sede / responsable</h3>

                <table class="dash-table-final">
                    <thead>
                        <tr>
                            <th>Sede</th>
                            <th>Asignadas</th>
                            <th>Válidas</th>
                            <th>Diferencias</th>
                            <th>Avance</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in dashboard.ToolsByBranch.Take(10))
                        {
                            var assigned = GetBranchAssigned(item.Total);
                            var valid = GetBranchValidated(item.Total);
                            var difference = GetBranchDifferences(item.Total);
                            var percent = GetBranchAdvance(item.Total);

                            <tr>
                                <td>
                                    <div class="dash-branch-name-final">
                                        <strong>@item.BranchCode</strong>
                                        <span>@item.BranchName</span>
                                    </div>
                                </td>

                                <td>@assigned</td>
                                <td>@valid</td>

                                <td>
                                    <span class="dash-difference-final">@difference</span>
                                </td>

                                <td>
                                    <div class="dash-progress-final">
                                        <span style="@($"width:{percent}%")"></span>
                                    </div>
                                    <small>@percent%</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </article>

            <article class="dash-card-final dash-chart-card-final equal">
                <h3>Herramientas por mes</h3>

                <div class="dash-chart-layout-final compact">
                    <div class="dash-donut-final md" style="@GetMaintenanceDonut()">
                        <div class="dash-donut-center-final">
                            <strong>@GetMaintenanceTotalForChart()</strong>
                            <span>Total</span>
                        </div>
                    </div>

                    <div class="dash-legend-final compact">
                        <div><i class="blue"></i><span>Asignada</span><strong>@dashboard.Summary.AssignedTools</strong></div>
                        <div><i class="orange"></i><span>Disponible</span><strong>@dashboard.Summary.AvailableTools</strong></div>
                        <div><i class="red"></i><span>Pendientes</span><strong>@dashboard.Summary.PendingValidationTools</strong></div>
                        <div><i class="purple"></i><span>Técnico</span><strong>@dashboard.Summary.InMaintenanceTools</strong></div>
                        <div><i class="gray"></i><span>Otras</span><strong>@GetOtherMaintenance()</strong></div>
                    </div>
                </div>
            </article>

            <article class="dash-card-final dash-chart-card-final equal">
                <h3>Hojas de vida</h3>

                <div class="dash-chart-layout-final compact">
                    <div class="dash-donut-final md" style="@GetLifeRecordDonut()">
                        <div class="dash-donut-center-final">
                            <strong>@dashboard.Summary.WithLifeRecord</strong>
                            <span>Con HV</span>
                        </div>
                    </div>

                    <div class="dash-legend-final compact">
                        <div><i class="purple"></i><span>Con hoja</span><strong>@dashboard.Summary.WithLifeRecord</strong></div>
                        <div><i class="orange"></i><span>Sin hoja</span><strong>@dashboard.Summary.WithoutLifeRecord</strong></div>
                        <div><i class="red"></i><span>Datos incompletos</span><strong>@dashboard.LifeRecordCoverage.MissingTechnicalData</strong></div>
                        <div><i class="blue"></i><span>Activos fijos</span><strong>@dashboard.Summary.FixedAssets</strong></div>
                        <div><i class="gray"></i><span>Otras</span><strong>@GetOtherLifeRecords()</strong></div>
                    </div>
                </div>
            </article>

            <article class="dash-card-final dash-mini-card-final">
                <h3>Mantenimientos por día</h3>

                <div class="dash-mini-metrics-final">
                    <div>
                        <strong>@dashboard.MaintenanceSummary.ThisMonth</strong>
                        <span>Por mes</span>
                    </div>

                    <div>
                        <strong>@dashboard.MaintenanceSummary.Today</strong>
                        <span>Por día</span>
                    </div>

                    <div>
                        <strong>@dashboard.Summary.RequiresMaintenance</strong>
                        <span>Pendientes</span>
                    </div>
                </div>
            </article>

            <article class="dash-card-final dash-mini-card-final">
                <h3>Toma física</h3>

                <p>Acciones rápidas para gestión de toma física y conciliación.</p>

                <div class="dash-actions-final">
                    <a href="/physical-counts">Volver</a>
                    <a href="/physical-counts">Generar participantes</a>
                    <a href="/physical-counts">Activar toma</a>
                    <a href="/reconciliation">Conciliar</a>
                </div>
            </article>

            <article class="dash-card-final dash-column-card-final">
                <h3>Históricos</h3>

                @if (dashboard.RecentActivity.Any())
                {
                    <div class="dash-history-final">
                        @foreach (var item in dashboard.RecentActivity.Take(6))
                        {
                            <div>
                                <strong>@item.Title</strong>
                                <span>@Display(item.Description)</span>
                                <small>@item.RegisteredAt.ToString("dd/MM/yyyy HH:mm") · @Display(item.User)</small>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="dash-history-final empty">
                        <div>
                            <strong>Sin historial reciente</strong>
                            <span>No hay eventos recientes para mostrar.</span>
                            <small>Dashboard operativo</small>
                        </div>
                    </div>
                }
            </article>

            <article class="dash-card-final dash-column-card-final">
                <h3>Pendientes</h3>

                <div class="dash-pending-final">
                    @foreach (var item in GetPendingItems().Take(6))
                    {
                        <div>
                            <strong>@item.Title</strong>
                            <span>@item.Description</span>
                            <small>@item.Value</small>
                        </div>
                    }
                </div>
            </article>
        </section>
    </section>
}

</PermissionGuard>

<style>
    .dash-web-final {
        display: grid;
        gap: .65rem;
        padding-bottom: 1rem;
    }

    .dash-hero-final {
        background:
            radial-gradient(circle at top right, rgba(208, 32, 224, .32), transparent 34%),
            linear-gradient(135deg, #060009 0%, #250030 45%, #8a0b99 100%);
        color: #fff;
        border-radius: .85rem;
        padding: .78rem 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .8rem;
        box-shadow: 0 .65rem 1.3rem rgba(75, 0, 92, .20);
    }

    .dash-hero-final span {
        display: block;
        color: #fff;
        font-size: .82rem;
        font-weight: 950;
    }

    .dash-hero-final p {
        margin: .12rem 0 0;
        color: rgba(255,255,255,.86);
        font-size: .86rem;
        font-weight: 700;
    }

    .dash-hero-actions-final {
        display: flex;
        align-items: center;
        gap: .45rem;
    }

    .dash-hero-actions-final strong,
    .dash-hero-actions-final button {
        border-radius: .55rem;
        color: #fff;
        background: rgba(255,255,255,.14);
        border: 1px solid rgba(255,255,255,.22);
        padding: .43rem .65rem;
        font-size: .76rem;
        font-weight: 950;
        white-space: nowrap;
    }

    .dash-kpis-final {
        display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: .5rem;
    }

    .dash-kpis-final article {
        background: #fff;
        border-radius: .65rem;
        border: 1px solid #eadff0;
        border-left: 4px solid #7b0d8e;
        padding: .55rem .65rem;
        box-shadow: 0 .25rem .65rem rgba(75,0,92,.055);
    }

    .dash-kpis-final article.cyan { border-left-color: #2186d9; }
    .dash-kpis-final article.green { border-left-color: #16a34a; }
    .dash-kpis-final article.yellow { border-left-color: #f0a224; }
    .dash-kpis-final article.red { border-left-color: #b4232e; }

    .dash-kpis-final span {
        display: block;
        color: #1f1427;
        font-size: .62rem;
        font-weight: 950;
    }

    .dash-kpis-final strong {
        display: block;
        color: #060009;
        font-size: 1.48rem;
        font-weight: 950;
        line-height: 1;
    }

    .dash-kpis-final small {
        color: #55445f;
        font-size: .64rem;
        font-weight: 750;
    }

    .dash-main-grid-final {
        display: grid;
        grid-template-columns: 1.05fr 1fr 1fr 1.05fr 1.05fr;
        gap: .65rem;
        align-items: stretch;
    }

    .dash-card-final {
        background: #fff;
        border: 1px solid #eadff0;
        border-radius: .82rem;
        padding: .72rem;
        box-shadow: 0 .28rem .75rem rgba(75,0,92,.055);
        min-height: 132px;
    }

    .dash-card-final h3 {
        margin: 0 0 .5rem;
        color: #100018;
        font-size: .92rem;
        font-weight: 950;
    }

    .dash-local-list-final {
        display: grid;
        gap: .26rem;
    }

    .dash-local-list-final div {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: .55rem;
        align-items: center;
        font-size: .76rem;
    }

    .dash-local-label {
        display: flex;
        align-items: center;
        gap: .45rem;
        color: #24102e;
        font-weight: 820;
    }

    .dash-local-list-final strong {
        color: #0d0013;
        font-weight: 950;
    }

    .dash-svg-icon {
        width: 20px;
        height: 20px;
        display: inline-grid;
        place-items: center;
        border-radius: 50%;
        border: 1px solid currentColor;
        background: #fff;
        flex: 0 0 auto;
    }

    .dash-svg-icon svg {
        width: 13px;
        height: 13px;
        stroke: currentColor;
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        fill: none;
        display: block;
    }

    .dash-svg-icon.green { color: #16a34a; }
    .dash-svg-icon.blue { color: #2186d9; }
    .dash-svg-icon.cyan { color: #0ea5e9; }
    .dash-svg-icon.yellow { color: #f0a224; }
    .dash-svg-icon.red { color: #b4232e; }

    .dash-card-head-final {
        display: flex;
        justify-content: space-between;
        gap: .5rem;
        align-items: center;
        margin-bottom: .3rem;
    }

    .dash-tabs-final {
        display: flex;
        gap: .25rem;
    }

    .dash-tabs-final span {
        background: #7b0d8e;
        color: #fff;
        border-radius: .45rem;
        padding: .25rem .5rem;
        font-size: .68rem;
        font-weight: 950;
    }

    .dash-tabs-final span + span {
        background: #f7eef9;
        color: #32103d;
        border: 1px solid #eadff0;
    }

    .dash-maintenance-centered-final {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: .45rem;
        height: calc(100% - 1.8rem);
        align-content: center;
    }

    .dash-maintenance-centered-final div {
        text-align: center;
        border-radius: .65rem;
        border: 1px solid #eadff0;
        background: #fbf6fd;
        padding: .5rem;
    }

    .dash-maintenance-centered-final span {
        display: block;
        color: #5b4666;
        font-size: .68rem;
        font-weight: 850;
    }

    .dash-maintenance-centered-final strong {
        display: block;
        color: #0c0012;
        font-size: 1.2rem;
        font-weight: 950;
        line-height: 1;
        margin-top: .15rem;
    }

    .dash-vs-metrics-final {
        height: calc(100% - 1.6rem);
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: .55rem;
        align-items: center;
    }

    .dash-vs-metrics-final div {
        text-align: center;
        border-radius: .7rem;
        background: #fbf6fd;
        border: 1px solid #eadff0;
        padding: .7rem .5rem;
    }

    .dash-vs-metrics-final span {
        display: block;
        color: #564260;
        font-size: .72rem;
        font-weight: 850;
    }

    .dash-vs-metrics-final strong {
        display: block;
        color: #060009;
        font-size: 2rem;
        font-weight: 950;
        line-height: 1;
        margin-top: .25rem;
    }

    .dash-chart-card-final {
        min-height: 178px;
    }

    .dash-chart-card-final.equal {
        min-height: 196px;
    }

    .dash-chart-layout-final {
        display: grid;
        grid-template-columns: 140px 1fr;
        align-items: center;
        gap: .7rem;
    }

    .dash-chart-layout-final.compact {
        grid-template-columns: 112px 1fr;
    }

    .dash-donut-final {
        border-radius: 50%;
        position: relative;
        display: grid;
        place-items: center;
        box-shadow:
            inset 0 0 0 1px rgba(75,0,92,.12),
            0 .25rem .6rem rgba(75,0,92,.08);
    }

    .dash-donut-final.xl {
        width: 132px;
        height: 132px;
    }

    .dash-donut-final.md {
        width: 104px;
        height: 104px;
    }

    .dash-donut-final::after {
        content: "";
        position: absolute;
        border-radius: 50%;
        background: #fff;
        box-shadow: inset 0 0 0 1px #eadff0;
    }

    .dash-donut-final.xl::after {
        inset: 27px;
    }

    .dash-donut-final.md::after {
        inset: 22px;
    }

    .dash-donut-center-final {
        position: relative;
        z-index: 1;
        text-align: center;
    }

    .dash-donut-center-final strong {
        display: block;
        color: #07000d;
        font-size: 1.22rem;
        font-weight: 950;
        line-height: 1;
    }

    .dash-donut-center-final span {
        display: block;
        color: #5d4a67;
        font-size: .58rem;
        font-weight: 850;
        margin-top: .2rem;
    }

    .dash-legend-final {
        display: grid;
        gap: .3rem;
        font-size: .72rem;
    }

    .dash-legend-final.compact {
        font-size: .68rem;
        gap: .23rem;
    }

    .dash-legend-final div {
        display: grid;
        grid-template-columns: 9px 1fr auto auto;
        gap: .32rem;
        align-items: center;
    }

    .dash-legend-final.compact div {
        grid-template-columns: 9px 1fr auto;
    }

    .dash-legend-final i {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .dash-legend-final .purple { background: #7b0d8e; }
    .dash-legend-final .blue { background: #2186d9; }
    .dash-legend-final .orange { background: #f0a224; }
    .dash-legend-final .red { background: #b4232e; }
    .dash-legend-final .gray { background: #64748b; }

    .dash-legend-final span {
        color: #2a1734;
        font-weight: 800;
    }

    .dash-legend-final strong {
        color: #0a0010;
        font-weight: 950;
    }

    .dash-legend-final small {
        color: #66536f;
        font-weight: 850;
    }

    .dash-branch-bars-final {
        height: 138px;
        display: grid;
        grid-template-columns: repeat(8, 1fr);
        gap: .48rem;
        align-items: end;
        border-left: 1px solid #eadff0;
        border-bottom: 1px solid #eadff0;
        padding: .25rem .3rem 0;
    }

    .dash-branch-bars-final div {
        height: 100%;
        display: grid;
        align-items: end;
        text-align: center;
    }

    .dash-branch-bars-final strong {
        display: block;
        min-height: 8px;
        border-radius: .36rem .36rem 0 0;
    }

    .dash-branch-bars-final span {
        display: block;
        margin-top: .2rem;
        color: #3f3048;
        font-size: .6rem;
        font-weight: 900;
    }

    .dash-branch-bars-final small {
        display: block;
        color: #6b5a73;
        font-size: .55rem;
        font-weight: 850;
    }

    .dash-table-card-final {
        grid-column: span 3;
        min-height: 304px;
    }

    .dash-table-final {
        width: 100%;
        border-collapse: collapse;
        font-size: .72rem;
    }

    .dash-table-final th {
        color: #160020;
        border-bottom: 1px solid #d9cce3;
        padding: .32rem;
