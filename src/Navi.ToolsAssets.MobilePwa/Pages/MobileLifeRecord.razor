    private bool CanSeeThisTool => tool is not null && IsToolVisible(tool);
    private bool CanManageThisTool => tool is not null && HasAnyManagementPermission && IsToolVisibleByScopeOnly(tool);

    private string PermissionMode => CanManageThisTool ? "Gestiona" : "Consulta";

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsAuthenticated)
        {
            isLoading = false;
            return;
        }

        var refreshedUser = await Api.RefreshCurrentSessionAsync();

        if (refreshedUser is null || !Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        if (!CanViewLifeRecord)
        {
            isLoading = false;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            message = null;

            tool = await Api.GetToolByIdAsync(ToolId);
            life = await Api.GetTechnicalLifeRecordAsync(ToolId);

            if (!CanSeeThisTool)
            {
                message = "No tienes permiso para consultar esta hoja de vida por sede, responsable o alcance.";
                life = null;
                return;
            }

            accessories = await Api.GetListJsonAsync<MobileAccessoryDto>($"api/tools/{ToolId}/accessories");
            documents = await Api.GetListJsonAsync<MobileDocumentDto>($"api/tools/{ToolId}/documents");
            maintenance = await Api.GetListJsonAsync<MobileMaintenanceScheduleDto>($"api/tools/{ToolId}/maintenance-schedule");
            safePractices = await Api.GetListJsonAsync<MobileSafePracticeDto>($"api/tools/{ToolId}/safe-practices");

            LoadTechnicalForm();

            if (!safePractices.Any())
            {
                safePracticeForm.SortOrder = 1;
            }
            else if (!editingSafePracticeId.HasValue)
            {
                safePracticeForm.SortOrder = safePractices.Max(x => x.SortOrder) + 1;
            }

            ApplyMaintenanceQueryMode();
        }
        catch (Exception ex)
        {
            message = $"No se pudo cargar la hoja de vida: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }


    private void ApplyMaintenanceQueryMode()
    {
        var query = Navigation.ToAbsoluteUri(Navigation.Uri).Query;

        var shouldOpenMaintenance =
            QueryHas(query, "section", "maintenance") ||
            QueryHas(query, "section", "cronograma") ||
            QueryHas(query, "from", "maintenance-plans");

        var shouldEditMaintenance =
            QueryHas(query, "edit", "maintenance") ||
            QueryHas(query, "mode", "edit") ||
            QueryHas(query, "open", "maintenance-edit");

        if (!shouldOpenMaintenance && !shouldEditMaintenance)
        {
            return;
        }

        forceOpenMaintenanceSection = true;

        if (shouldEditMaintenance && CanManageMaintenance)
        {
            CloseAllEditModes();
            editMaintenanceMode = true;
            CancelMaintenanceEdit(false);
            message = "Cronograma de mantenimiento abierto para edición.";
        }
        else if (shouldEditMaintenance && !CanManageMaintenance)
        {
            message = "Puedes consultar el cronograma, pero no tienes permiso para editarlo.";
        }
    }

    private static bool QueryHas(string? query, string key, string expected)
    {
        if (string.IsNullOrWhiteSpace(query))
        {
            return false;
        }

        var clean = query.TrimStart('?');

        foreach (var part in clean.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var pair = part.Split('=', 2);
            var currentKey = Uri.UnescapeDataString(pair[0] ?? string.Empty);
            var currentValue = pair.Length > 1 ? Uri.UnescapeDataString(pair[1]) : string.Empty;

            if (string.Equals(currentKey, key, StringComparison.OrdinalIgnoreCase) &&
                string.Equals(currentValue, expected, StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }

        return false;
    }


