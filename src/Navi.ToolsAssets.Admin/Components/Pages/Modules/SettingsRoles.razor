@code {
    private HttpClient Api => HttpClientFactory.CreateClient("NaviApi");

    private List<RoleDto> roles = new();
    private RoleFormModel formModel = new();
    private Guid? editingId;
    private bool isLoading;
    private string message = string.Empty;
    private string messageClass = "alert alert-info";
    private HashSet<string> selectedPermissions = new(StringComparer.OrdinalIgnoreCase);

    private readonly List<PermissionGroup> permissionGroups = new()
    {
        new PermissionGroup
        {
            Area = "Principal",
            Title = "Dashboard",
            Permissions = new()
            {
                new PermissionItem("DASHBOARD.VIEW", "Ver Dashboard"),
                new PermissionItem("DASHBOARD.EXECUTIVE", "Indicadores ejecutivos"),
                new PermissionItem("DASHBOARD.REFRESH", "Actualizar indicadores")
            }
        },
        new PermissionGroup
        {
            Area = "Activos fijos",
            Title = "Inventario de AF",
            Permissions = new()
            {
                new PermissionItem("INVENTORY.VIEW", "Consultar inventario"),
                new PermissionItem("INVENTORY.CREATE", "Crear activo"),
                new PermissionItem("INVENTORY.EDIT", "Editar activo"),
                new PermissionItem("INVENTORY.DELETE", "Eliminar / desactivar activo"),
                new PermissionItem("INVENTORY.EXPORT", "Exportar inventario")
            }
        },
        new PermissionGroup
        {
            Area = "Activos fijos",
            Title = "Ubicación y asignación",
            Permissions = new()
            {
                new PermissionItem("LOCATION.VIEW", "Ver ubicación"),
                new PermissionItem("LOCATION.MANAGE", "Gestionar ubicación"),
                new PermissionItem("ASSIGNMENT.VIEW", "Consultar asignaciones"),
                new PermissionItem("ASSIGNMENT.CREATE", "Asignar activo"),
                new PermissionItem("ASSIGNMENT.CLOSE", "Cerrar asignación")
            }
        },
        new PermissionGroup
        {
            Area = "Activos fijos",
            Title = "Hoja de vida",
            Permissions = new()
            {
                new PermissionItem("LIFERECORD.VIEW", "Ver hoja de vida"),
                new PermissionItem("LIFERECORD.EDIT", "Editar datos técnicos"),
                new PermissionItem("LIFERECORD.EXPORT", "Exportar PDF / Excel"),
                new PermissionItem("LIFERECORD.EVENTS", "Ver trazabilidad")
            }
        },
        new PermissionGroup
        {
            Area = "Operaciones",
            Title = "Compras y MRO",
            Permissions = new()
            {
                new PermissionItem("PURCHASE.VIEW", "Consultar compras"),
                new PermissionItem("PURCHASE.REQUEST", "Solicitar compra"),
                new PermissionItem("PURCHASE.APPROVE", "Aprobar compra"),
                new PermissionItem("PURCHASE.REJECT", "Rechazar compra")
            }
        },
        new PermissionGroup
        {
            Area = "Operaciones",
            Title = "Mantenimiento",
            Permissions = new()
            {
                new PermissionItem("MAINTENANCE.VIEW", "Consultar mantenimientos"),
                new PermissionItem("MAINTENANCE.REQUEST", "Solicitar mantenimiento"),
                new PermissionItem("MAINTENANCE.SCHEDULE", "Programar mantenimiento"),
                new PermissionItem("MAINTENANCE.EXECUTE", "Registrar ejecución"),
                new PermissionItem("MAINTENANCE.APPROVE", "Aprobar mantenimiento")
            }
        },
        new PermissionGroup
        {
            Area = "Operaciones",
            Title = "Préstamos y devoluciones",
            Permissions = new()
            {
                new PermissionItem("LOAN.VIEW", "Consultar préstamos"),
                new PermissionItem("LOAN.CREATE", "Crear préstamo"),
                new PermissionItem("LOAN.DELIVER", "Entregar herramienta"),
                new PermissionItem("LOAN.RETURN", "Registrar devolución"),
                new PermissionItem("LOAN.APPROVE", "Aprobar préstamo")
            }
        },
        new PermissionGroup
        {
            Area = "Operaciones",
            Title = "Daños y novedades",
            Permissions = new()
            {
                new PermissionItem("DAMAGE.VIEW", "Consultar daños"),
                new PermissionItem("DAMAGE.REPORT", "Reportar daño"),
                new PermissionItem("DAMAGE.EDIT", "Editar novedad"),
                new PermissionItem("DAMAGE.CLOSE", "Cerrar novedad")
            }
        },
        new PermissionGroup
        {
            Area = "Control",
            Title = "Tomas físicas",
            Permissions = new()
            {
                new PermissionItem("PHYSICALCOUNT.VIEW", "Consultar toma física"),
                new PermissionItem("PHYSICALCOUNT.CREATE", "Crear toma física"),
                new PermissionItem("PHYSICALCOUNT.EXECUTE", "Ejecutar conteo"),
                new PermissionItem("PHYSICALCOUNT.CLOSE", "Cerrar toma física")
            }
        },
        new PermissionGroup
        {
            Area = "Control",
            Title = "Documentos",
            Permissions = new()
            {
                new PermissionItem("DOCUMENT.VIEW", "Ver documentos"),
                new PermissionItem("DOCUMENT.UPLOAD", "Cargar documentos"),
                new PermissionItem("DOCUMENT.DOWNLOAD", "Descargar documentos"),
                new PermissionItem("DOCUMENT.DELETE", "Eliminar documentos")
            }
        },
        new PermissionGroup
        {
            Area = "Control",
            Title = "Reportes y auditoría",
            Permissions = new()
            {
                new PermissionItem("REPORT.VIEW", "Ver reportes"),
                new PermissionItem("REPORT.EXPORT", "Exportar reportes"),
                new PermissionItem("AUDIT.VIEW", "Ver auditoría"),
                new PermissionItem("RECONCILIATION.VIEW", "Ver conciliación"),
                new PermissionItem("RECONCILIATION.MANAGE", "Gestionar conciliación")
