@page "/tools/{ToolId:guid}/technical-life-record-view"
@page "/tools/{ToolId:guid}/life-record-view"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject IJSRuntime JsRuntime
@inject IConfiguration Configuration

<PageTitle>Consulta hoja de vida técnica - NAVI Herramientas</PageTitle>



@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @errorMessage
    </div>
}
else if (isLoading && record is null)
{
    <div class="alert alert-info">
        Cargando hoja de vida técnica...
    </div>
}
else if (record is not null)
{
        <section class="life-hero-banner">
        <div class="life-hero-main">
            <div class="life-hero-top-actions">
                <button class="btn-life-back" @onclick="GoBack">
                    @BackButtonText
                </button>
            </div>

            <span class="life-hero-pill">CONSULTA HOJA DE VIDA</span>

            <h2>@record.Summary.Name</h2>

            <div class="life-hero-code">
                @record.Summary.InternalCode
            </div>

            <p>Vista solo lectura abierta desde el detalle del activo fijo. Para editar o gestionar, ingresa desde el módulo Hoja de Vida del AF.</p>
        </div>

        <div class="life-hero-side">
            <div class="life-hero-status-card">
                <span>Estado operativo</span>
                <strong>@GetStatusLabel(record.Summary.OperationalStatus)</strong>
            </div>

            <div class="life-hero-badges">
                <span class="@GetStatusBadgeClass(record.Summary.OperationalStatus)">
                    @GetStatusLabel(record.Summary.OperationalStatus)
                </span>

                <span class="badge bg-light text-dark">
                    @(record.Summary.IsSpecialized ? "Especializada" : "No especializada")
                </span>
            </div>

            <div class="life-hero-buttons">
                <a class="btn btn-sm btn-outline-light life-hero-edit"
                   href="@($"/tools/{ToolId}/technical-life-record/edit")">
                    Editar datos técnicos
                </a>

                <button class="btn btn-sm btn-outline-light life-hero-refresh"
                        @onclick="LoadAsync"
                        disabled="@isLoading">
                    @(isLoading ? "Actualizando..." : "Actualizar")
                </button>
            </div>
        </div>
    </section>
<section class="life-record-quick-actions">
    <div class="quick-action-card">
        <span>Datos técnicos</span>
        <strong>Información base</strong>
        <a class="life-action life-action-primary" href="@($"/tools/{ToolId}/technical-life-record/edit")">
            Editar
        </a>
    </div>

    <div class="quick-action-card">
        <span>Accesorios</span>
        <strong>Partes y componentes</strong>
        <a class="life-action life-action-primary" href="@($"/tools/{ToolId}/accessories")">
            Gestionar
        </a>
    </div>

    <div class="quick-action-card">
        <span>Documentos</span>
        <strong>Fotos, fichas y evidencias</strong>
        <a class="life-action life-action-primary" href="@($"/tools/{ToolId}/documents")">
            Gestionar
        </a>
    </div>

    <div class="quick-action-card">
        <span>Mantenimiento</span>
        <strong>Cronograma y evidencias</strong>
        <a class="life-action life-action-primary" href="@($"/tools/{ToolId}/maintenance-schedule")">
            Gestionar
        </a>
    </div>

    <div class="quick-action-card">
        <span>Seguridad</span>
        <strong>Prácticas seguras</strong>
        <a class="life-action life-action-primary" href="@($"/tools/{ToolId}/safe-practices")">
            Gestionar
        </a>
    </div>

    <div class="quick-action-card">
        <span>Trazabilidad</span>
        <strong>Eventos de hoja de vida</strong>
        <a class="life-action life-action-primary" href="@($"/tools/{ToolId}/life-cycle-events")">
            Ver eventos
        </a>
    </div>

    <div class="quick-action-card">
        <span>Exportar</span>
        <strong>PDF / Excel</strong>
        <div class="d-flex gap-1 flex-wrap">
            <button class="life-action life-action-neutral" @onclick="PrintLifeRecord">
                PDF
            </button>

            <a class="life-action life-action-success"
               href="@BuildApiUrl($"/api/tools/{ToolId}/technical-life-record/export-excel")"
               target="_blank">
                Excel
            </a>
        </div>
    </div>
</section>
<section class="@GetMaintenanceAlertClass()">
    <div>
        <span>Estado de mantenimiento</span>
        <strong>@GetMaintenanceAlertTitle()</strong>
        <p>@GetMaintenanceAlertDescription()</p>
    </div>

    <div class="maintenance-alert-grid">
        <div>
            <span>Último mantenimiento</span>
            <strong>@ShowDate(record.MaintenancePlan.LastMaintenanceDate)</strong>
        </div>

        <div>
            <span>Próximo mantenimiento</span>
            <strong>@ShowDate(record.MaintenancePlan.NextMaintenanceDate)</strong>
        </div>

        <div>
            <span>Días restantes</span>
            <strong>@GetMaintenanceDaysText()</strong>
        </div>
    </div>
</section>



    <div class="life-readonly-note">Modo solo lectura. Esta vista se abrió desde el detalle del activo fijo.</div>
<div class="life-record-grid">
        <section class="life-record-section">
            <div class="section-title">
                <span>1</span>
                <h2>Información del equipo</h2>
            </div>

            <div class="excel-grid two-columns">
                <div><label>Código interno</label><strong>@Show(record.EquipmentInformation.InternalCode)</strong></div>
                <div><label>Nombre</label><strong>@Show(record.EquipmentInformation.Name)</strong></div>
                <div><label>Marca</label><strong>@Show(record.EquipmentInformation.Brand)</strong></div>
                <div><label>Modelo</label><strong>@Show(record.EquipmentInformation.Model)</strong></div>
                <div><label>Serial</label><strong>@Show(record.EquipmentInformation.SerialNumber)</strong></div>
                <div><label>Activo fijo</label><strong>@Show(record.EquipmentInformation.FixedAssetCode)</strong></div>
                <div><label>Código Fenix365</label><strong>@Show(record.EquipmentInformation.FenixCode)</strong></div>
                <div><label>Fecha adquisición</label><strong>@DateText(record.EquipmentInformation.AcquisitionDate)</strong></div>
                <div><label>Zona</label><strong>@Show(record.EquipmentInformation.ZoneCode) - @Show(record.EquipmentInformation.ZoneName)</strong></div>
                <div><label>Sede</label><strong>@Show(record.EquipmentInformation.BranchCode) - @Show(record.EquipmentInformation.BranchName)</strong></div>
                <div><label>Ubicación</label><strong>@Show(record.EquipmentInformation.LocationCode) - @Show(record.EquipmentInformation.LocationName)</strong></div>
                <div><label>Responsable</label><strong>@Show(record.EquipmentInformation.ResponsibleName)</strong></div>
                <div><label>Tipo</label><strong>@Show(record.EquipmentInformation.ToolTypeName)</strong></div>
                <div><label>Categoría</label><strong>@Show(record.EquipmentInformation.ToolCategoryName)</strong></div>
                <div><label>Unidad</label><strong>@Show(record.EquipmentInformation.UnitOfMeasure)</strong></div>
                <div><label>Cantidad</label><strong>@record.EquipmentInformation.Quantity</strong></div>
            </div>
        </section>

        <section class="life-record-section">
            <div class="section-title">
                <span>2</span>
                <h2>Especificaciones técnicas</h2>
            </div>

            <div class="excel-grid two-columns">
                <div><label>Voltaje</label><strong>@Show(record.TechnicalSpecifications.Voltage)</strong></div>
                <div><label>Capacidad de carga</label><strong>@Show(record.TechnicalSpecifications.LoadCapacity)</strong></div>
                <div><label>Proveedor</label><strong>@Show(record.TechnicalSpecifications.Provider)</strong></div>
                <div><label>Requiere mantenimiento</label><strong>@BoolText(record.TechnicalSpecifications.RequiresMaintenance)</strong></div>
                <div><label>Requiere preoperacional</label><strong>@BoolText(record.TechnicalSpecifications.RequiresPreOperationalCheck)</strong></div>
                <div><label>Requiere certificación</label><strong>@BoolText(record.TechnicalSpecifications.RequiresCertification)</strong></div>
                <div><label>Vence certificación</label><strong>@DateText(record.TechnicalSpecifications.CertificationExpirationDate)</strong></div>
                <div><label>Garantía</label><strong>@BoolText(record.Warranty.HasWarranty)</strong></div>
                <div><label>Tipo garantía</label><strong>@Show(record.Warranty.WarrantyType)</strong></div>
            </div>
        </section>
    </div>

    <div class="life-readonly-note">Modo solo lectura. Esta vista se abrió desde el detalle del activo fijo.</div>
<div class="life-record-grid">
        <section class="life-record-section">
            <div class="section-title">
                <span>3</span>
                <h2>Vida útil</h2>
            </div>

            <div class="excel-grid two-columns">
                <div><label>Fecha inicial vida útil</label><strong>@DateText(record.UsefulLife.StartDate)</strong></div>
                <div><label>Fecha final vida útil</label><strong>@DateText(record.UsefulLife.EndDate)</strong></div>
                <div><label>Vida útil meses</label><strong>@NumberText(record.UsefulLife.UsefulLifeMonths)</strong></div>
                <div><label>Vida útil días</label><strong>@NumberText(record.UsefulLife.UsefulLifeDays)</strong></div>
                <div><label>Días transcurridos</label><strong>@NumberText(record.UsefulLife.ElapsedDays)</strong></div>
                <div><label>Días restantes</label><strong>@NumberText(record.UsefulLife.RemainingDays)</strong></div>
            </div>

            <div class="life-progress mt-3">
                <div class="life-progress-header">
                    <span>Uso de vida útil</span>
                    <strong>@NumberText(record.UsefulLife.UsedPercentage)%</strong>
                </div>
                <div class="bar-track">
                    <div class="bar-fill" style="width:@GetPercent(record.UsefulLife.UsedPercentage)%"></div>
                </div>
            </div>
        </section>

        <section class="life-record-section">
            <div class="section-title">
                <span>4</span>
                <h2>Plan de mantenimiento</h2>
            </div>

            <div class="excel-grid two-columns">
                <div><label>Último mantenimiento</label><strong>@DateText(record.MaintenancePlan.LastMaintenanceDate)</strong></div>
                <div><label>Próximo mantenimiento</label><strong>@DateText(record.MaintenancePlan.NextMaintenanceDate)</strong></div>
                <div><label>Periodicidad meses</label><strong>@NumberText(record.MaintenancePlan.MaintenancePeriodMonths)</strong></div>
                <div><label>Total mantenimientos</label><strong>@record.MaintenancePlan.TotalMaintenanceRecords</strong></div>
                <div><label>Completados</label><strong>@record.MaintenancePlan.CompletedMaintenanceRecords</strong></div>
                <div><label>Pendientes</label><strong>@record.MaintenancePlan.PendingMaintenanceRecords</strong></div>
            </div>
        </section>
    </div>

    <section class="life-record-section">
        <div class="section-title section-title-actions">
            <div class="section-title-main">
                <span>5</span>
                <h2>Accesorios del equipo</h2>
            </div>

            <a class="life-action life-action-primary" href="@($"/tools/{ToolId}/accessories")">
                Gestionar accesorios
            </a>
        </div>

        @if (record.Accessories.Count == 0)
        {
            <p class="text-muted mb-0">No hay accesorios registrados para esta herramienta.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-bordered excel-table">
                    <thead>
                        <tr>
                            <th>Accesorio</th>
                            <th>Cantidad</th>
                            <th>Requiere mantenimiento</th>
                            <th>Equipo de medición</th>
                            <th>Observación</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in record.Accessories)
                        {
                            <tr>
                                <td>@item.Name</td>
                                <td>@item.Quantity</td>
                                <td>@BoolText(item.RequiresMaintenance)</td>
                                <td>@BoolText(item.IsMeasurementEquipment)</td>
                                <td>@Show(item.Observation)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <div class="life-readonly-note">Modo solo lectura. Esta vista se abrió desde el detalle del activo fijo.</div>
<div class="life-record-grid">
        <section class="life-record-section">
            <div class="section-title">
                <span>6</span>
                <h2>Registro fotográfico</h2>
            </div>

            @if (record.Documents.PhotoRecords.Count == 0)
            {
                <p class="text-muted mb-0">No hay fotografías registradas.</p>
            }
            else
            {
                <div class="document-list">
                    @foreach (var doc in record.Documents.PhotoRecords)
                    {
                        <a href="@BuildApiUrl(doc.DownloadUrl)" target="_blank" class="document-card">
                            <strong>@doc.FileName</strong>
                            <span>@doc.DocumentType</span>
                        </a>
                    }
                </div>
            }
        </section>

        <section class="life-record-section">
            <div class="section-title">
                <span>7</span>
                <h2>Ficha técnica y documentos</h2>
            </div>

            @if (record.Documents.TechnicalDocuments.Count == 0 && record.Documents.AllDocuments.Count == 0)
            {
                <p class="text-muted mb-0">No hay documentos técnicos registrados.</p>
            }
            else
            {
                <div class="document-list">
                    @foreach (var doc in record.Documents.TechnicalDocuments.Concat(record.Documents.AllDocuments).DistinctBy(x => x.Id))
                    {
                        <a href="@BuildApiUrl(doc.DownloadUrl)" target="_blank" class="document-card">
                            <strong>@doc.FileName</strong>
                            <span>@doc.DocumentType</span>
                        </a>
                    }
                </div>
            }
        </section>
    </div>

    <section class="life-record-section">
        <div class="section-title section-title-actions">
            <div class="section-title-main">
                <span>8</span>
                <h2>Cronograma de mantenimiento</h2>
            </div>

            <a class="life-action life-action-primary" href="@($"/tools/{ToolId}/maintenance-schedule")">
                Gestionar mantenimientos
            </a>
        </div>

        @if (record.MaintenanceSchedule.Count == 0)
        {
            <p class="text-muted mb-0">No hay registros de mantenimiento.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-bordered excel-table">
                    <thead>
                        <tr>
                            <th>Número</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                            <th>Programado</th>
                            <th>Proveedor</th>
                            <th>Técnico</th>
                            <th>Actividades</th>
                            <th>Factura</th>
                            <th>Evidencia</th>
                            <th>Responsable</th>
                            <th>Cargo</th>
                            <th>Operativa</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in record.MaintenanceSchedule)
                        {
                            <tr>
                                <td>@item.MaintenanceNumber</td>
                                <td>@item.Type</td>
                                <td>@item.Status</td>
                                <td>@DateText(item.ScheduledAt)</td>
                                <td>@Show(item.Provider)</td>
                                <td>@Show(item.Technician)</td>
                                <td>@Show(item.MaintenanceActivities ?? item.Description)</td>
                                <td>@Show(item.InvoiceNumber)</td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(item.EvidenceDownloadUrl))
                                    {
                                        <a class="life-action life-action-primary"
                                           href="@BuildApiUrl(item.EvidenceDownloadUrl)"
                                           target="_blank">
                                            Descargar
                                        </a>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>@Show(item.ResponsibleName)</td>
                                <td>@Show(item.ResponsiblePosition)</td>
                                <td>@BoolText(item.IsToolOperational)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="life-record-section">
        <div class="section-title section-title-actions">
            <div class="section-title-main">
                <span>9</span>
                <h2>Prácticas seguras</h2>
            </div>

            <a class="life-action life-action-primary" href="@($"/tools/{ToolId}/safe-practices")">
                Gestionar prácticas
            </a>
        </div>

        @if (record.SafePractices.Count == 0)
        {
            <p class="text-muted mb-0">No hay prácticas seguras registradas.</p>
        }
        else
        {
            <div class="safe-practices-grid">
                @foreach (var item in record.SafePractices)
                {
                    <div class="safe-practice-card">
                        <span>@item.SortOrder</span>
                        <div>
                            <strong>@item.PracticeName</strong>
                            <p>@item.Description</p>
                        </div>
                    </div>
                }
            </div>
        }
    </section>

    <section class="life-record-section">
        <div class="section-title">
            <span>10</span>
            <h2>Eventos de hoja de vida</h2>
        </div>

        @if (record.LifeCycleEvents.Count == 0)
        {
            <p class="text-muted mb-0">No hay eventos registrados.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm table-bordered excel-table">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Evento</th>
                            <th>Título</th>
                            <th>Anterior</th>
                            <th>Nuevo</th>
                            <th>Usuario</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in record.LifeCycleEvents)
                        {
                            <tr>
                                <td>@DateTimeText(item.EventDate)</td>
                                <td>@item.EventType</td>
                                <td>@item.Title</td>
                                <td>@Show(item.PreviousValue)</td>
                                <td>@Show(item.NewValue)</td>
                                <td>@Show(item.PerformedBy)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}


