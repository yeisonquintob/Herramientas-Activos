    .dash-card {
        background: #fff;
        border: 1px solid #dfe3e8;
        border-radius: .85rem;
        padding: .95rem;
        box-shadow: 0 .28rem .7rem rgba(0,0,0,.04);
    }

    .span-2 { grid-column: span 2; }
    .span-4 { grid-column: span 4; }

    .card-head {
        display: flex;
