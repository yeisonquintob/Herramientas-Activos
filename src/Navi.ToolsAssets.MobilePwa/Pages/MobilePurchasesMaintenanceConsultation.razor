@page "/mobile/maintenance"
@page "/mobile/purchases-maintenance"
@page "/mobile/consultation"

@using System.Globalization
@using System.Net.Http
@using System.Text.Json
@using Microsoft.JSInterop
@using Microsoft.AspNetCore.Components.Rendering
@using Navi.ToolsAssets.MobilePwa.Models

@inject NaviMobileApiClient Api
@inject MobileAuthSessionService Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Consulta Compras y Mtto. móvil - NAVI Herramientas y AF</PageTitle>

<section class="mobile-page navi-mobile-consult-v1">
    @if (isLoading && !initialized)
    {
        <div class="mobile-loading">Cargando consulta...</div>
    }
    else if (!Auth.IsAuthenticated)
    {
        <div class="mobile-empty">
            <strong>Sesión requerida</strong>
            <span>Debes iniciar sesión para consultar compras y mantenimientos.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoLogin">Ir al login</button>
        </div>
    }
    else if (!CanAccessModule)
    {
        <div class="mobile-empty">
            <strong>Sin permiso</strong>
            <span>No tienes permisos para visualizar consulta de compras y mantenimiento.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoHome">Volver al inicio</button>
        </div>
    }
    else
    {
        <header class="mcon-hero">
            <div>
                <span>CONSULTA · COMPRAS · MTTO</span>
                <h1>Consulta Compras y Mtto.</h1>
                <p>@Display(Auth.CurrentUser?.DisplayName) · @ScopeLabel</p>
            </div>

            <div class="mcon-hero-actions">
                <button type="button" @onclick="GoHome">Inicio</button>
                <button type="button" @onclick="RefreshAsync" disabled="@isLoading">
                    @(isLoading ? "Actualizando..." : "Actualizar")
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="mobile-alert success">@successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="mobile-alert error">@errorMessage</div>
        }

        <section class="mcon-kpis">
            <article>
                <span>Total</span>
                <strong>@FilteredItems.Count()</strong>
                <small>Solicitudes</small>
            </article>

            <article>
                <span>Compras</span>
                <strong>@FilteredPurchases.Count()</strong>
                <small>Herramientas y AF</small>
            </article>

            <article>
                <span>Mtto.</span>
                <strong>@FilteredMaintenances.Count()</strong>
                <small>Mantenimiento</small>
            </article>

            <article>
                <span>En revisión</span>
                <strong>@FilteredItems.Count(x => IsStatus(x, "InReview"))</strong>
                <small>Por aprobar</small>
            </article>

            <article>
                <span>Con costo</span>
                <strong>@CostedItemsCount</strong>
                <small>Aprobadas/cerradas</small>
            </article>

            <article>
                <span>Rechazadas</span>
                <strong>@FilteredItems.Count(x => IsRejectedOrCanceled(x.Status))</strong>
                <small>No suman</small>
            </article>

            <article>
                <span>Costo</span>
                <strong>@FormatMoney(TotalEstimatedCost)</strong>
                <small>Estimado</small>
            </article>
        </section>

        <section class="mcon-filter-card">
            <label>
                <span>Tipo</span>
                <select @bind="typeFilter">
                    <option value="all">Compra y mantenimiento</option>
                    <option value="purchase">Solo compras</option>
                    <option value="maintenance">Solo mantenimiento</option>
                </select>
            </label>

            <label>
                <span>Estado</span>
                <select @bind="statusFilter">
                    <option value="all">Todos los estados</option>
                    <option value="Draft">Borrador</option>
                    <option value="InReview">En revisión</option>
                    <option value="Approved">Aprobadas</option>
                    <option value="Scheduled">Programadas</option>
                    <option value="InExecution">En ejecución</option>
                    <option value="Closed">Cerradas</option>
                    <option value="Rejected">Rechazadas</option>
                    <option value="Canceled">Canceladas</option>
                </select>
            </label>

            <label>
                <span>Sede</span>
                <select @bind="selectedBranchCode">
                    <option value="">Todas las sedes</option>
                    @foreach (var branch in branches.OrderBy(x => x.Code))
                    {
                        <option value="@branch.Code">@branch.Code - @branch.Name</option>
                    }
                </select>
            </label>

            <label>
                <span>Buscar</span>
                <input @bind="searchText"
                       @bind:event="oninput"
                       placeholder="Solicitud, activo, proveedor, técnico, sede..." />
            </label>

            <div class="mcon-filter-actions">
                <button type="button" @onclick="ClearFilters">Limpiar</button>
            </div>
        </section>

        <details class="mcon-card" open>
            <summary>
                <span>Resumen de costos</span>
                <em>@FormatMoney(TotalEstimatedCost)</em>
            </summary>

            <section class="mcon-cost-grid">
                <article>
                    <span>Compras</span>
                    <strong>@FormatMoney(PurchaseCost)</strong>
                    <small>Promedio: @FormatMoney(PurchaseAverage)</small>
                    <small>Mayor: @FormatMoney(PurchaseMax)</small>
                    <small>Proveedores: @PurchaseProviders</small>
                </article>

                <article>
                    <span>Mantenimiento</span>
                    <strong>@FormatMoney(MaintenanceCost)</strong>
                    <small>Promedio: @FormatMoney(MaintenanceAverage)</small>
                    <small>Mayor: @FormatMoney(MaintenanceMax)</small>
                    <small>Proveedores: @MaintenanceProviders</small>
                </article>
            </section>
        </details>

        @if (ShowPurchases)
        {
            <details class="mcon-card" open>
                <summary>
                    <span>Compras</span>
                    <em>@FilteredPurchases.Count()</em>
                </summary>

                @if (!FilteredPurchases.Any())
                {
                    <div class="mobile-empty compact">No hay solicitudes de compra para los filtros seleccionados.</div>
                }
                else
                {
                    <div class="mcon-list">
                        @foreach (var item in FilteredPurchases)
                        {
                            @RenderCard(item)
                        }
                    </div>
                }
            </details>
        }

        @if (ShowMaintenances)
        {
            <details class="mcon-card" open>
                <summary>
                    <span>Mantenimiento</span>
                    <em>@FilteredMaintenances.Count()</em>
                </summary>

                @if (!FilteredMaintenances.Any())
                {
                    <div class="mobile-empty compact">No hay solicitudes de mantenimiento para los filtros seleccionados.</div>
                }
                else
                {
                    <div class="mcon-list">
                        @foreach (var item in FilteredMaintenances)
                        {
                            @RenderCard(item)
                        }
                    </div>
                }
            </details>
        }

        @if (selectedItem is not null)
        {
            <div class="mcon-modal-backdrop" @onclick="CloseDetails">
                <div class="mcon-modal" @onclick:stopPropagation="true">
                    <header class="mcon-modal-header">
                        <div>
                            <span>@(selectedItem.Kind == RequestKind.Purchase ? "Compra" : "Mantenimiento")</span>
                            <h2>@selectedItem.Number</h2>
                            <p>@ShortText(selectedItem.AssetName, 80)</p>
                        </div>

                        <button type="button" @onclick="CloseDetails">Cerrar</button>
                    </header>

                    <section class="mcon-modal-grid">
                        <div><span>Estado</span><strong>@StatusLabel(selectedItem.Status)</strong></div>
                        <div><span>Prioridad</span><strong>@Display(selectedItem.Priority)</strong></div>
                        <div><span>Tipo</span><strong>@Display(selectedItem.Type)</strong></div>
                        <div><span>Costo</span><strong>@FormatMoney(selectedItem.EstimatedCost)</strong></div>
                        <div><span>Proveedor</span><strong>@Display(selectedItem.Provider)</strong></div>
                        <div><span>Sede</span><strong>@Display(selectedItem.Branch)</strong></div>
                        <div><span>Solicitó</span><strong>@Display(selectedItem.RequestedBy)</strong></div>
                        <div><span>Preparó</span><strong>@Display(selectedItem.PreparedBy)</strong></div>
                        <div><span>Técnico</span><strong>@Display(selectedItem.Technician)</strong></div>
                        <div><span>Creada</span><strong>@FormatDate(selectedItem.CreatedAt)</strong></div>
                        <div><span>Programada</span><strong>@FormatDate(selectedItem.ScheduledAt)</strong></div>
                        <div><span>Cerrada</span><strong>@FormatDate(selectedItem.ClosedAt)</strong></div>
                    </section>

                    <section class="mcon-modal-section">
                        <h3>Necesidad / activo</h3>
                        <p>@Display(selectedItem.AssetName)</p>
                    </section>

                    <section class="mcon-modal-section">
                        <h3>Detalle de la solicitud</h3>
                        <p>@Display(selectedItem.Description)</p>
                    </section>

                    <section class="mcon-modal-section">
                        <h3>Notas / observaciones</h3>
                        <p>@Display(selectedItem.Notes)</p>
                    </section>

                    <section class="mcon-modal-actions">
                        @RenderActions(selectedItem)
                    </section>
                </div>
            </div>
        }
    }
</section>

@code {
    private bool initialized;
    private bool hasRendered;
    private bool isLoading = true;

    private string typeFilter = "all";
    private string statusFilter = "all";
    private string searchText = string.Empty;
    private string selectedBranchCode = string.Empty;
    private bool branchFilterInitialized;
private string? successMessage;
    private string? errorMessage;

    private List<ConsultationItem> apiItems = new();
    private List<ConsultationItem> localItems = new();
    private List<ConsultationItem> items = new();
    private List<MobileBranchDto> branches = new();

    private ConsultationItem? selectedItem;

    private bool IsAdmin =>
        string.Equals(Auth.CurrentUser?.RoleCode, "ADMIN", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(Auth.CurrentUser?.RoleCode, "SUPERADMIN", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(Auth.CurrentUser?.RoleName, "Administrador", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(Auth.CurrentUser?.RoleName, "Administrador NAVI", StringComparison.OrdinalIgnoreCase);

    private bool CanViewPurchase =>
        IsAdmin || HasAny("Purchases.View", "Purchases.Request", "Purchases.Quote", "Purchases.Generate", "Purchases.Approve", "Purchases.Reject");

    private bool CanViewMaintenance =>
        IsAdmin || HasAny("Maintenance.View", "Maintenance.Request", "Maintenance.Quote", "Maintenance.Generate", "Maintenance.Execute", "Maintenance.Close", "Maintenance.Reject");

    private bool CanAccessModule => CanViewPurchase || CanViewMaintenance;

    private bool CanApprovePurchase => IsAdmin || Has("Purchases.Approve");
    private bool CanRejectPurchase => IsAdmin || Has("Purchases.Reject");
    private bool CanExecuteMaintenance => IsAdmin || Has("Maintenance.Execute");
    private bool CanCloseMaintenance => IsAdmin || Has("Maintenance.Close");
    private bool CanRejectMaintenance => IsAdmin || Has("Maintenance.Reject");

    private string ScopeLabel =>
        UserCanSeeAllBranches()
            ? "Todas las sedes"
            : Display(Auth.CurrentUser?.BranchName ?? Auth.CurrentUser?.BranchCode);

    private IEnumerable<ConsultationItem> FilteredItems =>
        items
            .Where(MatchesBranchFilter)
            .Where(x => typeFilter == "all" ||
                        (typeFilter == "purchase" && x.Kind == RequestKind.Purchase) ||
                        (typeFilter == "maintenance" && x.Kind == RequestKind.Maintenance))
            .Where(x => statusFilter == "all" || IsStatus(x, statusFilter))
            .Where(MatchesSearch)
            .OrderByDescending(x => x.UpdatedAt ?? x.CreatedAt ?? DateTime.MinValue);

    private IEnumerable<ConsultationItem> FilteredPurchases => FilteredItems.Where(x => x.Kind == RequestKind.Purchase);
    private IEnumerable<ConsultationItem> FilteredMaintenances => FilteredItems.Where(x => x.Kind == RequestKind.Maintenance);

    private bool ShowPurchases => typeFilter is "all" or "purchase";
    private bool ShowMaintenances => typeFilter is "all" or "maintenance";

    private IEnumerable<ConsultationItem> CostItems => FilteredItems.Where(x => IsPositiveCostStatus(x.Status) && x.EstimatedCost > 0);
    private IEnumerable<ConsultationItem> PurchaseCostItems => CostItems.Where(x => x.Kind == RequestKind.Purchase);
    private IEnumerable<ConsultationItem> MaintenanceCostItems => CostItems.Where(x => x.Kind == RequestKind.Maintenance);

    private decimal TotalEstimatedCost => CostItems.Sum(x => x.EstimatedCost);
    private int CostedItemsCount => CostItems.Count();

    private decimal PurchaseCost => PurchaseCostItems.Sum(x => x.EstimatedCost);
    private decimal PurchaseAverage => PurchaseCostItems.Any() ? PurchaseCostItems.Average(x => x.EstimatedCost) : 0;
    private decimal PurchaseMax => PurchaseCostItems.Any() ? PurchaseCostItems.Max(x => x.EstimatedCost) : 0;
    private int PurchaseProviders => PurchaseCostItems.Select(x => x.Provider).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).Count();

    private decimal MaintenanceCost => MaintenanceCostItems.Sum(x => x.EstimatedCost);
    private decimal MaintenanceAverage => MaintenanceCostItems.Any() ? MaintenanceCostItems.Average(x => x.EstimatedCost) : 0;
    private decimal MaintenanceMax => MaintenanceCostItems.Any() ? MaintenanceCostItems.Max(x => x.EstimatedCost) : 0;
    private int MaintenanceProviders => MaintenanceCostItems.Select(x => x.Provider).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).Count();

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsAuthenticated)
        {
            isLoading = false;
            initialized = true;
            return;
        }

        await LoadBranchesAsync();
        ApplyDefaultBranchFilterIfNeeded();
        await RefreshApiOnlyAsync();

        items = Deduplicate(apiItems.Concat(localItems)).ToList();

        isLoading = false;
        initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        hasRendered = true;

        if (Auth.IsAuthenticated && CanAccessModule)
        {
            localItems = await LoadLocalItemsAsync();
            items = Deduplicate(apiItems.Concat(localItems)).ToList();
            StateHasChanged();
        }
    }

    private async Task RefreshAsync()
    {
        if (!CanAccessModule)
        {
            return;
        }

        isLoading = true;
        successMessage = null;
        errorMessage = null;

        try
        {
            await LoadBranchesAsync();
            ApplyDefaultBranchFilterIfNeeded();
            await RefreshApiOnlyAsync();

            if (hasRendered)
            {
                localItems = await LoadLocalItemsAsync();
            }

            items = Deduplicate(apiItems.Concat(localItems)).ToList();
            successMessage = $"Consulta actualizada correctamente. Registros cargados: {items.Count}.";
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudo actualizar la consulta: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadBranchesAsync()
    {
        try
        {
            branches = await Api.GetBranchesAsync();
        }
        catch
        {
            branches = new();
        }
    }

    private async Task RefreshApiOnlyAsync()
    {
        var loaded = new List<ConsultationItem>();

        if (CanViewPurchase)
        {
            try
            {
                var rows = await Api.GetListJsonAsync<PurchaseRequestItem>("api/purchase-requests");
                loaded.AddRange(rows.Select(MapPurchaseApiItem));
            }
            catch
            {
                // No rompe la consulta si el endpoint no está disponible.
            }
        }

        if (CanViewMaintenance)
        {
            try
            {
                var rows = await Api.GetListJsonAsync<MaintenanceRequestItem>("api/maintenance-requests");
                loaded.AddRange(rows.Select(MapMaintenanceApiItem));
            }
            catch
            {
                // No rompe la consulta si el endpoint no está disponible.
            }
        }

        apiItems = loaded;
    }

    private async Task<List<ConsultationItem>> LoadLocalItemsAsync()
    {
        var result = new List<ConsultationItem>();

        await LoadLocalStorageKeyAsync("navi-mobile-purchase-request-v1", RequestKind.Purchase, result);
        await LoadLocalStorageKeyAsync("navi-mobile-maintenance-request-v2", RequestKind.Maintenance, result);

        return result;
    }

    private async Task LoadLocalStorageKeyAsync(string key, RequestKind kind, List<ConsultationItem> result)
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", key);

            if (string.IsNullOrWhiteSpace(json))
            {
                return;
            }

            using var document = JsonDocument.Parse(json);

            if (document.RootElement.ValueKind != JsonValueKind.Array)
            {
                return;
            }

            foreach (var item in document.RootElement.EnumerateArray())
            {
                var mapped = kind == RequestKind.Purchase
                    ? MapPurchaseLocalItem(item, key)
                    : MapMaintenanceLocalItem(item, key);

                result.Add(mapped);
            }
        }
        catch
        {
            // El almacenamiento local es apoyo, no debe romper.
        }
    }

    private ConsultationItem MapPurchaseApiItem(PurchaseRequestItem item)
    {
        return new ConsultationItem
        {
            Id = item.Id.ToString(),
            Number = Display(item.RequestNumber),
            Kind = RequestKind.Purchase,
            SourceKind = SourceKind.Api,
            Source = "API",
            Type = item.PurchasePurpose ?? "Compra",
            Priority = item.Priority ?? "Media",
            Status = NormalizeStatus(item.Status),
            AssetName = FirstNonEmpty(item.ItemName, item.ItemCode, item.RequestNumber),
            Description = string.Join(" · ", new[] { item.ItemDescription, item.Justification, item.Notes }.Where(x => !string.IsNullOrWhiteSpace(x))),
            Provider = item.VendorSuggestion,
            EstimatedCostText = item.EstimatedCostText,
            EstimatedCost = ParseMoney(item.EstimatedCostText),
            CreatedAt = item.CreatedAt,
            UpdatedAt = item.UpdatedAt,
            ScheduledAt = item.RequiredAt,
            ClosedAt = item.ClosedAt ?? item.RejectedAt ?? item.CanceledAt,
            RequestedBy = FirstNonEmpty(item.RequestedByResponsiblePersonName, item.RequestedByUserName),
            PreparedBy = item.PreparedBy,
            Technician = null,
            Branch = FirstNonEmpty(item.BranchCode, item.BranchName),
            Notes = FirstNonEmpty(item.Notes, item.ApprovalComment, item.RejectionReason),
            RawText = JsonSerializer.Serialize(item)
        };
    }

    private ConsultationItem MapMaintenanceApiItem(MaintenanceRequestItem item)
    {
        return new ConsultationItem
        {
            Id = item.Id.ToString(),
            Number = Display(item.RequestNumber),
            Kind = RequestKind.Maintenance,
            SourceKind = SourceKind.Api,
            Source = "API",
            Type = item.RequestType ?? "Mtto.",
            Priority = item.Priority ?? "Media",
            Status = NormalizeStatus(item.Status),
            AssetName = FirstNonEmpty(item.Title, item.ToolName, item.ToolInternalCode, item.RequestNumber),
            Description = string.Join(" · ", new[] { item.ProblemDescription, item.WorkDescription, item.FailureCause, item.Notes }.Where(x => !string.IsNullOrWhiteSpace(x))),
            Provider = item.VendorSuggestion,
            EstimatedCostText = item.EstimatedCostText,
            EstimatedCost = ParseMoney(item.EstimatedCostText),
            CreatedAt = item.CreatedAt,
            UpdatedAt = item.UpdatedAt,
            ScheduledAt = item.ScheduledAt ?? item.RequiredAt,
            ClosedAt = item.ClosedAt ?? item.RejectedAt ?? item.CanceledAt,
            RequestedBy = FirstNonEmpty(item.RequestedByResponsiblePersonName, item.RequestedByUserName),
            PreparedBy = item.PreparedBy,
            Technician = FirstNonEmpty(item.AssignedTechnician, item.ExecutionStartedBy),
            Branch = FirstNonEmpty(item.BranchCode, item.BranchName),
            Notes = FirstNonEmpty(item.Notes, item.ApprovalComment, item.RejectionReason, item.ClosingComment),
            RawText = JsonSerializer.Serialize(item)
        };
    }

    private ConsultationItem MapPurchaseLocalItem(JsonElement item, string storageKey)
    {
        var id = GetString(item, "Id", "id");
        var number = GetString(item, "LocalNumber", "localNumber", "RequestNumber", "requestNumber", "Number", "number");
        var status = GetString(item, "Status", "status");
        var header = item.TryGetProperty("Header", out var headerElement) ? headerElement : default;
        var lines = item.TryGetProperty("Lines", out var linesElement) ? linesElement : default;
        var quotes = item.TryGetProperty("Quotations", out var quotesElement) ? quotesElement : default;

        var firstLine = GetFirstArrayObject(lines);
        var firstQuote = GetFirstArrayObject(quotes);

        var branchId = GetString(header, "BranchIdText", "branchIdText");
        var branch = ResolveBranchLabel(branchId);

        return new ConsultationItem
        {
            Id = id ?? number ?? Guid.NewGuid().ToString(),
            Number = number ?? "Local compra",
            Kind = RequestKind.Purchase,
            SourceKind = SourceKind.BrowserStorage,
            Source = "Local",
            StorageKey = storageKey,
            Type = GetString(header, "PurchasePurpose", "purchasePurpose") ?? "Compra",
            Priority = GetString(header, "Priority", "priority") ?? "Media",
            Status = NormalizeStatus(status),
            AssetName = FirstNonEmpty(GetString(firstLine, "ItemName", "itemName"), GetString(header, "RequestName", "requestName")),
            Description = string.Join(" · ", new[]
            {
                GetString(header, "Justification", "justification"),
                GetString(firstLine, "ItemDescription", "itemDescription"),
                GetString(firstLine, "NeedDetail", "needDetail")
            }.Where(x => !string.IsNullOrWhiteSpace(x))),
            Provider = GetString(firstQuote, "Provider", "provider"),
            EstimatedCostText = GetString(firstQuote, "PriceBeforeVat", "priceBeforeVat"),
            EstimatedCost = ParseMoney(GetString(firstQuote, "PriceBeforeVat", "priceBeforeVat")),
            CreatedAt = GetDate(item, "CreatedAt", "createdAt"),
            UpdatedAt = GetDate(item, "UpdatedAt", "updatedAt"),
            ScheduledAt = GetDate(header, "RequiredAt", "requiredAt"),
            RequestedBy = GetString(header, "RequestedBy", "requestedBy"),
            PreparedBy = GetString(header, "Approver", "approver"),
            Branch = branch,
            Notes = GetString(header, "AreaOrCostCenter", "areaOrCostCenter"),
            RawText = item.GetRawText()
        };
    }

    private ConsultationItem MapMaintenanceLocalItem(JsonElement item, string storageKey)
    {
        var id = GetString(item, "Id", "id");
        var number = GetString(item, "LocalNumber", "localNumber", "RequestNumber", "requestNumber", "Number", "number");
        var status = GetString(item, "Status", "status");
        var header = item.TryGetProperty("Header", out var headerElement) ? headerElement : default;
        var lines = item.TryGetProperty("Lines", out var linesElement) ? linesElement : default;
        var quotes = item.TryGetProperty("Quotations", out var quotesElement) ? quotesElement : default;

        var firstLine = GetFirstArrayObject(lines);
        var firstQuote = GetFirstArrayObject(quotes);

        var branchId = GetString(header, "BranchIdText", "branchIdText");
        var branch = ResolveBranchLabel(branchId);

        return new ConsultationItem
        {
            Id = id ?? number ?? Guid.NewGuid().ToString(),
            Number = number ?? "Local mtto.",
            Kind = RequestKind.Maintenance,
            SourceKind = SourceKind.BrowserStorage,
            Source = "Local",
            StorageKey = storageKey,
            Type = GetString(header, "RequestType", "requestType") ?? "Mtto.",
            Priority = GetString(header, "Priority", "priority") ?? "Media",
            Status = NormalizeStatus(status),
            AssetName = FirstNonEmpty(GetString(firstLine, "ToolName", "toolName"), GetString(header, "RequestName", "requestName")),
            Description = string.Join(" · ", new[]
            {
                GetString(header, "NeedDescription", "needDescription"),
                GetString(firstLine, "Details", "details"),
                GetString(firstLine, "Novelty", "novelty")
            }.Where(x => !string.IsNullOrWhiteSpace(x))),
            Provider = GetString(firstQuote, "Provider", "provider"),
            EstimatedCostText = GetString(firstQuote, "PriceBeforeVat", "priceBeforeVat"),
            EstimatedCost = ParseMoney(GetString(firstQuote, "PriceBeforeVat", "priceBeforeVat")),
            CreatedAt = GetDate(item, "CreatedAt", "createdAt"),
            UpdatedAt = GetDate(item, "UpdatedAt", "updatedAt"),
            ScheduledAt = GetDate(header, "RequiredAt", "requiredAt"),
            RequestedBy = GetString(header, "RequestedBy", "requestedBy"),
            PreparedBy = GetString(header, "Approver", "approver"),
            Technician = GetString(firstLine, "TechnicalOrSerial", "technicalOrSerial"),
            Branch = branch,
            Notes = GetString(header, "Location", "location"),
            RawText = item.GetRawText()
        };
    }

    private RenderFragment RenderCard(ConsultationItem item) => builder =>
    {
        var seq = 0;

        builder.OpenElement(seq++, "article");
        builder.AddAttribute(seq++, "class", $"mcon-item {StatusClass(item.Status)}");

        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "mcon-item-head");

        builder.OpenElement(seq++, "div");
        builder.OpenElement(seq++, "strong");
        builder.AddContent(seq++, item.Number);
        builder.CloseElement();
        builder.OpenElement(seq++, "span");
        builder.AddContent(seq++, item.Kind == RequestKind.Purchase ? "Compra" : "Mantenimiento");
        builder.CloseElement();
        builder.CloseElement();

        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", $"mcon-status {StatusClass(item.Status)}");
        builder.AddContent(seq++, StatusLabel(item.Status));
        builder.CloseElement();

        builder.CloseElement();

        builder.OpenElement(seq++, "h3");
        builder.AddContent(seq++, ShortText(item.AssetName, 56));
        builder.CloseElement();

        builder.OpenElement(seq++, "p");
        builder.AddContent(seq++, ShortText(item.Description, 120));
        builder.CloseElement();

        builder.OpenElement(seq++, "section");
        builder.AddAttribute(seq++, "class", "mcon-mini-grid");
        AddMini(builder, ref seq, "Prioridad", item.Priority);
        AddMini(builder, ref seq, "Costo", FormatMoney(item.EstimatedCost));
        AddMini(builder, ref seq, "Proveedor", Display(item.Provider));
        AddMini(builder, ref seq, "Sede", Display(item.Branch));
        AddMini(builder, ref seq, "Solicitó", Display(item.RequestedBy));
        AddMini(builder, ref seq, "Fecha", FormatDate(item.CreatedAt));
        builder.CloseElement();

        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "mcon-actions");

        builder.OpenElement(seq++, "button");
        builder.AddAttribute(seq++, "type", "button");
        builder.AddAttribute(seq++, "class", "view");
        builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, () => OpenDetails(item)));
        builder.AddContent(seq++, "Ver");
        builder.CloseElement();

        builder.AddContent(seq++, RenderActions(item));

        builder.CloseElement();

        builder.CloseElement();
    };

    private void AddMini(RenderTreeBuilder builder, ref int seq, string label, string value)
    {
        builder.OpenElement(seq++, "div");
        builder.OpenElement(seq++, "span");
        builder.AddContent(seq++, label);
        builder.CloseElement();
        builder.OpenElement(seq++, "strong");
        builder.AddContent(seq++, value);
        builder.CloseElement();
        builder.CloseElement();
    }

    private RenderFragment RenderActions(ConsultationItem item) => builder =>
    {
        var seq = 0;

        if (item.Kind == RequestKind.Purchase)
        {
            if (IsStatus(item, "InReview"))
            {
                ActionButton(builder, ref seq, "Aprobar", "approve", !CanApprovePurchase, () => ApprovePurchaseAsync(item));
                ActionButton(builder, ref seq, "Rechazar", "reject", !CanRejectPurchase, () => RejectPurchaseAsync(item));
            }
            else if (IsStatus(item, "Approved"))
            {
                ActionButton(builder, ref seq, "Cerrar", "approve", !CanApprovePurchase, () => ClosePurchaseAsync(item));
            }

            return;
        }

        if (IsStatus(item, "InReview"))
        {
            ActionButton(builder, ref seq, "Aprobar", "approve", !CanCloseMaintenance, () => ApproveMaintenanceAsync(item));
            ActionButton(builder, ref seq, "Rechazar", "reject", !CanRejectMaintenance, () => RejectMaintenanceAsync(item));
        }
        else if (IsStatus(item, "Approved") || IsStatus(item, "Scheduled"))
        {
            ActionButton(builder, ref seq, "Ejecutar", "execute", !CanExecuteMaintenance, () => ExecuteMaintenanceAsync(item));
            ActionButton(builder, ref seq, "Cerrar", "approve", !CanExecuteMaintenance && !CanCloseMaintenance, () => CloseMaintenanceAsync(item));
        }
        else if (IsStatus(item, "InExecution"))
        {
            ActionButton(builder, ref seq, "Cerrar", "approve", !CanExecuteMaintenance && !CanCloseMaintenance, () => CloseMaintenanceAsync(item));
        }
    };

    private void ActionButton(RenderTreeBuilder builder, ref int seq, string text, string css, bool disabled, Func<Task> action)
    {
        builder.OpenElement(seq++, "button");
        builder.AddAttribute(seq++, "type", "button");
        builder.AddAttribute(seq++, "class", css);
        builder.AddAttribute(seq++, "disabled", disabled);
        builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, action));
        builder.AddContent(seq++, text);
        builder.CloseElement();
    }

