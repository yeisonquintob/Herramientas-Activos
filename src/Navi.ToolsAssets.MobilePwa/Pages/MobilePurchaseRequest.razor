    private async Task ExecuteActionAsync(string endpoint, string okMessage, object? body = null)
    {
        try
        {
            errorMessage = null;
            successMessage = null;

            await Api.SendJsonAsync(HttpMethod.Post, endpoint, body ?? new { comment = "Acción ejecutada desde app móvil." });

            successMessage = okMessage;
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
