@page "/"

@inject NaviMobileApiClient Api
@inject MobileAuthSessionService Auth
@inject NavigationManager Navigation

<PageTitle>Inicio móvil - NAVI Herramientas y AF</PageTitle>

@if (isInitializing)
{
    <section class="mobile-page">
        <div class="mobile-loading">Cargando aplicación móvil...</div>
    </section>
}
else if (!Auth.IsAuthenticated)
{
    <section class="mobile-page">
        <div class="mobile-empty">
            <strong>Sesión requerida</strong>
            <span>Debes iniciar sesión para ingresar a la app móvil.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoLogin">Ir al login</button>
        </div>
    </section>
}
else
{
    <section class="mobile-page">
        <header class="mobile-hero">
            <div class="mobile-hero-top">
                <span class="mobile-pill">APP MÓVIL</span>

                <button class="mobile-logout-button" type="button" @onclick="LogoutAsync">
                    Cerrar sesión
                </button>
            </div>

            <h1>Hola, @Auth.CurrentUser?.DisplayName</h1>
            <p>@Auth.CurrentUser?.RoleName · @Auth.CurrentUser?.BranchName</p>
        </header>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="mobile-alert">@message</div>
        }

        <section class="mobile-kpi-grid">
            <div class="mobile-kpi-card">
                <span>Activos visibles</span>
                <strong>@visibleTools.Count</strong>
                <small>Según rol y sede</small>
            </div>

            <div class="mobile-kpi-card warning">
                <span>Con novedad</span>
                <strong>@damagedCount</strong>
                <small>Dañados / no aptos</small>
            </div>

            <div class="mobile-kpi-card ok">
                <span>Disponibles</span>
                <strong>@availableCount</strong>
                <small>Para operación</small>
            </div>
        </section>

        <section class="mobile-menu-panel">
            <div class="mobile-panel-head">
                <h2>Menú operativo</h2>
                <button type="button" @onclick="LoadAsync">Actualizar</button>
            </div>

            <div class="mobile-menu-grid">
                @foreach (var item in MenuItems)
                {
                    <a class="mobile-menu-card" href="@item.Url">
                        <span>@item.Code</span>
                        <strong>@item.Title</strong>
                        <small>@item.Description</small>
                    </a>
                }
            </div>
        </section>

        <section class="mobile-panel">
            <div class="mobile-panel-head">
                <h2>Últimos activos</h2>
                <a class="mobile-panel-link" href="/my-tools">Ver lista</a>
            </div>

            @if (!visibleTools.Any())
            {
                <div class="mobile-empty compact">
                    No se encontraron activos relacionados con tu usuario.
                </div>
            }
            else
            {
                @foreach (var tool in visibleTools.Take(4))
                {
                    <article class="mobile-tool-card">
                        <div>
                            <span>@tool.InternalCode</span>
                            <strong>@tool.Name</strong>
                            <small>@Display(tool.LocationName) · @Display(tool.OperationalStatus)</small>
                        </div>

                        <a class="mobile-mini-link" href="@GetDetailUrl(tool.Id)">Detalle</a>
                    </article>
                }
            }
        </section>
    </section>
}

@code {
    private bool isInitializing = true;
    private string? message;
    private List<MobileToolDto> tools = new();

    private List<MobileToolDto> visibleTools => FilterForCurrentUser(tools).ToList();

    private int damagedCount => visibleTools.Count(x =>
        ContainsStatus(x.OperationalStatus, "Damaged") ||
        ContainsStatus(x.OperationalStatus, "NotSuitable") ||
        ContainsStatus(x.PhysicalStatus, "Damaged"));

    private int availableCount => visibleTools.Count(x => ContainsStatus(x.OperationalStatus, "Available"));

    private IEnumerable<MobileMenuItem> MenuItems
    {
        get
        {
            if (Auth.IsTecnico())
            {
                return new[]
                {
                    new MobileMenuItem("AF", "Mis herramientas", "/my-tools", "Activos asignados"),
                    new MobileMenuItem("DAN", "Reportar novedad", "/report-damage", "Daño o falla"),
                    new MobileMenuItem("HV", "Hoja de vida AF", "/my-tools", "Consulta técnica"),
                    new MobileMenuItem("HIS", "Historial propio", "/mobile/history", "Movimientos propios"),
                    new MobileMenuItem("PRE", "Preoperacional", "/mobile/preoperational", "Reporte SSTA"),
                    new MobileMenuItem("DOC", "Documentos", "/mobile/documents", "Evidencias")
                };
            }

            if (Auth.CanSeeAllTools())
            {
                return new[]
                {
                    new MobileMenuItem("ALL", "Todas herramientas", "/all-tools", "Inventario visible"),
                    new MobileMenuItem("AF", "Mis herramientas", "/my-tools", "Activos relacionados"),
                    new MobileMenuItem("DAN", "Reportar novedad", "/report-damage", "Daño o falla"),
                    new MobileMenuItem("HV", "Hoja de vida AF", "/all-tools", "Consulta técnica"),
                    new MobileMenuItem("HIS", "Historial", "/mobile/history", "Movimientos"),
                    new MobileMenuItem("DOC", "Documentos", "/mobile/documents", "Evidencias"),
                    new MobileMenuItem("TF", "Tomas físicas", "/mobile/physical-counts", "Validaciones"),
                    new MobileMenuItem("REP", "Reportes", "/mobile/reports", "Indicadores")
                };
            }

            return new[]
            {
                new MobileMenuItem("AF", "Mis herramientas", "/my-tools", "Activos de la sede"),
                new MobileMenuItem("DAN", "Reportar novedad", "/report-damage", "Daño o falla"),
                new MobileMenuItem("HV", "Hoja de vida AF", "/my-tools", "Consulta técnica"),
                new MobileMenuItem("HIS", "Historial", "/mobile/history", "Movimientos"),
                new MobileMenuItem("DOC", "Documentos", "/mobile/documents", "Evidencias"),
                new MobileMenuItem("TF", "Tomas físicas", "/mobile/physical-counts", "Validaciones")
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        await LoadAsync();

        isInitializing = false;
    }

    private async Task LoadAsync()
    {
        try
        {
            message = null;
            tools = await Api.GetToolsAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void GoLogin()
    {
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private IEnumerable<MobileToolDto> FilterForCurrentUser(IEnumerable<MobileToolDto> source)
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return Enumerable.Empty<MobileToolDto>();
        }

        if (Auth.IsAdmin() || Auth.CanSeeAllTools())
        {
            return source;
        }

        if (Auth.IsTecnico())
        {
            if (user.ResponsiblePersonId.HasValue)
            {
                var own = source.Where(x => x.ResponsiblePersonId == user.ResponsiblePersonId.Value).ToList();

                if (own.Any())
                {
                    return own;
                }
            }

            if (!string.IsNullOrWhiteSpace(user.ResponsiblePersonName))
            {
                var ownByName = source.Where(x =>
                    string.Equals(x.ResponsiblePersonName, user.ResponsiblePersonName, StringComparison.OrdinalIgnoreCase)).ToList();

                if (ownByName.Any())
                {
                    return ownByName;
                }
            }

            if (!string.IsNullOrWhiteSpace(user.BranchCode) &&
                !string.Equals(user.BranchCode, "TODAS", StringComparison.OrdinalIgnoreCase))
            {
                return source.Where(x =>
                    string.Equals(x.BranchCode, user.BranchCode, StringComparison.OrdinalIgnoreCase) ||
                    string.Equals(x.BranchName, user.BranchName, StringComparison.OrdinalIgnoreCase));
            }

            return Enumerable.Empty<MobileToolDto>();
        }

        if (!string.IsNullOrWhiteSpace(user.BranchCode) &&
            !string.Equals(user.BranchCode, "TODAS", StringComparison.OrdinalIgnoreCase))
        {
            return source.Where(x =>
                string.Equals(x.BranchCode, user.BranchCode, StringComparison.OrdinalIgnoreCase) ||
                string.Equals(x.BranchName, user.BranchName, StringComparison.OrdinalIgnoreCase));
        }

        return source;
    }

    private static bool ContainsStatus(string? value, string expected)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               value.Contains(expected, StringComparison.OrdinalIgnoreCase);
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Sin dato" : value;
    }

    private static string GetDetailUrl(Guid id)
    {
        return "/tools/" + id;
    }

    private sealed record MobileMenuItem(string Code, string Title, string Url, string Description);
}
