@page "/"

@using Microsoft.AspNetCore.Components
@using Navi.ToolsAssets.MobilePwa.Models

@inject NaviMobileApiClient Api
@inject MobileAuthSessionService Auth
@inject NavigationManager Navigation

<PageTitle>Inicio móvil - NAVI Herramientas y AF</PageTitle>

@if (isInitializing)
{
    <section class="mobile-page mobile-page-compact">
        <div class="mobile-loading">Cargando aplicación móvil...</div>
    </section>
}
else if (!Auth.IsAuthenticated)
{
    <section class="mobile-page mobile-page-compact">
        <div class="mobile-empty">
            <strong>Sesión requerida</strong>
            <span>Debes iniciar sesión para ingresar a la app móvil.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoLogin">Ir al login</button>
        </div>
    </section>
}
else
{
    <section class="mobile-page mobile-page-compact">
        <header class="mobile-hero mobile-hero-compact-pro mobile-home-web-hero navi-home-hero-v4">
            <div class="navi-home-hero-v4-content">
                <div class="navi-home-hero-v4-left">
                    <span class="mobile-pill mobile-pill-dark mobile-app-pill-one-line">APP MÓVIL</span>
                    <h1>Hola, @Display(Auth.CurrentUser?.DisplayName)</h1>
                    <p>@Display(Auth.CurrentUser?.BranchName)</p>
                </div>

                <button class="mobile-logout-button mobile-logout-compact navi-home-logout-v4" type="button" @onclick="LogoutAsync">
                    Cerrar sesión
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="@messageClass">@message</div>
        }

        <section class="mobile-kpi-grid mobile-kpi-grid-compact mobile-kpi-grid-ultra">
            <div class="mobile-kpi-card mobile-kpi-compact mobile-kpi-ultra">
                <span>Mis activos</span>
                <strong>@assignedTools.Count</strong>
                <small>Asignados</small>
            </div>

            <div class="mobile-kpi-card mobile-kpi-compact mobile-kpi-ultra warning">
                <span>Novedad</span>
                <strong>@damageReportedCount</strong>
                <small>Reportados</small>
            </div>

            <div class="mobile-kpi-card mobile-kpi-compact mobile-kpi-ultra ok">
                <span>Disponibles</span>
                <strong>@availableCount</strong>
                <small>Operación</small>
            </div>
        </section>

        <section class="mobile-quick-actions navi-quick-actions-v4 navi-quick-actions-compact">
            <button type="button" class="loan" @onclick="ToggleLoanRequest">
                <strong>Solicitar asignación</strong>
                <span>Buscar herramienta y enviar solicitud</span>
            </button>

            <button type="button" class="damage" @onclick="ToggleDamageReport">
                <strong>Reportar daño</strong>
                <span>Registrar falla o novedad</span>
            </button>
        </section>

        @if (showLoanWindow)
        {
            <section class="mobile-loan-window navi-action-window">
                <div class="mobile-loan-head">
                    <div>
                        <strong>Solicitud de asignación</strong>
                        <span>La solicitud queda pendiente de aprobación.</span>
                    </div>

                    <button type="button" @onclick="CloseLoanRequest">Cerrar</button>
                </div>

                <div class="mobile-loan-user">
                    <span>Solicitante</span>
                    <strong>@CurrentResponsibleLabel</strong>
                </div>

                <label class="mobile-field">
                    <span>Buscar herramienta</span>
                    <input value="@loanSearch"
                           @oninput="OnLoanSearchChanged"
                           placeholder="Código, nombre, serial o sede..." />
                </label>

                @if (ShowLoanSearchResults)
                {
                    <div class="mobile-loan-results">
                        @if (!LoanRequestTools.Any())
                        {
                            <div class="mobile-loan-empty">No se encontraron herramientas.</div>
                        }
                        else
                        {
                            @foreach (var tool in LoanRequestTools.Take(8))
                            {
                                var selected = loanForm.ToolId == tool.Id;

                                <button type="button"
                                        class="mobile-loan-result @(selected ? "selected" : "")"
                                        @onclick="() => SelectLoanTool(tool)">
                                    <span>
                                        <strong>@tool.InternalCode</strong>
                                        <small>@tool.Name</small>
                                        <small>@Display(tool.BranchCode) · @Display(tool.LocationName)</small>
                                    </span>

                                    <em class="@GetToolStateClass(tool)">
                                        @GetStatusLabel(tool.OperationalStatus)
                                    </em>
                                </button>
                            }
                        }
                    </div>
                }

                @if (selectedLoanTool is not null)
                {
                    <div class="mobile-loan-selected">
                        <span>@selectedLoanTool.InternalCode</span>
                        <strong>@selectedLoanTool.Name</strong>
                        <small>@Display(selectedLoanTool.BranchCode) · @Display(selectedLoanTool.LocationName)</small>
                    </div>
                }

                <label class="mobile-field">
                    <span>Fecha estimada devolución</span>
                    <input type="date"
                           value="@FormatDateInput(loanForm.ExpectedReturnAt)"
                           @onchange="OnLoanExpectedReturnChanged" />
                </label>

                <label class="mobile-field">
                    <span>Observación</span>
                    <textarea rows="2"
                              value="@loanForm.Notes"
                              @oninput="OnLoanNotesChanged"
                              placeholder="Indique para qué requiere la herramienta..."></textarea>
                </label>

                <button class="mobile-loan-submit"
                        type="button"
                        disabled="@isSaving"
                        @onclick="SubmitLoanRequestAsync">
                    @(isSaving ? "Enviando..." : "Enviar solicitud")
                </button>
            </section>
        }

        @if (showDamageWindow)
        {
            <section class="mobile-loan-window navi-action-window">
                <div class="mobile-loan-head">
                    <div>
                        <strong>Reporte de daño</strong>
                        <span>Registra una falla, daño o novedad del activo.</span>
                    </div>

                    <button type="button" @onclick="CloseDamageReport">Cerrar</button>
                </div>

                <div class="mobile-loan-user">
                    <span>Reportado por</span>
                    <strong>@Display(Auth.CurrentUser?.DisplayName)</strong>
                </div>

                <label class="mobile-field">
                    <span>Buscar herramienta</span>
                    <input value="@damageSearch"
                           @oninput="OnDamageSearchChanged"
                           placeholder="Código, nombre, serial o sede..." />
                </label>

                @if (ShowDamageSearchResults)
                {
                    <div class="mobile-loan-results">
                        @if (!DamageTools.Any())
                        {
                            <div class="mobile-loan-empty">No se encontraron herramientas.</div>
                        }
                        else
                        {
                            @foreach (var tool in DamageTools.Take(8))
                            {
                                var selected = damageForm.ToolAssetId == tool.Id;

                                <button type="button"
                                        class="mobile-loan-result @(selected ? "selected" : "")"
                                        @onclick="() => SelectDamageTool(tool)">
                                    <span>
                                        <strong>@tool.InternalCode</strong>
                                        <small>@tool.Name</small>
                                        <small>@Display(tool.BranchCode) · @Display(tool.LocationName)</small>
                                    </span>

                                    <em class="@GetToolStateClass(tool)">
                                        @GetStatusLabel(tool.OperationalStatus)
                                    </em>
                                </button>
                            }
                        }
                    </div>
                }

                @if (selectedDamageTool is not null)
                {
                    <div class="mobile-loan-selected">
                        <span>@selectedDamageTool.InternalCode</span>
                        <strong>@selectedDamageTool.Name</strong>
                        <small>@Display(selectedDamageTool.BranchCode) · @Display(selectedDamageTool.LocationName)</small>
                    </div>
                }

                <label class="mobile-field">
                    <span>Severidad</span>
                    <select value="@damageForm.Severity" @onchange="OnDamageSeverityChanged">
                        <option value="Low">Baja</option>
                        <option value="Medium">Media</option>
                        <option value="High">Alta</option>
                        <option value="Critical">Crítica</option>
                    </select>
                </label>

                <label class="mobile-check-field">
                    <input type="checkbox"
                           checked="@damageForm.BlocksLoan"
                           @onchange="OnDamageBlocksLoanChanged" />
                    <span>Bloquea préstamo o asignación hasta revisión</span>
                </label>

                <label class="mobile-field">
                    <span>Descripción del daño o novedad</span>
                    <textarea rows="3"
                              value="@damageForm.Description"
                              @oninput="OnDamageDescriptionChanged"
                              placeholder="Describe claramente la falla, daño o novedad..."></textarea>
                </label>

                <button class="mobile-loan-submit"
                        type="button"
                        disabled="@isSaving"
                        @onclick="SubmitDamageReportAsync">
                    @(isSaving ? "Enviando..." : "Enviar reporte")
                </button>
            </section>
        }

        @if (MenuItems.Any())
        {
            <section class="mobile-menu-panel mobile-menu-panel-compact mobile-menu-panel-full mobile-menu-white-panel">
                <div class="mobile-panel-head mobile-panel-head-compact mobile-panel-head-no-action">
                    <h2>Menú operativo</h2>
                </div>

                <div class="mobile-menu-grid mobile-menu-grid-compact mobile-menu-grid-full">
                    @foreach (var item in MenuItems)
                    {
                        <a class="mobile-menu-card mobile-menu-card-compact mobile-menu-card-full mobile-menu-card-white" href="@item.Url">
                            <span class="mobile-icon-code mobile-icon-real">@GetMenuIcon(item.IconKey)</span>
                            <strong>@item.Title</strong>
                            <small>@item.Description</small>
                        </a>
                    }
                </div>
            </section>
        }

        <section class="mobile-panel mobile-panel-compact mobile-last-assets-panel">
            <div class="mobile-panel-head mobile-panel-head-compact">
                <h2>Mis activos asignados</h2>
                <a class="mobile-panel-link" href="/my-tools">Ver lista</a>
            </div>

            @if (!assignedTools.Any())
            {
                <div class="mobile-empty compact">
                    No se encontraron activos asignados a tu usuario.
                </div>
            }
            else
            {
                <div class="mobile-assigned-assets-list">
                    @foreach (var tool in assignedTools)
                    {
                        <article class="mobile-assigned-card">
                            <div class="mobile-assigned-card-head">
                                <div>
                                    <span>@tool.InternalCode</span>
                                    <strong>@tool.Name</strong>
                                </div>

                                <em class="@GetToolStateClass(tool)">
                                    @GetStatusLabel(tool.OperationalStatus)
                                </em>
                            </div>

                            <div class="mobile-assigned-grid">
                                <div>
                                    <span>Sede</span>
                                    <strong>@Display(tool.BranchCode)</strong>
                                </div>

                                <div>
                                    <span>Ubicación</span>
                                    <strong>@Display(tool.LocationName)</strong>
                                </div>

                                <div>
                                    <span>Responsable</span>
                                    <strong>@Display(tool.ResponsiblePersonName)</strong>
                                </div>

                                <div>
                                    <span>Físico</span>
                                    <strong>@Display(tool.PhysicalStatus)</strong>
                                </div>
                            </div>

                            <div class="mobile-assigned-actions">
                                <a href="@GetDetailUrl(tool.Id)">Detalle</a>
                                <a href="@GetLifeRecordUrl(tool.Id)">Hoja de vida</a>
                                <a class="danger" href="@GetDamageUrl(tool.Id)">Reportar</a>
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    </section>
}

@code {
    private bool isInitializing = true;
    private bool isSaving;
    private bool showLoanWindow;
    private bool showDamageWindow;

    private string? message;
    private string messageClass = "mobile-alert";
    private string loanSearch = string.Empty;
    private string damageSearch = string.Empty;

    private List<MobileToolDto> tools = new();

    private MobileLoanRequestForm loanForm = new();
    private DamageQuickForm damageForm = new();

    private List<MobileToolDto> visibleTools =>
        FilterByOperationalScope(tools)
            .OrderBy(x => x.BranchCode)
            .ThenBy(x => x.InternalCode)
            .ToList();

    private List<MobileToolDto> assignedTools =>
        tools
            .Where(IsAssignedToCurrentUser)
            .OrderBy(x => x.InternalCode)
            .ThenBy(x => x.Name)
            .ToList();

    private int damageReportedCount =>
        assignedTools.Count(x =>
            ContainsStatus(x.OperationalStatus, "Damaged") ||
            ContainsStatus(x.OperationalStatus, "NotSuitable") ||
            ContainsStatus(x.PhysicalStatus, "Damaged") ||
            ContainsStatus(x.PhysicalStatus, "Dañ"));

    private int availableCount =>
        visibleTools.Count(x => ContainsStatus(x.OperationalStatus, "Available"));

    private MobileToolDto? selectedLoanTool =>
        loanForm.ToolId.HasValue
            ? visibleTools.FirstOrDefault(x => x.Id == loanForm.ToolId.Value)
            : null;

    private MobileToolDto? selectedDamageTool =>
        damageForm.ToolAssetId.HasValue
            ? visibleTools.FirstOrDefault(x => x.Id == damageForm.ToolAssetId.Value)
            : null;

    private bool ShowLoanSearchResults =>
        !string.IsNullOrWhiteSpace(loanSearch) &&
        selectedLoanTool is null;

    private bool ShowDamageSearchResults =>
        !string.IsNullOrWhiteSpace(damageSearch) &&
        selectedDamageTool is null;

    private IEnumerable<MobileToolDto> LoanRequestTools =>
        visibleTools
            .Where(x => string.IsNullOrWhiteSpace(loanSearch) ||
                        ContainsText(x.InternalCode, loanSearch) ||
                        ContainsText(x.Name, loanSearch) ||
                        ContainsText(x.SerialNumber, loanSearch) ||
                        ContainsText(x.BranchCode, loanSearch) ||
                        ContainsText(x.LocationName, loanSearch) ||
                        ContainsText(x.ResponsiblePersonName, loanSearch))
            .OrderByDescending(x => ContainsStatus(x.OperationalStatus, "Available"))
            .ThenBy(x => x.InternalCode);

    private IEnumerable<MobileToolDto> DamageTools =>
        visibleTools
            .Where(x => string.IsNullOrWhiteSpace(damageSearch) ||
                        ContainsText(x.InternalCode, damageSearch) ||
                        ContainsText(x.Name, damageSearch) ||
                        ContainsText(x.SerialNumber, damageSearch) ||
                        ContainsText(x.BranchCode, damageSearch) ||
                        ContainsText(x.LocationName, damageSearch) ||
                        ContainsText(x.ResponsiblePersonName, damageSearch))
            .OrderBy(x => x.InternalCode);

    private string CurrentResponsibleLabel =>
        !string.IsNullOrWhiteSpace(Auth.CurrentUser?.ResponsiblePersonName)
            ? Auth.CurrentUser!.ResponsiblePersonName!
            : Auth.CurrentUser?.DisplayName ?? Auth.CurrentUser?.UserName ?? "Usuario móvil";

    private IEnumerable<MobileMenuItem> MenuItems
    {
        get
        {
            if (HasPermission("Dashboard.View"))
            {
                yield return new MobileMenuItem("dashboard", "Dashboard", "/mobile/dashboard", "Indicadores");
            }

            if (HasPermission("Tools.View"))
            {
                yield return new MobileMenuItem("inventory", "Inventario AF", "/all-tools", "Activos");
            }

            if (HasAny("AssetAvailability.View", "AssetAvailability.Update", "AssetAvailability.Manage"))
            {
                yield return new MobileMenuItem("location", "Disponible y ubicación", "/mobile/availability", "Ubicación");
            }

            if (HasAny("AssetAssignment.View", "AssetAssignment.Request", "Mobile.Loans.Request", "AssetAssignment.Assign", "AssetAssignment.Return", "AssetAssignment.Approve", "AssetAssignment.Deny"))
            {
                yield return new MobileMenuItem("assign", "Asignación y préstamos", "/mobile/assignment", "Préstamos");
            }

            if (HasPermission("AssetAssignment.History"))
            {
                yield return new MobileMenuItem("history", "Historial", "/mobile/history", "Movimientos");
            }

            if (HasAny("TechnicalLifeRecord.View", "ToolDetail.LifeRecord.Open"))
            {
                yield return new MobileMenuItem("life", "Hoja de vida AF", "/mobile/life-records", "Técnica");
            }

            if (HasAny("Purchases.View", "Purchases.Request"))
            {
                yield return new MobileMenuItem("purchase", "Solicitar compra", "/mobile/purchases", "Solicitud");
            }

            if (HasAny("Maintenance.View", "Maintenance.Request"))
            {
                yield return new MobileMenuItem("maintenance", "Solicitar mantenimiento", "/mobile/maintenance-request", "Servicio");
            }

            if (HasAny("Purchases.View", "Maintenance.View"))
            {
                yield return new MobileMenuItem("consult", "Consulta Compras y Mtto.", "/mobile/purchases", "Consulta");
            }

            if (HasPermission("MaintenancePlans.View"))
            {
                yield return new MobileMenuItem("calendar", "Planes mantenimiento", "/mobile/maintenance-plans", "Planes");
            }

            if (HasAny("PhysicalCounts.View", "PhysicalCounts.Report"))
            {
                yield return new MobileMenuItem("physical", "Tomas físicas", "/mobile/physical-counts", "Conteos");
            }

            if (HasPermission("Reconciliation.View"))
            {
                yield return new MobileMenuItem("reconcile", "Conciliación", "/mobile/reconciliation", "Validación");
            }

            if (HasAny("Documents.View", "Documents.Upload"))
            {
                yield return new MobileMenuItem("document", "Documentos", "/mobile/documents", "Evidencias");
            }

            if (HasPermission("Reports.View"))
            {
                yield return new MobileMenuItem("reports", "Reportes", "/mobile/reports", "Indicadores");
            }

            if (HasAny("Settings.View", "Settings.Manage", "Security.Users", "Security.Roles"))
            {
                yield return new MobileMenuItem("settings", "Configuración", "/mobile/settings", "Parámetros");
            }
        }
    }


    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        var refreshedUser = await Api.RefreshCurrentSessionAsync();

        if (refreshedUser is null || !Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        await LoadAsync(forceRefresh: true);

        isInitializing = false;
    }


    private async Task LoadAsync(bool forceRefresh)
    {
        try
        {
            message = null;
            tools = await Api.GetToolsAsync(forceRefresh);
        }
        catch (Exception ex)
        {
            ShowError(ex.Message);
        }
    }

    private void ToggleLoanRequest()
    {
        showLoanWindow = !showLoanWindow;

        if (showLoanWindow)
        {
            showDamageWindow = false;
            message = null;
        }
    }

    private void ToggleDamageReport()
    {
        showDamageWindow = !showDamageWindow;

        if (showDamageWindow)
        {
            showLoanWindow = false;
            message = null;
        }
    }

    private void CloseLoanRequest()
    {
        showLoanWindow = false;
        loanSearch = string.Empty;
        loanForm = new MobileLoanRequestForm();
    }

    private void CloseDamageReport()
    {
        showDamageWindow = false;
        damageSearch = string.Empty;
        damageForm = new DamageQuickForm();
    }

    private void OnLoanSearchChanged(ChangeEventArgs args)
    {
        loanSearch = args.Value?.ToString() ?? string.Empty;

        if (selectedLoanTool is not null &&
            !loanSearch.Equals($"{selectedLoanTool.InternalCode} - {selectedLoanTool.Name}", StringComparison.OrdinalIgnoreCase))
        {
            loanForm.ToolId = null;
        }
    }

    private void SelectLoanTool(MobileToolDto tool)
    {
        loanForm.ToolId = tool.Id;
        loanSearch = $"{tool.InternalCode} - {tool.Name}";
    }

    private void OnLoanExpectedReturnChanged(ChangeEventArgs args)
    {
        if (DateTime.TryParse(args.Value?.ToString(), out var value))
        {
            loanForm.ExpectedReturnAt = value;
        }
    }

    private void OnLoanNotesChanged(ChangeEventArgs args)
    {
        loanForm.Notes = args.Value?.ToString();
    }

    private async Task SubmitLoanRequestAsync()
    {
        if (loanForm.ToolId is null)
        {
            ShowError("Debe seleccionar una herramienta para solicitar asignación.");
            return;
        }

        var tool = selectedLoanTool;

        if (tool is null)
        {
            ShowError("No se encontró la herramienta seleccionada.");
            return;
        }

        if (string.IsNullOrWhiteSpace(tool.BranchCode))
        {
            ShowError("La herramienta no tiene sede asociada para generar la solicitud.");
            return;
        }

        try
        {
            isSaving = true;

            await Api.CreateLoanRequestAsync(new MobileLoanRequestCreateDto
            {
                BranchCode = tool.BranchCode!,
                RequestedByPersonId = Auth.CurrentUser?.ResponsiblePersonId,
                ToolInternalCodes = new[] { tool.InternalCode },
                ExpectedReturnAt = loanForm.ExpectedReturnAt,
                DeliveryCondition = "Solicitud creada desde app móvil.",
                Notes = string.IsNullOrWhiteSpace(loanForm.Notes)
                    ? $"Solicitud de asignación para {tool.InternalCode} - {tool.Name}."
                    : loanForm.Notes,
                RequestedBy = Auth.CurrentUser?.UserName
            });

            ShowSuccess("Solicitud de asignación creada correctamente. Queda pendiente de aprobación.");

            CloseLoanRequest();
            await LoadAsync(forceRefresh: true);
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo crear la solicitud: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void OnDamageSearchChanged(ChangeEventArgs args)
    {
        damageSearch = args.Value?.ToString() ?? string.Empty;

        if (selectedDamageTool is not null &&
            !damageSearch.Equals($"{selectedDamageTool.InternalCode} - {selectedDamageTool.Name}", StringComparison.OrdinalIgnoreCase))
        {
            damageForm.ToolAssetId = null;
            damageForm.ToolInternalCode = null;
        }
    }

    private void SelectDamageTool(MobileToolDto tool)
    {
        damageForm.ToolAssetId = tool.Id;
        damageForm.ToolInternalCode = tool.InternalCode;
        damageSearch = $"{tool.InternalCode} - {tool.Name}";
    }

    private void OnDamageSeverityChanged(ChangeEventArgs args)
    {
        damageForm.Severity = args.Value?.ToString() ?? "Medium";
    }

    private void OnDamageDescriptionChanged(ChangeEventArgs args)
    {
        damageForm.Description = args.Value?.ToString();
    }

    private void OnDamageBlocksLoanChanged(ChangeEventArgs args)
    {
        damageForm.BlocksLoan = args.Value is bool value && value;
    }

    private async Task SubmitDamageReportAsync()
    {
        if (damageForm.ToolAssetId is null && string.IsNullOrWhiteSpace(damageForm.ToolInternalCode))
        {
            ShowError("Debe seleccionar una herramienta o activo.");
            return;
        }

        if (string.IsNullOrWhiteSpace(damageForm.Description))
        {
            ShowError("Debe describir el daño o la novedad.");
            return;
        }

        try
        {
            isSaving = true;

            var result = await Api.ReportDamageAsync(new MobileDamageReportRequest
            {
                ToolAssetId = damageForm.ToolAssetId,
                ToolInternalCode = damageForm.ToolInternalCode,
                Severity = damageForm.Severity,
                Description = damageForm.Description,
                BlocksLoan = damageForm.BlocksLoan,
                ReportedBy = Auth.CurrentUser?.UserName ?? "mobile"
            });

            ShowSuccess($"Novedad registrada correctamente. Número: {result.ReportNumber}");

            CloseDamageReport();
            await LoadAsync(forceRefresh: true);
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo enviar el reporte: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void GoLogin()
    {
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private IEnumerable<MobileToolDto> FilterByOperationalScope(IEnumerable<MobileToolDto> source)
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return Enumerable.Empty<MobileToolDto>();
        }

        if (UserCanSeeAllBranches())
        {
            return source;
        }

        return source.Where(x =>
            SameNormalized(x.BranchCode, user.BranchCode) ||
            SameNormalized(x.BranchName, user.BranchName) ||
            SameNormalized(x.BranchCode, user.BranchName) ||
            SameNormalized(x.BranchName, user.BranchCode));
    }

    private bool UserCanSeeAllBranches()
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        return SameNormalized(user.BranchCode, "TODAS") ||
               SameNormalized(user.BranchCode, "ALL") ||
               SameNormalized(user.BranchName, "TODAS") ||
               SameNormalized(user.BranchName, "ALL") ||
               SameNormalized(user.BranchName, "Todas las sedes");
    }

    private bool IsAssignedToCurrentUser(MobileToolDto tool)
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        if (user.ResponsiblePersonId.HasValue &&
            tool.ResponsiblePersonId.HasValue &&
            tool.ResponsiblePersonId.Value == user.ResponsiblePersonId.Value)
        {
            return true;
        }

        return SameNormalized(tool.ResponsiblePersonName, user.ResponsiblePersonName)
            || SameNormalized(tool.ResponsiblePersonName, user.DisplayName)
            || SameNormalized(tool.ResponsiblePersonName, user.UserName);
    }

    private bool HasPermission(string permission)
    {
        return Auth.HasPermission(permission);
    }



    private bool HasAny(params string[] permissions)
    {
        return permissions.Any(HasPermission);
    }



    private static bool ContainsStatus(string? value, string expected)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               value.Contains(expected, StringComparison.OrdinalIgnoreCase);
    }

    private static bool ContainsText(string? value, string expected)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               !string.IsNullOrWhiteSpace(expected) &&
               Normalize(value).Contains(Normalize(expected), StringComparison.OrdinalIgnoreCase);
    }

    private static bool SameNormalized(string? left, string? right)
    {
        var a = Normalize(left);
        var b = Normalize(right);

        return !string.IsNullOrWhiteSpace(a)
            && !string.IsNullOrWhiteSpace(b)
            && string.Equals(a, b, StringComparison.OrdinalIgnoreCase);
    }

    private static string Normalize(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value
            .Trim()
            .ToUpperInvariant()
            .Replace("Á", "A")
            .Replace("É", "E")
            .Replace("Í", "I")
            .Replace("Ó", "O")
            .Replace("Ú", "U")
            .Replace("Ü", "U")
            .Replace("Ñ", "N");
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Sin dato" : value;
    }

    private static string GetStatusLabel(string? status)
    {
        return status switch
        {
            "Available" => "Disponible",
            "Assigned" => "Asignada",
            "Loaned" => "Prestada",
            "InMaintenance" => "En mantenimiento",
            "Damaged" => "Dañada",
            "NotSuitable" => "No apta",
            "PendingValidation" => "Pendiente validación",
            "NotLocated" => "No localizada",
            "Disposed" => "Baja",
            _ => Display(status)
        };
    }

    private static string GetToolStateClass(MobileToolDto tool)
    {
        return tool.OperationalStatus switch
        {
            "Available" => "mobile-state ok",
            "Assigned" => "mobile-state assigned",
            "Loaned" => "mobile-state assigned",
            "InMaintenance" => "mobile-state warning",
            "Damaged" => "mobile-state danger",
            "NotSuitable" => "mobile-state danger",
            "NotLocated" => "mobile-state dark",
            _ => "mobile-state neutral"
        };
    }

    private static string FormatDateInput(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("yyyy-MM-dd") : string.Empty;
    }

