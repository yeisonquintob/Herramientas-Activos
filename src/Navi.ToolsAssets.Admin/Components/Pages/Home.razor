    .bar-fill {
        height: 100%;
        border-radius: 999px;
    }

    .bar-fill.green { background: #198754; }
    .bar-fill.blue { background: #0d6efd; }
    .bar-fill.purple { background: #7b0d8e; }

    .day-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: .45rem;
    }

    .day-grid div {
        background: #f8fafc;
        border: 1px solid #edf1f5;
        border-radius: .55rem;
        padding: .45rem;
        text-align: center;
    }

    .day-grid span {
        display: block;
        font-size: .68rem;
        color: #657083;
        font-weight: 900;
    }

    .day-grid strong {
        font-size: 1rem;
        color: #17111c;
        font-weight: 950;
    }

    .compact-table {
        font-size: .78rem;
    }

    .compact-table th,
    .compact-table td {
        padding: .42rem .5rem;
        vertical-align: middle;
    }

