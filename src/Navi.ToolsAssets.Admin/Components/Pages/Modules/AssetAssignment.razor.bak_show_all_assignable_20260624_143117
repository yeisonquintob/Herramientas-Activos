@page "/asset-assignment"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@using Navi.ToolsAssets.Admin.Services.Auth
@inject NavigationManager NavigationManager
@inject WebAuthSessionService AuthSession

<PageTitle>Asignar Herramienta - NAVI</PageTitle>

<PermissionGuard Permission="AssetAssignment.View" ModuleName="Asignar Herramienta">

<section class="af-banner">
    <div>
        <span class="af-pill">ACTIVOS FIJOS</span>
        <h2>Asignar Herramienta</h2>
        <p>Asigna herramientas a usuarios/responsables o regresa herramientas a almacenes, talleres y ubicaciones internas.</p>
    </div>

    <div class="af-banner-side">
        <div class="af-status-box">
            <span>Herramientas</span>
            <strong>@FilteredTools.Count() visibles</strong>
        </div>

        <button class="btn btn-sm btn-outline-light" @onclick="LoadAsync">
            Actualizar
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="@messageClass">@message</div>
}

<section class="af-grid">
    <aside class="af-left-stack">
        <div class="af-card">
            <h3>@(form.AssignmentType == "Warehouse" ? "Regresar herramienta" : "Nueva asignación")</h3>

            <div class="mb-2">
                <label class="form-label">Herramienta</label>
                <InputSelect class="form-select" @bind-Value="form.ToolId" @bind-Value:after="LoadSelectedTool">
                    <option value="">Seleccione activo</option>
                    @foreach (var tool in tools.OrderBy(x => x.InternalCode))
                    {
                        <option value="@tool.Id">@tool.InternalCode - @tool.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-2">
                <label class="form-label">Tipo de movimiento</label>
                <InputSelect class="form-select" @bind-Value="form.AssignmentType">
                    <option value="Responsible">Asignar a usuario/responsable</option>
                    <option value="Warehouse">Regresar a almacén/taller</option>
                </InputSelect>
            </div>

            @if (form.AssignmentType == "Responsible")
            {
                <div class="mb-2">
                    <label class="form-label">Usuario / Responsable</label>
                    <InputSelect class="form-select" @bind-Value="form.ResponsiblePersonId">
                        <option value="">Seleccione responsable</option>
                        @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                        {
                            <option value="@responsible.Id">@responsible.FullName - @responsible.Position</option>
                        }
                    </InputSelect>
                </div>
            }

            @if (form.AssignmentType == "Warehouse")
            {
                <div class="mb-2">
                    <label class="form-label">Sede destino</label>
                    <InputSelect class="form-select" @bind-Value="form.BranchId" @bind-Value:after="OnBranchChanged">
                        <option value="">Seleccione sede</option>
                        @foreach (var branch in branches)
                        {
                            <option value="@branch.Id">@branch.Code - @branch.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="mb-2">
                    <label class="form-label">Almacén / Taller destino</label>
                    <InputSelect class="form-select" @bind-Value="form.LocationId">
                        <option value="">Seleccione almacén/taller</option>
                        @foreach (var location in AvailableLocations)
                        {
                            <option value="@location.Id">@location.Code - @location.Name</option>
                        }
                    </InputSelect>
                </div>
            }

            <div class="mb-2">
                <label class="form-label">
                    @(form.AssignmentType == "Warehouse" ? "Fecha de entrega / regreso" : "Fecha de asignación")
                </label>
                <InputDate class="form-control" @bind-Value="form.AssignmentDate" />
            </div>

            <div class="mb-3">
                <label class="form-label">Observación</label>
                <InputTextArea class="form-control" @bind-Value="form.Observation" rows="3" />
            </div>

            <div class="d-grid gap-2">
                @if (form.AssignmentType == "Warehouse")
                {
                    <button class="btn btn-warning fw-bold" @onclick="SaveAsync" disabled="@isSaving">
                        @(isSaving ? "Guardando..." : "Regresar herramienta")
                    </button>
                }
                else
                {
                    <button class="btn btn-primary fw-bold" @onclick="SaveAsync" disabled="@isSaving">
                        @(isSaving ? "Guardando..." : "Registrar asignación")
                    </button>
                }

                <button class="btn btn-outline-secondary" @onclick="ClearForm">
                    Limpiar
                </button>
            </div>
        </div>

        <div class="af-card history-launch-card">
            <span class="history-pill">HISTORIAL</span>
            <h3>Historial por usuario</h3>
            <p>Consulta en una vista completa las herramientas asignadas, entregadas, regresadas y sus detalles.</p>

            <div class="mb-2">
                <label class="form-label">Usuario / Responsable</label>
                <select class="form-select form-select-sm" @bind="historyResponsibleId">
                    <option value="">Todos los usuarios</option>
                    @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                    {
                        <option value="@responsible.Id">@responsible.FullName</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Buscar</label>
                <input class="form-control form-control-sm"
                       placeholder="Código, herramienta, serial o detalle..."
                       @bind="historySearch"
                       @bind:event="oninput" />
            </div>

            <button class="btn-open-history" @onclick="OpenHistory">
                Abrir historial de asignaciones
            </button>
        </div>
    </aside>

    <section class="af-card">
        <div class="af-table-header">
            <div>
                <h3>Herramientas asignables</h3>
                <p>Consulta el estado actual, filtra por usuario y registra asignaciones o regresos.</p>
            </div>

            <div class="af-filters">
                <input class="form-control form-control-sm" placeholder="Buscar código, nombre..." @bind="search" @bind:event="oninput" />

                <select class="form-select form-select-sm" @bind="selectedResponsibleId">
                    <option value="">Todos los usuarios</option>
                    <option value="SIN_RESPONSABLE">Sin responsable</option>
                    @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                    {
                        <option value="@responsible.Id">@responsible.FullName</option>
                    }
                </select>
            </div>
        </div>

        @if (isLoading)
        {
            <p>Cargando herramientas...</p>
        }
        else if (!FilteredTools.Any())
        {
            <div class="alert alert-info">No hay herramientas para los filtros seleccionados.</div>
        }
        else
        {
            <table class="table table-hover align-middle af-table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Activo</th>
                        <th>Sede</th>
                        <th>Ubicación</th>
                        <th>Usuario / Responsable</th>
                        <th>Estado</th>
                        <th>Fecha asignación</th>
                        <th>Fecha entrega</th>
                        <th class="text-end">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tool in FilteredTools)
                    {
                        <tr>
                            <td><strong>@tool.InternalCode</strong></td>
                            <td>
                                <div>@tool.Name</div>
                                <small class="text-muted">@Show(tool.SerialNumber)</small>
                            </td>
                            <td>@Show(tool.BranchCode)</td>
                            <td>@Show(tool.LocationName)</td>
                            <td>
                                <div>@Show(tool.ResponsiblePersonName)</div>
                                <small class="text-muted">@Show(tool.ResponsiblePosition)</small>
                            </td>
                            <td><span class="@GetStatusBadge(tool.OperationalStatus)">@GetStatusLabel(tool.OperationalStatus)</span></td>
                            <td>@ShowDate(tool.LastAssignmentDate)</td>
                            <td>@ShowDate(tool.LastReturnDate)</td>
                            <td class="text-end">
                                <div class="assignment-actions">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => SelectForAssignment(tool)">
                                        Asignar
                                    </button>

                                    <button class="btn btn-sm btn-outline-warning fw-bold" @onclick="() => SelectForReturn(tool)">
                                        Regresar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</section>

</PermissionGuard>

