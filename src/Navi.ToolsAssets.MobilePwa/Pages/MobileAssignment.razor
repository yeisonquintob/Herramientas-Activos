    private bool UserCanSeeAllBranches()
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(user.BranchCode)
            || SameNormalized(user.BranchCode, "TODAS")
            || SameNormalized(user.BranchCode, "ALL")
            || SameNormalized(user.BranchName, "Todas las sedes")
            || SameNormalized(user.BranchName, "TODAS")
            || SameNormalized(user.BranchName, "ALL");
    }


    private bool IsSameBranch(MobileAvailabilityToolDto tool)
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        if (UserCanSeeAllBranches())
        {
            return true;
        }

        return SameNormalized(tool.BranchCode, user.BranchCode)
            || SameNormalized(tool.BranchName, user.BranchName)
            || SameNormalized(tool.BranchCode, user.BranchName)
            || SameNormalized(tool.BranchName, user.BranchCode);
    }

    private bool IsVisibleBranch(MobileBranchDto branch)
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        if (UserCanSeeAllBranches())
        {
            return true;
        }

        return SameNormalized(branch.Code, user.BranchCode)
            || SameNormalized(branch.Name, user.BranchName);
    }

    private bool IsVisibleLocation(MobileLocationDto location)
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        if (UserCanSeeAllBranches())
        {
            return true;
        }

        return SameNormalized(location.BranchCode, user.BranchCode)
            || SameNormalized(location.BranchName, user.BranchName);
    }

    private string GetScopeText()
    {
        if (CanDirectAssign || CanReturnAssignment)
        {
            return "Puedes asignar o devolver activos según tus permisos.";
