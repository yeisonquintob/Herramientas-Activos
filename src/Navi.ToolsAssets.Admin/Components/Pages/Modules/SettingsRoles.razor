@code {
    private bool CanManageRoles => AuthSession.HasPermission("Security.Roles");
    private HttpClient Api => HttpClientFactory.CreateClient("NaviApi");

    private List<RoleDto> roles = new();
    private RoleFormModel formModel = new();
    private Guid? editingId;
    private bool isLoading;
    private string message = string.Empty;
    private string messageClass = "alert alert-info";
    private string permissionSearch = string.Empty;
    private string selectedTemplateCode = string.Empty;
    private HashSet<string> selectedPermissions = new(StringComparer.OrdinalIgnoreCase);
    private HashSet<string> collapsedPermissionGroups = new(StringComparer.OrdinalIgnoreCase);

    private readonly List<PermissionGroup> permissionGroups = BuildPermissionGroups();
    private readonly List<RoleTemplate> roleTemplates = BuildRoleTemplates();

    private List<PermissionItem> AllPermissions =>
        permissionGroups.SelectMany(x => x.Permissions).ToList();

    private IEnumerable<PermissionGroup> FilteredPermissionGroups
    {
        get
        {
            if (string.IsNullOrWhiteSpace(permissionSearch))
            {
                return permissionGroups;
            }

            var value = permissionSearch.Trim();

            return permissionGroups
                .Select(group => group with
                {
                    Permissions = group.Permissions
                        .Where(permission =>
                            Contains(group.Area, value) ||
                            Contains(group.Title, value) ||
                            Contains(permission.Code, value) ||
                            Contains(permission.Name, value) ||
                            Contains(permission.Scope, value) ||
                            Contains(permission.Kind, value))
                        .ToList()
                })
                .Where(group => group.Permissions.Count > 0)
                .ToList();
        }
    }

    private IEnumerable<RoleRule> CurrentRoleRules
    {
        get
        {
            var code = formModel.Code?.Trim().ToUpperInvariant() ?? selectedTemplateCode;

            if (code.Contains("TECNICO"))
            {
                return new[]
                {
                    new RoleRule("📱", "Operación móvil", "Debe trabajar principalmente desde la PWA móvil."),
                    new RoleRule("🧰", "Solo asignado", "Consulta herramientas propias o asignadas a su responsabilidad."),
                    new RoleRule("🚫", "Sin administración", "No compra, no aprueba, no configura, no concilia."),
                    new RoleRule("📸", "Puede reportar", "Reporta toma física, daños, novedades y evidencias.")
                };
            }

            if (code.Contains("HERR"))
            {
                return new[]
                {
                    new RoleRule("🧰", "Custodia herramientas", "Controla disponibilidad, préstamos, ubicación y evidencias."),
                    new RoleRule("📦", "Toma física", "Puede crear y gestionar tomas físicas de su sede."),
                    new RoleRule("🛠️", "Mantenimiento", "Puede solicitar o registrar mantenimiento operativo."),
                    new RoleRule("🚫", "Sin seguridad", "No administra usuarios ni matriz de roles.")
                };
            }

            if (code.Contains("COORD"))
            {
                return new[]
                {
                    new RoleRule("✅", "Aprobación operativa", "Aprueba préstamos, compras y mantenimientos según sede."),
                    new RoleRule("⚖️", "Conciliación", "Puede decidir diferencias de toma física."),
                    new RoleRule("📊", "Seguimiento", "Consulta reportes de operación."),
                    new RoleRule("🚫", "Sin seguridad global", "No debería modificar roles ni usuarios.")
                };
            }

            if (code.Contains("ING"))
            {
                return new[]
                {
                    new RoleRule("🛠️", "Servicio técnico", "Gestiona mantenimiento, cierre y validación técnica."),
                    new RoleRule("📄", "Consulta soportes", "Consulta documentos y hojas de vida."),
                    new RoleRule("🛒", "Aprueba operación", "Puede validar solicitudes relacionadas con servicio."),
                    new RoleRule("🚫", "No configura base", "No administra catálogos ni seguridad.")
                };
            }

            if (code.Contains("AUD"))
            {
                return new[]
                {
                    new RoleRule("👁️", "Solo lectura", "Debe consultar información sin modificar datos."),
                    new RoleRule("📄", "Evidencia", "Puede descargar documentos y reportes."),
                    new RoleRule("📊", "Reportes", "Consulta resultados para auditoría."),
                    new RoleRule("🚫", "Sin acciones", "No crea, aprueba, rechaza ni elimina.")
                };
            }

            if (code.Contains("ADMIN"))
            {
                return new[]
                {
                    new RoleRule("🔐", "Control total", "Administra usuarios, roles, sedes y parámetros."),
                    new RoleRule("⚙️", "Configuración", "Puede modificar catálogos y permisos."),
                    new RoleRule("📊", "Visión global", "Accede a todos los módulos y reportes."),
                    new RoleRule("🧾", "Auditoría", "Debe dejar trazabilidad en cambios críticos.")
                };
            }

            return new[]
            {
                new RoleRule("🔎", "Definir alcance", "Selecciona una plantilla o marca permisos manualmente."),
                new RoleRule("🏢", "Sede/Zona", "El alcance por sede se aplicará en backend y filtros."),
                new RoleRule("🧩", "Permisos granulares", "Separar ver, crear, editar, aprobar y eliminar."),
                new RoleRule("🛡️", "Seguridad", "Guardar rol y luego asignarlo a usuarios.")
            };
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        message = string.Empty;

        try
        {
            roles = await Api.GetFromJsonAsync<List<RoleDto>>("api/settings/roles") ?? new();
        }
        catch (Exception ex)
        {
            ShowError($"No se pudieron cargar los roles: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        message = string.Empty;

        if (!CanManageRoles)
        {
            ShowError("Tu usuario no tiene permiso para modificar roles.");
            return;
        }

        if (string.IsNullOrWhiteSpace(formModel.Code) || string.IsNullOrWhiteSpace(formModel.Name))
        {
            ShowError("Código y nombre son obligatorios.");
            return;
        }

        formModel.Permissions = string.Join(",", selectedPermissions.OrderBy(x => x));

        var request = new
        {
            code = formModel.Code.Trim().ToUpperInvariant(),
            name = formModel.Name.Trim(),
            description = formModel.Description,
            permissions = formModel.Permissions,
            isActive = formModel.IsActive,
            changedBy = string.IsNullOrWhiteSpace(AuthSession.UserName) ? "admin-web" : AuthSession.UserName
        };

        try
        {
            HttpResponseMessage response = editingId is null
                ? await Api.PostAsJsonAsync("api/settings/roles", request)
                : await Api.PutAsJsonAsync($"api/settings/roles/{editingId}", request);

            if (!response.IsSuccessStatusCode)
            {
                ShowError(await response.Content.ReadAsStringAsync());
                return;
            }

            ShowSuccess(editingId is null ? "Rol creado correctamente." : "Rol actualizado correctamente.");
            ClearForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Error guardando rol: {ex.Message}");
        }
    }

    private void Edit(RoleDto role)
    {
        editingId = role.Id;

        formModel = new RoleFormModel
        {
            Code = role.Code,
            Name = role.Name,
            Description = role.Description,
            Permissions = role.Permissions,
            IsActive = role.IsActive
        };

        selectedPermissions = ParsePermissions(role.Permissions);
        selectedTemplateCode = DetectTemplateCode(role);
    }

    private async Task DeleteAsync(Guid id)
    {
        if (!CanManageRoles)
        {
            ShowError("Tu usuario no tiene permiso para eliminar roles.");
            return;
        }

        try
        {
            var changedBy = string.IsNullOrWhiteSpace(AuthSession.UserName) ? "admin-web" : AuthSession.UserName;
            var response = await Api.DeleteAsync($"api/settings/roles/{id}?changedBy={Uri.EscapeDataString(changedBy)}");

            if (!response.IsSuccessStatusCode)
            {
                ShowError(await response.Content.ReadAsStringAsync());
                return;
            }

            ShowSuccess("Rol eliminado correctamente.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Error eliminando rol: {ex.Message}");
        }
    }

    private void ClearForm()
    {
        editingId = null;
        formModel = new RoleFormModel();
        selectedPermissions = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        selectedTemplateCode = string.Empty;
        permissionSearch = string.Empty;
        collapsedPermissionGroups.Clear();
    }

    private void SelectProfile(string code)
    {
        var template = roleTemplates.FirstOrDefault(x => x.Code == code);

        if (template is null)
        {
            return;
        }

        selectedTemplateCode = template.Code;
        selectedPermissions = template.Permissions.ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (editingId is null)
        {
            formModel.Code = template.RoleCode;
            formModel.Name = template.Name;
            formModel.Description = template.Description;
            formModel.IsActive = true;
        }
        else
        {
            formModel.Description = template.Description;
        }
    }

    private void SelectAdminProfile()
    {
        selectedTemplateCode = "ADMIN";
        selectedPermissions = AllPermissions
            .Select(x => x.Code)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);

        if (editingId is null)
        {
            formModel.Code = "ADMIN";
            formModel.Name = "Administrador NAVI";
            formModel.Description = "Control total del sistema, seguridad, configuración, operación, reportes y auditoría.";
            formModel.IsActive = true;
        }
    }

    private void ClearPermissions()
    {
        selectedPermissions.Clear();
        selectedTemplateCode = string.Empty;
    }

    private bool IsPermissionSelected(string code)
    {
        return selectedPermissions.Contains(code);
    }

    private void TogglePermission(string code, object? value)
    {
        var isChecked = value is bool boolValue && boolValue;

        if (isChecked)
        {
            selectedPermissions.Add(code);
        }
        else
        {
            selectedPermissions.Remove(code);
        }

        selectedTemplateCode = string.Empty;
    }

    private int CountByKind(params string[] terms)
    {
        return selectedPermissions.Count(permission =>
            terms.Any(term => permission.Contains($".{term}", StringComparison.OrdinalIgnoreCase)));
    }

    private string GetTemplateClass(string code)
    {
        return selectedTemplateCode == code ? "active" : string.Empty;
    }

    private static string GetGroupKey(PermissionGroup group)
    {
        return $"{group.Area}|{group.Title}";
    }

    private bool IsGroupCollapsed(PermissionGroup group)
    {
        return collapsedPermissionGroups.Contains(GetGroupKey(group));
    }

    private void TogglePermissionGroup(PermissionGroup group)
    {
        var key = GetGroupKey(group);

        if (!collapsedPermissionGroups.Add(key))
        {
            collapsedPermissionGroups.Remove(key);
        }
    }

    private void CollapseAllPermissionGroups()
    {
        collapsedPermissionGroups = FilteredPermissionGroups
            .Select(GetGroupKey)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private void ExpandAllPermissionGroups()
    {
        collapsedPermissionGroups.Clear();
    }

    private string GetSelectedTemplateIcon()
    {
        return roleTemplates.FirstOrDefault(x => x.Code == selectedTemplateCode)?.Icon ?? "🔐";
    }

    private string GetPermissionClass(PermissionItem permission)
    {
        var selected = IsPermissionSelected(permission.Code) ? " selected" : string.Empty;
        return $"rolesx-permission-item kind-{permission.Kind}{selected}";
    }

    private string DetectTemplateCode(RoleDto role)
    {
        var code = role.Code?.Trim().ToUpperInvariant() ?? string.Empty;

        return roleTemplates.FirstOrDefault(x =>
            string.Equals(x.RoleCode, code, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Code, code, StringComparison.OrdinalIgnoreCase))?.Code ?? string.Empty;
    }

    private string GetRoleProfileName(RoleDto role)
    {
        var template = roleTemplates.FirstOrDefault(x =>
            string.Equals(x.RoleCode, role.Code, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Name, role.Name, StringComparison.OrdinalIgnoreCase));

        return template?.Name ?? "Personalizado";
    }

    private int GetRolePermissionCount(RoleDto role)
    {
        if (string.Equals(role.Permissions, "ALL", StringComparison.OrdinalIgnoreCase))
        {
            return AllPermissions.Count;
        }

        return ParsePermissions(role.Permissions).Count;
    }

    private string GetRolePermissionPreview(RoleDto role)
    {
        var permissions = ParsePermissions(role.Permissions).Take(5).ToList();

        if (permissions.Count == 0)
        {
            return "Sin permisos";
        }

        var suffix = GetRolePermissionCount(role) > permissions.Count ? "..." : string.Empty;

        return string.Join(", ", permissions) + suffix;
    }

    private static HashSet<string> ParsePermissions(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        }

        if (value.Equals("ALL", StringComparison.OrdinalIgnoreCase))
        {
            return new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        }

        return value
            .Split(new[] { ',', ';', '|', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToHashSet(StringComparer.OrdinalIgnoreCase);
    }

    private void ShowSuccess(string value)
    {
        message = value;
        messageClass = "alert alert-success";
    }

    private void ShowError(string value)
    {
        message = value;
        messageClass = "alert alert-danger";
    }

    private static bool Contains(string? source, string value)
    {
        return !string.IsNullOrWhiteSpace(source)
            && source.Contains(value, StringComparison.OrdinalIgnoreCase);
    }

