@code {
    private HttpClient Api => HttpClientFactory.CreateClient("NaviApi");

    private List<ToolItem> tools = new();
    private List<BranchItem> branches = new();
    private List<LocationItem> locations = new();

    private AvailabilityForm form = new();

    private string toolSearchText = string.Empty;
    private string branchSearchText = string.Empty;
    private string locationSearchText = string.Empty;

    private bool isLoading;
    private bool isSaving;
    private string search = string.Empty;
    private string selectedBranchCode = string.Empty;
    private string selectedStatus = string.Empty;
    private string message = string.Empty;
    private string messageClass = "alert alert-info";

    private IEnumerable<LocationItem> AvailableLocations =>
        form.BranchId is null
            ? locations
            : locations.Where(x => x.BranchId == form.BranchId);

    private IEnumerable<ToolItem> ScopedTools =>
        AccessScope.FilterTools(
            tools,
            x => x.BranchCode,
            x => x.ResponsiblePersonName);

    private bool CanChangeAvailabilityLocation =>
        AuthSession.HasPermission("AssetAvailability.Edit");

    private bool CanChangeAvailabilityStatus =>
        AuthSession.HasPermission("AssetAvailability.Status.Change");

    private bool CanSaveAvailability =>
        CanChangeAvailabilityLocation || CanChangeAvailabilityStatus;

    private bool CanManageAvailability =>
        CanSaveAvailability;

    private ToolItem? SelectedAvailabilityTool =>
        form.ToolId.HasValue
            ? tools.FirstOrDefault(x => x.Id == form.ToolId.Value)
            : null;

    private bool HasAvailabilityLocationChange(ToolItem current)
    {
        return form.BranchId != current.BranchId ||
               form.LocationId != current.LocationId;
    }

    private bool HasAvailabilityStatusChange(ToolItem current)
    {
        return !string.Equals(
            form.OperationalStatus ?? string.Empty,
            current.OperationalStatus ?? string.Empty,
            StringComparison.OrdinalIgnoreCase);
    }

    private string? GetAvailabilityPermissionError()
    {
        if (form.ToolId is null)
        {
            return "Seleccione una herramienta antes de guardar cambios.";
        }

        var current = SelectedAvailabilityTool;

        if (current is null)
        {
            return "No se encontró la herramienta seleccionada.";
        }

        if (!CanSaveAvailability)
        {
            return "No tienes permiso para cambiar ubicación ni estado operativo.";
        }

        if (HasAvailabilityLocationChange(current) && !CanChangeAvailabilityLocation)
        {
            return "No tienes permiso para cambiar sede, almacén, taller o ubicación.";
        }

        if (HasAvailabilityStatusChange(current) && !CanChangeAvailabilityStatus)
        {
            return "No tienes permiso para cambiar el estado operativo.";
        }

        return null;
    }


private IEnumerable<ToolItem> FilteredTools =>
        ScopedTools
            .Where(x => string.IsNullOrWhiteSpace(search) ||
                        x.InternalCode.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                        x.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                        (x.SerialNumber ?? string.Empty).Contains(search, StringComparison.OrdinalIgnoreCase))
            .Where(x => string.IsNullOrWhiteSpace(selectedBranchCode) ||
                        (x.BranchCode ?? string.Empty).Contains(selectedBranchCode, StringComparison.OrdinalIgnoreCase))
            .Where(x => string.IsNullOrWhiteSpace(selectedStatus) || x.OperationalStatus == selectedStatus)
            .OrderBy(x => x.BranchCode)
            .ThenBy(x => x.InternalCode);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    
    private static bool IsToolOnly(ToolItem item)
    {
        var typeName = item.ToolTypeName ?? string.Empty;
        var typeCode = item.ToolTypeCode ?? string.Empty;

        return typeName.Equals("Herramienta", StringComparison.OrdinalIgnoreCase)
            || typeName.Equals("HERRAMIENTA", StringComparison.OrdinalIgnoreCase)
            || typeCode.Equals("HERRAMIENTA", StringComparison.OrdinalIgnoreCase)
            || typeCode.Equals("TOOL", StringComparison.OrdinalIgnoreCase);
    }
    private async Task LoadAsync()
    {
        isLoading = true;

        try
        {
                        tools = await Api.GetFromJsonAsync<List<ToolItem>>("api/tools") ?? new();
            branches = await Api.GetFromJsonAsync<List<BranchItem>>("api/settings/branches") ?? new();
            locations = await Api.GetFromJsonAsync<List<LocationItem>>("api/settings/warehouses") ?? new();
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo cargar la información: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectTool(ToolItem tool)
    {
        form = new AvailabilityForm
        {
            ToolId = tool.Id,
            BranchId = tool.BranchId,
            LocationId = tool.LocationId,
            OperationalStatus = string.IsNullOrWhiteSpace(tool.OperationalStatus) ? "Available" : tool.OperationalStatus
        };

        toolSearchText = FormatToolOption(tool);

        var branch = branches.FirstOrDefault(x => x.Id == tool.BranchId);
        branchSearchText = branch is null
            ? tool.BranchCode ?? string.Empty
            : FormatBranchOption(branch);

        var location = locations.FirstOrDefault(x => x.Id == tool.LocationId);
        locationSearchText = location is null
            ? tool.LocationName ?? string.Empty
            : FormatLocationOption(location);
    }

    private void LoadSelectedTool()
    {
        var tool = tools.FirstOrDefault(x => x.Id == form.ToolId);

        if (tool is not null)
        {
            SelectTool(tool);
        }
    }

    private void OnBranchChanged()
    {
        if (form.LocationId.HasValue &&
            !locations.Any(x => x.Id == form.LocationId && x.BranchId == form.BranchId))
        {
            form.LocationId = null;
        }
    }

    private async Task SaveAsync()
    {

        var permissionError = GetAvailabilityPermissionError();

        if (!string.IsNullOrWhiteSpace(permissionError))
        {
            ShowError(permissionError);
            return;
        }



        if (form.ToolId is null || form.BranchId is null)
        {
            ShowError("Debe seleccionar activo y sede.");
            return;
        }

        isSaving = true;

        var request = new
        {
            branchId = form.BranchId.Value,
            locationId = form.LocationId,
            operationalStatus = form.OperationalStatus,
            observation = form.Observation,
            changedBy = "admin-web"
        };

        try
        {
            var response = await Api.PatchAsJsonAsync($"api/tools/{form.ToolId}/availability-location", request);

            if (!response.IsSuccessStatusCode)
            {
                ShowError(await response.Content.ReadAsStringAsync());
                return;
            }

            ShowSuccess("Disponibilidad y ubicación actualizadas correctamente.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Error guardando cambios: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ClearForm()
    {
        form = new AvailabilityForm();
        toolSearchText = string.Empty;
        branchSearchText = string.Empty;
        locationSearchText = string.Empty;
    }

    
    private void OnToolSearchInput(ChangeEventArgs args)
    {
        toolSearchText = args.Value?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(toolSearchText))
        {
            form.ToolId = null;
            return;
        }

        var tool = ResolveTool(toolSearchText);

        if (tool is not null)
        {
            SelectTool(tool);
        }
    }

    private void OnBranchSearchInput(ChangeEventArgs args)
    {
        branchSearchText = args.Value?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(branchSearchText))
        {
            form.BranchId = null;
            form.LocationId = null;
            locationSearchText = string.Empty;
            return;
        }

        var branch = ResolveBranch(branchSearchText);

        if (branch is not null)
        {
            form.BranchId = branch.Id;
            branchSearchText = FormatBranchOption(branch);
            OnBranchChanged();
        }
    }

    private void OnLocationSearchInput(ChangeEventArgs args)
    {
        locationSearchText = args.Value?.ToString() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(locationSearchText))
        {
            form.LocationId = null;
            return;
        }

        var location = ResolveLocation(locationSearchText);

        if (location is not null)
        {
            form.LocationId = location.Id;
            locationSearchText = FormatLocationOption(location);
        }
    }

    private ToolItem? ResolveTool(string value)
    {
        return tools.FirstOrDefault(x =>
            string.Equals(FormatToolOption(x), value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals($"{x.InternalCode} - {x.Name}", value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.InternalCode, value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Name, value, StringComparison.OrdinalIgnoreCase));
    }

    private BranchItem? ResolveBranch(string value)
    {
        return branches.FirstOrDefault(x =>
            string.Equals(FormatBranchOption(x), value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Code, value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Name, value, StringComparison.OrdinalIgnoreCase));
    }

    private LocationItem? ResolveLocation(string value)
    {
        return AvailableLocations.FirstOrDefault(x =>
            string.Equals(FormatLocationOption(x), value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Code, value, StringComparison.OrdinalIgnoreCase) ||
            string.Equals(x.Name, value, StringComparison.OrdinalIgnoreCase));
    }

    private static string FormatToolOption(ToolItem tool)
    {
        var serial = string.IsNullOrWhiteSpace(tool.SerialNumber) ? "Sin serial" : tool.SerialNumber;
        var branch = string.IsNullOrWhiteSpace(tool.BranchCode) ? "Sin sede" : tool.BranchCode;
        return $"{tool.InternalCode} - {tool.Name} · {branch} · {serial}";
    }

    private static string FormatBranchOption(BranchItem branch)
    {
        return $"{branch.Code} - {branch.Name}";
    }

    private static string FormatLocationOption(LocationItem location)
    {
        return $"{location.Code} - {location.Name}";
    }

    private string GetToolSearchHint()
    {
        if (string.IsNullOrWhiteSpace(toolSearchText))
        {
            return "Escriba y seleccione una herramienta existente.";
        }

        return form.ToolId.HasValue
            ? "Herramienta seleccionada correctamente."
            : "Seleccione una herramienta de las coincidencias.";
    }

    private string GetBranchSearchHint()
    {
        if (string.IsNullOrWhiteSpace(branchSearchText))
        {
            return "Escriba y seleccione una sede.";
        }

        return form.BranchId.HasValue
            ? "Sede seleccionada correctamente."
            : "Seleccione una sede de las coincidencias.";
    }

    private string GetLocationSearchHint()
    {
        if (string.IsNullOrWhiteSpace(locationSearchText))
        {
            return "Puede dejarla vacía si no aplica ubicación.";
        }

        return form.LocationId.HasValue
            ? "Ubicación seleccionada correctamente."
            : "Seleccione una ubicación de las coincidencias.";
    }

    private string GetToolSearchHintClass() => form.ToolId.HasValue ? "navi-search-hint ok" : "navi-search-hint";
    private string GetBranchSearchHintClass() => form.BranchId.HasValue ? "navi-search-hint ok" : "navi-search-hint";
    private string GetLocationSearchHintClass() => form.LocationId.HasValue || string.IsNullOrWhiteSpace(locationSearchText) ? "navi-search-hint ok" : "navi-search-hint";

    private static string Show(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string GetStatusLabel(string status) => status switch
    {
        "Available" => "Disponible",
        "Assigned" => "Asignada",
        "Loaned" => "Prestada",
        "InMaintenance" => "En mantenimiento",
        "Damaged" => "Dañada",
        "NotSuitable" => "No apta",
        "PendingValidation" => "Pendiente validación",
        "NotLocated" => "No localizada",
        "PendingDisposal" => "Pendiente baja",
        "Disposed" => "Dada de baja",
        _ => status
    };

    private static string GetStatusBadge(string status) => status switch
    {
        "Available" => "badge bg-success",
        "Assigned" => "badge bg-warning text-dark",
        "Loaned" => "badge bg-info text-dark",
        "InMaintenance" => "badge bg-primary",
        "Damaged" => "badge bg-danger",
        "NotSuitable" => "badge bg-danger",
        "NotLocated" => "badge bg-dark",
        "Disposed" => "badge bg-secondary",
        _ => "badge bg-secondary"
    };

    private void ShowSuccess(string value)
    {
        message = value;
        messageClass = "alert alert-success";
    }

    private void ShowError(string value)
    {
        message = value;
        messageClass = "alert alert-danger";
    }

