@page "/physical-counts/{Id:guid}/reported-items"
@rendermode InteractiveServer

@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Components.Security

@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Conciliación de registros reportados</PageTitle>

<PermissionGuard Permission="PhysicalCounts.View" ModuleName="Conciliación de registros reportados">

    <section class="ri-hero">
        <div>
            <span class="ri-pill">TOMA FÍSICA · CONCILIACIÓN GLOBAL</span>
            <h2>Conciliación de registros reportados</h2>
            <p>
                Revisa, filtra y toma decisiones sobre lo reportado durante la toma física:
                encontrados, faltantes, diferencias, herramientas no listadas, aprobaciones, rechazos
                y creación controlada en Inventario de AF.
            </p>
        </div>

        <div class="ri-actions">
            <button class="btn btn-light" type="button" @onclick="LoadAsync" disabled="@isLoading">
                @(isLoading ? "Actualizando..." : "Actualizar")
            </button>

            <button class="btn btn-outline-light" type="button" @onclick="GoBack">
                Volver
            </button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">@successMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    @if (isLoading && board is null)
    {
        <div class="ri-empty">Cargando registros de conciliación...</div>
    }
    else if (board is null)
    {
        <div class="ri-empty">
            No se pudo cargar la información de conciliación de esta toma física.
        </div>
    }
    else
    {
        <section class="ri-kpis">
            <article>
                <span>Total</span>
                <strong>@board.Summary.Total</strong>
                <small>Registros</small>
            </article>

            <article>
                <span>No listadas</span>
                <strong>@board.Summary.ExtraNotListed</strong>
                <small>Por crear o rechazar</small>
            </article>

            <article>
                <span>Pendiente creación</span>
                <strong>@AllItems.Count(IsPendingCreation)</strong>
                <small>Revisión administrativa</small>
            </article>

            <article>
                <span>Pendiente conciliación</span>
                <strong>@AllItems.Count(x => IsStatus(x, "MatchedInSystem") || IsStatus(x, "PendingReview"))</strong>
                <small>Validar diferencias</small>
            </article>

            <article>
                <span>Aclaración</span>
                <strong>@AllItems.Count(x => x.RequiresUserClarification || IsStatus(x, "RequiresUserClarification"))</strong>
                <small>Contactar usuario</small>
            </article>

            <article>
                <span>Completos</span>
                <strong>@AllItems.Count(IsComplete)</strong>
                <small>Conciliados</small>
            </article>
        </section>

        <section class="ri-card ri-filter-card">
            <div class="ri-card-title">
                <div>
                    <h3>Filtros de conciliación</h3>
                    <p>
                        Use estos filtros para revisar únicamente los registros que requieren decisión o seguimiento.
                    </p>
                </div>

                <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="ClearFilters">
                    Limpiar filtros
                </button>
            </div>

            <div class="ri-filter-grid">
                <label>
                    Buscar
                    <input class="form-control"
                           placeholder="Código, nombre, serial, responsable, categoría..."
                           @bind="searchText"
                           @bind:event="oninput" />
                </label>

                <label>
                    Tipo de reporte
                    <select class="form-select" @bind="filterReportType">
                        <option value="">Todos</option>
                        <option value="Found">Encontrada</option>
                        <option value="NotFound">No encontrada</option>
                        <option value="ExtraNotListed">Herramienta no listada</option>
                        <option value="Damaged">Dañada</option>
                        <option value="ReturnedOrDelivered">Devuelta / entregada</option>
                    </select>
                </label>

                <label>
                    Conciliación
                    <select class="form-select" @bind="filterReconciliationStatus">
                        <option value="">Todos</option>
                        <option value="PendingReview">Pendiente revisión</option>
                        <option value="NotFoundInSystem">Pendiente creación</option>
                        <option value="MatchedInSystem">Pendiente conciliación</option>
                        <option value="RequiresUserClarification">Requiere aclaración</option>
                        <option value="ApprovedForCreation">Aprobado para creación</option>
                        <option value="Reconciled">Completo / conciliado</option>
                        <option value="Rejected">Rechazado</option>
                    </select>
                </label>

                <label>
                    Sede
                    <select class="form-select" @bind="filterBranch">
                        <option value="">Todas</option>
                        @foreach (var branch in BranchOptions)
                        {
                            <option value="@branch">@branch</option>
                        }
                    </select>
                </label>

                <label>
                    Responsable / usuario
                    <select class="form-select" @bind="filterResponsible">
                        <option value="">Todos</option>
                        @foreach (var responsible in ResponsibleOptions)
                        {
                            <option value="@responsible">@responsible</option>
                        }
                    </select>
                </label>

                <label>
                    Datos mínimos
                    <select class="form-select" @bind="filterMinimumData">
                        <option value="">Todos</option>
                        <option value="Complete">Completos</option>
                        <option value="Missing">Sin mínimos</option>
                    </select>
                </label>

                <label>
                    Desde
                    <input class="form-control"
                           placeholder="yyyy-MM-dd"
                           @bind="filterFromDateText" />
                </label>

                <label>
                    Hasta
                    <input class="form-control"
                           placeholder="yyyy-MM-dd"
                           @bind="filterToDateText" />
                </label>
            </div>

            <div class="ri-filter-checks">
                <label>
                    <input type="checkbox" @bind="onlyPendingDecision" />
                    Mostrar solo registros pendientes de decisión
                </label>

                <label>
                    <input type="checkbox" @bind="onlyCreatedAssets" />
                    Mostrar solo activos creados en inventario
                </label>

                <label>
                    <input type="checkbox" @bind="onlyExtraNotListed" />
                    Mostrar solo herramientas no listadas
                </label>
            </div>
        </section>

        <section class="ri-card">
            <div class="ri-card-title">
                <div>
                    <h3>Registros para conciliación</h3>
                    <p>
                        Vista global para revisar, filtrar y tomar decisiones administrativas sobre lo reportado en campo.
                        Esta pantalla no permite agregar nuevos registros.
                    </p>
                </div>

                <div class="ri-result-counter">
                    <span>Filtrados</span>
                    <strong>@FilteredItems.Count()</strong>
                </div>
            </div>

            @if (!FilteredItems.Any())
            {
                <div class="ri-empty">No hay registros que coincidan con los filtros seleccionados.</div>
            }
            else
            {
                <div class="ri-table-wrapper">
                    <table class="ri-table">
                        <thead>
                            <tr>
                                <th>Tipo / usuario</th>
                                <th>Código / activo</th>
                                <th>Clasificación</th>
                                <th>Ubicación / responsable</th>
                                <th>Estado reportado</th>
                                <th>Datos mínimos</th>
                                <th>Conciliación</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in FilteredItems)
                            {
                                var lifeRecordId = GetLifeRecordId(item);

                                <tr class="@GetRowClass(item)">
                                    <td>
                                        <span class="@GetReportTypeClass(item)">
                                            @GetReportTypeLabel(item)
                                        </span>

                                        <small>@Display(item.ParticipantName)</small>
                                        <small>@Display(item.ParticipantUserName)</small>
                                    </td>

                                    <td>
                                        <strong>@Display(item.ToolInternalCode ?? item.ReportedCode ?? item.MatchedToolInternalCode)</strong>
                                        <span>@Display(item.ToolName ?? item.ReportedName ?? item.MatchedToolName)</span>

                                        @if (!string.IsNullOrWhiteSpace(item.SerialNumber))
                                        {
                                            <small>Serial: @item.SerialNumber</small>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(item.Brand) || !string.IsNullOrWhiteSpace(item.Model))
                                        {
                                            <small>Marca/Modelo: @Display(item.Brand) @Display(item.Model)</small>
                                        }

                                        @if (item.CreatedToolAssetId.HasValue && item.CreatedToolAssetId.Value != Guid.Empty)
                                        {
                                            <small class="ri-created-id">Activo creado: @item.CreatedToolAssetId</small>
                                        }
                                    </td>

                                    <td>
                                        <small>Tipo: @Display(item.AssetTypeName)</small>
                                        <small>Categoría: @Display(item.CategoryName)</small>
                                    </td>

                                    <td>
                                        <small>Sede: @Display(item.BranchCode)</small>
                                        <small>Ubicación: @Display(item.FoundLocation)</small>
                                        <small>Responsable: @Display(item.ResponsibleName)</small>
                                    </td>

                                    <td>
                                        <small>Físico: @Display(item.PhysicalStatus)</small>
                                        <small>Operativo: @Display(item.OperationalStatus)</small>
                                        <small>Reportó: @Display(item.ReportedBy)</small>
                                        <small>Fecha: @FormatDate(item.ReportedAt)</small>
                                    </td>

                                    <td>
                                        @if (item.MinimumDataCompleted)
                                        {
                                            <span class="ri-status ok">Completos</span>
                                        }
                                        else
                                        {
                                            <span class="ri-status danger">Sin mínimos</span>
                                            <small>@Display(item.MissingRequiredData)</small>
                                        }
                                    </td>

                                    <td>
                                        <span class="@GetStatusClass(item)">
                                            @GetVisualReconciliationLabel(item)
                                        </span>

                                        <small>@Display(item.SuggestedAction)</small>
                                        <small>@Display(item.ReconciliationObservation)</small>
                                    </td>

                                    <td>
                                        <div class="ri-row-actions">
                                            @if (lifeRecordId.HasValue)
                                            {
                                                <a class="btn btn-sm btn-outline-primary"
                                                   href="@($"/tools/{lifeRecordId.Value}/technical-life-record")">
                                                    Hoja de vida
                                                </a>
                                            }

                                            @if (item.CreatedToolAssetId.HasValue && item.CreatedToolAssetId.Value != Guid.Empty)
                                            {
                                                <span class="ri-status done">Creado en Inventario</span>

                                                <a class="btn btn-sm btn-success"
                                                   href="@($"/tools/{item.CreatedToolAssetId.Value}")">
                                                    Ver activo
                                                </a>

                                                <button class="btn btn-sm btn-outline-danger"
                                                        type="button"
                                                        @onclick="() => VoidCreatedInventoryAssetAsync(item.Id)">
                                                    Anular activo creado
                                                </button>
                                            }
                                            else if (item.Rejected || IsStatus(item, "Rejected"))
                                            {
                                                <span class="ri-status danger">Rechazado / No procede</span>
                                            }
                                            else if (item.RequiresUserClarification || IsStatus(item, "RequiresUserClarification"))
                                            {
                                                <span class="ri-status warn">Pendiente aclaración</span>

                                                <button class="btn btn-sm btn-outline-primary"
                                                        type="button"
                                                        @onclick="() => ResolveClarificationAsync(item.Id)">
                                                    Marcar aclarado
                                                </button>

                                                <button class="btn btn-sm btn-outline-danger"
                                                        type="button"
                                                        @onclick="() => RejectAsync(item.Id)">
                                                    Rechazar
                                                </button>
                                            }
                                            else
                                            {
                                                @if (CanRequestClarification(item))
                                                {
                                                    <button class="btn btn-sm btn-outline-warning"
                                                            type="button"
                                                            @onclick="() => RequestClarificationAsync(item.Id)">
                                                        Aclarar
                                                    </button>
                                                }

                                                @if (CanApproveCreation(item))
                                                {
                                                    <button class="btn btn-sm btn-outline-success"
                                                            type="button"
                                                            @onclick="() => ApproveCreationAsync(item.Id)">
                                                        Aprobar creación
                                                    </button>
                                                }

                                                @if (CanCreateInventoryAsset(item))
                                                {
                                                    <button class="btn btn-sm btn-success"
                                                            type="button"
                                                            @onclick="() => CreateInventoryAssetAsync(item.Id)">
                                                        Crear en Inventario
                                                    </button>
                                                }

                                                @if (CanReconcile(item))
                                                {
                                                    <button class="btn btn-sm btn-outline-dark"
                                                            type="button"
                                                            @onclick="() => ReconcileAsync(item.Id)">
                                                        Conciliar
                                                    </button>
                                                }

                                                @if (CanReject(item))
                                                {
                                                    <button class="btn btn-sm btn-outline-danger"
                                                            type="button"
                                                            @onclick="() => RejectAsync(item.Id)">
                                                        Rechazar
                                                    </button>
                                                }
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    }

</PermissionGuard>

