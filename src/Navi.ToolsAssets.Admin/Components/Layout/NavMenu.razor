@rendermode InteractiveServer
@implements IDisposable
@using System.Text.Json
@using System.Net.Http.Json
@using Microsoft.JSInterop
@using Navi.ToolsAssets.Admin.Services.Auth
@inject WebAuthSessionService AuthSession
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IHttpClientFactory HttpClientFactory

<aside class="navi-sidebar-shell">
    <div class="navi-brand">
        <div class="navi-logo">N</div>
        <div class="navi-brand-text">
            <strong>NAVI Herramientas y AF</strong>
            <span>Consola de administración</span>
        </div>
    </div>

    @if (!sessionChecked)
    {
        <div class="nav-auth-required">
            <strong>Validando sesión</strong>
            <span>Estamos verificando tu sesión local.</span>
        </div>
    }
    else if (!AuthSession.IsAuthenticated)
    {
        <div class="nav-auth-required">
            <strong>Sesión requerida</strong>
            <span>Ingresa para ver los módulos disponibles.</span>
            <a class="nav-login-link" href="login">Ingresar</a>
        </div>
    }
    else
    {
        <div class="nav-user-card">
            <div class="nav-user-left">
                <div class="nav-avatar">@GetInitials()</div>

                <div class="nav-user-info">
                    <strong>@AuthSession.DisplayName</strong>
                    <span>@AuthSession.RoleName · @AuthSession.BranchCode</span>
                </div>
            </div>

            <button type="button" class="nav-logout-btn" @onclick="Logout">
                Salir
            </button>
        </div>

        <div class="nav-scrollable">
            <nav class="nav-menu-list">
                @if (AuthSession.HasPermission("Dashboard.View"))
                {
                    <div class="nav-section-title">PRINCIPAL</div>

                    <div class="nav-item">
                        <NavLink class="nav-link" href="dashboard" Match="NavLinkMatch.All">
                            <span class="nav-icon">📊</span>
                            <span class="nav-text">Dashboard</span>
                        </NavLink>
                    </div>
                }

                @if (HasAny("Tools.View", "AssetAvailability.View", "AssetAssignment.View", "AssetAssignment.History", "TechnicalLifeRecord.View"))
                {
                    <div class="nav-section-title">ACTIVOS FIJOS</div>

                    @if (Has("Tools.View"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="tools">
                                <span class="nav-icon">🧰</span>
                                <span class="nav-text">Inventario de Herramientas y AF</span>
                            </NavLink>
                        </div>
                    }

                    @if (Has("AssetAvailability.View"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="asset-availability">
                                <span class="nav-icon">📍</span>
                                <span class="nav-text">Disponible y Ubicación</span>
                            </NavLink>
                        </div>
                    }

                    @if (Has("AssetAssignment.View"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="asset-assignment">
                                <span class="nav-icon">🔁</span>
                                <span class="nav-text">Asignar Herramientas y AF</span>
                            </NavLink>
                        </div>
                    }

                    @if (Has("AssetAssignment.History"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="asset-assignment-history">
                                <span class="nav-icon">🕘</span>
                                <span class="nav-text">Historial de asignaciones</span>
                            </NavLink>
                        </div>
                    }

                    @if (Has("TechnicalLifeRecord.View"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="technical-life-records">
                                <span class="nav-icon">📋</span>
                                <span class="nav-text">Hoja de Vida de Herramientas y AF</span>
                            </NavLink>
                        </div>
                    }
                }

                @if (HasAny("Purchases.View", "Purchases.Request", "Maintenance.View", "Maintenance.Request", "Maintenance.Execute", "Maintenance.Close", "MaintenancePlans.View", "MaintenancePlans.Create", "MaintenancePlans.Edit", "MaintenancePlans.Delete"))
                {
                    <div class="nav-section-title">OPERACIONES</div>

                    @if (HasAny("Purchases.View", "Purchases.Request"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="mro-purchases">
                                <span class="nav-icon">🛒</span>
                                <span class="nav-text">Solicitar Compra Herramientas y AF</span>
                            </NavLink>
                        </div>
                    }

                    @if (HasAny("Maintenance.View", "Maintenance.Request"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="maintenance-request">
                                <span class="nav-icon">🛠️</span>
                                <span class="nav-text">Solicitar Mantenimiento</span>
                            </NavLink>
                        </div>
                    }

                    @if (HasAny("Maintenance.View", "Purchases.View"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="maintenance">
                                <span class="nav-icon">🔎</span>
                                <span class="nav-text">Consulta Compras y Mtto.</span>
                            </NavLink>
                        </div>
                    }

                    @if (HasAny("MaintenancePlans.View", "MaintenancePlans.Create", "MaintenancePlans.Edit", "MaintenancePlans.Delete"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="maintenance-plans">
                                <span class="nav-icon">🗓️</span>
                                <span class="nav-text">Planes de Mantenimiento</span>
                            </NavLink>
                        </div>
                    }
                }

                @if (HasAny("PhysicalCounts.View", "Reconciliation.View", "Reconciliation.Clarify", "Reconciliation.ApproveCreation", "Reconciliation.Manage", "Documents.View", "Reports.View", "Settings.View", "Security.Users", "Security.Roles"))
                {
                    <div class="nav-section-title">CONTROL</div>

                    @if (Has("PhysicalCounts.View"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="physical-counts">
                                <span class="nav-icon">📦</span>
                                <span class="nav-text">Tomas Físicas</span>
                            </NavLink>
                        </div>
                    }

                    @if (HasAny("Reconciliation.View", "Reconciliation.Clarify", "Reconciliation.ApproveCreation", "Reconciliation.Manage"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="reconciliation">
                                <span class="nav-icon">⚖️</span>
                                <span class="nav-text">Conciliación</span>
                            </NavLink>
                        </div>
                    }

                    @if (Has("Documents.View"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="documents">
                                <span class="nav-icon">📄</span>
                                <span class="nav-text">Documentos</span>
                            </NavLink>
                        </div>
                    }

                    @if (Has("Reports.View"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="reports">
                                <span class="nav-icon">📈</span>
                                <span class="nav-text">Reportes</span>
                            </NavLink>
                        </div>
                    }

                    @if (Has("Settings.View"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="settings">
                                <span class="nav-icon">⚙️</span>
                                <span class="nav-text">Configuración</span>
                            </NavLink>
                        </div>
                    }

                    @if (Has("Security.Users"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="settings/users">
                                <span class="nav-icon">👤</span>
                                <span class="nav-text">Usuarios</span>
                            </NavLink>
                        </div>
                    }

                    @if (Has("Security.Roles"))
                    {
                        <div class="nav-item">
                            <NavLink class="nav-link" href="settings/roles">
                                <span class="nav-icon">🔐</span>
                                <span class="nav-text">Roles y permisos</span>
                            </NavLink>
                        </div>
                    }
                }
            </nav>
        </div>
    }
</aside>

@code {
    private const string StorageKey = "navi-auth-session";
    private bool sessionChecked;

    protected override void OnInitialized()
    {
        AuthSession.OnChange += HandleAuthChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        try
        {
            if (!AuthSession.IsAuthenticated)
            {
                var json = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);

                if (!string.IsNullOrWhiteSpace(json))
                {
                    var user = JsonSerializer.Deserialize<AuthSessionUser>(
                        json,
                        new JsonSerializerOptions
                        {
                            PropertyNameCaseInsensitive = true
                        });

                    if (user is not null && !string.IsNullOrWhiteSpace(user.UserName))
                    {
                        AuthSession.Login(user);
                        await RefreshCurrentRolePermissionsAsync();
                    }
                }
            }
        }
        catch
        {
            try
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey);
            }
            catch
            {
                // Ignorar error limpiando sesión.
            }
        }
        finally
        {
            sessionChecked = true;
            await InvokeAsync(StateHasChanged);
        }
    }

    private bool Has(string permission)
    {
        return AuthSession.HasPermission(permission);
    }

    private bool HasAny(params string[] permissions)
    {
        return AuthSession.HasAnyPermission(permissions);
    }

    
    private async Task RefreshCurrentRolePermissionsAsync()
    {
        if (!AuthSession.IsAuthenticated || AuthSession.RoleId is null)
        {
            return;
        }

        try
        {
            var api = HttpClientFactory.CreateClient("NaviApi");
            var roles = await api.GetFromJsonAsync<List<RoleRefreshDto>>("api/settings/roles") ?? new();

            var role = roles.FirstOrDefault(x => x.Id == AuthSession.RoleId.Value);

            if (role is null)
            {
                return;
            }

            var current = AuthSession.CurrentUser;

            if (current is null)
            {
                return;
            }

            current.RoleCode = role.Code;
            current.RoleName = role.Name;
            current.Permissions = ParsePermissions(role.Permissions).ToList();

            AuthSession.Login(current);

            var json = JsonSerializer.Serialize(current);
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
        }
        catch
        {
            // Si no se puede refrescar, se conserva la sesión actual.
        }
    }

    private static IEnumerable<string> ParsePermissions(string? permissions)
    {
        if (string.IsNullOrWhiteSpace(permissions))
        {
            return Array.Empty<string>();
        }

        if (permissions.Equals("ALL", StringComparison.OrdinalIgnoreCase))
        {
            return Array.Empty<string>();
        }

        return permissions
            .Split(new[] { ',', ';', '|', '\n', '\r' }, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase);
    }

    private sealed class RoleRefreshDto
    {
        public Guid Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Permissions { get; set; }
        public bool IsActive { get; set; }
    }


    private string GetInitials()
    {
        var value = string.IsNullOrWhiteSpace(AuthSession.DisplayName)
            ? AuthSession.UserName
            : AuthSession.DisplayName;

        if (string.IsNullOrWhiteSpace(value))
        {
            return "N";
        }

        var parts = value.Split(' ', StringSplitOptions.RemoveEmptyEntries);

        if (parts.Length == 1)
        {
            return parts[0].Substring(0, Math.Min(2, parts[0].Length)).ToUpperInvariant();
        }

        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    private async Task Logout()
    {
        AuthSession.Logout();

        try
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey);
        }
        catch
        {
            // Ignorar error JS.
        }

        Navigation.NavigateTo("/login", forceLoad: true);
    }

    private void HandleAuthChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthSession.OnChange -= HandleAuthChanged;
    }
}
