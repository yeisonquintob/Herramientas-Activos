@page "/settings"

<PageTitle>Configuración - NAVI Herramientas</PageTitle>

<div class="page-header">
    <div>
        <h1>Configuración</h1>
        <p>Administra usuarios, roles, sedes, almacenes, ubicaciones, catálogos y parámetros generales del módulo de activos fijos.</p>
    </div>
</div>

<section class="settings-dashboard">

    <div class="settings-group">
        <div class="settings-group-header">
            <span>Seguridad</span>
            <strong>Usuarios, roles y permisos</strong>
        </div>

        <div class="settings-grid">
            <a class="settings-card" href="/settings/users">
                <div class="settings-card-icon">&#x1F464;</div>
                <div>
                    <h2>Usuarios</h2>
                    <p>Crear, editar, activar o bloquear usuarios del sistema.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/roles">
                <div class="settings-card-icon">&#x1F510;</div>
                <div>
                    <h2>Roles y permisos</h2>
                    <p>Configurar perfiles y permisos por módulo, acción, sede y zona.</p>
                </div>
            </a>
        </div>
    </div>

    <div class="settings-group">
        <div class="settings-group-header">
            <span>Organización</span>
            <strong>Sedes, zonas, almacenes y responsables</strong>
        </div>

        <div class="settings-grid">
            <a class="settings-card" href="/settings/branches">
                <div class="settings-card-icon">&#x1F3E2;</div>
                <div>
                    <h2>Sedes</h2>
                    <p>Administrar sedes como AGU, Medellín, Bogotá u otras operaciones.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/zones">
                <div class="settings-card-icon">&#x1F5FA;</div>
                <div>
                    <h2>Zonas</h2>
                    <p>Agrupar sedes por regional, operación o zona administrativa.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/warehouses">
                <div class="settings-card-icon">&#x1F3ED;</div>
                <div>
                    <h2>Almacenes / Talleres</h2>
                    <p>Crear almacenes, talleres, bodegas, patios, oficinas y áreas técnicas.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/locations">
                <div class="settings-card-icon">&#x1F4CD;</div>
                <div>
                    <h2>Ubicaciones</h2>
                    <p>Definir estantes, bahías, puestos, zonas internas o ubicaciones físicas.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/responsibles">
                <div class="settings-card-icon">&#x1F465;</div>
                <div>
                    <h2>Responsables</h2>
                    <p>Gestionar técnicos, herramienteros, jefes, coordinadores y responsables.</p>
                </div>
            </a>
        </div>
    </div>

    <div class="settings-group">
        <div class="settings-group-header">
            <span>Activos fijos</span>
            <strong>Catálogos de herramientas y otros activos</strong>
        </div>

        <div class="settings-grid">
            <a class="settings-card" href="/settings/asset-types">
                <div class="settings-card-icon">&#x1F527;</div>
                <div>
                    <h2>Tipos de activo</h2>
                    <p>Herramientas, equipos de diagnóstico, computadores, medición y otros activos.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/categories">
                <div class="settings-card-icon">&#x1F5C2;</div>
                <div>
                    <h2>Categorías</h2>
                    <p>Gato pluma, escáner, computador, herramienta manual, eléctrica o especial.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/statuses">
                <div class="settings-card-icon">&#x1F6A6;</div>
                <div>
                    <h2>Estados</h2>
                    <p>Disponible, asignado, prestado, mantenimiento, dañado, baja o pendiente.</p>
                </div>
            </a>
        </div>
    </div>

    <div class="settings-group">
        <div class="settings-group-header">
            <span>Operación</span>
            <strong>Documentos, mantenimiento, causales y parámetros</strong>
        </div>

        <div class="settings-grid">
            <a class="settings-card" href="/settings/document-types">
                <div class="settings-card-icon">&#x1F4CE;</div>
                <div>
                    <h2>Tipos de documento</h2>
                    <p>Ficha técnica, garantía, foto, acta, factura, evidencia y soporte.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/maintenance-types">
                <div class="settings-card-icon">&#x1F6E0;</div>
                <div>
                    <h2>Tipos de mantenimiento</h2>
                    <p>Preventivo, correctivo, calibración, inspección y certificación.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/maintenance-plans">
                <div class="settings-card-icon">&#x1F4C5;</div>
                <div>
                    <h2>Planes de mantenimiento</h2>
                    <p>Frecuencias, alertas, cronogramas y reglas por tipo de activo.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/causes">
                <div class="settings-card-icon">&#x26A0;</div>
                <div>
                    <h2>Causales</h2>
                    <p>Causales de daño, novedad, pérdida, baja, traslado o mantenimiento.</p>
                </div>
            </a>

            <a class="settings-card" href="/settings/system-parameters">
                <div class="settings-card-icon">&#x2699;</div>
                <div>
                    <h2>Parámetros</h2>
                    <p>Reglas globales, días de alerta, límites de archivo y parámetros generales.</p>
                </div>
            </a>
        </div>
    </div>

</section>
