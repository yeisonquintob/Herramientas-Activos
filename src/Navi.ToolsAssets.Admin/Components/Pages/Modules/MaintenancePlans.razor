    }

    .plan-pill.ontime { background: #d1e7dd; color: #0f5132; }
    .plan-pill.duesoon { background: #fff3cd; color: #7a5200; }
    .plan-pill.overdue { background: #f8d7da; color: #842029; }

    .row-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .28rem;
    }

    .row-actions .btn {
        font-size: .68rem;
        padding: .22rem .42rem;
        min-height: 27px;
    }

    .plans-empty {
        padding: .9rem;
        border-radius: .75rem;
        background: #f8fafc;
