@inherits LayoutComponentBase
@using Navi.ToolsAssets.Admin.Components.Security
@inject NavigationManager Navigation

@if (IsLoginPage)
{
    <main class="login-layout-only">
        @Body
    </main>
}
else
{
    <div class="navi-layout-shell">
        <aside class="navi-sidebar-area">
            <NavMenu />
        </aside>

        <main class="navi-main-area">
<article class="navi-content">
                @Body
            </article>
        </main>
    </div>

    <footer class="navi-bottom-bar">
        <span>Navitrans 40 años</span>
        <span class="separator">·</span>
        <span>Mockup diseñado por TI Soluciones</span>
    </footer>
}

<RoutePermissionRedirector />

<div id="blazor-error-ui">
    Ha ocurrido un error inesperado.
    <a href="" class="reload">Recargar</a>
    <a class="dismiss">x</a>
</div>

@code {
    private bool IsLoginPage =>
        Navigation.ToBaseRelativePath(Navigation.Uri)
            .Trim('/')
            .Equals("login", StringComparison.OrdinalIgnoreCase);
}
