    private async Task OnImageSelected(InputFileChangeEventArgs args)
    {
        errorMessage = null;

        var file = args.File;

        if (file is null)
        {
            return;
        }

        if (!file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            errorMessage = "Solo se permiten imágenes como referencia visual.";
            return;
        }

        const long maxFileSize = 2 * 1024 * 1024;

        if (file.Size > maxFileSize)
        {
            errorMessage = "La imagen no puede superar 2 MB.";
            return;
        }

        await using var stream = file.OpenReadStream(maxFileSize);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);

        lineForm.ImageReference = file.Name;
        lineForm.ImagePreview = $"data:{file.ContentType};base64,{Convert.ToBase64String(memory.ToArray())}";
    }

    private void AddLine()
    {
        successMessage = null;
        errorMessage = null;

        if (!CanEditRequest)
        {
            errorMessage = "Solo puedes modificar activos cuando la solicitud está nueva o en borrador.";
            return;
        }

        if (string.IsNullOrWhiteSpace(lineForm.ItemName))
        {
            errorMessage = "Debes indicar el nombre del activo o herramienta.";
            return;
        }

        if (lineForm.Quantity <= 0)
        {
            errorMessage = "La cantidad debe ser mayor a cero.";
            return;
        }

        if (editingLineId.HasValue)
        {
            var existing = currentLines.FirstOrDefault(x => x.Id == editingLineId.Value);

            if (existing is not null)
            {
                existing.ItemName = lineForm.ItemName.Trim();
                existing.ItemCode = lineForm.ItemCode?.Trim();
                existing.ItemDescription = lineForm.ItemDescription?.Trim();
                existing.Quantity = lineForm.Quantity;
                existing.Unit = string.IsNullOrWhiteSpace(lineForm.Unit) ? "Und" : lineForm.Unit.Trim();
                existing.Category = string.IsNullOrWhiteSpace(lineForm.Category) ? "Herramienta" : lineForm.Category;
                existing.NeedDetail = lineForm.NeedDetail?.Trim();
                existing.ImageReference = lineForm.ImageReference;
                existing.ImagePreview = lineForm.ImagePreview;
            }
        }
        else
        {
            currentLines.Add(new PurchaseLineItem
            {
                Id = Guid.NewGuid(),
                ItemName = lineForm.ItemName.Trim(),
                ItemCode = lineForm.ItemCode?.Trim(),
                ItemDescription = lineForm.ItemDescription?.Trim(),
                Quantity = lineForm.Quantity,
                Unit = string.IsNullOrWhiteSpace(lineForm.Unit) ? "Und" : lineForm.Unit.Trim(),
                Category = string.IsNullOrWhiteSpace(lineForm.Category) ? "Herramienta" : lineForm.Category,
                NeedDetail = lineForm.NeedDetail?.Trim(),
                ImageReference = lineForm.ImageReference,
                ImagePreview = lineForm.ImagePreview,
                Selected = true
            });
        }

        ClearLine();
    }

    private void EditLine(Guid id)
    {
        var item = currentLines.FirstOrDefault(x => x.Id == id);

        if (item is null)
        {
            return;
        }

        editingLineId = item.Id;
        lineForm.ItemName = item.ItemName;
        lineForm.ItemCode = item.ItemCode;
        lineForm.ItemDescription = item.ItemDescription;
        lineForm.Quantity = item.Quantity;
        lineForm.Unit = item.Unit;
        lineForm.Category = item.Category;
        lineForm.NeedDetail = item.NeedDetail;
        lineForm.ImageReference = item.ImageReference;
        lineForm.ImagePreview = item.ImagePreview;
    }

    private void RemoveLine(Guid id)
    {
        currentLines.RemoveAll(x => x.Id == id);
        currentQuotes.RemoveAll(x => x.LineId == id);

        if (editingLineId == id)
        {
            ClearLine();
        }
    }

    private void ClearLine()
    {
        editingLineId = null;
        lineForm.ItemName = string.Empty;
        lineForm.ItemCode = string.Empty;
        lineForm.ItemDescription = string.Empty;
        lineForm.Quantity = 1;
        lineForm.Unit = "Und";
        lineForm.Category = "Herramienta";
