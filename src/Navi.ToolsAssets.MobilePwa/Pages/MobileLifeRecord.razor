    private async Task RunSaveAsync(Func<Task> action)
    {
        try
        {
            isSaving = true;
            message = null;

            await action();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            message = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private bool IsToolVisibleByScopeOnly(MobileToolDto item)
    {
        if (UserCanSeeAllBranches())
        {
            return true;
        }

        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        return SameNormalized(item.BranchCode, user.BranchCode)
            || SameNormalized(item.BranchName, user.BranchName);
    }

    private bool IsToolVisible(MobileToolDto item)
    {
        if (!IsToolVisibleByScopeOnly(item))
        {
            return false;
        }

        if (IsOwnDataOnly())
        {
            return Auth.CurrentUser?.ResponsiblePersonId == item.ResponsiblePersonId ||
                   SameNormalized(item.ResponsiblePersonName, Auth.CurrentUser?.ResponsiblePersonName) ||
                   SameNormalized(item.ResponsiblePersonName, Auth.CurrentUser?.DisplayName);
        }

        return true;
    }

    private bool IsOwnDataOnly()
    {
        var role = $"{Auth.CurrentUser?.RoleCode} {Auth.CurrentUser?.RoleName}";
        return Normalize(role).Contains("TECNICO") && !HasAnyManagementPermission;
    }

    private bool UserCanSeeAllBranches()
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(user.BranchCode)
            || SameNormalized(user.BranchCode, "TODAS")
            || SameNormalized(user.BranchCode, "ALL")
            || SameNormalized(user.BranchName, "Todas las sedes")
            || SameNormalized(user.BranchName, "TODAS")
            || SameNormalized(user.BranchName, "ALL");
    }

