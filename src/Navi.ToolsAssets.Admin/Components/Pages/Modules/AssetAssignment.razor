@page "/asset-assignment"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject NaviAccessScopeService AccessScope
@using Navi.ToolsAssets.Admin.Services.Auth
@inject NavigationManager NavigationManager
@inject WebAuthSessionService AuthSession

<PageTitle>Asignar Herramientas y AF - NAVI</PageTitle>

<PermissionGuard Permission="AssetAssignment.View" ModuleName="Asignar Herramientas y AF">

<section class="af-banner">
    <div>
        <span class="af-pill">ACTIVOS FIJOS</span>
        <h2>Asignar Herramientas y AF</h2>
        <p>Solicita, aprueba, asigna o regresa activos fijos con trazabilidad de préstamo y responsable.</p>
    </div>

    <div class="af-banner-side"><button class="btn btn-sm btn-outline-light" @onclick="LoadAsync">
            Actualizar
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(message))
{
    <div class="@messageClass">@message</div>
}

<section class="af-grid">
    <aside class="af-left-stack">
        <div class="af-card">
            <h3>@GetMovementTitle()</h3>

            <div class="mb-2 navi-search-field">
                <label class="form-label">Activo fijo</label>
                <input class="form-control"
                       list="assignment-tools-list"
                       value="@assignmentToolSearchText"
                       @oninput="OnAssignmentToolSearchInput"
                       placeholder="Escriba código, nombre o serial..." />

                <datalist id="assignment-tools-list">
                    @foreach (var tool in ScopedTools.OrderBy(x => x.InternalCode))
                    {
                        <option value="@FormatToolOption(tool)"></option>
                    }
                </datalist>

                <small class="@GetAssignmentToolHintClass()">@GetAssignmentToolHint()</small>
            </div>

            <div class="mb-2">
                <label class="form-label">Tipo de movimiento</label>
                <InputSelect class="form-select" @bind-Value="form.AssignmentType">
                    <option value="Responsible">Asignar a usuario/responsable</option>
                    <option value="Warehouse">Regresar a almacén/taller</option>
                </InputSelect>
            </div>

            @if (form.AssignmentType == "Responsible")
            {
                <div class="mb-2 navi-search-field">
                    <label class="form-label">Usuario / Responsable</label>
                    <input class="form-control"
                           list="assignment-responsibles-list"
                           value="@assignmentResponsibleSearchText"
                           @oninput="OnAssignmentResponsibleSearchInput"
                           placeholder="Escriba nombre, cargo o responsable..." />

                    <datalist id="assignment-responsibles-list">
                        @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                        {
                            <option value="@FormatResponsibleOption(responsible)"></option>
                        }
                    </datalist>

                    <small class="@GetAssignmentResponsibleHintClass()">@GetAssignmentResponsibleHint()</small>
                </div>
            }

            @if (form.AssignmentType == "Warehouse")
            {
                <div class="mb-2 navi-search-field">
                    <label class="form-label">Sede destino</label>
                    <input class="form-control"
                           list="assignment-branches-list"
                           value="@assignmentBranchSearchText"
                           @oninput="OnAssignmentBranchSearchInput"
                           placeholder="Escriba código o nombre de sede..." />

                    <datalist id="assignment-branches-list">
                        @foreach (var branch in branches.OrderBy(x => x.Code))
                        {
                            <option value="@FormatBranchOption(branch)"></option>
                        }
                    </datalist>

                    <small class="@GetAssignmentBranchHintClass()">@GetAssignmentBranchHint()</small>
                </div>

                <div class="mb-2 navi-search-field">
                    <label class="form-label">Almacén / Taller destino</label>
                    <input class="form-control"
                           list="assignment-locations-list"
                           value="@assignmentLocationSearchText"
                           @oninput="OnAssignmentLocationSearchInput"
                           placeholder="Escriba almacén, taller o ubicación..." />

                    <datalist id="assignment-locations-list">
                        @foreach (var location in AvailableLocations.OrderBy(x => x.Code))
                        {
                            <option value="@FormatLocationOption(location)"></option>
                        }
                    </datalist>

                    <small class="@GetAssignmentLocationHintClass()">@GetAssignmentLocationHint()</small>
                </div>
            }

            <div class="mb-2">
                <label class="form-label">
                    @(form.AssignmentType == "Warehouse" ? "Fecha de regreso" : "Fecha de asignación")
                </label>
                <InputDate class="form-control" @bind-Value="form.AssignmentDate" />
            </div>

            <div class="mb-3">
                <label class="form-label">Observación</label>
                <InputTextArea class="form-control" @bind-Value="form.Observation" rows="3" />
            </div>

            <div class="d-grid gap-2">
                @if (form.AssignmentType == "Warehouse")
                {
                    <button class="assign-main assign-main-warning" @onclick="SaveAsync" disabled="@(isSaving || !CanReturnAsset)">
                        @(isSaving ? "Guardando..." : "Confirmar regreso")
                    </button>
                }
                else
                {
                    <button class="assign-main assign-main-primary" @onclick="SaveAsync" disabled="@(isSaving || !CanAssignAsset)">
                        @(isSaving ? "Guardando..." : "Confirmar asignación")
                    </button>
                }

                <button class="assign-main assign-main-neutral" @onclick="ClearForm">
                    Limpiar
                </button>
            </div>
        </div>

        <div class="af-card history-launch-card">
            <span class="history-pill">HISTORIAL</span>
            <h3>Historial por usuario</h3>
            <p>Consulta en una vista completa los activos asignados, entregados, regresados y sus detalles.</p>

            <div class="mb-2">
                <label class="form-label">Usuario / Responsable</label>
                <input class="form-control form-control-sm"
                       list="history-responsibles-list"
                       value="@historyResponsibleSearchText"
                       @oninput="OnHistoryResponsibleSearchInput"
                       placeholder="Escriba usuario o responsable..." />

                <datalist id="history-responsibles-list">
                    <option value="Todos los usuarios"></option>
                    @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                    {
                        <option value="@FormatResponsibleOption(responsible)"></option>
                    }
                </datalist>
            </div>

            <div class="mb-3">
                <label class="form-label">Buscar</label>
                <input class="form-control form-control-sm"
                       placeholder="Código, activo fijo, serial o detalle..."
                       @bind="historySearch"
                       @bind:event="oninput" />
            </div>

            <button class="btn-open-history" @onclick="OpenHistory" disabled="@(!CanViewAssignmentHistory)">
                Abrir historial de asignaciones
            </button>
        </div>

        <div class="af-card request-card">
            <span class="history-pill request">SOLICITUD</span>
            <h3>Solicitud de asignación</h3>
            <p>Busca una herramienta y solicita que sea asignada a tu usuario. El herramentero la aprueba desde esta misma vista.</p>

            <div class="request-user">
                <span>Solicitante</span>
                <strong>@GetCurrentResponsibleLabel()</strong>
            </div>

            @if (!CanRequestAssignment)
            {
                <div class="assignment-request-warning">
                    No tienes permiso AssetAssignment.Request para crear solicitudes de asignación.
                </div>
            }
            else if (CurrentRequesterPersonId is null)
            {
                <div class="assignment-request-info">
                    No hay responsable operativo asociado al usuario. Asócialo en Configuración > Usuarios antes de crear solicitudes.
                </div>
            }

            <div class="mb-2">
                <label class="form-label">Buscar herramienta</label>
                <input class="form-control form-control-sm"
                       placeholder="Escriba código, nombre o serial..."
                       @bind="requestSearch"
                       @bind:event="oninput" />
            </div>

            @if (!requestForm.ToolId.HasValue && !string.IsNullOrWhiteSpace(requestSearch))
            {
                <div class="request-results">
                    <div class="request-results-title">
                        <span>Resultados filtrados</span>
                        <strong>@RequestTools.Count()</strong>
                    </div>

                    @if (!RequestTools.Any())
                    {
                        <div class="request-result-empty">
                            No se encontraron herramientas con ese criterio.
                        </div>
                    }
                    else
                    {
                        @foreach (var tool in RequestTools.Take(7))
                        {
                            var pending = FindPendingRequestForTool(tool.Id);
                            var isSelected = requestForm.ToolId == tool.Id;

                            <button type="button"
                                    class="request-result-card @(isSelected ? "selected" : "")"
                                    @onclick="() => SelectRequestTool(tool)">
                                <span>
                                    <strong>@tool.InternalCode</strong>
                                    <small>@tool.Name</small>
                                    <small>@Show(tool.BranchCode) · @Show(tool.LocationName)</small>
                                </span>

                                <em class="@GetRequestAvailabilityClass(tool, pending)">
                                    @(pending is not null ? "Con solicitud" : GetStatusLabel(tool.OperationalStatus))
                                </em>
                            </button>
                        }
                    }
                </div>
            }

            @if (SelectedRequestTool is not null)
            {
                <div class="selected-request-tool">
                    <div>
                        <span>Herramienta seleccionada</span>
                        <strong>@SelectedRequestTool.InternalCode - @SelectedRequestTool.Name</strong>
                        <small>@Show(SelectedRequestTool.BranchCode) · @Show(SelectedRequestTool.LocationName)</small>
                    </div>

                    <button type="button" @onclick="ClearRequestToolSelection">
                        Cambiar
                    </button>
                </div>
            }

            <div class="mb-2">
                <label class="form-label">Fecha estimada de devolución</label>
                <InputDate class="form-control form-control-sm" @bind-Value="requestForm.ExpectedReturnAt" />
            </div>

            <div class="mb-3">
                <label class="form-label">Observación</label>
                <InputTextArea class="form-control form-control-sm" rows="2" @bind-Value="requestForm.Notes" />
            </div>

            @if (!CanRequestAssignment)
            {
                <div class="assignment-permission-note">
                    Solicitud bloqueada por permiso AssetAssignment.Request.
                </div>
            }

            <button type="button"
                    class="btn-request-assignment"
                    @onclick="SubmitSelfAssignmentRequestAsync"
                    disabled="@(isSaving || !CanRequestAssignment || CurrentRequesterPersonId is null || !requestForm.ToolId.HasValue)">
                @(isSaving ? "Registrando..." : "Solicitud de asignación")
            </button>
        </div>

        <div class="af-card pending-card">
            <span class="history-pill approve">APROBACIÓN</span>
            <h3>Solicitudes pendientes</h3>

            @if (!PendingLoanRequests.Any())
            {
                <div class="pending-empty">No hay solicitudes pendientes.</div>
            }
            else
            {
                <div class="pending-list">
                    @foreach (var request in PendingLoanRequests.Take(6))
                    {
                        var item = request.Items.FirstOrDefault();

                        <article>
                            <div>
                                <strong>@request.LoanNumber</strong>
                                <span>@Show(item?.ToolInternalCode) - @Show(item?.ToolName)</span>
                                <small>Solicita: @Show(request.CreatedBy) · @ShowDate(request.RequestedAt)</small>
                            </div>

                            <div class="pending-actions">
                                <button class="approve" @onclick="() => ApproveRequestAsync(request)"
                                        disabled="@(isSaving || !CanApproveAssignmentRequest)">
                                    Aprobar
                                </button>

                                <button class="deny" @onclick="() => RejectRequestAsync(request)"
                                        disabled="@(isSaving || !CanDenyAssignmentRequest)">
                                    Denegar
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </div>
    </aside>

    <section class="af-card">
        <div class="af-table-header">
            <div>
                <h3>Activos asignables</h3>
                <p>Consulta el estado actual, filtra por usuario y registra asignaciones, regresos o aprobaciones.</p>
            </div>

            <div class="af-filters af-filters-standard">
                <input class="form-control form-control-sm"
                       placeholder="Buscar código, nombre, serial..."
                       @bind="search"
                       @bind:event="oninput" />

                <input class="form-control form-control-sm"
                       list="assignment-table-branches-list"
                       value="@selectedBranchSearchText"
                       @oninput="OnTableBranchSearchInput"
                       placeholder="Todas las sedes" />

                <datalist id="assignment-table-branches-list">
                    @if (IsAllBranchScope())
                    {
                        <option value="Todas las sedes"></option>
                    }

                    @foreach (var branch in BranchFilterOptions)
                    {
                        <option value="@FormatBranchOption(branch)"></option>
                        <option value="@branch.Code"></option>
                        <option value="@branch.Name"></option>
                    }
                </datalist>

                <input class="form-control form-control-sm"
                       list="table-responsibles-list"
                       value="@selectedResponsibleSearchText"
                       @oninput="OnTableResponsibleSearchInput"
                       placeholder="Todos los usuarios" />

                <datalist id="table-responsibles-list">
                    <option value="Todos los usuarios"></option>
                    <option value="Sin responsable"></option>
                    @foreach (var responsible in responsibles.OrderBy(x => x.FullName))
                    {
                        <option value="@FormatResponsibleOption(responsible)"></option>
                        <option value="@responsible.FullName"></option>
                    }
                </datalist>
            </div>
        </div>

        @if (isLoading)
        {
            <p>Cargando activos...</p>
        }
        else if (!FilteredTools.Any())
        {
            <div class="alert alert-info">No hay activos para los filtros seleccionados.</div>
        }
        else
        {
            <table class="table table-hover align-middle af-table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Activo</th>
                        <th>Sede</th>
                        <th>Ubicación</th>
                        <th>Usuario / Responsable</th>
                        <th>Estado</th>
                        <th>Solicitud</th>
                        <th>Fecha asignación</th>
                        <th>Fecha entrega</th>
                        <th class="text-end">Acción</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tool in FilteredTools)
                    {
                        var pending = FindPendingRequestForTool(tool.Id);

                        <tr>
                            <td><strong>@tool.InternalCode</strong></td>
                            <td>
                                <div>@tool.Name</div>
                                <small class="text-muted">@Show(tool.SerialNumber)</small>
                            </td>
                            <td>@Show(tool.BranchCode)</td>
                            <td>@Show(tool.LocationName)</td>
                            <td>
                                <div>@Show(tool.ResponsiblePersonName)</div>
                                <small class="text-muted">@Show(tool.ResponsiblePosition)</small>
                            </td>
                            <td><span class="@GetStatusBadge(tool.OperationalStatus)">@GetStatusLabel(tool.OperationalStatus)</span></td>
                            <td>
                                @if (pending is null)
                                {
                                    <span class="request-state empty">Sin solicitud</span>
                                }
                                else
                                {
                                    <span class="request-state pending">@pending.LoanNumber</span>
                                }
                            </td>
                            <td>@ShowDate(tool.LastAssignmentDate)</td>
                            <td>@ShowDate(tool.LastReturnDate)</td>
                            <td class="text-end">
                                <div class="assignment-actions">
                                    <button class="assign-action assign-action-primary" @onclick="() => SelectForAssignment(tool)" disabled="@(!CanDirectAssign)">
                                        Asignar
                                    </button>

                                    <button class="assign-action assign-action-success"
                                            @onclick="() => ApproveRequestAsync(pending)"
                                            disabled="@(pending is null || !CanApproveAssignmentRequest || isSaving)">
                                        Aprobar
                                    </button>

                                    <button class="assign-action assign-action-danger"
                                            @onclick="() => RejectRequestAsync(pending)"
                                            disabled="@(pending is null || !CanDenyAssignmentRequest || isSaving)">
                                        Denegar
                                    </button>

                                    <button class="assign-action assign-action-warning" @onclick="() => SelectForReturn(tool)" disabled="@(!CanReturnAssignment)">
                                        Regresar
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</section>

</PermissionGuard>

<style>
    .af-banner {
        background: linear-gradient(135deg, #050008 0%, #280032 45%, #5c006b 100%);
        color: #fff;
        border-radius: .85rem;
        padding: 1.25rem 1.4rem;
        margin-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        box-shadow: 0 .65rem 1.35rem rgba(75,0,92,.22);
    }

    .af-pill {
        display: inline-flex;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.35);
        border-radius: 999px;
        padding: .22rem .65rem;
        font-size: .7rem;
        font-weight: 900;
        margin-bottom: .6rem;
    }

    .af-banner h2 {
        color: #fff;
        font-weight: 950;
        margin: 0;
    }

    .af-banner p {
        color: rgba(255,255,255,.78);
        margin: .35rem 0 0;
        font-size: .9rem;
    }

    .af-banner-side {
        min-width: 185px;
        display: grid;
        gap: .65rem;
    }

    .af-status-box {
        background: rgba(255,255,255,.12);
        border-radius: .65rem;
        padding: .55rem .75rem;
        text-align: right;
    }

    .af-status-box span {
        color: #ffdd57;
        display: block;
        font-size: .75rem;
        font-weight: 900;
    }

    .af-grid {
        display: grid;
        grid-template-columns: 360px minmax(0, 1fr);
        gap: 1rem;
    }

    .af-left-stack {
        display: grid;
        gap: .75rem;
        align-content: start;
    }

    .af-card {
        background: #fff;
        border: 1px solid #dfe3e8;
        border-radius: .85rem;
        padding: 1rem;
        box-shadow: 0 .3rem .75rem rgba(0,0,0,.045);
    }

    .af-card h3 {
        font-size: 1.05rem;
        font-weight: 900;
        margin-bottom: .75rem;
    }

    .af-table-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: .75rem;
    }

    .af-table-header p {
        margin: 0;
        color: #6c757d;
        font-size: .8rem;
    }

    .af-filters {
        display: flex;
        gap: .45rem;
        min-width: 520px;
    }

    .af-table {
        font-size: .82rem;
    }

    .af-table th,
    .af-table td {
        padding: .45rem .5rem;
    }

    .history-launch-card,
    .request-card,
    .pending-card {
        background: linear-gradient(180deg, #ffffff 0%, #fbf8fc 100%);
    }

    .history-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #f3ecf7;
        color: #4b005c;
        border-radius: 999px;
        padding: .15rem .55rem;
        font-size: .66rem;
        font-weight: 950;
        margin-bottom: .45rem;
    }

    .history-pill.request {
        background: #eef6ff;
        color: #1d4ed8;
    }

    .history-pill.approve {
        background: #ecfdf5;
        color: #047857;
    }

    .history-launch-card p,
    .request-card p {
        color: #657083;
        font-size: .76rem;
        line-height: 1.28;
        margin-bottom: .75rem;
    }

    .btn-open-history,
    .btn-request-assignment {
        width: 100%;
        height: 34px;
        border: 0;
        border-radius: 999px;
        background: linear-gradient(135deg, #4b005c 0%, #8c119f 100%);
        color: #ffffff;
        font-size: .78rem;
        font-weight: 950;
        box-shadow: 0 .25rem .7rem rgba(75, 0, 92, .25);
    }

    .btn-request-assignment {
        background: linear-gradient(135deg, #1d4ed8 0%, #7c3aed 100%);
    }

    .request-results {
        border: 1px solid #eadff0;
        border-radius: .72rem;
        background: #fbf7fd;
        padding: .45rem;
        margin: -.15rem 0 .65rem;
        display: grid;
        gap: .38rem;
        max-height: 305px;
        overflow-y: auto;
    }

    .request-results-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #4b005c;
        font-size: .68rem;
        font-weight: 950;
        padding: .1rem .15rem .25rem;
    }

    .request-results-title strong {
        min-width: 24px;
        height: 20px;
        border-radius: 999px;
        background: #4b005c;
        color: #fff;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .62rem;
        font-weight: 950;
    }

    .request-result-empty {
        border: 1px dashed #dccbe5;
        border-radius: .6rem;
        padding: .65rem;
        color: #6c5775;
        font-size: .74rem;
        text-align: center;
        font-weight: 850;
        background: #fff;
    }

    .request-result-card {
        width: 100%;
        border: 1px solid #eadff0;
        background: #fff;
        border-radius: .62rem;
        padding: .48rem .55rem;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: .45rem;
        align-items: center;
        text-align: left;
        cursor: pointer;
    }

    .request-result-card:hover,
    .request-result-card.selected {
        border-color: #8c119f;
        box-shadow: 0 .25rem .65rem rgba(75,0,92,.12);
    }

    .request-result-card span,
    .request-result-card strong,
    .request-result-card small {
        display: block;
    }

    .request-result-card strong {
        color: #4b005c;
        font-size: .72rem;
        font-weight: 950;
    }

    .request-result-card small {
        color: #4d3b56;
        font-size: .66rem;
        font-weight: 750;
        line-height: 1.25;
    }

    .request-status {
        border-radius: 999px;
        padding: .16rem .48rem;
        font-style: normal;
        font-size: .58rem;
        font-weight: 950;
        border: 1px solid transparent;
        white-space: nowrap;
    }

    .request-status-available {
        color: #047857;
        background: #ecfdf5;
        border-color: #bbf7d0;
    }

    .request-status-assigned {
        color: #7c2d12;
        background: #fff7ed;
        border-color: #fed7aa;
    }

    .request-status-loaned {
        color: #075985;
        background: #e0f2fe;
        border-color: #bae6fd;
    }

    .request-status-maintenance {
        color: #1d4ed8;
        background: #eff6ff;
        border-color: #bfdbfe;
    }

    .request-status-danger {
        color: #dc2626;
        background: #fff1f2;
        border-color: #fecdd3;
    }

    .request-status-warning {
        color: #a16207;
        background: #fff8e1;
        border-color: #fde68a;
    }

    .request-status-pending {
        color: #6d28d9;
        background: #f5f3ff;
        border-color: #ddd6fe;
    }

    .request-status-neutral {
        color: #475569;
        background: #f8fafc;
        border-color: #e2e8f0;
    }
    .request-user {
        border: 1px solid #eadff0;
        border-radius: .65rem;
        padding: .5rem .65rem;
        margin-bottom: .65rem;
        background: #fbf7fd;
    }

    .request-user span {
        display: block;
        color: #6c5775;
        font-size: .66rem;
        font-weight: 850;
    }

    .request-user strong {
        display: block;
        color: #180020;
        font-size: .78rem;
        font-weight: 950;
    }

    .pending-empty {
        border: 1px dashed #dccbe5;
        border-radius: .65rem;
        padding: .75rem;
        color: #6c5775;
        font-size: .78rem;
