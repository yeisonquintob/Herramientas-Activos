    private async Task SaveDraftAsync()
    {
        if (!CanSaveAsDraft)
        {
            errorMessage = RequestConditionText;
            return;
        }

        await SaveCurrentLocalAsync(LocalStatusDraft);

        if (string.IsNullOrWhiteSpace(errorMessage))
        {
            successMessage = "Borrador guardado correctamente.";
        }
    }

    private async Task ConfirmRequestAsync()
    {
        if (!CanConfirmRequest)
        {
            errorMessage = RequestConditionText;
            return;
        }

        await SaveCurrentLocalAsync(LocalStatusConfirmed);

        if (string.IsNullOrWhiteSpace(errorMessage))
        {
            successMessage = "Solicitud confirmada. Ahora puede pasar a cotización.";
            ClearWorkspace(keepBranchAndRequester: true);
        }
    }

    private async Task SaveCurrentLocalAsync(string status)
    {
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(header.BranchIdText))
        {
            errorMessage = "Debes seleccionar la sede.";
            return;
        }

        if (string.IsNullOrWhiteSpace(header.RequestName))
        {
            header.RequestName = "Solicitud de compra móvil";
        }

        var now = DateTime.UtcNow;
        var id = activeStoredRequestId ?? Guid.NewGuid();

        var existing = storedRequests.FirstOrDefault(x => x.Id == id);

        if (existing is null)
        {
            existing = new StoredPurchaseRequest
            {
                Id = id,
                LocalNumber = BuildLocalNumber(status, now),
                CreatedAt = now
            };

            storedRequests.Add(existing);
        }

        existing.Header = header.Clone();
        existing.Lines = currentLines.Select(x => x.Clone()).ToList();
        existing.Quotations = currentQuotes.Select(x => x.Clone()).ToList();
        existing.Status = status;
        existing.UpdatedAt = now;

        activeStoredRequestId = existing.Id;
        currentStatus = status;

        await SaveLocalStateAsync();
    }

    private void LoadDraftForEdit(Guid id)
    {
        var item = storedRequests.FirstOrDefault(x => x.Id == id && x.Status == LocalStatusDraft);

        if (item is null)
        {
            return;
        }

        LoadStoredRequestToWorkspace(item);
        currentStatus = LocalStatusDraft;
        successMessage = "Borrador cargado para edición.";
    }

    private async Task ConfirmStoredRequestAsync(Guid id)
    {
        var item = storedRequests.FirstOrDefault(x => x.Id == id && x.Status == LocalStatusDraft);

        if (item is null)
        {
            return;
        }

        item.Status = LocalStatusConfirmed;
        item.UpdatedAt = DateTime.UtcNow;
        await SaveLocalStateAsync();

        if (activeStoredRequestId == id)
        {
            ClearWorkspace(keepBranchAndRequester: true);
        }

        successMessage = "Solicitud confirmada. Ahora puede realizar cotización.";
    }

    private async Task StartQuotationAsync(Guid id)
    {
        if (!CanRegisterQuotation)
        {
            errorMessage = "No tienes permiso para registrar cotización.";
            return;
        }

        var item = storedRequests.FirstOrDefault(x => x.Id == id && x.Status == LocalStatusConfirmed);

        if (item is null)
        {
            errorMessage = "Solo una solicitud confirmada puede pasar a cotización.";
            return;
        }

        item.Status = LocalStatusQuoting;
        item.UpdatedAt = DateTime.UtcNow;

        await SaveLocalStateAsync();

        LoadStoredRequestToWorkspace(item);
        currentStatus = LocalStatusQuoting;
        successMessage = "Cotización habilitada. Agrega cotizaciones y luego genera la compra.";
    }

    private void ContinueQuotation(Guid id)
    {
        if (!CanRegisterQuotation)
        {
            errorMessage = "No tienes permiso para continuar cotización.";
            return;
        }

        var item = storedRequests.FirstOrDefault(x => x.Id == id && x.Status == LocalStatusQuoting);

        if (item is null)
        {
            return;
        }

        LoadStoredRequestToWorkspace(item);
        currentStatus = LocalStatusQuoting;
        successMessage = "Cotización cargada para continuar.";
    }

    private void LoadStoredRequestToWorkspace(StoredPurchaseRequest item)
    {
        activeStoredRequestId = item.Id;
        header.CopyFrom(item.Header);
        currentLines = item.Lines.Select(x => x.Clone()).ToList();
        currentQuotes = item.Quotations.Select(x => x.Clone()).ToList();
        currentStatus = item.Status;
        ClearLine();
        ClearQuotation();
    }

    private async Task AddQuotationAsync()
    {
        errorMessage = null;

        if (!CanQuote)
        {
            errorMessage = "Primero selecciona una solicitud confirmada y presiona Realizar cotización.";
            return;
        }

        if (string.IsNullOrWhiteSpace(quoteForm.Provider))
        {
            errorMessage = "Debes indicar el proveedor.";
            return;
        }

        if (quoteForm.PriceBeforeVat is null || quoteForm.PriceBeforeVat <= 0)
        {
            errorMessage = "Debes indicar el precio antes de IVA.";
            return;
        }

        Guid? lineId = null;

        if (Guid.TryParse(quoteForm.LineIdText, out var parsed))
        {
            lineId = parsed;
        }

        if (editingQuoteId.HasValue)
        {
            var existing = currentQuotes.FirstOrDefault(x => x.Id == editingQuoteId.Value);

            if (existing is not null)
            {
                existing.Provider = quoteForm.Provider.Trim();
                existing.LineId = lineId;
                existing.QuotationDate = quoteForm.QuotationDate;
                existing.DeliveryTime = quoteForm.DeliveryTime?.Trim();
                existing.PriceBeforeVat = quoteForm.PriceBeforeVat;
                existing.AdditionalDetails = quoteForm.AdditionalDetails?.Trim();
            }
        }
        else
        {
            currentQuotes.Add(new QuotationItem
            {
                Id = Guid.NewGuid(),
                Provider = quoteForm.Provider.Trim(),
                LineId = lineId,
                QuotationDate = quoteForm.QuotationDate,
                DeliveryTime = quoteForm.DeliveryTime?.Trim(),
                PriceBeforeVat = quoteForm.PriceBeforeVat,
                AdditionalDetails = quoteForm.AdditionalDetails?.Trim(),
                Selected = true
            });
        }

        ClearQuotation();
        await PersistActiveQuotationStateAsync();
    }

    private void EditQuotation(Guid id)
    {
        if (!CanQuote)
        {
            return;
        }

        var quote = currentQuotes.FirstOrDefault(x => x.Id == id);

        if (quote is null)
        {
            return;
        }

        editingQuoteId = quote.Id;
        quoteForm.Provider = quote.Provider;
        quoteForm.LineIdText = quote.LineId?.ToString() ?? string.Empty;
        quoteForm.QuotationDate = quote.QuotationDate;
        quoteForm.DeliveryTime = quote.DeliveryTime;
        quoteForm.PriceBeforeVat = quote.PriceBeforeVat;
        quoteForm.AdditionalDetails = quote.AdditionalDetails;
    }

    private async Task RemoveQuotationAsync(Guid id)
    {
        if (!CanQuote)
        {
            return;
        }

        currentQuotes.RemoveAll(x => x.Id == id);

        if (editingQuoteId == id)
        {
            ClearQuotation();
        }

        await PersistActiveQuotationStateAsync();
    }

    private async Task PersistActiveQuotationStateAsync()
    {
        if (!activeStoredRequestId.HasValue)
        {
            return;
        }

        var item = storedRequests.FirstOrDefault(x => x.Id == activeStoredRequestId.Value);

        if (item is null)
        {
            return;
        }

        item.Status = LocalStatusQuoting;
        item.Header = header.Clone();
        item.Lines = currentLines.Select(x => x.Clone()).ToList();
        item.Quotations = currentQuotes.Select(x => x.Clone()).ToList();
        item.UpdatedAt = DateTime.UtcNow;

        currentStatus = LocalStatusQuoting;

        await SaveLocalStateAsync();
    }

    private void ClearQuotation()
    {
        editingQuoteId = null;
        quoteForm.Provider = string.Empty;
        quoteForm.LineIdText = string.Empty;
        quoteForm.QuotationDate = DateTime.Today;
        quoteForm.DeliveryTime = string.Empty;
        quoteForm.PriceBeforeVat = null;
        quoteForm.AdditionalDetails = string.Empty;
    }

    private async Task GenerateAsync()
    {
        if (!CanGenerateRequest)
        {
            errorMessage = "Para generar debes tener permiso, la solicitud en cotización y mínimo una cotización seleccionada.";
            return;
        }

        if (!Guid.TryParse(header.BranchIdText, out var branchId))
        {
            errorMessage = "Debes seleccionar una sede válida.";
            return;
        }

        var selectedLines = SelectedLines.ToList();
        var selectedQuotes = SelectedQuotes.ToList();
        var firstLine = selectedLines.First();
        var firstQuote = selectedQuotes.FirstOrDefault();
        var summary = BuildSummary(selectedLines, selectedQuotes);
        var total = selectedQuotes.Sum(x => x.PriceBeforeVat ?? 0);

        try
        {
            isSaving = true;
            errorMessage = null;
            successMessage = null;

            await Api.SendJsonAsync(HttpMethod.Post, "api/purchase-requests", new
            {
                itemName = firstLine.ItemName,
                itemCode = firstLine.ItemCode,
                itemDescription = summary,
                quantity = firstLine.Quantity <= 0 ? 1 : firstLine.Quantity,
                unit = string.IsNullOrWhiteSpace(firstLine.Unit) ? "Und" : firstLine.Unit,
                purchasePurpose = header.PurchasePurpose,
                justification = header.Justification,
                priority = header.Priority,
                branchId,
                requiredAt = header.RequiredAt,
                vendorSuggestion = firstQuote?.Provider,
                estimatedCostText = total > 0 ? total.ToString("N0") : null,
                requestChannel = "Mobile",
                notes = summary,
                sendToReview = true
            });

            if (activeStoredRequestId.HasValue)
            {
                storedRequests.RemoveAll(x => x.Id == activeStoredRequestId.Value);
                await SaveLocalStateAsync();
            }

            successMessage = "Solicitud de compra generada y enviada a revisión.";
            ClearWorkspace(keepBranchAndRequester: true);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteLocalRequestAsync(Guid id)
    {
        storedRequests.RemoveAll(x => x.Id == id);

        if (activeStoredRequestId == id)
        {
            ClearWorkspace(keepBranchAndRequester: true);
        }

        await SaveLocalStateAsync();
        successMessage = "Solicitud local eliminada.";
    }

