@page "/"
@page "/dashboard"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Dashboard - NAVI</PageTitle>

<section class="dash-hero">
    <div>
        <span class="dash-pill">NAVI HERRAMIENTAS Y ACTIVOS</span>
        <h2>Dashboard general</h2>
        <p>Vista ejecutiva del local de herramientas, activos fijos, disponibilidad, mantenimiento, hojas de vida, documentos, solicitudes e historial.</p>
    </div>

    <div class="dash-hero-side">
        <div class="dash-hero-box">
            <span>Última actualización</span>
            <strong>@ShowDateTime(dashboard?.GeneratedAt)</strong>
        </div>

        <button class="btn btn-sm btn-outline-light" @onclick="LoadDashboardAsync" disabled="@isLoading">
            @(isLoading ? "Actualizando..." : "Actualizar")
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (isLoading && dashboard is null)
{
    <div class="alert alert-info">Cargando dashboard...</div>
}
else if (dashboard is not null)
{
    <section class="kpi-grid">
        <article class="kpi-card blue">
            <span>Total herramientas</span>
            <strong>@dashboard.Summary.TotalTools</strong>
            <small>Inventario registrado</small>
        </article>

        <article class="kpi-card green">
            <span>Disponibles</span>
            <strong>@dashboard.Summary.AvailableTools</strong>
            <small>Listas para uso</small>
        </article>

        <article class="kpi-card yellow">
            <span>Pendientes validación</span>
            <strong>@dashboard.Summary.PendingValidationTools</strong>
            <small>Por revisar</small>
        </article>

        <article class="kpi-card purple">
            <span>Activos fijos</span>
            <strong>@dashboard.Summary.FixedAssets</strong>
            <small>Con código AF</small>
        </article>

        <article class="kpi-card purple">
            <span>Especializados</span>
            <strong>@dashboard.Summary.SpecializedTools</strong>
            <small>Control especial</small>
        </article>

        <article class="kpi-card cyan">
            <span>Con mantenimiento</span>
            <strong>@dashboard.Summary.RequiresMaintenance</strong>
            <small>Requieren plan</small>
        </article>

        <article class="kpi-card blue">
            <span>Responsables</span>
            <strong>@dashboard.Summary.ActiveResponsibles</strong>
            <small>@dashboard.Summary.InactiveResponsibles inactivos</small>
        </article>

        <article class="kpi-card orange">
            <span>Sedes activas</span>
            <strong>@dashboard.Summary.ActiveBranches</strong>
            <small>@dashboard.Summary.InactiveBranches desactivadas</small>
        </article>
    </section>

    <section class="dashboard-layout">
        <article class="dash-card span-2">
            <div class="card-head">
                <div>
                    <h3>Local de herramientas</h3>
                    <p>Resumen operativo de disponibilidad.</p>
                </div>
            </div>

            <div class="status-grid">
                <div><span>Disponibles</span><strong>@dashboard.Summary.AvailableTools</strong></div>
                <div><span>Asignadas</span><strong>@dashboard.Summary.AssignedTools</strong></div>
                <div><span>Prestadas</span><strong>@dashboard.Summary.LoanedTools</strong></div>
                <div><span>En mantenimiento</span><strong>@dashboard.Summary.InMaintenanceTools</strong></div>
                <div><span>Dañadas / no aptas</span><strong>@dashboard.Summary.DamagedTools</strong></div>
                <div><span>No localizadas</span><strong>@dashboard.Summary.NotLocatedTools</strong></div>
            </div>
        </article>

        <article class="dash-card">
            <div class="card-head">
                <div>
                    <h3>Herramientas vs activos</h3>
                    <p>Clasificación general.</p>
                </div>
            </div>

            <div class="split-metric">
                <div><span>Herramientas</span><strong>@dashboard.Summary.ToolsOnly</strong></div>
                <div><span>Otros activos</span><strong>@dashboard.Summary.NonToolAssets</strong></div>
                <div><span>Sin código AF</span><strong>@dashboard.Summary.ToolsWithoutFixedAssetCode</strong></div>
            </div>
        </article>

        <article class="dash-card">
            <div class="card-head">
                <div>
                    <h3>Hojas de vida</h3>
                    <p>Cobertura y calidad.</p>
                </div>
            </div>

            <div class="life-summary">
                <div><span>Con hoja de vida</span><strong>@dashboard.Summary.WithLifeRecord</strong></div>
                <div><span>Sin hoja de vida</span><strong>@dashboard.Summary.WithoutLifeRecord</strong></div>
                <div><span>Datos incompletos</span><strong>@dashboard.LifeRecordCoverage.MissingTechnicalData</strong></div>
            </div>
        </article>

        <article class="dash-card span-2">
            <div class="card-head">
                <div>
                    <h3>Mantenimientos por mes</h3>
                    <p>Actividad de los últimos meses.</p>
                </div>
                <strong class="mini-total">@dashboard.MaintenanceSummary.Total total</strong>
            </div>

            <div class="bars-list">
                @foreach (var item in dashboard.MaintenanceByMonth)
                {
                    <div class="bar-row">
                        <span>@item.Label</span>
                        <div class="bar-track">
                            <div class="bar-fill purple" style="@($"width: {GetPercent(item.Count, GetMaxMonthMaintenance())}%")"></div>
                        </div>
                        <strong>@item.Count</strong>
                    </div>
                }
            </div>
        </article>

        <article class="dash-card span-2">
            <div class="card-head">
                <div>
                    <h3>Mantenimientos por día</h3>
                    <p>Últimos 14 días.</p>
                </div>
                <strong class="mini-total">@dashboard.MaintenanceSummary.Today hoy</strong>
            </div>

            <div class="day-grid">
                @foreach (var item in dashboard.MaintenanceByDay)
                {
                    <div>
                        <span>@item.Label</span>
                        <strong>@item.Count</strong>
                    </div>
                }
            </div>
        </article>

        <article class="dash-card span-2">
            <div class="card-head">
                <div>
                    <h3>Herramientas por sede</h3>
                    <p>Distribución por sede.</p>
                </div>
            </div>

            <div class="bars-list">
                @foreach (var item in dashboard.ToolsByBranch)
                {
                    <div class="bar-row">
                        <span>@item.BranchCode</span>
                        <div class="bar-track">
                            <div class="bar-fill blue" style="@($"width: {GetPercent(item.Total, GetMaxBranch())}%")"></div>
                        </div>
                        <strong>@item.Total</strong>
                    </div>
                }
            </div>
        </article>

        <article class="dash-card span-2">
            <div class="card-head">
                <div>
                    <h3>Herramientas por estado</h3>
                    <p>Conteo por estado operativo.</p>
                </div>
            </div>

            <div class="bars-list">
                @foreach (var item in dashboard.ToolsByStatus)
                {
                    <div class="bar-row">
                        <span>@GetStatusLabel(item.Status)</span>
                        <div class="bar-track">
                            <div class="bar-fill green" style="@($"width: {GetPercent(item.Count, GetMaxStatus())}%")"></div>
                        </div>
                        <strong>@item.Count</strong>
                    </div>
                }
            </div>
        </article>

        <article class="dash-card span-2">
            <div class="card-head">
                <div>
                    <h3>Solicitudes de compra AF</h3>
                    <p>Indicador preparado para el módulo de compras.</p>
                </div>
                <span class="module-pill">@dashboard.PurchaseSummary.ModuleStatus</span>
            </div>

            <div class="purchase-grid">
                <div><span>Solicitudes creadas</span><strong>@dashboard.PurchaseSummary.Total</strong></div>
                <div><span>Realizadas</span><strong>@dashboard.PurchaseSummary.Completed</strong></div>
                <div><span>Pendientes</span><strong>@dashboard.PurchaseSummary.Pending</strong></div>
                <div><span>Rechazadas</span><strong>@dashboard.PurchaseSummary.Rejected</strong></div>
            </div>

            <p class="note">@dashboard.PurchaseSummary.Note</p>
        </article>

        <article class="dash-card span-2">
            <div class="card-head">
                <div>
                    <h3>Documentos y evidencias</h3>
                    <p>Soportes recientes cargados al sistema.</p>
                </div>
                <strong class="mini-total">@dashboard.DocumentSummary.Total docs</strong>
            </div>

            <table class="table table-sm compact-table">
                <thead>
                    <tr>
                        <th>Documento</th>
                        <th>Tipo</th>
                        <th>Fecha</th>
                        <th>Usuario</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var doc in dashboard.DocumentSummary.Recent)
                    {
                        <tr>
                            <td>@doc.FileName</td>
                            <td>@doc.DocumentType</td>
                            <td>@ShowDate(doc.UploadedAt)</td>
                            <td>@Show(doc.UploadedBy)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </article>

        <article class="dash-card span-2">
            <div class="card-head">
                <div>
                    <h3>Hojas de vida incompletas</h3>
                    <p>Activos que requieren completar información base.</p>
                </div>
            </div>

            <table class="table table-sm compact-table">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Activo</th>
                        <th>Sede</th>
                        <th>Falta</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in dashboard.LifeRecordCoverage.MissingTechnicalDataItems)
                    {
                        <tr>
                            <td><strong>@item.InternalCode</strong></td>
                            <td>@item.Name</td>
                            <td>@Show(item.BranchCode)</td>
                            <td>@Show(item.Missing)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </article>

        <article class="dash-card span-4">
            <div class="card-head">
                <div>
                    <h3>Actividad reciente del historial</h3>
                    <p>Últimos eventos registrados en trazabilidad.</p>
                </div>
            </div>

            <table class="table table-sm compact-table">
                <thead>
                    <tr>
                        <th>Evento</th>
                        <th>Herramienta / Activo</th>
                        <th>Detalle</th>
                        <th>Usuario</th>
                        <th>Fecha</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var activity in dashboard.RecentActivity)
                    {
                        <tr>
                            <td>
                                <strong>@activity.Title</strong>
                                <br />
                                <small class="text-muted">@activity.EventType</small>
                            </td>
                            <td>@Show(activity.ToolInternalCode)</td>
                            <td>@Show(activity.Description)</td>
                            <td>@Show(activity.User)</td>
                            <td>@ShowDateTime(activity.RegisteredAt)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </article>
    </section>
}

<style>
    .dash-hero {
        background: linear-gradient(135deg, #050008 0%, #280032 45%, #5c006b 100%);
        color: #fff;
        border-radius: .85rem;
        padding: 1.25rem 1.4rem;
        margin-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        box-shadow: 0 .65rem 1.35rem rgba(75,0,92,.22);
    }

    .dash-pill {
        display: inline-flex;
        background: rgba(255,255,255,.12);
        border: 1px solid rgba(255,255,255,.35);
        border-radius: 999px;
        padding: .22rem .65rem;
        font-size: .7rem;
        font-weight: 900;
        margin-bottom: .6rem;
    }

    .dash-hero h2 {
        color: #fff;
        font-weight: 950;
        margin: 0;
        font-size: 1.8rem;
    }

