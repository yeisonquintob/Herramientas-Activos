    private void NewRequest()
    {
        ClearWorkspace(keepBranchAndRequester: true);
        successMessage = "Formulario listo para una nueva solicitud.";
    }

    private void ClearWorkspace(bool keepBranchAndRequester)
    {
        var currentRequester = header.RequestedBy;
        var currentBranch = header.BranchIdText;

        activeStoredRequestId = null;
        editingLineId = null;
        editingQuoteId = null;
        currentStatus = "New";
        currentLines = new();
        currentQuotes = new();
        ClearLine();
        ClearQuotation();

        header.Clear();
        ResetHeaderDefaults();

        if (keepBranchAndRequester)
        {
            if (!string.IsNullOrWhiteSpace(currentRequester))
            {
                header.RequestedBy = currentRequester;
            }

            if (!string.IsNullOrWhiteSpace(currentBranch))
            {
                header.BranchIdText = currentBranch;
            }
        }
    }

    private void OnSearchChanged(ChangeEventArgs args) => searchText = args.Value?.ToString() ?? string.Empty;
    private void OnBranchFilterChanged(ChangeEventArgs args) => selectedBranchCode = args.Value?.ToString() ?? string.Empty;
    private void OnBottomStatusChanged(ChangeEventArgs args) => selectedBottomStatus = args.Value?.ToString() ?? string.Empty;

    private void ClearTopFilters()
    {
        searchText = string.Empty;
        selectedBranchCode = string.Empty;
    }

    private void ClearBottomStatus()
    {
        selectedBottomStatus = string.Empty;
    }

    private bool MatchesLocalScope(StoredPurchaseRequest item)
    {
        var branch = BranchByIdText(item.Header.BranchIdText);

        if (!string.IsNullOrWhiteSpace(selectedBranchCode))
        {
            return branch is not null && SameNormalized(branch.Code, selectedBranchCode);
        }

        if (branch is null)
        {
            return UserCanSeeAllBranches();
        }

        return UserCanSeeAllBranches() ||
               SameNormalized(branch.Code, Auth.CurrentUser?.BranchCode) ||
               SameNormalized(branch.Name, Auth.CurrentUser?.BranchName);
    }

    private bool MatchesApiScope(ApiPurchaseItem item)
    {
        if (!string.IsNullOrWhiteSpace(selectedBranchCode))
        {
            return SameNormalized(item.BranchCode, selectedBranchCode);
        }

        return UserCanSeeAllBranches() ||
               SameNormalized(item.BranchCode, Auth.CurrentUser?.BranchCode) ||
               SameNormalized(item.BranchName, Auth.CurrentUser?.BranchName);
    }

    private bool MatchesLocalSearch(StoredPurchaseRequest item)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
        }

        return ContainsText(item.LocalNumber, searchText) ||
               ContainsText(item.Status, searchText) ||
               ContainsText(GetStoredStatusLabel(item.Status), searchText) ||
               ContainsText(item.Header.RequestName, searchText) ||
               ContainsText(item.Header.PurchasePurpose, searchText) ||
               item.Lines.Any(x => ContainsText(x.ItemName, searchText) || ContainsText(x.ItemCode, searchText) || ContainsText(x.NeedDetail, searchText));
    }

    private bool MatchesApiSearch(ApiPurchaseItem item)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
        }

        return ContainsText(item.RequestNumber, searchText) ||
               ContainsText(item.Title, searchText) ||
               ContainsText(item.Status, searchText) ||
               ContainsText(StatusLabel(item.Status), searchText) ||
               ContainsText(item.RequestedBy, searchText) ||
               ContainsText(item.BranchCode, searchText);
    }

    private bool MatchesBottomStatus(StoredPurchaseRequest item)
    {
        return string.IsNullOrWhiteSpace(selectedBottomStatus) ||
               string.Equals(item.Status, selectedBottomStatus, StringComparison.OrdinalIgnoreCase);
    }

    private bool MatchesApiBottomStatus(ApiPurchaseItem item)
    {
        return string.IsNullOrWhiteSpace(selectedBottomStatus) ||
               string.Equals(item.Status, selectedBottomStatus, StringComparison.OrdinalIgnoreCase);
    }

    private MobileBranchDto? BranchByIdText(string? value)
    {
        if (!Guid.TryParse(value, out var branchId))
        {
            return null;
        }

        return branches.FirstOrDefault(x => x.Id == branchId);
    }

    private bool IsVisibleBranch(MobileBranchDto branch)
    {
        if (UserCanSeeAllBranches())
        {
            return true;
        }

        return SameNormalized(branch.Code, Auth.CurrentUser?.BranchCode) ||
               SameNormalized(branch.Name, Auth.CurrentUser?.BranchName);
    }

    private bool UserCanSeeAllBranches()
    {
        var user = Auth.CurrentUser;

        if (user is null)
        {
            return false;
        }

        return string.IsNullOrWhiteSpace(user.BranchCode) ||
               SameNormalized(user.BranchCode, "TODAS") ||
               SameNormalized(user.BranchCode, "ALL") ||
               SameNormalized(user.BranchName, "TODAS") ||
               SameNormalized(user.BranchName, "ALL") ||
               SameNormalized(user.BranchName, "Todas las sedes");
    }

    private bool Has(string permission) => Auth.HasPermission(permission);
    private bool HasAny(params string[] permissions) => permissions.Any(Has);

    private bool IsOpenStatus(string? status)
    {
        return status is "Draft" or "Confirmed" or "Quoting" or "InReview" or "Approved";
    }

    private string BuildSummary(List<PurchaseLineItem> lines, List<QuotationItem> quotes)
    {
        var sb = new System.Text.StringBuilder();

        sb.AppendLine("ENCABEZADO");
        sb.AppendLine($"Solicitud: {Display(header.RequestName)}");
        sb.AppendLine($"Tipo compra: {Display(header.PurchasePurpose)}");
        sb.AppendLine($"Sede: {SelectedBranchLabel}");
        sb.AppendLine($"Solicitante: {Display(header.RequestedBy)}");
        sb.AppendLine($"Responsable aprueba: {Display(header.Approver)}");
        sb.AppendLine($"Prioridad: {Display(header.Priority)}");
        sb.AppendLine($"Fecha requerida: {DateLabel(header.RequiredAt)}");
        sb.AppendLine($"Área/Centro costo: {Display(header.AreaOrCostCenter)}");
        sb.AppendLine($"Justificación: {Display(header.Justification)}");
        sb.AppendLine();

        sb.AppendLine("ACTIVOS / HERRAMIENTAS");
        foreach (var line in lines)
        {
            sb.AppendLine($"- {line.ItemName} | Código/ref: {Display(line.ItemCode)} | Cantidad: {line.Quantity} {Display(line.Unit)} | Categoría: {Display(line.Category)}");
            sb.AppendLine($"  Imagen/referencia: {Display(line.ImageReference)}");
            sb.AppendLine($"  Descripción técnica: {Display(line.ItemDescription)}");
            sb.AppendLine($"  Necesidad: {Display(line.NeedDetail)}");
        }

        sb.AppendLine();
        sb.AppendLine("COTIZACIONES");
        foreach (var quote in quotes)
        {
            sb.AppendLine($"- Proveedor: {quote.Provider} | Activo: {GetLineName(quote.LineId)} | Fecha: {DateLabel(quote.QuotationDate)} | Entrega: {Display(quote.DeliveryTime)} | Precio sin IVA: {MoneyLabel(quote.PriceBeforeVat)}");
            sb.AppendLine($"  Detalles: {Display(quote.AdditionalDetails)}");
        }

        return sb.ToString();
    }

    private string GetLineName(Guid? id)
    {
        if (!id.HasValue)
        {
            return "Toda la solicitud / kit";
        }

        return currentLines.FirstOrDefault(x => x.Id == id.Value)?.ItemName ?? "Activo no encontrado";
    }

    private string BuildLocalNumber(string status, DateTime date)
    {
        var suffix = status == LocalStatusConfirmed ? "CONF" : "DRAFT";
        return $"BOR-COMP-{suffix}-{date:yyyyMMddHHmmss}";
    }

    private string GetStoredStatusLabel(string status)
    {
        return status switch
        {
            LocalStatusDraft => "Borrador",
            LocalStatusConfirmed => "Confirmada / pendiente por cotizar",
            LocalStatusQuoting => "Cotizando",
            _ => StatusLabel(status)
        };
    }

    private string GetStoredRowClass(StoredPurchaseRequest item)
    {
        return item.Status switch
        {
            LocalStatusDraft => "draft-row",
            LocalStatusConfirmed => "confirmed-row",
            LocalStatusQuoting => "quoting-row",
            _ => string.Empty
        };
    }

    private void GoHome() => Navigation.NavigateTo("/");
    private void GoLogin() => Navigation.NavigateTo("/login", forceLoad: true);

    private static bool ContainsText(string? value, string expected)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               Normalize(value).Contains(Normalize(expected), StringComparison.OrdinalIgnoreCase);
    }

    private static bool SameNormalized(string? left, string? right)
    {
        var a = Normalize(left);
        var b = Normalize(right);

        return !string.IsNullOrWhiteSpace(a) &&
               !string.IsNullOrWhiteSpace(b) &&
               string.Equals(a, b, StringComparison.OrdinalIgnoreCase);
    }

    private static string Normalize(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value.Trim()
            .ToUpperInvariant()
            .Replace("Á", "A")
            .Replace("É", "E")
            .Replace("Í", "I")
            .Replace("Ó", "O")
            .Replace("Ú", "U")
            .Replace("Ü", "U")
            .Replace("Ñ", "N");
    }

    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;
    private static string DateLabel(DateTime? value) => value.HasValue ? value.Value.ToString("dd/MM/yyyy") : "—";
    private static string DateTimeLabel(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—";
    private static string MoneyLabel(decimal? value) => value.HasValue ? $"${value.Value:N0}" : "—";

    private static string StatusLabel(string? status) => status switch
    {
        "Draft" => "Borrador",
        "Confirmed" => "Confirmada",
        "Quoting" => "Cotizando",
        "InReview" => "En revisión",
        "Approved" => "Aprobada",
        "Closed" => "Cerrada",
        "Rejected" => "Rechazada",
        "Canceled" => "Cancelada",
        "Cancelled" => "Cancelada",
        _ => Display(status)
    };

    private sealed class PurchaseHeader
    {
        public string RequestName { get; set; } = string.Empty;
        public string BranchIdText { get; set; } = string.Empty;
        public string RequestedBy { get; set; } = string.Empty;
        public string Approver { get; set; } = string.Empty;
        public string PurchasePurpose { get; set; } = "SPC";
        public string Priority { get; set; } = "Media";
        public DateTime? RequiredAt { get; set; } = DateTime.Today.AddDays(7);
        public string AreaOrCostCenter { get; set; } = string.Empty;
        public string Justification { get; set; } = string.Empty;

        public PurchaseHeader Clone()
        {
            return new PurchaseHeader
            {
                RequestName = RequestName,
                BranchIdText = BranchIdText,
                RequestedBy = RequestedBy,
                Approver = Approver,
                PurchasePurpose = PurchasePurpose,
                Priority = Priority,
                RequiredAt = RequiredAt,
                AreaOrCostCenter = AreaOrCostCenter,
                Justification = Justification
            };
        }

        public void CopyFrom(PurchaseHeader other)
        {
            RequestName = other.RequestName;
            BranchIdText = other.BranchIdText;
            RequestedBy = other.RequestedBy;
            Approver = other.Approver;
            PurchasePurpose = other.PurchasePurpose;
            Priority = other.Priority;
            RequiredAt = other.RequiredAt;
            AreaOrCostCenter = other.AreaOrCostCenter;
            Justification = other.Justification;
        }

        public void Clear()
        {
            RequestName = string.Empty;
            BranchIdText = string.Empty;
            RequestedBy = string.Empty;
            Approver = string.Empty;
            PurchasePurpose = "SPC";
            Priority = "Media";
            RequiredAt = DateTime.Today.AddDays(7);
            AreaOrCostCenter = string.Empty;
            Justification = string.Empty;
        }
    }

