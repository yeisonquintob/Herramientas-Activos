    private async Task ExecuteItemActionAsync(ConsultationItem item, string action, string localStatus, string successMessage)
    {
        StatusMessage = null;
        ErrorMessage = null;

        var applied = item.SourceKind == SourceKind.Api
            ? await TryPostApiActionAsync(item, action)
            : await UpdateLocalRequestStatusAsync(item, localStatus);

        if (applied)
        {
            item.Status = localStatus;
            item.UpdatedAt = DateTime.Now;
            StatusMessage = successMessage;
            selectedItem = null;
            await RefreshAsync();
            return;
        }

        if (string.IsNullOrWhiteSpace(ErrorMessage))
        {
            ErrorMessage = $"No fue posible ejecutar la acción '{action}'. Valida que el estado de la solicitud permita esa acción y que tengas el permiso correspondiente.";
        }
    }

    private async Task<bool> TryPostApiActionAsync(ConsultationItem item, string action)
    {
        var baseUrl = item.Kind == RequestKind.Purchase
            ? "api/purchase-requests"
            : "api/maintenance-requests";

        if (!Guid.TryParse(item.Id, out var id))
        {
            ErrorMessage = "El registro viene de API pero no tiene un Id válido para ejecutar la acción.";
            return false;
        }

        var url = $"{baseUrl}/{id}/{action}";

        try
        {
            var body = new
            {
                comment = $"Acción {action} realizada desde Consulta Compras y Mtto.",
                scheduledAt = DateTime.UtcNow,
                assignedTechnician = AuthSession.UserName ?? "admin"
            };

            using var response = await Api.PostAsJsonAsync(url, body);
            var detail = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                return true;
            }

            if (response.StatusCode is HttpStatusCode.Forbidden or HttpStatusCode.Unauthorized)
            {
                ErrorMessage = "El servidor rechazó la acción por falta de permisos.";
                return false;
            }

            ErrorMessage = $"No fue posible ejecutar la acción. Código {(int)response.StatusCode}. {ExtractServerMessage(detail)}";
            return false;
        }
        catch (Exception ex)
        {
            ErrorMessage = $"No fue posible ejecutar la acción contra API. Detalle: {ex.Message}";
            return false;
        }
    }

    private async Task<bool> UpdateLocalRequestStatusAsync(ConsultationItem item, string newStatus)
    {
        try
        {
            var script =
                "(function(storageKey, id, number, newStatus) {" +
                "  const stores = [localStorage, sessionStorage];" +
                "  let updated = false;" +
                "  function txt(v) { return v === null || v === undefined ? '' : String(v); }" +
                "  function matches(obj) {" +
                "    if (!obj || typeof obj !== 'object') return false;" +
                "    const values = [obj.id, obj.Id, obj.requestId, obj.RequestId, obj.rowId, obj.RowId, obj.number, obj.Number, obj.requestNumber, obj.RequestNumber, obj.code, obj.Code, obj.requestCode, obj.RequestCode].filter(Boolean).map(txt);" +
                "    return values.includes(txt(id)) || values.includes(txt(number));" +
                "  }" +
                "  function touch(obj) {" +
                "    if (!obj || typeof obj !== 'object') return false;" +
                "    let local = false;" +
                "    if (matches(obj)) {" +
                "      obj.status = newStatus; obj.Status = newStatus; obj.state = newStatus; obj.State = newStatus;" +
                "      obj.localStatus = newStatus; obj.LocalStatus = newStatus; obj.statusText = newStatus; obj.StatusText = newStatus;" +
                "      obj.statusLabel = newStatus; obj.StatusLabel = newStatus; obj.updatedAt = new Date().toISOString(); obj.UpdatedAt = obj.updatedAt;" +
                "      local = true;" +
                "    }" +
                "    if (Array.isArray(obj)) { for (const child of obj) if (touch(child)) local = true; }" +
                "    else { for (const key of Object.keys(obj)) if (obj[key] && typeof obj[key] === 'object') if (touch(obj[key])) local = true; }" +
                "    return local;" +
                "  }" +
                "  for (const store of stores) {" +
                "    for (let i = 0; i < store.length; i++) {" +
                "      const key = store.key(i);" +
                "      if (storageKey && key !== storageKey && !key.includes(storageKey)) continue;" +
                "      const raw = store.getItem(key);" +
                "      if (!raw) continue;" +
                "      try {" +
                "        const data = JSON.parse(raw);" +
                "        if (touch(data)) { store.setItem(key, JSON.stringify(data)); updated = true; }" +
                "      } catch(e) {}" +
                "    }" +
                "  }" +
                "  return updated;" +
                "})(arguments[0], arguments[1], arguments[2], arguments[3]);";

            return await JS.InvokeAsync<bool>("eval", script, item.StorageKey ?? string.Empty, item.Id, item.Number, newStatus);
        }
        catch
        {
            return false;
        }
    }

