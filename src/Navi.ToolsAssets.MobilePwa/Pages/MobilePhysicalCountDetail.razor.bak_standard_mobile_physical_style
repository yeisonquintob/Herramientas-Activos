    private void OnEvidenceSelected(InputFileChangeEventArgs args)
    {
        evidenceSelectionError = null;

        if (!CanUploadPhysicalEvidence)
        {
            evidenceSelectionError = "No tienes permiso para cargar evidencia de toma física.";
            return;
        }

        IReadOnlyList<IBrowserFile> files;

        try
        {
            files = args.GetMultipleFiles(MaxEvidenceFiles);
        }
        catch
        {
            evidenceSelectionError = $"Puedes seleccionar máximo {MaxEvidenceFiles} evidencias por validación.";
            return;
        }

        foreach (var file in files)
        {
            if (selectedEvidences.Count >= MaxEvidenceFiles)
            {
                evidenceSelectionError = $"Solo puedes agregar máximo {MaxEvidenceFiles} evidencias.";
                return;
            }

            var alreadyAdded = selectedEvidences.Any(x =>
                string.Equals(x.Name, file.Name, StringComparison.OrdinalIgnoreCase) &&
                x.Size == file.Size);

            if (!alreadyAdded)
            {
                selectedEvidences.Add(file);
            }
        }
    }

    private void RemoveSelectedEvidence(int index)
    {
        if (index < 0 || index >= selectedEvidences.Count)
        {
            return;
        }

        selectedEvidences.RemoveAt(index);
    }

    private string? GetSelectedLocationName()
    {
        if (!validationForm.LocationId.HasValue)
        {
            return selectedTool?.LocationName;
        }

        return locations.FirstOrDefault(x => x.Id == validationForm.LocationId.Value)?.Name ?? selectedTool?.LocationName;
    }

    private static Guid EffectiveToolId(PendingToolDto tool)
    {
        return tool.ToolAssetId.HasValue && tool.ToolAssetId.Value != Guid.Empty
            ? tool.ToolAssetId.Value
            : tool.Id;
    }

    private bool IsOwnParticipant(PhysicalCountParticipantDto participant)
    {
        var userName = Auth.CurrentUser?.UserName;
        var displayName = Auth.CurrentUser?.DisplayName;
        var responsibleId = Auth.CurrentUser?.ResponsiblePersonId;

        return Same(participant.UserName, userName) ||
               Same(participant.DisplayName, displayName) ||
               Same(participant.DisplayName, Auth.CurrentUser?.ResponsiblePersonName) ||
               (responsibleId.HasValue && participant.ResponsiblePersonId.HasValue && responsibleId.Value == participant.ResponsiblePersonId.Value);
    }

