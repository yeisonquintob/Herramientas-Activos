    private static bool ContainsText(string? value, string expected)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               Normalize(value).Contains(Normalize(expected), StringComparison.OrdinalIgnoreCase);
    }

    private static bool SameNormalized(string? left, string? right)
    {
        var a = Normalize(left);
        var b = Normalize(right);

        return !string.IsNullOrWhiteSpace(a) &&
               !string.IsNullOrWhiteSpace(b) &&
               string.Equals(a, b, StringComparison.OrdinalIgnoreCase);
    }

    private static string Normalize(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value.Trim()
            .ToUpperInvariant()
            .Replace("Á", "A")
            .Replace("É", "E")
            .Replace("Í", "I")
            .Replace("Ó", "O")
            .Replace("Ú", "U")
            .Replace("Ü", "U")
            .Replace("Ñ", "N");
    }

    private static string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value;
    private static string DateLabel(DateTime? value) => value.HasValue ? value.Value.ToString("dd/MM/yyyy") : "—";
    private static string DateTimeLabel(DateTime? value) => value.HasValue ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm") : "—";
    private static string MoneyLabel(decimal? value) => value.HasValue ? $"${value.Value:N0}" : "—";

    private static string StatusLabel(string? status) => status switch
    {
        "Draft" => "Borrador",
        "Confirmed" => "Confirmada",
        "Quoting" => "Cotizando",
        "InReview" => "En revisión",
        "Approved" => "Aprobada",
        "Scheduled" => "Programada",
        "InExecution" => "En ejecución",
        "Closed" => "Cerrada",
        "Rejected" => "Rechazada",
        "Canceled" => "Cancelada",
        "Cancelled" => "Cancelada",
        _ => Display(status)
    };

    private sealed class RequestHeader
    {
        public string RequestName { get; set; } = string.Empty;
        public string BranchIdText { get; set; } = string.Empty;
        public string RequestedBy { get; set; } = string.Empty;
        public string Approver { get; set; } = string.Empty;
        public string RequestType { get; set; } = "Correctivo";
        public string Priority { get; set; } = "Media";
        public DateTime? RequiredAt { get; set; } = DateTime.Today.AddDays(7);
        public string Location { get; set; } = string.Empty;
        public string NeedDescription { get; set; } = string.Empty;

        public RequestHeader Clone()
        {
            return new RequestHeader
            {
                RequestName = RequestName,
                BranchIdText = BranchIdText,
                RequestedBy = RequestedBy,
                Approver = Approver,
                RequestType = RequestType,
                Priority = Priority,
                RequiredAt = RequiredAt,
                Location = Location,
                NeedDescription = NeedDescription
            };
        }

        public void CopyFrom(RequestHeader other)
        {
            RequestName = other.RequestName;
            BranchIdText = other.BranchIdText;
            RequestedBy = other.RequestedBy;
            Approver = other.Approver;
            RequestType = other.RequestType;
            Priority = other.Priority;
            RequiredAt = other.RequiredAt;
            Location = other.Location;
            NeedDescription = other.NeedDescription;
        }

        public void Clear()
        {
            RequestName = string.Empty;
            BranchIdText = string.Empty;
            RequestedBy = string.Empty;
            Approver = string.Empty;
            RequestType = "Correctivo";
            Priority = "Media";
            RequiredAt = DateTime.Today.AddDays(7);
            Location = string.Empty;
            NeedDescription = string.Empty;
        }
    }

