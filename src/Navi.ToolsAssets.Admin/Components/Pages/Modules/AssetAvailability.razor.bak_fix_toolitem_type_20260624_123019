        background: linear-gradient(135deg, #050008 0%, #280032 45%, #5c006b 100%);
        color: #fff;
        border-radius: .85rem;
        padding: 1.25rem 1.4rem;
        margin-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        box-shadow: 0 .65rem 1.35rem rgba(75,0,92,.22);
    }

    .af-pill {
        display: inline-flex;
        background: rgba(255,255,255,.12);
