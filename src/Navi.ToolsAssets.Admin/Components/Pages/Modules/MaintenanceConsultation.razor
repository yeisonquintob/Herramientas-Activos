    private bool IsStatus(ConsultationItem item, string status)
    {
        return string.Equals(NormalizeStatus(item.Status), NormalizeStatus(status), StringComparison.OrdinalIgnoreCase);
    }

    private static string NormalizeStatus(string? status)
    {
        if (string.IsNullOrWhiteSpace(status))
        {
            return "Draft";
        }

        var value = status.Trim();

        return value.ToLowerInvariant() switch
        {
            "draft" or "borrador" or "nueva solicitud" => "Draft",
            "inreview" or "in review" or "en revision" or "en revisión" or "review" or "confirmed" or "confirmada" or "confirmada / pendiente por cotizar" => "InReview",
            "approved" or "aprobada" or "aprobado" or "aprobar" => "Approved",
            "scheduled" or "programada" or "programado" => "Scheduled",
            "inexecution" or "in execution" or "en ejecucion" or "en ejecución" or "ejecucion" or "ejecución" => "InExecution",
            "closed" or "cerrada" or "cerrado" or "finalizada" or "generada" or "generated" => "Closed",
            "rejected" or "rechazada" or "rechazado" => "Rejected",
            "canceled" or "cancelled" or "cancelada" or "cancelado" => "Canceled",
            "quoting" or "cotizando" or "cotización" or "cotizacion" => "InReview",
            _ => value
        };
    }

    private static string StatusLabel(string? status)
    {
        return NormalizeStatus(status) switch
        {
            "Draft" => "Borrador",
            "InReview" => "En revisión",
            "Approved" => "Aprobada",
            "Scheduled" => "Programada",
            "InExecution" => "En ejecución",
            "Closed" => "Cerrada",
            "Rejected" => "Rechazada",
            "Canceled" => "Cancelada",
            _ => status ?? "—"
        };
    }

    private static string StatusClass(string? status)
    {
        return NormalizeStatus(status) switch
        {
            "InReview" => "review",
            "Approved" => "approved",
            "Scheduled" => "scheduled",
            "InExecution" => "execution",
            "Closed" => "closed",
            "Rejected" => "rejected",
            "Canceled" => "canceled",
            _ => "draft"
        };
    }

    private static bool IsPositiveCostStatus(string? status)
    {
        return NormalizeStatus(status) is "Approved" or "Scheduled" or "InExecution" or "Closed";
    }

    private static bool IsRejectedOrCanceled(string? status)
    {
        return NormalizeStatus(status) is "Rejected" or "Canceled";
    }

    private static string GetString(JsonElement element, params string[] names)
    {
        foreach (var name in names)
        {
            if (element.ValueKind == JsonValueKind.Object && element.TryGetProperty(name, out var property))
            {
                if (property.ValueKind == JsonValueKind.String)
                {
                    return property.GetString() ?? string.Empty;
                }

                if (property.ValueKind is JsonValueKind.Number or JsonValueKind.True or JsonValueKind.False)
                {
                    return property.ToString();
                }
            }
        }

        return string.Empty;
    }

    private static string? FirstText(JsonElement element, params string[] names)
    {
        foreach (var name in names)
        {
            var value = GetString(element, name);

            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return null;
    }

    private static DateTime? GetDate(JsonElement element, params string[] names)
    {
        foreach (var name in names)
        {
            var value = GetString(element, name);

            if (DateTime.TryParse(value, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var date))
            {
                return date;
            }
        }

        return null;
    }

    private static string BuildPurchaseDescription(JsonElement element)
    {
        var parts = new[]
        {
            FirstText(element, "ItemDescription", "itemDescription"),
            FirstText(element, "Justification", "justification"),
            FirstText(element, "PurchasePurpose", "purchasePurpose"),
            FirstText(element, "Notes", "notes")
        }
        .Where(x => !string.IsNullOrWhiteSpace(x));

        return string.Join(" · ", parts);
    }

    private static string BuildMaintenanceDescription(JsonElement element)
    {
        var parts = new[]
        {
            FirstText(element, "ProblemDescription", "problemDescription"),
            FirstText(element, "WorkDescription", "workDescription"),
            FirstText(element, "FailureCause", "failureCause"),
            FirstText(element, "Notes", "notes")
        }
        .Where(x => !string.IsNullOrWhiteSpace(x));

        return string.Join(" · ", parts);
    }

    private static decimal ParseMoney(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return 0;
        }

        var clean = new string(value.Where(x => char.IsDigit(x) || x == ',' || x == '.' || x == '-').ToArray());

        if (string.IsNullOrWhiteSpace(clean))
        {
            return 0;
        }

        if (clean.Contains('.') && clean.Contains(','))
        {
            clean = clean.Replace(".", "").Replace(",", ".");
        }
        else if (clean.Count(x => x == '.') > 1)
        {
            clean = clean.Replace(".", "");
        }
        else if (clean.Contains(','))
        {
            clean = clean.Replace(",", ".");
        }

        return decimal.TryParse(clean, NumberStyles.Number, CultureInfo.InvariantCulture, out var parsed)
            ? parsed
            : 0;
    }

    private static string FormatMoney(decimal value)
    {
        return value <= 0
            ? "$0"
            : value.ToString("'$' #,0", CultureInfo.GetCultureInfo("es-CO"));
    }

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            : "—";
    }

    private static string Dash(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "—" : value;
    }

    private static bool Contains(string? source, string value)
    {
        return !string.IsNullOrWhiteSpace(source)
            && source.Contains(value, StringComparison.OrdinalIgnoreCase);
    }

    private static string ShortText(string? value, int max)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return "—";
        }

        return value.Length <= max
            ? value
            : value[..max] + "…";
    }

    private static string NormalizeKey(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value.Where(char.IsLetterOrDigit).Select(char.ToUpperInvariant).ToArray());
    }

    private static string ExtractServerMessage(string? content)
    {
        if (string.IsNullOrWhiteSpace(content))
        {
            return string.Empty;
        }

        try
        {
            using var document = JsonDocument.Parse(content);
            var message = GetString(document.RootElement, "Message", "message", "Detail", "detail", "error");

            if (!string.IsNullOrWhiteSpace(message))
            {
                return message;
            }
        }
        catch
        {
            // Usa el texto plano.
        }

        return content.Length > 260 ? content[..260] + "…" : content;
    }

