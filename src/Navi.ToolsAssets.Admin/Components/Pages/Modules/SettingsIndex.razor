@page "/settings"

<PageTitle>Configuración - NAVI Herramientas</PageTitle>

<section class="settings-tech-banner">
    <div>
        <span class="settings-tech-pill">CONFIGURACIÓN</span>
        <h2>Administración base del sistema</h2>
        <p>Todo lo que define usuarios, permisos, sedes, almacenes, talleres, ubicaciones y reglas operativas.</p>
    </div>

    <div class="settings-tech-side">
        <div class="settings-tech-status">
            <span>Usuarios</span>
            <strong>6 perfiles base</strong>
        </div>

        <a class="btn btn-sm btn-outline-light settings-back-button" href="/dashboard">
            Volver al Dashboard
        </a>
    </div>
</section>

<section class="settings-tech-grid">

    <article class="settings-tech-card">
        <span>SEGURIDAD</span>
        <h3>Usuarios</h3>
        <p>Crear, editar, activar o bloquear usuarios del sistema.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/users">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>SEGURIDAD</span>
        <h3>Roles y permisos</h3>
        <p>Configurar perfiles y permisos por módulo, acción, sede y zona.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/roles">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>ORGANIZACIÓN</span>
        <h3>Sedes</h3>
        <p>Administrar sedes como AGU, Medellín, Bogotá u otras operaciones.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/branches">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>ORGANIZACIÓN</span>
        <h3>Zonas</h3>
        <p>Agrupar sedes por regional, operación o zona administrativa.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/zones">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>ORGANIZACIÓN</span>
        <h3>Almacenes / Talleres</h3>
        <p>Crear almacenes, talleres, bodegas, patios, oficinas y áreas técnicas.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/warehouses">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>ORGANIZACIÓN</span>
        <h3>Ubicaciones</h3>
        <p>Definir estantes, bahías, puestos, zonas internas o ubicaciones físicas.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/locations">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>RESPONSABLES</span>
        <h3>Responsables</h3>
        <p>Gestionar técnicos, herramienteros, jefes, coordinadores y responsables.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/responsibles">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>ACTIVOS FIJOS</span>
        <h3>Tipos de activo</h3>
        <p>Herramientas, equipos de diagnóstico, computadores, medición y otros activos.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/asset-types">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>ACTIVOS FIJOS</span>
        <h3>Categorías</h3>
        <p>Gato pluma, escáner, computador, herramienta manual, eléctrica o especial.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/categories">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>ACTIVOS FIJOS</span>
        <h3>Estados</h3>
        <p>Disponible, asignado, prestado, mantenimiento, dañado, baja o pendiente.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/statuses">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>DOCUMENTOS</span>
        <h3>Tipos de documento</h3>
        <p>Ficha técnica, garantía, foto, acta, factura, evidencia y soporte.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/document-types">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>MANTENIMIENTO</span>
        <h3>Tipos de mantenimiento</h3>
        <p>Preventivo, correctivo, calibración, inspección y certificación.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/maintenance-types">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>MANTENIMIENTO</span>
        <h3>Planes de mantenimiento</h3>
        <p>Frecuencias, alertas, cronogramas y reglas por tipo de activo.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/maintenance-plans">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>OPERACIÓN</span>
        <h3>Causales</h3>
        <p>Causales de daño, novedad, pérdida, baja, traslado o mantenimiento.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/causes">Gestionar</a>
    </article>

    <article class="settings-tech-card">
        <span>SISTEMA</span>
        <h3>Parámetros</h3>
        <p>Reglas globales, días de alerta, límites de archivo y parámetros generales.</p>
        <a class="btn btn-outline-primary w-100" href="/settings/system-parameters">Gestionar</a>
    </article>

</section>

<style>
    .settings-tech-banner {
        background: linear-gradient(135deg, #050008 0%, #280032 45%, #5c006b 100%);
        color: #ffffff;
        border-radius: 0.85rem;
        padding: 1.25rem 1.4rem;
        margin-bottom: 1rem;
        min-height: 105px;
        display: flex;
        justify-content: space-between;
        align-items: stretch;
        gap: 1rem;
        box-shadow: 0 0.65rem 1.35rem rgba(75, 0, 92, 0.22);
    }

    .settings-tech-pill {
        display: inline-flex;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.35);
        color: #ffffff;
        border-radius: 999px;
        padding: 0.22rem 0.65rem;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 0.04rem;
        margin-bottom: 0.6rem;
    }

    .settings-tech-banner h2 {
        font-size: 1.65rem;
        font-weight: 950;
        margin: 0;
        color: #ffffff;
    }

    .settings-tech-banner p {
        margin: 0.35rem 0 0 0;
        color: rgba(255, 255, 255, 0.78);
        font-size: 0.9rem;
    }

    .settings-tech-side {
        min-width: 170px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: stretch;
        gap: 0.65rem;
    }

    .settings-tech-status {
        display: grid;
        gap: 0.2rem;
        background: rgba(255, 255, 255, 0.12);
        border-radius: 0.65rem;
        padding: 0.55rem 0.75rem;
        text-align: right;
    }

    .settings-tech-status span {
        color: #ffdd57;
        font-weight: 900;
        font-size: 0.75rem;
    }

    .settings-tech-status strong {
        color: #ffffff;
        font-size: 0.82rem;
    }

    .settings-back-button {
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 800;
        border-color: rgba(255, 255, 255, 0.65);
        color: #ffffff;
        background: rgba(255, 255, 255, 0.08);
    }

    .settings-back-button:hover {
        color: #4b005c;
        background: #ffffff;
        border-color: #ffffff;
    }

    .settings-tech-grid {
        display: grid;
        grid-template-columns: repeat(6, minmax(180px, 1fr));
        gap: 0.75rem;
        align-items: stretch;
    }

    .settings-tech-card {
        background: #ffffff;
        border: 1px solid #dfe3e8;
        border-radius: 0.75rem;
        padding: 0.85rem;
        min-height: 132px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 0 0.3rem 0.75rem rgba(0, 0, 0, 0.045);
    }

    .settings-tech-card:hover {
        border-color: #4b005c;
        box-shadow: 0 0.5rem 1.1rem rgba(75, 0, 92, 0.12);
        transform: translateY(-1px);
        transition: all 0.15s ease;
    }

    .settings-tech-card span {
        display: block;
        color: #637083;
        font-size: 0.68rem;
        font-weight: 950;
        letter-spacing: 0.05rem;
        text-transform: uppercase;
        margin-bottom: 0.45rem;
    }

    .settings-tech-card h3 {
        color: #111827;
        font-size: 0.98rem;
        font-weight: 950;
        margin: 0 0 0.3rem 0;
    }

    .settings-tech-card p {
        color: #5f5963;
        font-size: 0.78rem;
        line-height: 1.3;
        margin: 0 0 0.85rem 0;
    }

    .settings-tech-card .btn {
        height: 30px;
        padding: 0.25rem 0.6rem;
        font-size: 0.78rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    @@media (max-width: 1500px) {
        .settings-tech-grid {
            grid-template-columns: repeat(4, minmax(180px, 1fr));
        }
    }

    @@media (max-width: 1100px) {
        .settings-tech-grid {
            grid-template-columns: repeat(2, minmax(180px, 1fr));
        }

        .settings-tech-banner {
            flex-direction: column;
        }

        .settings-tech-side {
            width: 100%;
        }

        .settings-tech-status {
            text-align: left;
        }
    }

    @@media (max-width: 700px) {
        .settings-tech-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
