@rendermode InteractiveServer
@using Navi.ToolsAssets.Admin.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject WebAuthSessionService AuthSession

<section class="settings-entity-banner">
    <div>
        <span class="settings-entity-pill">@Pill</span>
        <h2>@Title</h2>
        <p>@Description</p>
    </div>

    <div class="settings-entity-side">
        <div class="settings-entity-status">
            <span>@CountLabel</span>
            <strong>@items.Count registrados</strong>
        </div>

        <a class="btn btn-sm btn-outline-light settings-entity-back" href="/settings">
            Volver a Configuración
        </a>
    </div>
</section>

<section class="settings-crud-layout">
    <div class="settings-crud-form">
        <h2>@(editingId is null ? $"Crear {Title.ToLowerInvariant()}" : $"Editar {Title.ToLowerInvariant()}")</h2>

        <EditForm Model="formModel" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Código</label>
                <InputText class="form-control" @bind-Value="formModel.Code" disabled="@(!CanManageSettings)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Nombre</label>
                <InputText class="form-control" @bind-Value="formModel.Name" disabled="@(!CanManageSettings)" />
            </div>

            <div class="mb-3">
                <label class="form-label">Descripción</label>
                <InputTextArea class="form-control" @bind-Value="formModel.Description" rows="3" disabled="@(!CanManageSettings)" />
            </div>

            <div class="form-check mb-3">
                <InputCheckbox class="form-check-input" @bind-Value="formModel.IsActive" disabled="@(!CanManageSettings)" />
                <label class="form-check-label">Activo</label>
            </div>

            @if (!string.IsNullOrWhiteSpace(message))
            {
                <div class="@messageClass">@message</div>
            }

            <div class="settings-crud-actions">
                @if (CanManageSettings)
                {
                    <button class="btn btn-primary" type="submit">Guardar</button>
                }
                else
                {
                    <span class="permission-action-denied">Solo consulta</span>
                }
                <button class="btn btn-outline-secondary" type="button" @onclick="ClearForm">Limpiar</button>
            </div>
        </EditForm>
    </div>

    <div class="settings-crud-table">
        <div class="settings-table-header">
            <h2>@Title registrados</h2>
            <button class="btn btn-sm btn-outline-primary" @onclick="LoadAsync">Actualizar</button>
        </div>

        @if (isLoading)
        {
            <p>Cargando...</p>
        }
        else if (items.Count == 0)
        {
            <div class="alert alert-info">No hay registros configurados para este catálogo.</div>
        }
        else if (items.Count == 0)
        {
            <div class="alert alert-info">No hay registros configurados para este catálogo.</div>
        }
        else
        {
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in items)
                    {
                        <tr>
                            <td><strong>@item.Code</strong></td>
                            <td>@item.Name</td>
                            <td>
                                <span class="settings-description-cell">@item.Description</span>
                            </td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                    @(item.IsActive ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-end">
                                @if (CanManageSettings)
                                    {
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(item)">Editar</button>
                                    }
                                @if (CanManageSettings)
                                    {
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteAsync(item.Id)">Eliminar</button>
                                    }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</section>

<style>
    .settings-entity-banner {
        background: linear-gradient(135deg, #050008 0%, #280032 45%, #5c006b 100%);
        color: #ffffff;
        border-radius: 0.85rem;
        padding: 1.25rem 1.4rem;
        margin-bottom: 1rem;
        min-height: 105px;
        display: flex;
        justify-content: space-between;
        align-items: stretch;
        gap: 1rem;
        box-shadow: 0 0.65rem 1.35rem rgba(75, 0, 92, 0.22);
    }

    .settings-entity-pill {
        display: inline-flex;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.35);
        color: #ffffff;
        border-radius: 999px;
        padding: 0.22rem 0.65rem;
        font-size: 0.7rem;
        font-weight: 900;
        letter-spacing: 0.04rem;
        margin-bottom: 0.6rem;
    }

    .settings-entity-banner h2 {
        font-size: 1.65rem;
        font-weight: 950;
        margin: 0;
        color: #ffffff;
    }

    .settings-entity-banner p {
        margin: 0.35rem 0 0 0;
        color: rgba(255, 255, 255, 0.78);
        font-size: 0.9rem;
    }

    .settings-entity-side {
        min-width: 185px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: stretch;
        gap: 0.65rem;
    }

    .settings-entity-status {
        display: grid;
        gap: 0.2rem;
        background: rgba(255, 255, 255, 0.12);
        border-radius: 0.65rem;
        padding: 0.55rem 0.75rem;
        text-align: right;
    }

    .settings-entity-status span {
        color: #ffdd57;
        font-weight: 900;
        font-size: 0.75rem;
    }

    .settings-entity-status strong {
        color: #ffffff;
        font-size: 0.82rem;
    }

    .settings-entity-back {
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.78rem;
        font-weight: 800;
        border-color: rgba(255, 255, 255, 0.65);
        color: #ffffff;
        background: rgba(255, 255, 255, 0.08);
    }

    .settings-entity-back:hover {
        color: #4b005c;
        background: #ffffff;
        border-color: #ffffff;
    }

    .settings-description-cell {
        display: inline-block;
        max-width: 420px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: #5f5963;
        font-size: 0.82rem;
    }
</style>

@code {
    private bool IsAdmin =>
        string.Equals(AuthSession.RoleCode, "ADMIN", StringComparison.OrdinalIgnoreCase)
        || string.Equals(AuthSession.RoleCode, "SUPERADMIN", StringComparison.OrdinalIgnoreCase);

    private bool CanManageSettings => IsAdmin || AuthSession.HasPermission("Settings.Manage");

    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Pill { get; set; } = string.Empty;
    [Parameter] public string Description { get; set; } = string.Empty;
    [Parameter] public string CountLabel { get; set; } = string.Empty;
    [Parameter] public string Endpoint { get; set; } = string.Empty;

    private HttpClient Api => HttpClientFactory.CreateClient("NaviApi");

    private List<CatalogDto> items = new();
    private CatalogFormModel formModel = new();
    private Guid? editingId;
    private bool isLoading;
    private string message = string.Empty;
    private string messageClass = "alert alert-info";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        message = string.Empty;

        try
        {
            items = await Api.GetFromJsonAsync<List<CatalogDto>>(Endpoint) ?? new();
        }
        catch (Exception ex)
        {
            ShowError($"No se pudieron cargar los datos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task SaveAsync()
    {
        if (!CanManageSettings)
        {
            ShowError("No tienes permiso para modificar configuración.");
            return;
        }

        if (string.IsNullOrWhiteSpace(formModel.Code) ||
            string.IsNullOrWhiteSpace(formModel.Name))
        {
            ShowError("Código y nombre son obligatorios.");
            return;
        }

        var request = new
        {
            code = formModel.Code,
            name = formModel.Name,
            description = formModel.Description,
            isActive = formModel.IsActive,
            changedBy = "admin-web"
        };

        try
        {
            HttpResponseMessage response = editingId is null
                ? await Api.PostAsJsonAsync(Endpoint, request)
                : await Api.PutAsJsonAsync($"{Endpoint}/{editingId}", request);

            if (!response.IsSuccessStatusCode)
            {
                ShowError(await response.Content.ReadAsStringAsync());
                return;
            }

            ShowSuccess(editingId is null ? "Registro creado correctamente." : "Registro actualizado correctamente.");
            ClearForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Error guardando registro: {ex.Message}");
        }
    }

    private void Edit(CatalogDto item)
    {
        if (!CanManageSettings)
        {
            ShowError("No tienes permiso para editar configuración.");
            return;
        }

        editingId = item.Id;

        formModel = new CatalogFormModel
        {
            Code = item.Code,
            Name = item.Name,
            Description = item.Description,
            IsActive = item.IsActive
        };
    }

    private async Task DeleteAsync(Guid id)
    {
        if (!CanManageSettings)
        {
            ShowError("No tienes permiso para eliminar configuración.");
            return;
        }

        try
        {
            var response = await Api.DeleteAsync($"{Endpoint}/{id}?changedBy=admin-web");

            if (!response.IsSuccessStatusCode)
            {
                ShowError(await response.Content.ReadAsStringAsync());
                return;
            }

            ShowSuccess("Registro eliminado correctamente.");
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"Error eliminando registro: {ex.Message}");
        }
    }

    private void ClearForm()
    {
        editingId = null;
        formModel = new CatalogFormModel();
    }

    private void ShowSuccess(string value)
    {
        message = value;
        messageClass = "alert alert-success";
    }

    private void ShowError(string value)
    {
        message = value;
        messageClass = "alert alert-danger";
    }

    private sealed class CatalogDto
    {
        public Guid Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsActive { get; set; }
    }

    private sealed class CatalogFormModel
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
    }
}



