@page "/access-denied"

<PageTitle>Acceso denegado - NAVI</PageTitle>

<section class="access-denied-page">
    <div class="access-denied-card">
        <span>ACCESO DENEGADO</span>
        <h2>No tienes permisos para acceder</h2>
        <p>Tu usuario o rol actual no tiene permisos para ingresar a este módulo.</p>

        <a class="btn btn-primary" href="/dashboard">Volver al dashboard</a>
    </div>
</section>

<style>
    .access-denied-page {
        min-height: calc(100vh - 160px);
        display: grid;
        place-items: center;
    }

    .access-denied-card {
        width: min(520px, 100%);
        background: #ffffff;
        border: 1px solid #dfe3e8;
        border-radius: 1rem;
        padding: 1.5rem;
        text-align: center;
        box-shadow: 0 .65rem 1.6rem rgba(0,0,0,.08);
    }

    .access-denied-card span {
        display: inline-flex;
        background: #fff3cd;
        color: #7a5200;
        border-radius: 999px;
        padding: .22rem .7rem;
        font-size: .72rem;
        font-weight: 950;
        margin-bottom: .7rem;
    }

    .access-denied-card h2 {
        margin: 0;
        color: #17111c;
        font-size: 1.45rem;
        font-weight: 950;
    }

    .access-denied-card p {
        color: #657083;
        margin: .55rem 0 1rem;
    }
</style>
