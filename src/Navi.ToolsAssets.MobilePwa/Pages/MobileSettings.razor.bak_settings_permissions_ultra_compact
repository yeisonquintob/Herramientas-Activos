        new("AssetAssignment.History", "Asignar AF", "Ver / consultar", "Ver historial de asignaciones.", "view", 11),

        new("TechnicalLifeRecord.View", "Hoja de vida", "Ver / consultar", "Ver hoja de vida técnica.", "view", 10),
        new("TechnicalLifeRecord.Edit", "Hoja de vida", "Editar / gestionar", "Editar datos técnicos de hoja de vida.", "edit", 30),
        new("TechnicalLifeRecord.Export", "Hoja de vida", "Exportar", "Exportar hoja de vida a PDF o Excel.", "approve", 45),

        new("Documents.View", "Documentos", "Ver / consultar", "Ver documentos y evidencias.", "view", 10),
        new("Documents.Upload", "Documentos", "Crear / solicitar", "Cargar documentos y evidencias.", "create", 20),
        new("Documents.Download", "Documentos", "Exportar", "Descargar documentos.", "approve", 45),
        new("Documents.Delete", "Documentos", "Eliminar / rechazar", "Eliminar documentos.", "danger", 60),

