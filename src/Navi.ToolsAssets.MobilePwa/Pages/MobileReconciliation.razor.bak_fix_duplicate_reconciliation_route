    private static bool Contains(string? value, string text)
    {
        return !string.IsNullOrWhiteSpace(value) &&
               value.Contains(text, StringComparison.OrdinalIgnoreCase);
    }

    private static bool SameUser(string? left, string? right)
    {
        return !string.IsNullOrWhiteSpace(left) &&
               !string.IsNullOrWhiteSpace(right) &&
               left.Trim().Equals(right.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private static bool Same(string? left, string? right)
    {
        return string.Equals(Normalize(left), Normalize(right), StringComparison.OrdinalIgnoreCase);
    }

    private static string Normalize(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return value.Trim()
            .ToUpperInvariant()
            .Replace("Á", "A")
            .Replace("É", "E")
            .Replace("Í", "I")
            .Replace("Ó", "O")
            .Replace("Ú", "U")
            .Replace("Ü", "U")
            .Replace("Ñ", "N");
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "—" : value;
    }

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue
            ? value.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            : "—";
    }

    private static string StatusLabel(string? status, string? label)
    {
        if (!string.IsNullOrWhiteSpace(label))
        {
            return label;
        }

        return status switch
        {
            "Draft" => "Borrador",
            "InProgress" => "En proceso",
            "Completed" => "Completada",
            "Reconciled" => "Conciliada",
            "Cancelled" => "Cancelada",
            _ => Display(status)
        };
    }

    private static string GetReportTypeLabel(ReportedItem item)
    {
        return item.ReportType switch
        {
            "Found" => "Encontrada",
            "NotFound" => "No encontrada",
            "ExtraNotListed" => "No listada",
            "Damaged" => "Dañada",
            "ReturnedOrDelivered" => "Devuelta",
            _ => string.IsNullOrWhiteSpace(item.ReportTypeLabel) ? Display(item.ReportType) : item.ReportTypeLabel
        };
    }

    private static string GetReportTypeClass(ReportedItem item)
    {
        return item.ReportType switch
        {
            "Found" => "mrec-chip ok",
            "NotFound" => "mrec-chip danger",
            "ExtraNotListed" => "mrec-chip purple",
            "Damaged" => "mrec-chip danger",
            "ReturnedOrDelivered" => "mrec-chip info",
            _ => "mrec-chip"
        };
    }

    private static string GetReconciliationLabel(ReportedItem item)
    {
        if (item.CreatedToolAssetId.HasValue)
        {
            return "Creado";
        }

        if (item.Rejected || Same(item.ReconciliationStatus, "Rejected"))
        {
            return "Rechazado";
        }

        if (item.RequiresUserClarification || Same(item.ReconciliationStatus, "RequiresUserClarification"))
        {
            return "Aclaración";
        }

        return item.ReconciliationStatus switch
        {
            "Reconciled" => "Conciliado",
            "ApprovedForCreation" => "Aprobado",
            "MatchedInSystem" => "Pendiente conciliación",
            "NotFoundInSystem" => "Pendiente creación",
            "PendingReview" => "Pendiente revisión",
            _ => string.IsNullOrWhiteSpace(item.ReconciliationStatusLabel)
                ? Display(item.ReconciliationStatus)
                : item.ReconciliationStatusLabel
        };
    }

    private static string GetReconciliationStatusClass(ReportedItem item)
    {
        if (item.Rejected || Same(item.ReconciliationStatus, "Rejected"))
        {
            return "mrec-chip danger";
        }

        if (item.CreatedToolAssetId.HasValue || Same(item.ReconciliationStatus, "Reconciled"))
        {
            return "mrec-chip ok";
        }

        if (item.RequiresUserClarification || Same(item.ReconciliationStatus, "RequiresUserClarification"))
        {
            return "mrec-chip warning";
        }

        return item.ReconciliationStatus switch
        {
            "ApprovedForCreation" => "mrec-chip info",
            "MatchedInSystem" => "mrec-chip warning",
            "NotFoundInSystem" => "mrec-chip danger-soft",
            "PendingReview" => "mrec-chip",
            _ => "mrec-chip"
        };
    }

    private static string GetItemCardClass(ReportedItem item)
    {
        if (item.Rejected || Same(item.ReconciliationStatus, "Rejected"))
        {
            return "mrec-item-card danger";
        }

        if (item.CreatedToolAssetId.HasValue || Same(item.ReconciliationStatus, "Reconciled"))
        {
            return "mrec-item-card success";
        }

        if (item.RequiresUserClarification || Same(item.ReconciliationStatus, "RequiresUserClarification"))
        {
            return "mrec-item-card warning";
        }

        if (Same(item.ReportType, "ExtraNotListed"))
        {
            return "mrec-item-card purple";
        }

        return "mrec-item-card";
    }

