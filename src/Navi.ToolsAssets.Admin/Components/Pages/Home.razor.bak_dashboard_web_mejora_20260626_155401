@page "/"
@page "/dashboard"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Components.Shared
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Dashboard - NAVI</PageTitle>

<PermissionGuard Permission="Dashboard.View" ModuleName="Dashboard">

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (isLoading && dashboard is null)
{
    <div class="alert alert-info">Cargando dashboard...</div>
}
else if (dashboard is not null)
{
    <section class="state-dashboard">
        <section class="state-hero">
            <div>
                <span>Estado</span>
                <p>Control operativo de herramientas, activos, responsables, diferencias, mantenimientos y hojas de vida.</p>
            </div>

            <strong>En progreso</strong>
        </section>

        <section class="state-kpis">
            <article>
                <span>PARTICIPANTES</span>
                <strong>@dashboard.Summary.ActiveResponsibles</strong>
                <small>Usuarios / responsables</small>
            </article>

            <article>
                <span>EN PROCESO</span>
                <strong>@GetInProcess()</strong>
                <small>Inventario activo</small>
            </article>

            <article>
                <span>FINALIZADOS</span>
                <strong>@dashboard.Summary.WithLifeRecord</strong>
                <small>Con hoja de vida</small>
            </article>

            <article>
                <span>PENDIENTES</span>
                <strong>@GetPendingTotal()</strong>
                <small>Herramientas por validar</small>
            </article>

            <article>
                <span>DIFERENCIAS</span>
                <strong>@GetDifferences()</strong>
                <small>Conciliación</small>
            </article>

            <article>
                <span>AVANCE</span>
                <strong>@GetAdvancePercent()%</strong>
                <small>@dashboard.Summary.WithLifeRecord de @dashboard.Summary.TotalTools</small>
            </article>
        </section>

        <section class="state-grid">
            <article class="state-card">
                <h3>Local de herramientas</h3>

                <div class="state-list">
                    <div><span>Total herramientas</span><strong>@dashboard.Summary.TotalTools</strong></div>
                    <div><span>Disponibles</span><strong>@dashboard.Summary.AvailableTools</strong></div>
                    <div><span>Asignadas</span><strong>@dashboard.Summary.AssignedTools</strong></div>
                    <div><span>En mantenimiento</span><strong>@dashboard.Summary.InMaintenanceTools</strong></div>
                    <div><span>Pendientes validación</span><strong>@dashboard.Summary.PendingValidationTools</strong></div>
                    <div><span>Desactivados / baja</span><strong>@dashboard.Summary.DisposedTools</strong></div>
                </div>
            </article>

            <article class="state-card">
                <div class="state-card-head">
                    <h3>Mantenimientos realizado</h3>
                    <span>Por mes</span>
                </div>

                <div class="state-list">
                    <div><span>Total</span><strong>@dashboard.MaintenanceSummary.Total</strong></div>
                    <div><span>Este mes</span><strong>@dashboard.MaintenanceSummary.ThisMonth</strong></div>
                    <div><span>Hoy</span><strong>@dashboard.MaintenanceSummary.Today</strong></div>
                    <div><span>Pendientes</span><strong>@dashboard.Summary.RequiresMaintenance</strong></div>
                </div>
            </article>

            <article class="state-card state-metric-card">
                <h3>Herramientas vs activos</h3>

                <div class="state-dual-metric">
                    <div>
                        <span>Herramientas</span>
                        <strong>@dashboard.Summary.ToolsOnly</strong>
                    </div>

                    <div>
                        <span>Activos fijos</span>
                        <strong>@dashboard.Summary.FixedAssets</strong>
                    </div>
                </div>
            </article>

            <article class="state-card">
                <h3>Herramientas vs activos</h3>

                <div class="state-donut-row">
                    <div class="state-donut" style="@GetToolsVsAssetsDonut()">
                        <strong>@dashboard.Summary.TotalTools</strong>
                        <span>Total</span>
                    </div>

                    <div class="state-legend">
                        <div><i class="purple"></i><span>Herramientas</span><strong>@dashboard.Summary.ToolsOnly</strong></div>
                        <div><i class="blue"></i><span>Activos fijos</span><strong>@dashboard.Summary.FixedAssets</strong></div>
                        <div><i class="orange"></i><span>Sin código AF</span><strong>@dashboard.Summary.ToolsWithoutFixedAssetCode</strong></div>
                    </div>
                </div>
            </article>

            <article class="state-card">
                <h3>Herramientas por sede</h3>

                <div class="state-bars-vertical">
                    @foreach (var item in dashboard.ToolsByBranch.Take(7))
                    {
                        <div>
                            <strong style="@($"height:{GetPercent(item.Total, GetMaxBranch())}%")"></strong>
                            <span>@item.BranchCode</span>
                        </div>
                    }
                </div>
            </article>

            <article class="state-card state-table-card">
                <h3>Resumen por sede / responsable</h3>

                <table class="state-table">
                    <thead>
                        <tr>
                            <th>Sede</th>
                            <th>Herramientas</th>
                            <th>Pendientes</th>
                            <th>Avance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in dashboard.ToolsByBranch.Take(8))
                        {
                            var percent = GetPercent(item.Total, GetMaxBranch());

                            <tr>
                                <td>
                                    <strong>@item.BranchCode</strong>
                                    <small>@item.BranchName</small>
                                </td>
                                <td>@item.Total</td>
                                <td>@GetPendingByBranch(item.Total)</td>
                                <td>
                                    <div class="state-progress">
                                        <span style="@($"width:{percent}%")"></span>
                                    </div>
                                    <small>@percent%</small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </article>

            <article class="state-card">
                <h3>Herramientas por mes</h3>

                <div class="state-donut-row">
                    <div class="state-donut blue" style="@GetMaintenanceDonut()">
                        <strong>@dashboard.MaintenanceSummary.Total</strong>
                        <span>Total</span>
                    </div>

                    <div class="state-legend">
                        @foreach (var item in dashboard.MaintenanceByMonth.Take(5))
                        {
                            <div><i class="blue"></i><span>@item.Label</span><strong>@item.Count</strong></div>
                        }
                    </div>
                </div>
            </article>

            <article class="state-card">
                <h3>Hojas de vida</h3>

                <div class="state-donut-row">
                    <div class="state-donut orange" style="@GetLifeRecordDonut()">
                        <strong>@dashboard.Summary.WithLifeRecord</strong>
                        <span>Con HV</span>
                    </div>

                    <div class="state-legend">
                        <div><i class="purple"></i><span>Con hoja</span><strong>@dashboard.Summary.WithLifeRecord</strong></div>
                        <div><i class="orange"></i><span>Sin hoja</span><strong>@dashboard.Summary.WithoutLifeRecord</strong></div>
                        <div><i class="red"></i><span>Datos incompletos</span><strong>@dashboard.LifeRecordCoverage.MissingTechnicalData</strong></div>
                    </div>
                </div>
            </article>

            <article class="state-card state-maintenance-day">
                <h3>Mantenimientos por día</h3>

                <div>
                    <strong>@dashboard.MaintenanceSummary.ThisMonth</strong>
                    <span>Por mes</span>
                </div>

                <div>
                    <strong>@dashboard.MaintenanceSummary.Today</strong>
                    <span>Por día</span>
                </div>

                <div>
                    <strong>@dashboard.Summary.RequiresMaintenance</strong>
                    <span>Pendientes</span>
                </div>
            </article>

            <article class="state-card">
                <h3>Toma física</h3>
                <p class="state-note">Acciones rápidas para gestión de toma física y conciliación.</p>

                <div class="state-actions">
                    <a href="/physical-counts">Volver</a>
                    <a href="/physical-counts">Generar participantes</a>
                    <a href="/physical-counts">Activar toma</a>
                    <a href="/reconciliation">Conciliar</a>
                </div>
            </article>
        </section>
    </section>
}

</PermissionGuard>

