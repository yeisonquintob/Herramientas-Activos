    @@media (max-width: 1400px) {
        .kpi-grid {
            grid-template-columns: repeat(4, 1fr);
        }

        .dashboard-layout {
            grid-template-columns: repeat(2, 1fr);
        }

        .span-2,
        .span-4 {
            grid-column: span 2;
        }
