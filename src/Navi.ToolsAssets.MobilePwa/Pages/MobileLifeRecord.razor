@page "/tools/{ToolId:guid}/life-record"
@page "/tools/{ToolId:guid}/technical-life-record"

@using Navi.ToolsAssets.MobilePwa.Models
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http

@inject NaviMobileApiClient Api
@inject MobileAuthSessionService Auth
@inject NavigationManager Navigation

<PageTitle>Hoja de vida AF - NAVI Herramientas y AF</PageTitle>

<section class="mobile-page mobile-compact-page navi-life-manage-v3">
    @if (isLoading)
    {
        <div class="mobile-loading">Cargando hoja de vida...</div>
    }
    else if (!Auth.IsAuthenticated)
    {
        <div class="mobile-empty">
            <strong>Sesión requerida</strong>
            <span>Debes iniciar sesión para consultar la hoja de vida.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoLogin">Ir al login</button>
        </div>
    }
    else if (!CanViewLifeRecord)
    {
        <div class="mobile-empty">
            <strong>Sin permiso</strong>
            <span>Tu usuario no tiene permiso para consultar hoja de vida.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoBack">Regresar</button>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(message) && life is null)
    {
        <div class="mobile-alert">@message</div>
        <button class="mobile-primary-button" type="button" @onclick="GoBack">Regresar</button>
    }
    else if (life is not null)
    {
        <header class="mlife-hero">
            <div>
                <span>HOJA DE VIDA AF</span>
                <h1>@Show(life.EquipmentInformation.Name ?? life.Summary.Name)</h1>
                <p>@Show(life.EquipmentInformation.InternalCode ?? life.Summary.InternalCode) · @StatusLabel(life.Summary.OperationalStatus)</p>
            </div>

            <div class="mlife-hero-actions">
                <button type="button" @onclick="GoBack">Regresar</button>
                <button type="button" @onclick="LoadAsync" disabled="@isLoading">Actualizar</button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="mobile-alert">@message</div>
        }

        <section class="mlife-kpis">
            <article>
                <span>Vida útil</span>
                <strong>@PercentLabel(life.UsefulLife.UsedPercentage)</strong>
                <small>Uso</small>
            </article>

            <article>
                <span>Documentos</span>
                <strong>@life.Documents.AllDocuments.Count</strong>
                <small>Archivos</small>
            </article>

            <article>
                <span>Accesorios</span>
                <strong>@life.Accessories.Count</strong>
                <small>Componentes</small>
            </article>

            <article>
                <span>Permiso</span>
                <strong>@PermissionMode</strong>
                <small>Matriz</small>
            </article>
        </section>

        @if (!CanManageThisTool && HasAnyManagementPermission)
        {
            <section class="mobile-empty compact">
                Tienes permisos de gestión, pero este activo no está dentro de tu sede o alcance operativo.
            </section>
        }

        <details id="info" class="mobile-fold mlife-section" open>
            <summary>
                <span>Información del equipo</span>

                <div class="mlife-summary-actions">
                    @if (CanEditTechnical)
                    {
                        @if (editInfoMode)
                        {
                            <button type="button" class="cancel" @onclick="CancelInfoEdit" @onclick:stopPropagation="true">Cancelar</button>
                            <button type="button" class="save" @onclick="SaveTechnicalAsync" @onclick:stopPropagation="true" disabled="@isSaving">
                                @(isSaving ? "Guardando..." : "Guardar")
                            </button>
                        }
                        else
                        {
                            <button type="button" @onclick="BeginInfoEdit" @onclick:stopPropagation="true">Editar</button>
                        }
                    }
                </div>
            </summary>

            @if (!editInfoMode)
            {
                <div class="mobile-info-grid compact">
                    <div><span>Código interno</span><strong>@Show(life.EquipmentInformation.InternalCode)</strong></div>
                    <div><span>Nombre</span><strong>@Show(life.EquipmentInformation.Name)</strong></div>
                    <div><span>Activo fijo</span><strong>@Show(life.EquipmentInformation.FixedAssetCode)</strong></div>
                    <div><span>Código Fenix365</span><strong>@Show(life.EquipmentInformation.FenixCode)</strong></div>
                    <div><span>Marca</span><strong>@Show(life.EquipmentInformation.Brand)</strong></div>
                    <div><span>Modelo</span><strong>@Show(life.EquipmentInformation.Model)</strong></div>
                    <div><span>Serial</span><strong>@Show(life.EquipmentInformation.SerialNumber)</strong></div>
                    <div><span>Sede</span><strong>@JoinCodeName(life.EquipmentInformation.BranchCode, life.EquipmentInformation.BranchName)</strong></div>
                    <div><span>Ubicación</span><strong>@JoinCodeName(life.EquipmentInformation.LocationCode, life.EquipmentInformation.LocationName)</strong></div>
                    <div><span>Responsable</span><strong>@Show(life.EquipmentInformation.ResponsibleName)</strong></div>
                </div>
            }
            else
            {
                <EditForm Model="technicalForm" OnValidSubmit="SaveTechnicalAsync">
                    <div class="mlife-form-grid">
                        <label><span>Marca</span><InputText @bind-Value="technicalForm.Brand" /></label>
                        <label><span>Modelo</span><InputText @bind-Value="technicalForm.Model" /></label>
                        <label><span>Serial</span><InputText @bind-Value="technicalForm.SerialNumber" /></label>
                        <label><span>Activo fijo</span><InputText @bind-Value="technicalForm.FixedAssetCode" /></label>
                        <label><span>Código Fenix365</span><InputText @bind-Value="technicalForm.FenixCode" /></label>
                        <label><span>Fecha adquisición</span><InputDate @bind-Value="technicalForm.AcquisitionDate" /></label>
                    </div>

                    <label class="mlife-full">
                        <span>Observación</span>
                        <InputTextArea @bind-Value="technicalForm.Observation" />
                    </label>
                </EditForm>
            }
        </details>

        
        <details id="technical" class="mobile-fold mlife-section" open>
            <summary>
                <span>Datos técnicos, garantía y vida útil</span>

                <div class="mlife-summary-actions">
                    @if (CanEditTechnical)
                    {
                        @if (editTechnicalMode)
                        {
                            <button type="button" class="cancel" @onclick="CancelTechnicalEdit" @onclick:stopPropagation="true">
                                Cancelar
                            </button>

                            <button type="button" class="save" @onclick="SaveTechnicalAsync" @onclick:stopPropagation="true" disabled="@isSaving">
                                @(isSaving ? "Guardando..." : "Guardar")
                            </button>
                        }
                        else
                        {
                            <button type="button" @onclick="BeginTechnicalEdit" @onclick:stopPropagation="true">
                                Editar
                            </button>
                        }
                    }
                </div>
            </summary>

            @if (!editTechnicalMode)
            {
                <div class="mobile-info-grid compact">
                    <div>
                        <span>Voltaje</span>
                        <strong>@Show(life.TechnicalSpecifications.Voltage)</strong>
                    </div>

                    <div>
                        <span>Capacidad</span>
                        <strong>@Show(life.TechnicalSpecifications.LoadCapacity)</strong>
                    </div>

                    <div>
                        <span>Proveedor</span>
                        <strong>@Show(life.TechnicalSpecifications.Provider)</strong>
                    </div>

                    <div>
                        <span>Garantía</span>
                        <strong>@BoolLabel(life.Warranty.HasWarranty)</strong>
                    </div>

                    <div>
                        <span>Tipo garantía</span>
                        <strong>@Show(life.Warranty.WarrantyType)</strong>
                    </div>

                    <div>
                        <span>Vence certificación</span>
                        <strong>@DateLabel(life.TechnicalSpecifications.CertificationExpirationDate)</strong>
                    </div>

                    <div>
                        <span>Inicio vida útil</span>
                        <strong>@DateLabel(life.UsefulLife.StartDate)</strong>
                    </div>

                    <div>
                        <span>Fin estimado</span>
                        <strong>@DateLabel(life.UsefulLife.EndDate)</strong>
                    </div>

                    <div>
                        <span>Vida útil meses</span>
                        <strong>@ValueLabel(life.UsefulLife.UsefulLifeMonths)</strong>
                    </div>

                    <div>
                        <span>Vida útil días</span>
                        <strong>@ValueLabel(life.UsefulLife.UsefulLifeDays)</strong>
                    </div>

                    <div>
                        <span>Último mantenimiento</span>
                        <strong>@DateLabel(life.MaintenancePlan.LastMaintenanceDate)</strong>
                    </div>

                    <div>
                        <span>Próximo mantenimiento</span>
                        <strong>@DateLabel(life.MaintenancePlan.NextMaintenanceDate)</strong>
                    </div>

                    <div>
                        <span>Periodicidad mantenimiento</span>
                        <strong>@ValueLabel(life.MaintenancePlan.MaintenancePeriodMonths)</strong>
                    </div>

                    <div>
                        <span>Requiere mantenimiento</span>
                        <strong>@BoolLabel(life.TechnicalSpecifications.RequiresMaintenance)</strong>
                    </div>

                    <div>
                        <span>Requiere preoperacional</span>
                        <strong>@BoolLabel(life.TechnicalSpecifications.RequiresPreOperationalCheck)</strong>
                    </div>

                    <div>
                        <span>Requiere certificación</span>
                        <strong>@BoolLabel(life.TechnicalSpecifications.RequiresCertification)</strong>
                    </div>
                </div>
            }
            else
            {
                <EditForm Model="technicalForm" OnValidSubmit="SaveTechnicalAsync">
                    <div class="mlife-form-grid">
                        <label>
                            <span>Voltaje</span>
                            <InputText @bind-Value="technicalForm.Voltage" />
                        </label>

                        <label>
                            <span>Capacidad carga</span>
                            <InputText @bind-Value="technicalForm.LoadCapacity" />
                        </label>

                        <label>
                            <span>Proveedor</span>
                            <InputText @bind-Value="technicalForm.Provider" />
                        </label>

                        <label>
                            <span>Tipo garantía</span>
                            <InputText @bind-Value="technicalForm.WarrantyType" />
                        </label>

                        <label>
                            <span>Inicio vida útil</span>
                            <InputDate @bind-Value="technicalForm.UsefulLifeStartDate" />
                        </label>

                        <label>
                            <span>Vida útil meses</span>
                            <InputNumber @bind-Value="technicalForm.UsefulLifeMonths" />
                        </label>

                        <label>
                            <span>Vida útil días</span>
                            <InputNumber @bind-Value="technicalForm.UsefulLifeDays" />
                        </label>

                        <label>
                            <span>Último mantenimiento</span>
                            <InputDate @bind-Value="technicalForm.LastMaintenanceDate" />
                        </label>

                        <label>
                            <span>Próximo mantenimiento</span>
                            <InputDate @bind-Value="technicalForm.NextMaintenanceDate" />
                        </label>

                        <label>
                            <span>Periodicidad meses</span>
                            <InputNumber @bind-Value="technicalForm.MaintenancePeriodMonths" />
                        </label>

                        <label>
                            <span>Vence certificación</span>
                            <InputDate @bind-Value="technicalForm.CertificationExpirationDate" />
                        </label>
                    </div>

                    <div class="mlife-check-grid">
                        <label>
                            <InputCheckbox @bind-Value="technicalForm.HasWarranty" />
                            Garantía
                        </label>

                        <label>
                            <InputCheckbox @bind-Value="technicalForm.RequiresMaintenance" />
                            Requiere mantenimiento
                        </label>

                        <label>
                            <InputCheckbox @bind-Value="technicalForm.RequiresPreOperationalCheck" />
                            Requiere preoperacional
                        </label>

                        <label>
                            <InputCheckbox @bind-Value="technicalForm.RequiresCertification" />
                            Requiere certificación
                        </label>
                    </div>

                    <label class="mlife-full">
                        <span>Observación</span>
                        <InputTextArea @bind-Value="technicalForm.Observation" />
                    </label>
                </EditForm>
            }
        </details>


        <details id="accessories" class="mobile-fold mlife-section">
            <summary>
                <span>Accesorios (@accessories.Count)</span>

                <div class="mlife-summary-actions">
                    @if (CanManageAccessories)
                    {
                        @if (editAccessoriesMode)
                        {
                            <button type="button" class="cancel" @onclick="CancelAccessoriesSection" @onclick:stopPropagation="true">Cancelar</button>
                            <button type="button" class="save" @onclick="SaveAccessoryAsync" @onclick:stopPropagation="true" disabled="@isSaving">
                                @(isSaving ? "Guardando..." : "Guardar")
                            </button>
                        }
                        else
                        {
                            <button type="button" @onclick="BeginAccessoriesEdit" @onclick:stopPropagation="true">Editar</button>
                        }
                    }
                </div>
            </summary>

            @if (editAccessoriesMode)
            {
                <EditForm Model="accessoryForm" OnValidSubmit="SaveAccessoryAsync">
                    <div class="mlife-form-grid">
                        <label><span>Nombre</span><InputText @bind-Value="accessoryForm.Name" /></label>
                        <label><span>Cantidad</span><InputNumber @bind-Value="accessoryForm.Quantity" /></label>
                    </div>

                    <div class="mlife-check-grid">
                        <label><InputCheckbox @bind-Value="accessoryForm.RequiresMaintenance" /> Requiere mantenimiento</label>
                        <label><InputCheckbox @bind-Value="accessoryForm.IsMeasurementEquipment" /> Equipo medición</label>
                    </div>

                    <label class="mlife-full">
                        <span>Observación</span>
                        <InputTextArea @bind-Value="accessoryForm.Observation" />
                    </label>
                </EditForm>
            }

            <div class="mobile-mini-list">
                @foreach (var item in accessories)
                {
                    <article>
                        <strong>@Show(item.Name)</strong>
                        <span>Cantidad: @item.Quantity · Mant.: @BoolLabel(item.RequiresMaintenance) · Medición: @BoolLabel(item.IsMeasurementEquipment)</span>
                        <small>@Show(item.Observation)</small>

                        @if (editAccessoriesMode && CanManageAccessories)
                        {
                            <div class="mlife-row-actions">
                                <button type="button" @onclick="() => StartAccessoryEdit(item)">Editar este</button>
                                <button class="danger" type="button" @onclick="() => DeleteAccessoryAsync(item)">Desactivar</button>
                            </div>
                        }
                    </article>
                }
            </div>
        </details>

        <details id="documents" class="mobile-fold mlife-section">
            <summary>
                <span>Documentos (@documents.Count)</span>

                <div class="mlife-summary-actions">
                    @if (CanManageDocuments)
                    {
                        @if (editDocumentsMode)
                        {
                            <button type="button" class="cancel" @onclick="CancelDocumentsSection" @onclick:stopPropagation="true">Cancelar</button>
                            <button type="button" class="save" @onclick="UploadDocumentAsync" @onclick:stopPropagation="true" disabled="@isSaving">
                                @(isSaving ? "Cargando..." : "Guardar")
                            </button>
                        }
                        else
                        {
                            <button type="button" @onclick="BeginDocumentsEdit" @onclick:stopPropagation="true">Editar</button>
                        }
                    }
                </div>
            </summary>

            @if (editDocumentsMode)
            {
                <div class="mlife-form-grid">
                    <label>
                        <span>Tipo documento</span>
                        <InputSelect @bind-Value="documentForm.DocumentType">
                            <option value="TechnicalDocument">Ficha técnica</option>
                            <option value="PhotographicRecord">Registro fotográfico</option>
                            <option value="MaintenanceEvidence">Evidencia mantenimiento</option>
                            <option value="Other">Otro</option>
                        </InputSelect>
                    </label>

                    <label>
                        <span>Archivo</span>
                        <InputFile OnChange="OnFileSelected" />
                    </label>
                </div>

                <label class="mlife-full">
                    <span>Descripción</span>
                    <InputTextArea @bind-Value="documentForm.Description" />
                </label>

                @if (selectedFile is not null)
                {
                    <div class="mobile-empty compact">Archivo seleccionado: @selectedFile.Name</div>
                }
            }

            <div class="mobile-doc-list">
                @foreach (var item in documents)
                {
                    <article class="mlife-doc-card">
                        <a href="@Api.ToApiUrl(item.DownloadUrl)" target="_blank">
                            <strong>@Show(item.FileName)</strong>
                            <span>@Show(item.DocumentType) · @SizeLabel(item.SizeBytes)</span>
                            <small>@DateLabel(item.UploadedAt) · @Show(item.UploadedBy)</small>
                        </a>

                        @if (editDocumentsMode && CanManageDocuments)
                        {
                            <button class="danger" type="button" @onclick="() => DeleteDocumentAsync(item)">Desactivar</button>
                        }
                    </article>
                }
            </div>
        </details>

        <details id="maintenance" class="mobile-fold mlife-section" open="@forceOpenMaintenanceSection">
            <summary>
                <span>Cronograma mantenimiento (@maintenance.Count)</span>

                <div class="mlife-summary-actions">
                    @if (CanManageMaintenance)
                    {
                        @if (editMaintenanceMode)
                        {
                            <button type="button" class="cancel" @onclick="CancelMaintenanceSection" @onclick:stopPropagation="true">Cancelar</button>
                            <button type="button" class="save" @onclick="SaveMaintenanceAsync" @onclick:stopPropagation="true" disabled="@isSaving">
                                @(isSaving ? "Guardando..." : "Guardar")
                            </button>
                        }
                        else
                        {
                            <button type="button" @onclick="BeginMaintenanceEdit" @onclick:stopPropagation="true">Editar</button>
                        }
                    }
                </div>
            </summary>

            @if (editMaintenanceMode)
            {
                <EditForm Model="maintenanceForm" OnValidSubmit="SaveMaintenanceAsync">
                    <div class="mlife-form-grid">
                        <label><span>Número</span><InputText @bind-Value="maintenanceForm.MaintenanceNumber" /></label>
                        <label><span>Fecha programada</span><InputDate @bind-Value="maintenanceForm.ScheduledAt" /></label>
                        <label>
                            <span>Tipo</span>
                            <InputSelect @bind-Value="maintenanceForm.Type">
                                <option value="Preventive">Preventivo</option>
                                <option value="Corrective">Correctivo</option>
                                <option value="Calibration">Calibración</option>
                                <option value="Inspection">Inspección</option>
                            </InputSelect>
                        </label>
                        <label>
                            <span>Estado</span>
                            <InputSelect @bind-Value="maintenanceForm.Status">
                                <option value="Scheduled">Programado</option>
                                <option value="InProgress">En proceso</option>
                                <option value="Completed">Completado</option>
                                <option value="Cancelled">Cancelado</option>
                            </InputSelect>
                        </label>
                        <label><span>Proveedor</span><InputText @bind-Value="maintenanceForm.Provider" /></label>
                        <label><span>Técnico</span><InputText @bind-Value="maintenanceForm.Technician" /></label>
                        <label><span>Factura</span><InputText @bind-Value="maintenanceForm.InvoiceNumber" /></label>
                        <label><span>Costo</span><InputNumber @bind-Value="maintenanceForm.Cost" /></label>
                    </div>

                    <label class="mlife-full"><span>Descripción</span><InputTextArea @bind-Value="maintenanceForm.Description" /></label>
                    <label class="mlife-full"><span>Actividades</span><InputTextArea @bind-Value="maintenanceForm.MaintenanceActivities" /></label>
                    <label class="mlife-full"><span>Resultado</span><InputTextArea @bind-Value="maintenanceForm.Result" /></label>
                </EditForm>
            }

            <div class="mobile-mini-list">
                @foreach (var item in maintenance)
                {
                    <article>
                        <strong>@Show(item.MaintenanceNumber) · @Show(item.Status)</strong>
                        <span>@DateLabel(item.ScheduledAt) · @Show(item.Provider) · @Show(item.Technician)</span>
                        <small>@Show(item.Description ?? item.MaintenanceActivities ?? item.Result)</small>

                        @if (editMaintenanceMode && CanManageMaintenance)
                        {
                            <div class="mlife-row-actions">
                                <button type="button" @onclick="() => StartMaintenanceEdit(item)">Editar este</button>
                                <button class="danger" type="button" @onclick="() => DeleteMaintenanceAsync(item)">Desactivar</button>
                            </div>
                        }
                    </article>
                }
            </div>
        </details>

        <details id="safe" class="mobile-fold mlife-section">
            <summary>
                <span>Prácticas seguras (@safePractices.Count)</span>

                <div class="mlife-summary-actions">
                    @if (CanManageSafePractices)
                    {
                        @if (editSafePracticesMode)
                        {
                            <button type="button" class="cancel" @onclick="CancelSafePracticesSection" @onclick:stopPropagation="true">Cancelar</button>
                            <button type="button" class="save" @onclick="SaveSafePracticeAsync" @onclick:stopPropagation="true" disabled="@isSaving">
                                @(isSaving ? "Guardando..." : "Guardar")
                            </button>
                        }
                        else
                        {
                            <button type="button" @onclick="BeginSafePracticesEdit" @onclick:stopPropagation="true">Editar</button>
                        }
                    }
                </div>
            </summary>

            @if (editSafePracticesMode)
            {
                <EditForm Model="safePracticeForm" OnValidSubmit="SaveSafePracticeAsync">
                    <div class="mlife-form-grid">
                        <label><span>Orden</span><InputNumber @bind-Value="safePracticeForm.SortOrder" /></label>
                        <label><span>Práctica</span><InputText @bind-Value="safePracticeForm.PracticeName" /></label>
                    </div>

                    <label class="mlife-full">
                        <span>Descripción</span>
                        <InputTextArea @bind-Value="safePracticeForm.Description" />
                    </label>

                    <button class="mlife-secondary inline" type="button" @onclick="CreateDefaultSafePracticesAsync" disabled="@isSaving">
                        Cargar predeterminadas
                    </button>
                </EditForm>
            }

            <div class="mobile-mini-list">
                @foreach (var item in safePractices)
                {
                    <article>
                        <strong>@item.SortOrder. @Show(item.PracticeName)</strong>
                        <span>@Show(item.Description)</span>

                        @if (editSafePracticesMode && CanManageSafePractices)
                        {
                            <div class="mlife-row-actions">
                                <button type="button" @onclick="() => StartSafePracticeEdit(item)">Editar este</button>
                                <button class="danger" type="button" @onclick="() => DeleteSafePracticeAsync(item)">Desactivar</button>
                            </div>
                        }
                    </article>
                }
            </div>
        </details>

        <details class="mobile-fold mlife-section">
            <summary>
                <span>Eventos de hoja de vida (@life.LifeCycleEvents.Count)</span>
            </summary>

            <div class="mobile-timeline compact">
                @foreach (var item in life.LifeCycleEvents.Take(20))
                {
                    <article>
                        <strong>@Show(item.Title)</strong>
                        <span>@Show(item.Description)</span>
                        <small>@DateTimeLabel(item.EventDate) · @Show(item.PerformedBy ?? item.CreatedBy)</small>
                    </article>
                }
            </div>
        </details>
    }
</section>

@code {
    private const long MaxFileSize = 50 * 1024 * 1024;

    [Parameter]
    public Guid ToolId { get; set; }

    [SupplyParameterFromQuery(Name = "from")]
    public string? From { get; set; }

    private bool isLoading = true;
    private bool isSaving;
    private string? message;

    private bool editInfoMode;
    private bool editTechnicalMode;
    private bool editAccessoriesMode;
    private bool editDocumentsMode;
    private bool editMaintenanceMode;
    private bool forceOpenMaintenanceSection;
    private bool editSafePracticesMode;

    private MobileTechnicalLifeRecordDto? life;
    private MobileToolDto? tool;

    private TechnicalEditModel technicalForm = new();
    private AccessoryForm accessoryForm = new();
    private DocumentForm documentForm = new() { DocumentType = "TechnicalDocument" };
    private MaintenanceForm maintenanceForm = new()
    {
        Type = "Preventive",
        Status = "Scheduled",
        ScheduledAt = DateTime.Today.AddDays(30),
        IsToolOperational = true
    };
    private SafePracticeForm safePracticeForm = new() { SortOrder = 1 };

    private Guid? editingAccessoryId;
    private Guid? editingMaintenanceId;
    private Guid? editingSafePracticeId;
    private IBrowserFile? selectedFile;

    private List<MobileAccessoryDto> accessories = new();
    private List<MobileDocumentDto> documents = new();
    private List<MobileMaintenanceScheduleDto> maintenance = new();
    private List<MobileSafePracticeDto> safePractices = new();

    private bool CanViewLifeRecord => Auth.HasAnyPermission("TechnicalLifeRecord.View", "ToolDetail.LifeRecord.Open");
    private bool CanEditTechnical => Auth.HasPermission("TechnicalLifeRecord.Edit") && CanManageThisTool;
    private bool CanManageAccessories => Auth.HasAnyPermission("TechnicalLifeRecord.Accessories", "TechnicalLifeRecord.Edit") && CanManageThisTool;
    private bool CanManageDocuments => Auth.HasAnyPermission("TechnicalLifeRecord.Documents", "Documents.Upload", "Documents.View") && CanManageThisTool;
    private bool CanManageMaintenance => Auth.HasAnyPermission("TechnicalLifeRecord.Maintenance", "Maintenance.Execute", "Maintenance.View") && CanManageThisTool;
    private bool CanManageSafePractices => Auth.HasAnyPermission("TechnicalLifeRecord.SafePractices", "SafePractices.Manage", "SafePractices.View") && CanManageThisTool;

    private bool HasAnyManagementPermission =>
        Auth.HasAnyPermission(
            "TechnicalLifeRecord.Edit",
            "TechnicalLifeRecord.Accessories",
