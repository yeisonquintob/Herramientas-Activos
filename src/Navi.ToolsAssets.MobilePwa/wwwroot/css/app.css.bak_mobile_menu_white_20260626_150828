:root {
    --navi-purple: #4b005c;
    --navi-purple-2: #7b0d8e;
    --navi-bg: #f6f1f8;
    --navi-card: #ffffff;
    --navi-text: #25112f;
    --navi-muted: #756a7f;
    --navi-border: #eadff0;
}

* {
    box-sizing: border-box;
}

html,
body {
    margin: 0;
    min-height: 100%;
    font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: var(--navi-bg);
    color: var(--navi-text);
}

a {
    color: inherit;
}

.mobile-shell {
    min-height: 100vh;
    background:
        radial-gradient(circle at top right, rgba(123, 13, 142, .22), transparent 34%),
        linear-gradient(180deg, #fbf7fc 0%, #f1e8f5 100%);
}

.mobile-main {
    min-height: 100vh;
    padding-bottom: 92px;
}

.mobile-page {
    width: min(560px, 100%);
    margin: 0 auto;
    padding: 1rem;
}

.mobile-login-page {
    min-height: 100vh;
    display: grid;
    align-content: center;
    gap: 1.2rem;
    padding: 1.25rem;
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.24), transparent 28%),
        linear-gradient(135deg, #16001d 0%, #4b005c 58%, #7b0d8e 100%);
    color: white;
}

.mobile-login-brand {
    text-align: center;
}

.mobile-brand-mark {
    width: 70px;
    height: 70px;
    margin: 0 auto .8rem;
    border-radius: 1.1rem;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #8f1bb1, #3b0048);
    color: #fff;
    font-size: 2.1rem;
    font-weight: 950;
    box-shadow: 0 1rem 2rem rgba(0,0,0,.25);
}

.mobile-login-brand h1,
.mobile-login-card h2,
.mobile-hero h1 {
    margin: 0;
    font-weight: 950;
    letter-spacing: -.04rem;
}

.mobile-login-brand p,
.mobile-login-card p,
.mobile-hero p {
    margin: .35rem 0 0;
    color: rgba(255,255,255,.78);
    font-weight: 700;
}

.mobile-login-card,
.mobile-form-card,
.mobile-panel,
.mobile-kpi-card,
.mobile-action-card,
.mobile-tool-card,
.mobile-empty,
.mobile-loading {
    background: var(--navi-card);
    border: 1px solid var(--navi-border);
    border-radius: 1.15rem;
    box-shadow: 0 1rem 2.4rem rgba(75, 0, 92, .10);
}

.mobile-login-card {
    color: var(--navi-text);
    padding: 1.25rem;
}

.mobile-login-card p {
    color: var(--navi-muted);
    margin-bottom: 1rem;
}

.mobile-pill {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: .2rem .62rem;
    border-radius: 999px;
    background: rgba(123, 13, 142, .10);
    color: var(--navi-purple);
    font-size: .68rem;
    font-weight: 950;
    letter-spacing: .05rem;
}

.mobile-login-page .mobile-pill {
    background: rgba(75, 0, 92, .10);
}

.mobile-login-card label,
.mobile-form-card label {
    display: block;
    color: #2f1938;
    font-size: .8rem;
    font-weight: 950;
    margin-top: .85rem;
}

.mobile-input,
.mobile-search {
    width: 100%;
    min-height: 46px;
    margin-top: .38rem;
    border: 1px solid #dfd4e7;
    border-radius: .75rem;
    padding: .7rem .85rem;
    background: #fff;
    color: var(--navi-text);
    font-size: .92rem;
    outline: none;
}

.mobile-input:focus,
.mobile-search:focus {
    border-color: var(--navi-purple-2);
    box-shadow: 0 0 0 .18rem rgba(123, 13, 142, .12);
}

.mobile-textarea {
    min-height: 130px;
    resize: vertical;
}

.mobile-primary-button {
    width: 100%;
    min-height: 48px;
    margin-top: 1rem;
    border: 0;
    border-radius: .85rem;
    background: linear-gradient(135deg, var(--navi-purple-2), var(--navi-purple));
    color: #fff;
    font-size: .93rem;
    font-weight: 950;
    box-shadow: 0 .8rem 1.5rem rgba(75, 0, 92, .22);
}

.mobile-primary-button:disabled {
    opacity: .7;
}

.mobile-alert,
.mobile-success {
    margin: .85rem 0;
    padding: .8rem .9rem;
    border-radius: .85rem;
    font-size: .82rem;
    font-weight: 850;
    line-height: 1.35;
}

.mobile-alert {
    color: #9f1239;
    background: #fff1f2;
    border: 1px solid #fecdd3;
}

.mobile-success {
    color: #166534;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
}

.mobile-hero {
    padding: 1.15rem;
    border-radius: 1.25rem;
    color: #fff;
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.18), transparent 34%),
        linear-gradient(135deg, #15001b 0%, #4b005c 58%, #7b0d8e 100%);
    box-shadow: 0 1rem 2.2rem rgba(75, 0, 92, .22);
}

.mobile-hero.compact {
    padding: 1rem;
}

.mobile-hero .mobile-pill {
    color: #fff;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.16);
    margin-bottom: .55rem;
}

.mobile-kpi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .65rem;
    margin: .85rem 0;
}

.mobile-kpi-card {
    padding: .85rem;
}

.mobile-kpi-card span {
    display: block;
    color: var(--navi-muted);
    font-size: .68rem;
    font-weight: 900;
}

.mobile-kpi-card strong {
    display: block;
    color: var(--navi-purple);
    font-size: 1.7rem;
    font-weight: 950;
    line-height: 1;
    margin: .35rem 0;
}

.mobile-kpi-card small {
    display: block;
    color: #8b8092;
    font-size: .65rem;
    font-weight: 700;
}

.mobile-kpi-card.warning strong {
    color: #b45309;
}

.mobile-kpi-card.ok strong {
    color: #15803d;
}

.mobile-action-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .75rem;
    margin: .85rem 0;
}

.mobile-action-card {
    border: 1px solid var(--navi-border);
    text-align: left;
    padding: 1rem;
    color: var(--navi-text);
}

.mobile-action-card span {
    display: inline-flex;
    padding: .2rem .55rem;
    border-radius: 999px;
    background: rgba(123, 13, 142, .10);
    color: var(--navi-purple);
    font-size: .68rem;
    font-weight: 950;
}

.mobile-action-card strong,
.mobile-tool-card strong,
.mobile-selected-tool strong {
    display: block;
    margin-top: .45rem;
    font-size: .95rem;
    font-weight: 950;
}

.mobile-action-card small,
.mobile-tool-card small {
    display: block;
    margin-top: .2rem;
    color: var(--navi-muted);
    font-size: .75rem;
    font-weight: 700;
}

.mobile-panel {
    padding: 1rem;
    margin-top: .9rem;
}

.mobile-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: .75rem;
    margin-bottom: .75rem;
}

.mobile-panel-head h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 950;
}

.mobile-panel-head button,
.mobile-tool-card button,
.mobile-card-actions button {
    border: 1px solid var(--navi-purple);
    background: #fff;
    color: var(--navi-purple);
    border-radius: .7rem;
    padding: .48rem .7rem;
    font-size: .72rem;
    font-weight: 950;
}

.mobile-tool-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: .75rem;
    padding: .85rem;
    margin-top: .65rem;
}

.mobile-tool-card.big {
    align-items: flex-start;
}

.mobile-tool-card span,
.mobile-selected-tool span {
    display: block;
    color: var(--navi-purple);
    font-size: .72rem;
    font-weight: 950;
}

.mobile-list {
    margin-top: .8rem;
}

.mobile-card-actions {
    display: grid;
    justify-items: end;
    gap: .55rem;
    min-width: 108px;
}

.mobile-status {
    display: inline-flex;
    padding: .25rem .55rem;
    border-radius: 999px;
    background: #fef3c7;
    color: #92400e;
    font-size: .65rem;
    font-style: normal;
    font-weight: 950;
}

.mobile-status.ok {
    background: #dcfce7;
    color: #166534;
}

.mobile-status.danger {
    background: #fee2e2;
    color: #991b1b;
}

.mobile-search {
    margin-top: .85rem;
}

.mobile-form-card {
    padding: 1rem;
    margin-top: .85rem;
}

.mobile-selected-tool {
    border: 1px solid var(--navi-border);
    background: #fbf7fc;
    border-radius: .85rem;
    padding: .85rem;
}

.mobile-check-row {
    display: flex !important;
    align-items: center;
    gap: .55rem;
}

.mobile-check-row input {
    width: 18px;
    height: 18px;
}

.mobile-empty,
.mobile-loading {
    padding: 1rem;
    text-align: center;
    color: var(--navi-muted);
    font-weight: 750;
}

.mobile-empty strong {
    display: block;
    color: var(--navi-text);
    font-weight: 950;
}

.mobile-empty span {
    display: block;
    margin-top: .25rem;
}

.mobile-empty.compact {
    box-shadow: none;
    background: #fbf7fc;
}

.mobile-bottom-nav {
    position: fixed;
    left: 50%;
    bottom: .75rem;
    transform: translateX(-50%);
    width: min(520px, calc(100% - 1.5rem));
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: .35rem;
    padding: .45rem;
    border-radius: 1.1rem;
    background: rgba(255,255,255,.94);
    border: 1px solid var(--navi-border);
    box-shadow: 0 1rem 2rem rgba(75,0,92,.18);
    backdrop-filter: blur(16px);
    z-index: 50;
}

.mobile-bottom-nav a,
.mobile-bottom-nav button {
    border: 0;
    background: transparent;
    text-decoration: none;
    display: grid;
    place-items: center;
    gap: .15rem;
    padding: .45rem .2rem;
    border-radius: .8rem;
    color: var(--navi-muted);
    font-family: inherit;
}

.mobile-bottom-nav a.active {
    background: linear-gradient(135deg, var(--navi-purple-2), var(--navi-purple));
    color: #fff;
}

.mobile-bottom-nav span {
    font-size: .62rem;
    font-weight: 950;
}

.mobile-bottom-nav strong {
    font-size: .68rem;
    font-weight: 950;
}

@media (max-width: 420px) {
    .mobile-kpi-grid {
        grid-template-columns: 1fr;
    }

    .mobile-action-grid {
        grid-template-columns: 1fr;
    }

    .mobile-tool-card {
        flex-direction: column;
        align-items: flex-start;
    }

    .mobile-card-actions {
        width: 100%;
        justify-items: stretch;
    }

    .mobile-card-actions button,
    .mobile-tool-card button {
        width: 100%;
    }
}

/* ============================================================
   Ajustes MVP móvil - navegación y cierre de sesión
   ============================================================ */

.mobile-hero-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .75rem;
    margin-bottom: .65rem;
}

.mobile-logout-button {
    border: 1px solid rgba(255,255,255,.55);
    background: rgba(255,255,255,.10);
    color: #ffffff;
    border-radius: 999px;
    padding: .42rem .7rem;
    font-size: .72rem;
    font-weight: 950;
}

.mobile-logout-button:active {
    transform: scale(.98);
}

.mobile-action-card {
    text-decoration: none;
    display: block;
}

.mobile-action-card:active {
    transform: scale(.985);
}

.mobile-mini-link {
    border: 1px solid var(--navi-purple);
    background: #fff;
    color: var(--navi-purple);
    border-radius: .7rem;
    padding: .48rem .7rem;
    font-size: .72rem;
    font-weight: 950;
    text-decoration: none;
    white-space: nowrap;
}

.mobile-bottom-nav {
    display: grid !important;
    visibility: visible !important;
}

.mobile-bottom-nav button {
    cursor: pointer;
}

/* ============================================================
   Detalle móvil / Hoja de vida AF
   ============================================================ */

.mobile-toolbar {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .7rem;
    margin: .85rem 0;
}

.mobile-primary-link,
.mobile-secondary-link,
.mobile-secondary-button {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: .85rem;
    font-size: .82rem;
    font-weight: 950;
    text-decoration: none;
    padding: .65rem .85rem;
}

.mobile-primary-link {
    background: linear-gradient(135deg, var(--navi-purple-2), var(--navi-purple));
    color: #ffffff;
    border: 1px solid var(--navi-purple);
}

.mobile-secondary-link,
.mobile-secondary-button {
    background: #ffffff;
    color: var(--navi-purple);
    border: 1px solid var(--navi-purple);
}

.mobile-detail-card {
    background: #ffffff;
    border: 1px solid var(--navi-border);
    border-radius: 1.15rem;
    box-shadow: 0 1rem 2.4rem rgba(75, 0, 92, .10);
    padding: 1rem;
    margin-top: .85rem;
}

.mobile-detail-card h2 {
    margin: 0 0 .8rem;
    color: var(--navi-text);
    font-size: 1rem;
    font-weight: 950;
    letter-spacing: -.02rem;
}

.mobile-detail-card-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: .75rem;
    margin-bottom: .85rem;
}

.mobile-detail-card-head span {
    color: var(--navi-muted);
    font-size: .75rem;
    font-weight: 900;
}

.mobile-detail-card-head strong {
    color: var(--navi-purple);
    font-size: .9rem;
    font-weight: 950;
    text-align: right;
}

.mobile-status-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .55rem;
}

.mobile-status-grid div {
    padding: .7rem;
    border-radius: .85rem;
    background: #fbf7fc;
    border: 1px solid var(--navi-border);
}

.mobile-status-grid span,
.mobile-detail-list span {
    display: block;
    color: var(--navi-muted);
    font-size: .68rem;
    font-weight: 900;
}

.mobile-status-grid strong,
.mobile-detail-list strong {
    display: block;
    margin-top: .25rem;
    color: var(--navi-text);
    font-size: .82rem;
    font-weight: 950;
    line-height: 1.25;
}

.mobile-detail-list {
    display: grid;
    gap: .55rem;
}

.mobile-detail-list div {
    padding: .72rem .8rem;
    border-radius: .85rem;
    background: #fbf7fc;
    border: 1px solid var(--navi-border);
}

.mobile-tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
}

.mobile-tag {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: .45rem .7rem;
    background: #f8fafc;
    color: #64748b;
    border: 1px solid #e2e8f0;
    font-size: .72rem;
    font-weight: 950;
}

.mobile-tag.active {
    background: #f3e8ff;
    color: var(--navi-purple);
    border-color: #e9d5ff;
}

.mobile-description {
    margin: 0;
    color: var(--navi-muted);
    font-size: .86rem;
    font-weight: 700;
    line-height: 1.45;
}

.mobile-tool-info {
    min-width: 0;
}

.mobile-mini-link.secondary {
    border-color: #6d28d9;
    color: #6d28d9;
}

.mobile-mini-link.danger {
    border-color: #be123c;
    color: #be123c;
}

@media (max-width: 420px) {
    .mobile-toolbar {
        grid-template-columns: 1fr;
    }

    .mobile-status-grid {
        grid-template-columns: 1fr;
    }
}

/* ============================================================
   Menú móvil por roles
   ============================================================ */

.mobile-menu-panel {
    background: #ffffff;
    border: 1px solid var(--navi-border);
    border-radius: 1.15rem;
    box-shadow: 0 1rem 2.4rem rgba(75, 0, 92, .10);
    padding: 1rem;
    margin-top: .9rem;
}

.mobile-menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .7rem;
}

.mobile-menu-card {
    min-height: 112px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: .32rem;
    text-decoration: none;
    text-align: center;
    border-radius: 1rem;
    padding: .8rem .55rem;
    background:
        radial-gradient(circle at top right, rgba(255,255,255,.18), transparent 36%),
        linear-gradient(135deg, #4b005c 0%, #7b0d8e 100%);
    color: #ffffff;
    box-shadow: 0 .85rem 1.6rem rgba(75, 0, 92, .22);
}

.mobile-menu-card span {
    width: 42px;
    height: 42px;
    margin: 0 auto .15rem;
    display: grid;
    place-items: center;
    border-radius: .8rem;
    background: rgba(255,255,255,.13);
    border: 1px solid rgba(255,255,255,.18);
    color: #ffffff;
    font-size: .72rem;
    font-weight: 950;
}

.mobile-menu-card strong {
    color: #ffffff;
    font-size: .78rem;
    font-weight: 950;
    line-height: 1.1;
}

.mobile-menu-card small {
    color: rgba(255,255,255,.76);
    font-size: .62rem;
    font-weight: 750;
    line-height: 1.15;
}

.mobile-menu-card:active {
    transform: scale(.985);
}

.mobile-panel-link {
    color: var(--navi-purple);
    font-size: .78rem;
    font-weight: 950;
    text-decoration: none;
}

.mobile-back-button {
    border: 1px solid rgba(255,255,255,.55);
    background: rgba(255,255,255,.10);
    color: #ffffff;
    border-radius: 999px;
    padding: .42rem .7rem;
    font-size: .72rem;
    font-weight: 950;
}

.mobile-back-button:active {
    transform: scale(.98);
}

.mobile-tool-card.big {
    display: grid;
    grid-template-columns: 1fr 96px;
    align-items: start;
}

.mobile-card-actions {
    display: grid;
    gap: .45rem;
}

.mobile-card-actions .mobile-mini-link {
    text-align: center;
}

@media (max-width: 420px) {
    .mobile-menu-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .mobile-tool-card.big {
        grid-template-columns: 1fr;
    }
}

/* ============================================================
   Desarrollo móvil: reducir banner rojo global de Blazor
   ============================================================ */

#blazor-error-ui {
    display: none !important;
}

.mobile-page {
    max-width: 560px;
}

.mobile-shell {
    overflow-x: hidden;
}

/* ============================================================
   Mobile Home Compact V3 - NAVI Herramientas y AF
   Referencia: menú móvil tipo cuadrícula corporativa
   ============================================================ */

.mobile-page-compact {
    width: min(448px, 100%);
    max-width: 448px;
    padding: .72rem;
    transform-origin: top center;
}

.mobile-hero-compact-pro {
    padding: .82rem .9rem !important;
    border-radius: 1.05rem !important;
    background:
        radial-gradient(circle at top right, rgba(173, 37, 189, .45), transparent 38%),
        linear-gradient(135deg, #09000d 0%, #25002f 43%, #7b0d8e 100%) !important;
    box-shadow: 0 .8rem 1.6rem rgba(25, 0, 31, .28) !important;
    min-height: auto !important;
}

.mobile-hero-compact-pro .mobile-hero-top {
    margin-bottom: .46rem !important;
}

.mobile-hero-compact-pro h1 {
    font-size: 1.33rem !important;
    line-height: 1.05 !important;
    letter-spacing: -.045rem !important;
    max-width: 285px;
}

.mobile-hero-compact-pro p {
    font-size: .78rem !important;
    line-height: 1.2 !important;
    margin-top: .28rem !important;
    color: rgba(255,255,255,.86) !important;
}

.mobile-pill-dark {
    padding: .18rem .5rem !important;
    font-size: .59rem !important;
    border-radius: 999px !important;
    background: rgba(255,255,255,.10) !important;
    border: 1px solid rgba(255,255,255,.24) !important;
    color: #fff !important;
}

.mobile-logout-compact {
    padding: .32rem .56rem !important;
    font-size: .61rem !important;
    min-height: 28px !important;
}

.mobile-kpi-grid-compact {
    grid-template-columns: repeat(3, 1fr) !important;
    gap: .48rem !important;
    margin: .62rem 0 !important;
}

.mobile-kpi-compact {
    padding: .58rem .52rem !important;
    border-radius: .85rem !important;
    min-height: 74px !important;
    box-shadow: 0 .55rem 1.1rem rgba(75, 0, 92, .08) !important;
}

.mobile-kpi-compact span {
    font-size: .58rem !important;
    line-height: 1.05 !important;
}

.mobile-kpi-compact strong {
    font-size: 1.28rem !important;
    margin: .22rem 0 .14rem !important;
    line-height: .95 !important;
}

.mobile-kpi-compact small {
    font-size: .54rem !important;
    line-height: 1.05 !important;
}

.mobile-menu-panel-compact {
    padding: .78rem !important;
    margin-top: .62rem !important;
    border-radius: 1.02rem !important;
    box-shadow: 0 .75rem 1.6rem rgba(75, 0, 92, .08) !important;
}

.mobile-panel-head-compact {
    margin-bottom: .55rem !important;
}

.mobile-panel-head-compact h2 {
    font-size: .9rem !important;
}

.mobile-panel-head-compact button,
.mobile-panel-head-compact .mobile-panel-link {
    min-height: 30px !important;
