@page "/asset-assignment-history"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
@inject NaviAccessScopeService AccessScope
@inject WebAuthSessionService AuthSession

<PageTitle>Historial de asignaciones - NAVI</PageTitle>

<PermissionGuard Permission="AssetAssignment.History" ModuleName="Historial de asignaciones">

<section class="history-hero history-hero-v2">
    <div>
        <span class="history-pill">HISTORIAL</span>
        <h2>Historial de asignaciones</h2>
        <p>Consulta herramientas asignadas por usuario, sede, estado, fecha de entrega, fecha de regreso y detalle del movimiento.</p>
    </div>

    <div class="history-hero-side history-hero-side-v2">
        <button class="btn btn-sm btn-outline-light" @onclick="LoadHistoryAsync">
            Actualizar
        </button>

        <button type="button" class="btn-history-back" @onclick="GoBackToAssignment">
            ← Regresar
        </button>
    </div>
</section>

<section class="history-kpis-v2">
    <article>
        <span>Mostrando</span>
        <strong>@FilteredHistory.Count()</strong>
        <small>Con filtros</small>
    </article>

    <article>
        <span>Total visible</span>
        <strong>@VisibleHistory.Count()</strong>
        <small>@ScopeLabel</small>
    </article>

    <article>
        <span>Sedes</span>
        <strong>@VisibleBranchCount</strong>
        <small>Alcance</small>
    </article>

    <article>
        <span>Usuario</span>
        <strong>@SelectedResponsibleLabel</strong>
        <small>Filtro actual</small>
    </article>
</section>

<section class="history-filter-panel history-filter-panel-v2">
    <div class="history-filter-grid-v2">
        <div>
            <label class="form-label">Usuario / Responsable</label>
            <select class="form-select form-select-sm" @bind="selectedResponsibleId">
                <option value="">Todos los usuarios</option>
                @foreach (var responsible in VisibleResponsibles)
                {
                    <option value="@responsible.Id">@responsible.FullName</option>
                }
            </select>
        </div>

        <div>
            <label class="form-label">Buscar</label>
            <input class="form-control form-control-sm"
                   placeholder="Código, herramienta, serial, detalle, usuario..."
                   @bind="search"
                   @bind:event="oninput" />
        </div>

        <div>
            <label class="form-label">Sede</label>
            @if (AccessScope.IsAllBranchScope() || AccessScope.IsAdminRole())
            {
                <select class="form-select form-select-sm" @bind="selectedBranchCode">
                    <option value="">Todas las sedes</option>
                    @foreach (var branch in BranchOptions)
                    {
                        <option value="@branch">@branch</option>
                    }
                </select>
            }
            else
            {
                <input class="form-control form-control-sm" value="@ScopeLabel" disabled />
            }
        </div>

        <div class="history-filter-actions">
            <button class="btn btn-primary btn-sm" @onclick="LoadHistoryAsync">
                Filtrar
            </button>

            <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilters">
                Limpiar
            </button>
        </div>
    </div>

    <div class="history-status-filter-v2">
        <div class="history-status-head-v2">
            <div>
                <strong>Estado</strong>
                <span>@SelectedStatusLabel</span>
            </div>

            <button type="button" @onclick="ClearStatusFilter">
                Limpiar estados
            </button>
        </div>

        <div class="history-status-chips-v2">
            @foreach (var status in StatusOptions)
            {
                var selected = selectedStatuses.Contains(status.Value);

                <button type="button"
                        class="@(selected ? "selected" : "")"
                        @onclick="() => ToggleStatus(status.Value)">
                    @status.Text
                </button>
            }
        </div>
    </div>
</section>

<section class="history-card history-card-v2">
    <div class="history-table-header history-table-header-v2">
        <div>
            <h3>Resultado del historial</h3>
            <p>Se muestran las asignaciones y regresos encontrados según usuario, sede, estado y texto de búsqueda.</p>
        </div>

        <div class="history-summary-pill-v2">
            @FilteredHistory.Count() de @VisibleHistory.Count()
        </div>
    </div>

    @if (isLoading)
    {
        <p>Cargando historial...</p>
    }
    else if (!FilteredHistory.Any())
    {
        <div class="alert alert-info">No hay movimientos para mostrar con los filtros actuales.</div>
    }
    else
    {
        <table class="table table-hover align-middle history-table">
            <thead>
                <tr>
                    <th>Código</th>
                    <th>Herramienta / Activo</th>
                    <th>Usuario actual</th>
                    <th>Sede / ubicación</th>
                    <th>Estado</th>
                    <th>Fecha entrega</th>
                    <th>Fecha regreso</th>
                    <th>Detalle</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in FilteredHistory)
                {
                    <tr>
                        <td><strong>@item.ToolInternalCode</strong></td>

                        <td>
                            <div>@item.ToolName</div>
                            <small class="text-muted">@Show(item.ToolSerialNumber)</small>
                        </td>

                        <td>@Show(item.CurrentResponsibleName)</td>

                        <td>
                            <div>@Show(item.CurrentBranchCode)</div>
                            <small class="text-muted">@Show(item.CurrentLocationName)</small>
                        </td>

                        <td>
                            <span class="@GetStatusBadge(item.CurrentStatus ?? string.Empty)">
                                @GetStatusLabel(item.CurrentStatus ?? string.Empty)
                            </span>
                        </td>

                        <td>@ShowDate(item.AssignedAt)</td>

                        <td>@ShowDate(item.ReturnedAt)</td>

                        <td>
                            <div>@Show(item.Detail)</div>

                            @if (!string.IsNullOrWhiteSpace(item.ReturnDetail))
                            {
                                <small class="text-muted">Regreso: @item.ReturnDetail</small>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

</PermissionGuard>

