    private async Task SubmitLoanRequestAsync()
    {
        if (!CanRequestLoan)
        {
            ShowError("No tienes permiso para solicitar préstamos.");
            return;
        }

        if (loanForm.ToolId is null)
        {
            ShowError("Debe seleccionar una herramienta para solicitar préstamo.");
            return;
        }

        var tool = selectedLoanTool;

        if (tool is null)
        {
            ShowError("No se encontró la herramienta seleccionada o no está dentro de tu sede.");
            return;
        }

        if (!IsToolAvailableForLoan(tool))
        {
            ShowError("La herramienta seleccionada ya no está disponible para préstamo. Actualiza la pantalla y selecciona una herramienta disponible.");
            return;
        }

        await RequestLoanForToolAsync(tool);
    }



    private async Task RequestLoanForToolAsync(MobileAvailabilityToolDto tool)
    {
        if (!CanRequestLoan)
        {
            ShowError("No tienes permiso para solicitar préstamos.");
            return;
        }

        if (!IsToolAvailableForLoan(tool))
        {
            ShowError("La herramienta seleccionada ya no está disponible para préstamo. Actualiza la pantalla y selecciona una herramienta disponible.");
            return;
        }

        if (!(Auth.CurrentUser?.ResponsiblePersonId.HasValue ?? false))
        {
            ShowError("Tu usuario no tiene solicitante operativo asociado. Edita el usuario y guarda nuevamente.");
            return;
        }

        if (string.IsNullOrWhiteSpace(tool.BranchCode))
        {
            ShowError("La herramienta no tiene sede asociada para generar la solicitud.");
            return;
        }

        try
        {
            isSaving = true;

            await Api.CreateLoanRequestAsync(new MobileLoanRequestCreateDto
            {
                BranchCode = tool.BranchCode!,
                RequestedByPersonId = Auth.CurrentUser?.ResponsiblePersonId,
                ToolInternalCodes = new[] { tool.InternalCode },
                ExpectedReturnAt = loanForm.ExpectedReturnAt ?? DateTime.Today.AddDays(7),
                DeliveryCondition = "Solicitud creada desde app móvil.",
                Notes = string.IsNullOrWhiteSpace(loanForm.Notes)
                    ? $"Solicitud de préstamo para {tool.InternalCode} - {tool.Name}."
                    : loanForm.Notes,
                RequestedBy = Auth.CurrentUser?.UserName
            });

            ShowSuccess("Solicitud de préstamo creada correctamente. Queda pendiente de aprobación.");
            ClearLoanRequest();

            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo crear la solicitud: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }



