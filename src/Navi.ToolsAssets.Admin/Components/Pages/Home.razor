    }

    .kpi-card.green { border-left-color: #198754; }
    .kpi-card.yellow { border-left-color: #ffc107; }
    .kpi-card.blue { border-left-color: #0d6efd; }
    .kpi-card.purple { border-left-color: #7b0d8e; }
    .kpi-card.cyan { border-left-color: #0dcaf0; }
    .kpi-card.orange { border-left-color: #fd7e14; }

    .kpi-card span {
