@page "/tools/{ToolId:guid}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Detalle herramienta - NAVI Herramientas</PageTitle>



@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">
        @successMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        <strong>Error:</strong> @errorMessage
    </div>
}
else if (isLoading && tool is null)
{
    <div class="alert alert-info">
        Cargando detalle de la herramienta...
    </div>
}
else if (tool is not null)
{
        <section class="detail-hero-banner">
        <div class="detail-hero-main">
            <div class="detail-hero-actions">
                <button class="btn-detail-back" @onclick="GoBack">
                    ← Volver al inventario
                </button>
            </div>

            <span class="detail-hero-pill">DETALLE DE ACTIVO FIJO</span>

            <h2>@tool!.Name</h2>

            <div class="detail-hero-code">
                @tool!.InternalCode
            </div>

            @if (!string.IsNullOrWhiteSpace(tool.Description))
            {
                <p>@tool!.Description</p>
            }
            else
            {
                <p>Consulta visual de datos maestros, ubicación, clasificación, estados y hoja de vida operativa.</p>
            }
        </div>

        <div class="detail-hero-side">
            <div class="detail-hero-status-card">
                <span>Estado operativo</span>
                <strong>@GetStatusLabel(tool.OperationalStatus)</strong>
            </div>

            <div class="detail-hero-badges">
                <span class="@GetStatusBadgeClass(tool.OperationalStatus)">
                    @GetStatusLabel(tool.OperationalStatus)
                </span>

                @if (tool.IsSpecialized)
                {
                    <span class="badge bg-primary">Especializada</span>
                }
                else
                {
                    <span class="badge bg-secondary">No especializada</span>
                }
            </div>

            <button class="btn btn-sm btn-outline-light detail-hero-refresh" @onclick="LoadAsync" disabled="@isLoading">
                @(isLoading ? "Actualizando..." : "Actualizar")
            </button>
        </div>
    </section>

    
    <section class="tool-detail-panel tool-admin-control">
        <div class="admin-control-header">
            <div>
                <h2>Control administrativo del activo</h2>
                <p>Permite editar datos maestros, guardar cambios, cancelar edición o anular el activo.</p>
            </div>

            <div class="admin-control-actions">
                @if (!isEditingMasterData)
                {
                    <button class="detail-action detail-action-primary" type="button" @onclick="StartMasterDataEdit">
                        Editar
                    </button>

                    <button class="detail-action detail-action-danger" type="button" @onclick="VoidCurrentToolAsync">
                        Anular activo
                    </button>
                }
                else
                {
                    <button class="detail-action detail-action-success" type="button" @onclick="SaveMasterDataAsync">
                        Guardar
                    </button>

                    <button class="detail-action detail-action-neutral" type="button" @onclick="CancelMasterDataEdit">
                        Cancelar
                    </button>

                    <button class="detail-action detail-action-danger" type="button" @onclick="VoidCurrentToolAsync">
                        Anular activo
                    </button>
                }
            </div>
        </div>

        @if (isEditingMasterData)
        {
            <div class="admin-edit-grid">
                <div>
                    <label>Código interno</label>
                    <input class="form-control" @bind="editModel.InternalCode" />
                </div>

                <div>
                    <label>Nombre</label>
                    <input class="form-control" @bind="editModel.Name" />
                </div>

                <div>
                    <label>Serial</label>
                    <input class="form-control" @bind="editModel.SerialNumber" />
                </div>

                <div>
                    <label>Activo fijo</label>
                    <input class="form-control" @bind="editModel.FixedAssetCode" />
                </div>

                <div>
                    <label>Código Fenix365</label>
                    <input class="form-control" @bind="editModel.FenixCode" />
                </div>

                <div>
                    <label>Marca</label>
                    <input class="form-control" @bind="editModel.Brand" />
                </div>

                <div>
                    <label>Modelo</label>
                    <input class="form-control" @bind="editModel.Model" />
                </div>

                <div>
                    <label>Estado operativo</label>
                    <select class="form-select" @bind="editModel.OperationalStatus">
                        <option value="Available">Disponible</option>
                        <option value="Assigned">Asignado</option>
                        <option value="Loaned">Prestado</option>
                        <option value="InMaintenance">En mantenimiento</option>
                        <option value="Damaged">Dañado</option>
                        <option value="NotSuitable">No apto</option>
                        <option value="PendingValidation">Pendiente validación</option>
                        <option value="Inconsistent">Inconsistente</option>
                        <option value="NotLocated">No localizado</option>
                        <option value="PendingDisposal">Pendiente baja</option>
                        <option value="Disposed">Dado de baja</option>
                    </select>
                </div>

                <div>
                    <label>Estado físico</label>
                    <select class="form-select" @bind="editModel.PhysicalStatus">
                        <option value="Good">Bueno</option>
                        <option value="Regular">Regular</option>
                        <option value="Damaged">Dañado</option>
                        <option value="Lost">Perdido</option>
                        <option value="Incomplete">Incompleto</option>
                    </select>
                </div>

                <div class="admin-check">
                    <input type="checkbox" class="form-check-input" @bind="editModel.IsSpecialized" />
                    <label>Activo especializado</label>
                </div>

                <div class="admin-check">
                    <input type="checkbox" class="form-check-input" @bind="editModel.RequiresMaintenance" />
                    <label>Requiere mantenimiento</label>
                </div>

                <div class="admin-check">
                    <input type="checkbox" class="form-check-input" @bind="editModel.RequiresPreOperationalCheck" />
                    <label>Requiere preoperacional</label>
                </div>

                <div class="admin-check">
                    <input type="checkbox" class="form-check-input" @bind="editModel.RequiresCertification" />
                    <label>Requiere certificación</label>
                </div>

                <div>
                    <label>Vence certificación</label>
                    <InputDate class="form-control" @bind-Value="editModel.CertificationExpirationDate" />
                </div>

                <div>
                    <label>Periodo mantenimiento meses</label>
                    <input type="number" class="form-control" @bind="editModel.MaintenancePeriodMonths" min="0" />
                </div>

                <div class="admin-edit-full">
                    <label>Descripción / observación</label>
                    <textarea class="form-control" rows="3" @bind="editModel.Description"></textarea>
                </div>
            </div>
        }
        else
        {
            <div class="admin-readonly-note">
                <strong>Modo lectura.</strong> Presiona <b>Editar</b> para modificar datos del activo. Usa <b>Anular activo</b> solo si el activo no debe permanecer en Inventario de AF.
            </div>
        }
    </section>


    @if (reportedSource?.HasSource == true)
