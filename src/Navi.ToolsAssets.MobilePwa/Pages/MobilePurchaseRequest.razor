@page "/mobile/purchases"

@using System.Text.Json
@using System.Net.Http
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Navi.ToolsAssets.MobilePwa.Models

@inject NaviMobileApiClient Api
@inject MobileAuthSessionService Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Solicitud de compra móvil - NAVI Herramientas y AF</PageTitle>

<section class="mobile-page navi-mobile-purchase-request-v1">
    @if (isLoading && !initialized)
    {
        <div class="mobile-loading">Cargando solicitud de compra...</div>
    }
    else if (!Auth.IsAuthenticated)
    {
        <div class="mobile-empty">
            <strong>Sesión requerida</strong>
            <span>Debes iniciar sesión para continuar.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoLogin">Ir al login</button>
        </div>
    }
    else if (!CanAccessModule)
    {
        <div class="mobile-empty">
            <strong>Sin permiso</strong>
            <span>No tienes permisos para visualizar solicitud de compra.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoHome">Volver al inicio</button>
        </div>
    }
    else
    {
        <header class="mpur-hero">
            <div>
                <span>COMPRA AF</span>
                <h1>Solicitud de compra</h1>
                <p>@Display(Auth.CurrentUser?.DisplayName) · @ScopeLabel</p>
            </div>

            <div class="mpur-hero-actions">
                <button type="button" @onclick="GoHome">Inicio</button>
                <button type="button" @onclick="RefreshAsync" disabled="@isLoading">
                    @(isLoading ? "Cargando..." : "Actualizar")
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="mobile-alert success">@successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="mobile-alert error">@errorMessage</div>
        }

        <section class="mpur-kpis">
            <article>
                <span>Locales</span>
                <strong>@LocalVisibleRequests.Count()</strong>
                <small>Borrador / cotización</small>
            </article>

            <article>
                <span>Generadas</span>
                <strong>@FilteredRegistered.Count()</strong>
                <small>API</small>
            </article>

            <article>
                <span>Pendientes</span>
                <strong>@FilteredRegistered.Count(x => IsOpenStatus(x.Status))</strong>
                <small>Proceso</small>
            </article>

            <article>
                <span>Permiso</span>
                <strong>@PermissionMode</strong>
                <small>Matriz</small>
            </article>
        </section>

        <section class="mpur-filter-card">
            <label>
                <span>Buscar</span>
                <input value="@searchText"
                       @oninput="OnSearchChanged"
                       placeholder="Número, activo, herramienta, solicitante, sede..." />
            </label>

            @if (UserCanSeeAllBranches())
            {
                <label>
                    <span>Sede</span>
                    <select value="@selectedBranchCode" @onchange="OnBranchFilterChanged">
                        <option value="">Todas las sedes</option>
                        @foreach (var branch in VisibleBranches)
                        {
                            <option value="@branch.Code">@branch.Code - @branch.Name</option>
                        }
                    </select>
                </label>
            }
            else
            {
                <label>
                    <span>Sede</span>
                    <input value="@ScopeLabel" disabled />
                </label>
            }

            <div class="mpur-filter-actions">
                <button type="button" @onclick="ClearTopFilters">Limpiar búsqueda</button>
            </div>
        </section>

        @if (CanCreateOrConfirmRequest)
        {
            <details class="mpur-card" open>
                <summary>
                    <span>Nueva solicitud y activos solicitados</span>
                    <em>@RequestVisualState</em>
                </summary>

                @if (!CanEditRequest)
                {
                    <div class="mpur-locked">
                        La solicitud solo se puede modificar cuando está nueva o en borrador.
                    </div>
                }

                <div class="mpur-form-grid">
                    <label>
                        <span>Nombre de la solicitud</span>
                        <InputText @bind-Value="header.RequestName" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Sede</span>
                        <InputSelect @bind-Value="header.BranchIdText" disabled="@(!CanEditRequest)">
                            <option value="">Seleccione sede</option>
                            @foreach (var branch in VisibleBranches)
                            {
                                <option value="@branch.Id">@branch.Code - @branch.Name</option>
                            }
                        </InputSelect>
                    </label>

                    <label>
                        <span>Solicitante</span>
                        <InputText @bind-Value="header.RequestedBy" disabled />
                    </label>

                    <label>
                        <span>Responsable que aprueba</span>
                        <InputText @bind-Value="header.Approver" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Tipo de compra</span>
                        <InputSelect @bind-Value="header.PurchasePurpose" disabled="@(!CanEditRequest)">
                            <option value="SPC">SPC</option>
                            <option value="Activo fijo">Activo fijo</option>
                            <option value="Herramienta">Herramienta</option>
                            <option value="Equipo">Equipo</option>
                            <option value="Kit de herramientas">Kit de herramientas</option>
                            <option value="Reposición">Reposición</option>
                            <option value="Dotación">Dotación</option>
                            <option value="Emergencia">Emergencia</option>
                        </InputSelect>
                    </label>

                    <label>
                        <span>Prioridad</span>
                        <InputSelect @bind-Value="header.Priority" disabled="@(!CanEditRequest)">
                            <option value="Baja">Baja</option>
                            <option value="Media">Media</option>
                            <option value="Alta">Alta</option>
                            <option value="Crítica">Crítica</option>
                        </InputSelect>
                    </label>

                    <label>
                        <span>Fecha requerida</span>
                        <InputDate @bind-Value="header.RequiredAt" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Área / centro de costo</span>
                        <InputText @bind-Value="header.AreaOrCostCenter" disabled="@(!CanEditRequest)" />
                    </label>
                </div>

                <label class="mpur-full">
                    <span>Justificación general de la compra</span>
                    <InputTextArea @bind-Value="header.Justification" disabled="@(!CanEditRequest)" />
                </label>

                <div class="mpur-subsection-title">
                    <strong>Activos / herramientas solicitadas</strong>
                    <span>Agrega los activos, cantidades y especificaciones requeridas.</span>
                </div>

                <div class="mpur-form-grid">
                    <label>
                        <span>Imagen / referencia visual</span>
                        <InputFile OnChange="OnImageSelected" accept="image/*" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Código / referencia</span>
                        <InputText @bind-Value="lineForm.ItemCode" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Nombre del activo / herramienta</span>
                        <InputText @bind-Value="lineForm.ItemName" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Cantidad</span>
                        <InputNumber @bind-Value="lineForm.Quantity" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Unidad</span>
                        <InputText @bind-Value="lineForm.Unit" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Tipo / categoría</span>
                        <InputSelect @bind-Value="lineForm.Category" disabled="@(!CanEditRequest)">
                            <option value="Herramienta">Herramienta</option>
                            <option value="Activo fijo">Activo fijo</option>
                            <option value="Equipo">Equipo</option>
                            <option value="Repuesto">Repuesto</option>
                            <option value="Accesorio">Accesorio</option>
                            <option value="Consumible">Consumible</option>
                        </InputSelect>
                    </label>
                </div>

                @if (!string.IsNullOrWhiteSpace(lineForm.ImagePreview))
                {
                    <img class="mpur-photo-preview" src="@lineForm.ImagePreview" alt="Referencia visual" />
                }

                <label class="mpur-full">
                    <span>Descripción técnica</span>
                    <InputTextArea @bind-Value="lineForm.ItemDescription" disabled="@(!CanEditRequest)" />
                </label>

                <label class="mpur-full">
                    <span>Observación / necesidad</span>
                    <InputTextArea @bind-Value="lineForm.NeedDetail" disabled="@(!CanEditRequest)" />
                </label>

                <div class="mpur-action-row">
                    <button type="button" class="primary" @onclick="AddLine" disabled="@(!CanEditRequest)">
                        @(editingLineId.HasValue ? "Actualizar activo" : "Agregar activo")
                    </button>

                    <button type="button" @onclick="ClearLine">
                        Limpiar línea
                    </button>
                </div>

                @if (!currentLines.Any())
                {
                    <div class="mobile-empty compact">No hay activos agregados.</div>
                }
                else
                {
                    <div class="mpur-list">
                        @foreach (var item in currentLines)
                        {
                            <article>
                                <div>
                                    <strong>@item.ItemName</strong>
                                    <span>@Display(item.ItemCode)</span>
                                    <small>Cantidad: @item.Quantity @Display(item.Unit) · @item.Category</small>
                                    <small>@Display(item.ItemDescription)</small>
                                    <small>@Display(item.NeedDetail)</small>

                                    @if (!string.IsNullOrWhiteSpace(item.ImagePreview))
                                    {
                                        <img class="mpur-thumb" src="@item.ImagePreview" alt="Referencia" />
                                    }
                                </div>

                                <div class="mpur-row-actions">
                                    <label>
                                        <InputCheckbox @bind-Value="item.Selected" disabled="@(!CanEditRequest)" />
                                        Usar
                                    </label>

                                    <button type="button" @onclick="() => EditLine(item.Id)" disabled="@(!CanEditRequest)">Editar</button>
                                    <button type="button" class="danger" @onclick="() => RemoveLine(item.Id)" disabled="@(!CanEditRequest)">Quitar</button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </details>

            <details class="mpur-card" open>
                <summary>
                    <span>Estado y confirmación de la solicitud</span>
                    <em>@RequestVisualState</em>
                </summary>

                <div class="mpur-state-box">
                    <span>Condiciones</span>
                    <strong>@RequestConditionText</strong>
                </div>

                <div class="mpur-action-row">
                    <button type="button" @onclick="SaveDraftAsync" disabled="@(!CanSaveAsDraft)">
                        Guardar borrador
                    </button>

                    <button type="button" class="primary" @onclick="ConfirmRequestAsync" disabled="@(!CanConfirmRequest)">
                        Confirmar solicitud
                    </button>

                    <button type="button" class="danger" @onclick="NewRequest">
                        Nueva
                    </button>
                </div>
            </details>
        }

        @if (CanRegisterQuotation)
        {
            <details class="mpur-card" open="@CanQuote">
                <summary>
                    <span>Cotización de compra</span>
                    <em>@(CanQuote ? "Habilitada" : "Bloqueada")</em>
                </summary>

                @if (!CanQuote)
                {
                    <div class="mpur-locked">
                        Selecciona abajo una solicitud confirmada y presiona <strong>Realizar cotización</strong>.
                    </div>
                }

                <div class="mpur-quote-head">
                    <div>
                        <span>Solicitud</span>
                        <strong>@Display(header.RequestName)</strong>
                    </div>

                    <div>
                        <span>Sede</span>
                        <strong>@SelectedBranchLabel</strong>
                    </div>

                    <div>
                        <span>Estado</span>
                        <strong>@RequestVisualState</strong>
                    </div>
                </div>

                <div class="mpur-form-grid">
                    <label>
                        <span>Proveedor</span>
                        <InputText @bind-Value="quoteForm.Provider" disabled="@(!CanQuote)" />
                    </label>

                    <label>
                        <span>Activo cotizado</span>
                        <InputSelect @bind-Value="quoteForm.LineIdText" disabled="@(!CanQuote)">
                            <option value="">Toda la solicitud / kit</option>
                            @foreach (var line in currentLines)
                            {
                                <option value="@line.Id">@line.ItemName</option>
                            }
                        </InputSelect>
                    </label>

                    <label>
                        <span>Fecha cotización</span>
                        <InputDate @bind-Value="quoteForm.QuotationDate" disabled="@(!CanQuote)" />
                    </label>

                    <label>
                        <span>Tiempo entrega</span>
                        <InputText @bind-Value="quoteForm.DeliveryTime" disabled="@(!CanQuote)" />
                    </label>

                    <label>
                        <span>Precio antes de IVA</span>
                        <InputNumber @bind-Value="quoteForm.PriceBeforeVat" disabled="@(!CanQuote)" />
                    </label>
                </div>

                <label class="mpur-full">
                    <span>Detalles adicionales de cotización</span>
                    <InputTextArea @bind-Value="quoteForm.AdditionalDetails" disabled="@(!CanQuote)" />
                </label>

                <div class="mpur-action-row">
                    <button type="button" class="primary" @onclick="AddQuotationAsync" disabled="@(!CanQuote)">
                        @(editingQuoteId.HasValue ? "Actualizar cotización" : "Agregar cotización")
                    </button>

                    <button type="button" @onclick="ClearQuotation">
                        Limpiar cotización
                    </button>
                </div>

                @if (!currentQuotes.Any())
                {
                    <div class="mobile-empty compact">No hay cotizaciones agregadas.</div>
                }
                else
                {
                    <div class="mpur-list">
                        @foreach (var quote in currentQuotes)
                        {
                            <article>
                                <div>
                                    <strong>@quote.Provider</strong>
                                    <span>@GetLineName(quote.LineId)</span>
                                    <small>@DateLabel(quote.QuotationDate) · @Display(quote.DeliveryTime)</small>
                                    <small>@MoneyLabel(quote.PriceBeforeVat)</small>
                                    <small>@Display(quote.AdditionalDetails)</small>
                                </div>

                                <div class="mpur-row-actions">
                                    <label>
                                        <InputCheckbox @bind-Value="quote.Selected" disabled="@(!CanQuote)" />
                                        Usar
                                    </label>

                                    <button type="button" @onclick="() => EditQuotation(quote.Id)" disabled="@(!CanQuote)">Editar</button>
                                    <button type="button" class="danger" @onclick="() => RemoveQuotationAsync(quote.Id)" disabled="@(!CanQuote)">Quitar</button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </details>
        }

        @if (CanGenerateFinalRequest)
        {
            <details class="mpur-card" open>
                <summary>
                    <span>Generar compra</span>
                    <em>@SelectedQuotes.Count() cotización(es)</em>
                </summary>

                <div class="mpur-summary-grid">
                    <article>
                        <span>Activos seleccionados</span>
                        <strong>@SelectedLines.Count()</strong>
                    </article>

                    <article>
                        <span>Cotizaciones seleccionadas</span>
                        <strong>@SelectedQuotes.Count()</strong>
                    </article>

                    <article>
                        <span>Total antes de IVA</span>
                        <strong>@MoneyLabel(SelectedQuotes.Sum(x => x.PriceBeforeVat ?? 0))</strong>
                    </article>
                </div>

                @if (!CanGenerateRequest)
                {
                    <div class="mpur-locked">
                        Para generar debes tener una solicitud en cotización y mínimo una cotización seleccionada.
                    </div>
                }

                <button type="button" class="mpur-generate" @onclick="GenerateAsync" disabled="@(!CanGenerateRequest || isSaving)">
                    @(isSaving ? "Generando..." : "Generar solicitud de compra")
                </button>
            </details>
        }

        <details class="mpur-card" open>
            <summary>
                <span>Solicitudes realizadas</span>
                <em>@(LocalVisibleRequests.Count() + FilteredRegistered.Count())</em>
            </summary>

            <section class="mpur-bottom-filter">
                <label>
                    <span>Estado</span>
                    <select value="@selectedBottomStatus" @onchange="OnBottomStatusChanged">
                        <option value="">Todos los estados</option>
                        @foreach (var status in BottomStatusOptions)
                        {
                            <option value="@status.Value">@status.Text</option>
                        }
                    </select>
                </label>

                <button type="button" @onclick="ClearBottomStatus">
                    Limpiar estado
                </button>
            </section>

            @if (!LocalVisibleRequests.Any() && !FilteredRegistered.Any())
            {
                <div class="mobile-empty compact">No hay solicitudes realizadas para los filtros actuales.</div>
            }
            else
            {
                <div class="mpur-list">
                    @foreach (var item in LocalVisibleRequests)
                    {
                        <article class="@GetStoredRowClass(item)">
                            <div>
                                <strong>@item.LocalNumber</strong>
                                <span>@Display(item.Header.RequestName)</span>
                                <small>@Display(item.Header.PurchasePurpose) · @Display(item.Header.Priority)</small>
                                <small>@GetStoredStatusLabel(item.Status) · @DateTimeLabel(item.UpdatedAt)</small>
                                <small>Activos: @item.Lines.Count · Cotizaciones: @item.Quotations.Count</small>
                            </div>

                            <div class="mpur-row-actions">
                                @if (item.Status == LocalStatusDraft && CanCreateOrConfirmRequest)
                                {
                                    <button type="button" @onclick="() => LoadDraftForEdit(item.Id)">Editar</button>
                                    <button type="button" class="primary" @onclick="() => ConfirmStoredRequestAsync(item.Id)">Confirmar</button>
                                }
                                else if (item.Status == LocalStatusConfirmed && CanRegisterQuotation)
                                {
                                    <button type="button" class="warning" @onclick="() => StartQuotationAsync(item.Id)">Realizar cotización</button>
                                }
                                else if (item.Status == LocalStatusQuoting && CanRegisterQuotation)
                                {
                                    <button type="button" class="warning" @onclick="() => ContinueQuotation(item.Id)">Continuar cotización</button>
                                }

                                <button type="button" class="danger" @onclick="() => DeleteLocalRequestAsync(item.Id)">Eliminar</button>
                            </div>
                        </article>
                    }

                    @if (CanViewGeneratedRequests)
                    {
                        @foreach (var item in FilteredRegistered.Take(80))
                        {
                            <article>
                                <div>
                                    <strong>@item.RequestNumber</strong>
                                    <span>@item.Title</span>
                                    <small>@Display(item.BranchCode) · @Display(item.Priority) · @StatusLabel(item.Status)</small>
                                    <small>@Display(item.RequestedBy) · @DateTimeLabel(item.CreatedAt)</small>
                                </div>

                                <div class="mpur-row-actions">
                                    @if (CanApproveRequest && item.Status == "InReview")
                                    {
                                        <button type="button" class="approve" @onclick="() => ApproveAsync(item)">Aprobar</button>
                                    }

                                    @if (CanRejectRequest && item.Status == "InReview")
                                    {
                                        <button type="button" class="danger" @onclick="() => RejectAsync(item)">Rechazar</button>
                                    }

                                    @if (CanApproveRequest && item.Status == "Approved")
                                    {
                                        <button type="button" class="primary" @onclick="() => ClosePurchaseAsync(item)">Cerrar</button>
                                    }
                                </div>
                            </article>
                        }
                    }
                </div>
            }
        </details>
    }
</section>

@code {
    private const string LocalStatusDraft = "Draft";
    private const string LocalStatusConfirmed = "Confirmed";
    private const string LocalStatusQuoting = "Quoting";

    private readonly JsonSerializerOptions jsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = false
    };

    private bool initialized;
    private bool isLoading = true;
    private bool isSaving;
    private string? successMessage;
    private string? errorMessage;

    private string searchText = string.Empty;
    private string selectedBranchCode = string.Empty;
    private string selectedBottomStatus = string.Empty;

    private readonly PurchaseHeader header = new();
    private readonly PurchaseLineForm lineForm = new();
    private readonly QuotationForm quoteForm = new();

    private List<PurchaseLineItem> currentLines = new();
    private List<QuotationItem> currentQuotes = new();
    private List<StoredPurchaseRequest> storedRequests = new();
    private List<ApiPurchaseItem> registeredItems = new();
    private List<MobileBranchDto> branches = new();

    private Guid? activeStoredRequestId;
    private Guid? editingLineId;
    private Guid? editingQuoteId;

    private string currentStatus = "New";

    private bool CanViewGeneratedRequests =>
        HasAny("Purchases.View", "Purchases.Request", "Purchases.Quote", "Purchases.Generate", "Purchases.Approve", "Purchases.Reject");

    private bool CanCreateOrConfirmRequest => Has("Purchases.Request");
    private bool CanRegisterQuotation => Has("Purchases.Quote");
    private bool CanGenerateFinalRequest => Has("Purchases.Generate");
    private bool CanApproveRequest => Has("Purchases.Approve");
    private bool CanRejectRequest => Has("Purchases.Reject");

    private bool CanAccessModule =>
        HasAny("Purchases.View", "Purchases.Request", "Purchases.Quote", "Purchases.Generate", "Purchases.Approve", "Purchases.Reject");

    private bool CanEditRequest => CanCreateOrConfirmRequest && (currentStatus == "New" || currentStatus == LocalStatusDraft);
    private bool CanSaveAsDraft => CanEditRequest && SelectedLines.Any();
    private bool CanConfirmRequest => CanEditRequest && SelectedLines.Any();
    private bool CanQuote => CanRegisterQuotation && currentStatus == LocalStatusQuoting && activeStoredRequestId.HasValue;
    private bool CanGenerateRequest => CanGenerateFinalRequest && CanQuote && SelectedLines.Any() && SelectedQuotes.Any();

    private IEnumerable<PurchaseLineItem> SelectedLines => currentLines.Where(x => x.Selected);
    private IEnumerable<QuotationItem> SelectedQuotes => currentQuotes.Where(x => x.Selected);

    private IEnumerable<MobileBranchDto> VisibleBranches =>
        branches
            .Where(IsVisibleBranch)
            .OrderBy(x => x.Code);

    private IEnumerable<StoredPurchaseRequest> LocalVisibleRequests =>
        storedRequests
            .Where(MatchesLocalScope)
            .Where(MatchesLocalSearch)
            .Where(MatchesBottomStatus)
            .OrderByDescending(x => x.UpdatedAt);

    private IEnumerable<ApiPurchaseItem> FilteredRegistered =>
        registeredItems
            .Where(MatchesApiScope)
            .Where(MatchesApiSearch)
            .Where(MatchesApiBottomStatus)
            .OrderByDescending(x => x.CreatedAt);

    private string ScopeLabel =>
        UserCanSeeAllBranches()
            ? "Todas las sedes"
            : Display(Auth.CurrentUser?.BranchName ?? Auth.CurrentUser?.BranchCode);

    private string PermissionMode
    {
        get
        {
            if (CanGenerateFinalRequest)
            {
                return "Genera";
            }

            if (CanRegisterQuotation)
            {
                return "Cotiza";
            }

            if (CanCreateOrConfirmRequest)
            {
                return "Solicita";
            }

            if (CanViewGeneratedRequests)
            {
                return "Consulta";
            }

            return "Sin permiso";
        }
    }

    private string RequestVisualState => currentStatus switch
    {
        LocalStatusDraft => "Borrador",
        LocalStatusConfirmed => "Confirmada",
        LocalStatusQuoting => "Cotizando",
        _ => "Nueva"
    };

    private string RequestConditionText
    {
        get
        {
            if (!SelectedLines.Any())
            {
                return "Agrega y selecciona mínimo un activo o herramienta.";
            }

            if (string.IsNullOrWhiteSpace(header.BranchIdText))
            {
                return "Selecciona la sede.";
            }

            return "Lista para guardar o confirmar.";
        }
    }

    private string SelectedBranchLabel
    {
        get
        {
            var branch = BranchByIdText(header.BranchIdText);
            return branch is null ? "Sin sede" : $"{branch.Code} - {branch.Name}";
        }
    }

    private readonly (string Value, string Text)[] BottomStatusOptions =
    {
        ("Draft", "Borrador"),
        ("Confirmed", "Confirmada / pendiente por cotizar"),
        ("Quoting", "Cotizando"),
        ("InReview", "En revisión"),
        ("Approved", "Aprobada"),
        ("Closed", "Cerrada"),
        ("Rejected", "Rechazada"),
        ("Canceled", "Cancelada")
    };

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsAuthenticated)
        {
            isLoading = false;
            return;
        }

        var refreshedUser = await Api.RefreshCurrentSessionAsync();

        if (refreshedUser is null || !Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        ResetHeaderDefaults();
        await LoadStaticAsync();
        await RefreshAsync();

        initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadLocalStateAsync();
        StateHasChanged();
    }

    private async Task LoadStaticAsync()
    {
        try
        {
            branches = await Api.GetBranchesAsync();
        }
        catch
        {
            branches = new();
        }
    }

    private async Task RefreshAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            if (CanViewGeneratedRequests)
            {
                var data = await Api.GetListJsonAsync<PurchaseRequestItem>("api/purchase-requests");

                registeredItems = data.Select(x => new ApiPurchaseItem
                {
                    Id = x.Id,
                    RequestNumber = x.RequestNumber,
                    Title = x.ItemName,
                    Priority = x.Priority,
                    Status = x.Status,
                    BranchId = x.BranchId,
                    BranchCode = x.BranchCode,
                    BranchName = x.BranchName,
                    RequestedBy = x.RequestedByResponsiblePersonName ?? x.RequestedByUserName,
                    CreatedAt = x.CreatedAt
                }).ToList();
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudieron cargar las solicitudes de compra: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetHeaderDefaults()
    {
        header.RequestedBy = Display(Auth.CurrentUser?.DisplayName ?? Auth.CurrentUser?.UserName);
        header.Priority = "Media";
        header.PurchasePurpose = "SPC";
        header.RequiredAt = DateTime.Today.AddDays(7);

        if (Auth.CurrentUser?.BranchId is Guid branchId)
        {
            header.BranchIdText = branchId.ToString();
        }
