        {
            branches = await Api.GetBranchesAsync();
        }
        catch
        {
            branches = new();
        }
    }

    private async Task RefreshAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            if (CanViewGeneratedRequests)
            {
                if (IsPurchase)
                {
                    var data = await Api.GetListJsonAsync<PurchaseRequestItem>("api/purchase-requests");
                    registeredItems = data.Select(x => new ApiRegisteredItem
                    {
                        Id = x.Id,
                        RequestNumber = x.RequestNumber,
                        Title = x.ItemName,
                        Type = "Compra",
                        Priority = x.Priority,
                        Status = x.Status,
                        BranchId = x.BranchId,
                        BranchCode = x.BranchCode,
                        BranchName = x.BranchName,
                        RequestedBy = x.RequestedByResponsiblePersonName ?? x.RequestedByUserName,
                        CreatedAt = x.CreatedAt
                    }).ToList();
                }
                else
                {
                    var data = await Api.GetListJsonAsync<MaintenanceRequestItem>("api/maintenance-requests");
                    registeredItems = data.Select(x => new ApiRegisteredItem
                    {
                        Id = x.Id,
                        RequestNumber = x.RequestNumber,
                        Title = x.Title,
                        Type = x.RequestType,
                        Priority = x.Priority,
                        Status = x.Status,
                        BranchId = x.BranchId,
                        BranchCode = x.BranchCode,
                        BranchName = x.BranchName,
                        RequestedBy = x.RequestedByResponsiblePersonName ?? x.RequestedByUserName,
                        CreatedAt = x.CreatedAt
                    }).ToList();
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudieron cargar las solicitudes: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ResetHeaderDefaults()
    {
        header.RequestedBy = Display(Auth.CurrentUser?.DisplayName ?? Auth.CurrentUser?.UserName);
        header.Priority = "Media";
        header.RequestType = IsPurchase ? "SPC" : "Correctivo";
        header.RequiredAt = DateTime.Today.AddDays(7);

        if (Auth.CurrentUser?.BranchId is Guid branchId)
        {
            header.BranchIdText = branchId.ToString();
        }
    }

    private async Task LoadLocalStateAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);
            storedRequests = string.IsNullOrWhiteSpace(json)
                ? new()
                : JsonSerializer.Deserialize<List<StoredRequest>>(json, jsonOptions) ?? new();
        }
        catch
        {
            storedRequests = new();
        }
    }

    private async Task SaveLocalStateAsync()
    {
        var json = JsonSerializer.Serialize(storedRequests, jsonOptions);
        await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, json);
    }

    private void AddLine()
    {
        successMessage = null;
        errorMessage = null;

        if (!CanEditRequest)
        {
            errorMessage = "Solo puedes modificar líneas cuando la solicitud está nueva o en borrador.";
            return;
        }

        if (string.IsNullOrWhiteSpace(lineForm.ToolName))
        {
            errorMessage = "Debes indicar herramienta, equipo o repuesto.";
            return;
        }

        if (editingLineId.HasValue)
        {
            var existing = currentLines.FirstOrDefault(x => x.Id == editingLineId.Value);

            if (existing is not null)
            {
                existing.ToolName = lineForm.ToolName.Trim();
                existing.TechnicalOrSerial = lineForm.TechnicalOrSerial?.Trim();
                existing.Quantity = lineForm.Quantity <= 0 ? 1 : lineForm.Quantity;
                existing.Criticality = string.IsNullOrWhiteSpace(lineForm.Criticality) ? "Normal" : lineForm.Criticality;
                existing.Details = lineForm.Details?.Trim();
                existing.Novelty = lineForm.Novelty?.Trim();
            }
        }
        else
        {
            currentLines.Add(new RequestLineItem
            {
                Id = Guid.NewGuid(),
                ToolName = lineForm.ToolName.Trim(),
                TechnicalOrSerial = lineForm.TechnicalOrSerial?.Trim(),
                Quantity = lineForm.Quantity <= 0 ? 1 : lineForm.Quantity,
                Criticality = string.IsNullOrWhiteSpace(lineForm.Criticality) ? "Normal" : lineForm.Criticality,
                Details = lineForm.Details?.Trim(),
                Novelty = lineForm.Novelty?.Trim(),
                Selected = true
            });
        }

        ClearLine();
    }

    private void EditLine(Guid id)
    {
        var item = currentLines.FirstOrDefault(x => x.Id == id);

        if (item is null)
        {
            return;
        }

        editingLineId = item.Id;
        lineForm.ToolName = item.ToolName;
        lineForm.TechnicalOrSerial = item.TechnicalOrSerial;
        lineForm.Quantity = item.Quantity;
        lineForm.Criticality = item.Criticality;
        lineForm.Details = item.Details;
        lineForm.Novelty = item.Novelty;
    }

    private void RemoveLine(Guid id)
    {
        currentLines.RemoveAll(x => x.Id == id);
        currentQuotes.RemoveAll(x => x.LineId == id);

        if (editingLineId == id)
        {
            ClearLine();
        }
    }

    private void ClearLine()
    {
        editingLineId = null;
        lineForm.ToolName = string.Empty;
        lineForm.TechnicalOrSerial = string.Empty;
        lineForm.Quantity = 1;
        lineForm.Criticality = "Normal";
        lineForm.Details = string.Empty;
        lineForm.Novelty = string.Empty;
    }

    private async Task SaveDraftAsync()
    {
