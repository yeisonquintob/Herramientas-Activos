@page "/physical-counts/{Id:guid}/reported-items"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Components.Security
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager

<PageTitle>Registros reportados</PageTitle>

<PermissionGuard Permission="PhysicalCounts.View" ModuleName="Registros reportados">

<section class="ri-hero">
    <div>
        <span class="ri-pill">TOMA FÍSICA · REGISTROS REPORTADOS</span>
        <h2>Registros reportados</h2>
        <p>Administra lo que reportan los usuarios durante la toma física: encontrados, faltantes, daños, devoluciones, diferencias y herramientas no listadas.</p>
    </div>

    <div class="ri-actions">
        <button class="btn btn-light" @onclick="LoadAsync">Actualizar</button>
        <button class="btn btn-outline-light" @onclick="GoBack">Volver</button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading && board is null)
{
    <div class="ri-empty">Cargando registros reportados...</div>
}
else if (board is not null)
{
    <section class="ri-kpis">
        <article><span>Total</span><strong>@board.Summary.Total</strong><small>Registros</small></article>
        <article><span>No listadas</span><strong>@board.Summary.ExtraNotListed</strong><small>Por conciliar</small></article>
        <article><span>Dañadas</span><strong>@board.Summary.Damaged</strong><small>Posible mantenimiento</small></article>
        <article><span>Devueltas</span><strong>@board.Summary.ReturnedOrDelivered</strong><small>Validar entrega</small></article>
        <article><span>Aclaración</span><strong>@board.Summary.RequiresUserClarification</strong><small>Contactar usuario</small></article>
        <article><span>Sin mínimos</span><strong>@board.Summary.MissingMinimumData</strong><small>No aptas para crear</small></article>
    </section>

    <section class="ri-card">
        <div class="ri-card-title">
            <div>
                <h3>Nuevo registro reportado</h3>
                <p>Captura los datos mínimos para que el registro pueda pasar a conciliación y, si aplica, creación en Inventario de AF.</p>
            </div>

            <button class="btn btn-sm btn-outline-primary" @onclick="ToggleForm">
                @(showForm ? "Ocultar formulario" : "+ Agregar registro reportado")
            </button>
        </div>

        @if (showForm)
        {
            <div class="ri-form-grid">
                <div>
                    <label>Participante / usuario que reporta *</label>
                    <select class="form-select" @bind="form.ParticipantId">
                        <option value="">Seleccione...</option>
                        @foreach (var p in participants)
                        {
                            <option value="@p.Id">@p.DisplayName - @p.UserName</option>
                        }
                    </select>
                </div>

                <div>
                    <label>Tipo de reporte *</label>
                    <select class="form-select" @bind="form.ReportType">
                        <option value="ExtraNotListed">Herramienta no listada</option>
                        <option value="Found">Encontrada</option>
                        <option value="NotFound">No encontrada</option>
                        <option value="ReturnedOrDelivered">Devuelta / entregada</option>
                        <option value="Damaged">Dañada</option>
                        <option value="DifferentLocation">Ubicación diferente</option>
                        <option value="DifferentResponsible">Responsable diferente</option>
                    </select>
                </div>

                <div>
                    <label>Código / placa visible</label>
                    <input class="form-control" @bind="form.ReportedCode" placeholder="Ej: AGU-001, SIN-PLACA-001..." />
                </div>

                <div>
                    <label>Nombre del activo / herramienta *</label>
                    <input class="form-control" @bind="form.ReportedName" placeholder="Ej: Taladro, gato, escáner..." />
                </div>

                <div>
                    <label>Tipo de activo *</label>
                    <input class="form-control" @bind="form.AssetTypeName" placeholder="Ej: Herramienta, equipo, activo fijo..." />
                </div>

                <div>
                    <label>Categoría *</label>
                    <input class="form-control" @bind="form.CategoryName" placeholder="Ej: Eléctrica, hidráulica, cómputo..." />
                </div>

                <div>
                    <label>Sede *</label>
                    <input class="form-control" @bind="form.BranchCode" placeholder="Ej: AGU" />
                </div>

                <div>
                    <label>Ubicación encontrada *</label>
                    <input class="form-control" @bind="form.FoundLocation" placeholder="Ej: Taller principal, almacén..." />
                </div>

                <div>
                    <label>Responsable reportado</label>
                    <input class="form-control" @bind="form.ResponsibleName" placeholder="Nombre de quien la tiene o reporta" />
                </div>

                <div>
                    <label>Estado físico *</label>
                    <select class="form-select" @bind="form.PhysicalStatus">
                        <option value="">Seleccione...</option>
                        <option value="Bueno">Bueno</option>
                        <option value="Regular">Regular</option>
                        <option value="Dañado">Dañado</option>
                        <option value="Incompleto">Incompleto</option>
                        <option value="No operativo">No operativo</option>
                    </select>
                </div>

                <div>
                    <label>Serial</label>
                    <input class="form-control" @bind="form.SerialNumber" />
                </div>

                <div>
                    <label>Marca</label>
                    <input class="form-control" @bind="form.Brand" />
                </div>

                <div>
                    <label>Modelo</label>
                    <input class="form-control" @bind="form.Model" />
                </div>

                <div>
                    <label>Estado operativo</label>
                    <input class="form-control" @bind="form.OperationalStatus" placeholder="Operativo / No operativo" />
                </div>

                <div class="ri-full">
                    <label>Observación *</label>
                    <textarea class="form-control" rows="3" @bind="form.Observation" placeholder="Describa lo que reportó el usuario y cualquier detalle para conciliación."></textarea>
                </div>

                <div class="ri-full ri-check">
                    <input type="checkbox" class="form-check-input" @bind="form.RequiresUserClarification" />
                    <label>Requiere llamar/contactar al usuario para aclaración</label>
                </div>
            </div>

            <div class="ri-form-actions">
                <button class="btn btn-success" @onclick="SaveAsync">Guardar registro reportado</button>
                <button class="btn btn-outline-secondary" @onclick="ClearForm">Limpiar</button>
            </div>
        }
    </section>

    <section class="ri-card">
        <div class="ri-card-title">
            <div>
                <h3>Registros reportados</h3>
                <p>Vista estilo inventario para revisar, filtrar y conciliar lo reportado en campo.</p>
            </div>

            <input class="form-control ri-search"
                   placeholder="Buscar código, nombre, responsable, categoría..."
                   @bind="searchText"
                   @bind:event="oninput" />
        </div>

        @if (!FilteredItems.Any())
        {
            <div class="ri-empty">No hay registros reportados para esta toma física.</div>
        }
        else
        {
            <div class="ri-table-wrapper">
                <table class="ri-table">
                    <thead>
                        <tr>
                            <th>Tipo</th>
                            <th>Código / nombre</th>
                            <th>Clasificación</th>
                            <th>Ubicación / responsable</th>
                            <th>Estado</th>
                            <th>Datos mínimos</th>
                            <th>Conciliación</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in FilteredItems)
                        {
                            <tr>
                                <td>
                                    <span class="ri-badge">@item.ReportTypeLabel</span>
                                    <small>@item.ParticipantName</small>
                                    <small>@item.ParticipantUserName</small>
                                </td>

                                <td>
                                    <strong>@Display(item.ReportedCode)</strong>
                                    <span>@item.ReportedName</span>
                                    <small>Serial: @Display(item.SerialNumber)</small>
                                    <small>Marca: @Display(item.Brand)</small>
                                    <small>Modelo: @Display(item.Model)</small>
                                </td>

                                <td>
                                    <small>Tipo: @Display(item.AssetTypeName)</small>
                                    <small>Categoría: @Display(item.CategoryName)</small>
                                </td>

                                <td>
                                    <small>Sede: @Display(item.BranchCode)</small>
                                    <small>Ubicación: @Display(item.FoundLocation)</small>
                                    <small>Responsable: @Display(item.ResponsibleName)</small>
                                </td>

                                <td>
                                    <small>Físico: @Display(item.PhysicalStatus)</small>
                                    <small>Operativo: @Display(item.OperationalStatus)</small>
                                    <small>Reportó: @Display(item.ReportedBy)</small>
                                    <small>@FormatDate(item.ReportedAt)</small>
                                </td>

                                <td>
                                    @if (item.MinimumDataCompleted)
                                    {
                                        <span class="ri-status ok">Completos</span>
                                    }
                                    else
                                    {
                                        <span class="ri-status warn">Incompletos</span>
                                        <small>@Display(item.MissingRequiredData)</small>
                                    }
                                </td>

                                <td>
                                    <span class="@GetStatusClass(item.ReconciliationStatus)">
                                        @GetVisualReconciliationLabel(item)
                                    </span>
                                    <small>@Display(item.SuggestedAction)</small>
                                    <small>@Display(item.ReconciliationObservation)</small>

                                    @if (item.CreatedToolAssetId.HasValue && item.CreatedToolAssetId.Value != Guid.Empty)
                                    {
                                        <small>Activo creado: @item.CreatedToolAssetId</small>
                                    }
                                </td>

                                <td>
                                    <div class="ri-row-actions">
                                        @if (item.CreatedToolAssetId.HasValue && item.CreatedToolAssetId.Value != Guid.Empty)
                                        {
                                            <span class="ri-status done">Creado en Inventario</span>

                                            <button class="btn btn-sm btn-success" @onclick="() => ViewCreatedToolAsync(item.CreatedToolAssetId.Value)">
                                                Ver activo
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => VoidCreatedInventoryAssetAsync(item.Id)">
                                                Anular activo creado
                                            </button>
                                        }
                                        else if (item.Rejected || item.ReconciliationStatus == "Rejected")
                                        {
                                            <span class="ri-status danger">Rechazado / No procede</span>
                                        }
                                        else if (item.RequiresUserClarification || item.ReconciliationStatus == "RequiresUserClarification")
                                        {
                                            <span class="ri-status warn">Pendiente de aclaración</span>

                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ResolveClarificationAsync(item.Id)">
                                                Marcar aclarado
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RejectAsync(item.Id)">
                                                Rechazar
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-warning" @onclick="() => RequestClarificationAsync(item.Id)">Aclarar</button>

                                            <button class="btn btn-sm btn-outline-success" @onclick="() => ApproveCreationAsync(item.Id)">
                                                Aprobar creación
                                            </button>

                                            @if (item.ReportType == "ExtraNotListed" && item.MinimumDataCompleted && item.ApprovedForCreation)
                                            {
                                                <button class="btn btn-sm btn-success" @onclick="() => CreateInventoryAssetAsync(item.Id)">
                                                    Crear en Inventario
                                                </button>
                                            }

                                            <button class="btn btn-sm btn-outline-dark" @onclick="() => ReconcileAsync(item.Id)">Conciliar</button>
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RejectAsync(item.Id)">Rechazar</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
}

</PermissionGuard>

