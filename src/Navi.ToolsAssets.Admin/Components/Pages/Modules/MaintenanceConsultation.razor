@page "/maintenance"
@rendermode InteractiveServer
@using System.Globalization
@using System.Net
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.JSInterop
@using Navi.ToolsAssets.Admin.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject WebAuthSessionService AuthSession
@inject IJSRuntime JS

<PageTitle>Consulta Compras y Mtto.</PageTitle>

@if (!CanViewModule)
{
    <section class="navi-module-hero">
        <div>
            <span class="navi-module-pill">OPERACIONES · COMPRAS · MTTO · COSTOS</span>
            <h2>Consulta Compras y Mtto.</h2>
            <p>No tienes permisos para consultar solicitudes de compra o mantenimiento.</p>
        </div>
    </section>

    <div class="alert alert-warning">
        Requiere al menos <strong>Purchases.View</strong> o <strong>Maintenance.View</strong>.
    </div>
}
else
{
    <section class="navi-module-hero">
        <div>
            <span class="navi-module-pill">OPERACIONES · COMPRAS · MTTO · COSTOS</span>
            <h2>Consulta Compras y Mtto.</h2>
            <p>Consulta solicitudes y cotizaciones de compra y mantenimiento. La generación final y la cotización se realizan desde la solicitud; esta vista es de consulta, seguimiento y cierre.</p>
        </div>

        <div class="navi-module-hero-actions">
            <button type="button" class="navi-module-hero-btn" @onclick="RefreshAsync" disabled="@isLoading">
                @(isLoading ? "Actualizando..." : "Actualizar")
            </button>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(StatusMessage))
    {
        <div class="alert alert-success">@StatusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(ErrorMessage))
    {
        <div class="alert alert-warning">@ErrorMessage</div>
    }

    <section class="consult-kpi-grid">
        <article class="consult-kpi blue">
            <span>Total</span>
            <strong>@FilteredItems.Count()</strong>
            <small>Solicitudes</small>
        </article>

        <article class="consult-kpi indigo">
            <span>Compras</span>
            <strong>@FilteredPurchases.Count()</strong>
            <small>Herramientas y AF</small>
        </article>

        <article class="consult-kpi purple">
            <span>Mtto.</span>
            <strong>@FilteredMaintenances.Count()</strong>
            <small>Mantenimiento</small>
        </article>

        <article class="consult-kpi amber">
            <span>En revisión</span>
            <strong>@FilteredItems.Count(x => IsStatus(x, "InReview"))</strong>
            <small>Por aprobar</small>
        </article>

        <article class="consult-kpi green">
            <span>Aprobadas / ejecución</span>
            <strong>@FilteredItems.Count(x => IsPositiveCostStatus(x.Status))</strong>
            <small>Suman costo</small>
        </article>

        <article class="consult-kpi red">
            <span>Rechazadas</span>
            <strong>@FilteredItems.Count(x => IsRejectedOrCanceled(x.Status))</strong>
            <small>No suman costo</small>
        </article>

        <article class="consult-kpi violet">
            <span>Costo estimado</span>
            <strong>@FormatMoney(TotalEstimatedCost)</strong>
            <small>@CostedItemsCount con costo</small>
        </article>
    </section>

    <section class="consult-layout">
        <article class="consult-panel main">
            <div class="consult-title-row">
                <div>
                    <h3>Solicitudes registradas</h3>
                    <p>Compras y mantenimientos separados. Se muestran todos los estados: revisión, aprobadas, programadas, ejecución, cerradas, canceladas y rechazadas.</p>
                </div>

                <div class="consult-filters">
                    <select @bind="typeFilter">
                        <option value="all">Compra y mantenimiento</option>
                        <option value="purchase">Solo compras</option>
                        <option value="maintenance">Solo mantenimiento</option>
                    </select>

                    <select @bind="statusFilter">
                        <option value="all">Todos los estados</option>
                        <option value="InReview">En revisión</option>
                        <option value="Approved">Aprobadas</option>
                        <option value="Scheduled">Programadas</option>
                        <option value="InExecution">En ejecución</option>
                        <option value="Closed">Cerradas</option>
                        <option value="Rejected">Rechazadas</option>
                        <option value="Canceled">Canceladas</option>
                    </select>

                    <input @bind="searchText" @bind:event="oninput" placeholder="Buscar solicitud, activo, proveedor, técnico..." />

                    <button type="button" @onclick="ApplyFilters">Filtrar</button>
                </div>
            </div>

            @if (ShowPurchases)
            {
                <div class="consult-section-title">
                    <strong>Compras</strong>
                    <span>@FilteredPurchases.Count()</span>
                </div>

                <div class="consult-table-wrap">
                    <table class="consult-table">
                        <colgroup>
                            <col style="width: 14%" />
                            <col style="width: 25%" />
                            <col style="width: 7%" />
                            <col style="width: 7%" />
                            <col style="width: 8%" />
                            <col style="width: 10%" />
                            <col style="width: 9%" />
                            <col style="width: 9%" />
                            <col style="width: 11%" />
                        </colgroup>
                        <thead>
                            <tr>
                                <th>Solicitud</th>
                                <th>Necesidad / activo</th>
                                <th>Tipo</th>
                                <th>Prioridad</th>
                                <th>Estado</th>
                                <th>Costo / proveedor</th>
                                <th>Fechas</th>
                                <th>Responsable</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!FilteredPurchases.Any())
                            {
                                <tr>
                                    <td colspan="9">
                                        <div class="consult-empty">No hay solicitudes de compra para los filtros seleccionados.</div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in FilteredPurchases)
                                {
                                    @RenderConsultRow(item)
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }

            @if (ShowMaintenances)
            {
                <div class="consult-section-title maintenance">
                    <strong>Mantenimiento</strong>
                    <span>@FilteredMaintenances.Count()</span>
                </div>

                <div class="consult-table-wrap">
                    <table class="consult-table">
                        <colgroup>
                            <col style="width: 14%" />
                            <col style="width: 25%" />
                            <col style="width: 7%" />
                            <col style="width: 7%" />
                            <col style="width: 8%" />
                            <col style="width: 10%" />
                            <col style="width: 9%" />
                            <col style="width: 9%" />
                            <col style="width: 11%" />
                        </colgroup>
                        <thead>
                            <tr>
                                <th>Solicitud</th>
                                <th>Necesidad / activo</th>
                                <th>Tipo</th>
                                <th>Prioridad</th>
                                <th>Estado</th>
                                <th>Costo / proveedor</th>
                                <th>Fechas</th>
                                <th>Responsable</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!FilteredMaintenances.Any())
                            {
                                <tr>
                                    <td colspan="9">
                                        <div class="consult-empty">No hay solicitudes de mantenimiento para los filtros seleccionados.</div>
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var item in FilteredMaintenances)
                                {
                                    @RenderConsultRow(item)
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </article>

        <aside class="consult-panel summary">
            <h3>Resumen de costos</h3>
            <p>Compras y mantenimiento se calculan por separado. Rechazadas, canceladas, borradores y en revisión se muestran, pero no suman.</p>

            <div class="cost-block purchase">
                <div class="cost-block-header">
                    <strong>Compras</strong>
                    <span>@FormatMoney(PurchaseCost)</span>
                </div>

                <div class="cost-mini-grid">
                    <div><span>Total compras</span><strong>@FormatMoney(PurchaseCost)</strong></div>
                    <div><span>Promedio</span><strong>@FormatMoney(PurchaseAverage)</strong></div>
                    <div><span>Mayor costo</span><strong>@FormatMoney(PurchaseMax)</strong></div>
                    <div><span>Proveedores</span><strong>@PurchaseProviders</strong></div>
                </div>

                @if (PurchaseCostItems.Any())
                {
                    <ul class="cost-list">
                        @foreach (var item in PurchaseCostItems.Take(5))
                        {
                            <li>
                                <strong>@ShortText(item.AssetName, 24)</strong>
                                <span>@FormatMoney(item.EstimatedCost)</span>
                                <small>@item.Number</small>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="cost-empty">No hay costos positivos de compras para sumar.</div>
                }
            </div>

            <div class="cost-block maintenance">
                <div class="cost-block-header">
                    <strong>Mantenimiento</strong>
                    <span>@FormatMoney(MaintenanceCost)</span>
                </div>

                <div class="cost-mini-grid">
                    <div><span>Total mtto.</span><strong>@FormatMoney(MaintenanceCost)</strong></div>
                    <div><span>Promedio</span><strong>@FormatMoney(MaintenanceAverage)</strong></div>
                    <div><span>Mayor costo</span><strong>@FormatMoney(MaintenanceMax)</strong></div>
                    <div><span>Proveedores</span><strong>@MaintenanceProviders</strong></div>
                </div>

                @if (MaintenanceCostItems.Any())
                {
                    <ul class="cost-list">
                        @foreach (var item in MaintenanceCostItems.Take(5))
                        {
                            <li>
                                <strong>@ShortText(item.AssetName, 24)</strong>
                                <span>@FormatMoney(item.EstimatedCost)</span>
                                <small>@item.Number</small>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="cost-empty">No hay costos positivos de mantenimiento para sumar.</div>
                }
            </div>
        </aside>
    </section>

    @if (selectedItem is not null)
    {
        <div class="consult-modal-backdrop" @onclick="CloseDetails">
            <div class="consult-modal" @onclick:stopPropagation="true">
                <div class="consult-modal-header">
                    <div>
                        <span>@(selectedItem.Kind == RequestKind.Purchase ? "Compra" : "Mantenimiento")</span>
                        <h3>@selectedItem.Number</h3>
                    </div>

                    <button type="button" @onclick="CloseDetails">Cerrar</button>
                </div>

                <div class="consult-modal-grid">
                    <div>
                        <span>Estado</span>
                        <strong>@StatusLabel(selectedItem.Status)</strong>
                    </div>

                    <div>
                        <span>Prioridad</span>
                        <strong>@selectedItem.Priority</strong>
                    </div>

                    <div>
                        <span>Tipo</span>
                        <strong>@selectedItem.Type</strong>
                    </div>

                    <div>
                        <span>Costo</span>
                        <strong>@FormatMoney(selectedItem.EstimatedCost)</strong>
                    </div>

                    <div>
                        <span>Proveedor</span>
                        <strong>@Dash(selectedItem.Provider)</strong>
                    </div>

                    <div>
                        <span>Sede</span>
                        <strong>@Dash(selectedItem.Branch)</strong>
                    </div>

                    <div>
                        <span>Solicitó</span>
                        <strong>@Dash(selectedItem.RequestedBy)</strong>
                    </div>

                    <div>
                        <span>Preparó</span>
                        <strong>@Dash(selectedItem.PreparedBy)</strong>
                    </div>

                    <div>
                        <span>Técnico</span>
                        <strong>@Dash(selectedItem.Technician)</strong>
                    </div>

                    <div>
                        <span>Creada</span>
                        <strong>@FormatDate(selectedItem.CreatedAt)</strong>
                    </div>

                    <div>
                        <span>Programada</span>
                        <strong>@FormatDate(selectedItem.ScheduledAt)</strong>
                    </div>

                    <div>
                        <span>Cerrada</span>
                        <strong>@FormatDate(selectedItem.ClosedAt)</strong>
                    </div>
                </div>

                <div class="consult-modal-section">
                    <h4>Necesidad / activo</h4>
                    <p>@Dash(selectedItem.AssetName)</p>
                </div>

                <div class="consult-modal-section">
                    <h4>Detalle de la solicitud</h4>
                    <p>@Dash(selectedItem.Description)</p>
                </div>

                <div class="consult-modal-section">
                    <h4>Notas / observaciones</h4>
                    <p>@Dash(selectedItem.Notes)</p>
                </div>

                <div class="consult-modal-actions">
                    @RenderActions(selectedItem)
                </div>
            </div>
        </div>
    }
}

@code {
    private HttpClient? apiClient;
    private List<ConsultationItem> items = new();
    private ConsultationItem? selectedItem;

    private bool isLoading;
    private string typeFilter = "all";
    private string statusFilter = "all";
    private string searchText = string.Empty;

    private string? StatusMessage;
    private string? ErrorMessage;

    private HttpClient Api => apiClient ??= HttpClientFactory.CreateClient("NaviApi");

    private bool IsAdmin =>
        string.Equals(AuthSession.RoleCode, "ADMIN", StringComparison.OrdinalIgnoreCase)
        || string.Equals(AuthSession.RoleCode, "SUPERADMIN", StringComparison.OrdinalIgnoreCase)
        || string.Equals(AuthSession.RoleName, "Administrador", StringComparison.OrdinalIgnoreCase)
        || string.Equals(AuthSession.RoleName, "Administrador NAVI", StringComparison.OrdinalIgnoreCase);

    private bool CanViewPurchase => IsAdmin || AuthSession.HasPermission("Purchases.View");
    private bool CanViewMaintenance => IsAdmin || AuthSession.HasPermission("Maintenance.View");
    private bool CanViewModule => CanViewPurchase || CanViewMaintenance;

    private bool CanApprovePurchase => IsAdmin || AuthSession.HasPermission("Purchases.Approve");
    private bool CanRejectPurchase => IsAdmin || AuthSession.HasPermission("Purchases.Reject");
    private bool CanExecuteMaintenance => IsAdmin || AuthSession.HasPermission("Maintenance.Execute");
    private bool CanCloseMaintenance => IsAdmin || AuthSession.HasPermission("Maintenance.Close");
    private bool CanRejectMaintenance => IsAdmin || AuthSession.HasPermission("Maintenance.Reject");

    private IEnumerable<ConsultationItem> FilteredItems =>
        items
            .Where(x => typeFilter == "all" || (typeFilter == "purchase" && x.Kind == RequestKind.Purchase) || (typeFilter == "maintenance" && x.Kind == RequestKind.Maintenance))
            .Where(x => statusFilter == "all" || IsStatus(x, statusFilter))
            .Where(MatchesSearch)
            .OrderByDescending(x => x.UpdatedAt ?? x.CreatedAt ?? DateTime.MinValue);

    private IEnumerable<ConsultationItem> FilteredPurchases => FilteredItems.Where(x => x.Kind == RequestKind.Purchase);
    private IEnumerable<ConsultationItem> FilteredMaintenances => FilteredItems.Where(x => x.Kind == RequestKind.Maintenance);

    private bool ShowPurchases => typeFilter is "all" or "purchase";
    private bool ShowMaintenances => typeFilter is "all" or "maintenance";

    private IEnumerable<ConsultationItem> CostItems => FilteredItems.Where(x => IsPositiveCostStatus(x.Status) && x.EstimatedCost > 0);
    private IEnumerable<ConsultationItem> PurchaseCostItems => CostItems.Where(x => x.Kind == RequestKind.Purchase);
    private IEnumerable<ConsultationItem> MaintenanceCostItems => CostItems.Where(x => x.Kind == RequestKind.Maintenance);

    private decimal TotalEstimatedCost => CostItems.Sum(x => x.EstimatedCost);
    private int CostedItemsCount => CostItems.Count();

    private decimal PurchaseCost => PurchaseCostItems.Sum(x => x.EstimatedCost);
    private decimal PurchaseAverage => PurchaseCostItems.Any() ? PurchaseCostItems.Average(x => x.EstimatedCost) : 0;
    private decimal PurchaseMax => PurchaseCostItems.Any() ? PurchaseCostItems.Max(x => x.EstimatedCost) : 0;
    private int PurchaseProviders => PurchaseCostItems.Select(x => x.Provider).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).Count();

    private decimal MaintenanceCost => MaintenanceCostItems.Sum(x => x.EstimatedCost);
    private decimal MaintenanceAverage => MaintenanceCostItems.Any() ? MaintenanceCostItems.Average(x => x.EstimatedCost) : 0;
    private decimal MaintenanceMax => MaintenanceCostItems.Any() ? MaintenanceCostItems.Max(x => x.EstimatedCost) : 0;
    private int MaintenanceProviders => MaintenanceCostItems.Select(x => x.Provider).Where(x => !string.IsNullOrWhiteSpace(x)).Distinct(StringComparer.OrdinalIgnoreCase).Count();

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        if (!CanViewModule)
        {
            return;
        }

        isLoading = true;
        StatusMessage = null;
        ErrorMessage = null;

        try
        {
            var loaded = new List<ConsultationItem>();

            if (CanViewPurchase)
            {
                loaded.AddRange(await LoadApiItemsAsync("api/purchase-requests", RequestKind.Purchase));
            }

            if (CanViewMaintenance)
            {
                loaded.AddRange(await LoadApiItemsAsync("api/maintenance-requests", RequestKind.Maintenance));
            }

            loaded.AddRange(await LoadBrowserStorageAsync("localStorage", "Local"));
            loaded.AddRange(await LoadBrowserStorageAsync("sessionStorage", "Sesión"));

            items = Deduplicate(loaded).ToList();

            StatusMessage = $"Consulta actualizada correctamente. Registros cargados: {items.Count}.";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"No se pudo actualizar la consulta. Detalle: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task<List<ConsultationItem>> LoadApiItemsAsync(string endpoint, RequestKind kind)
    {
        var result = new List<ConsultationItem>();

        try
        {
            using var response = await Api.GetAsync(endpoint);

            if (response.StatusCode is HttpStatusCode.Forbidden or HttpStatusCode.Unauthorized)
            {
                return result;
            }

            if (!response.IsSuccessStatusCode)
            {
                return result;
            }

            await using var stream = await response.Content.ReadAsStreamAsync();
            using var document = await JsonDocument.ParseAsync(stream);

            if (document.RootElement.ValueKind == JsonValueKind.Array)
            {
                foreach (var element in document.RootElement.EnumerateArray())
                {
                    result.Add(MapApiItem(element, kind));
                }
            }
        }
        catch
        {
            // La consulta no debe romper si un endpoint no está disponible.
        }

        return result;
    }

    private async Task<List<ConsultationItem>> LoadBrowserStorageAsync(string storageName, string sourcePrefix)
    {
        var result = new List<ConsultationItem>();

        try
        {
            var script =
                "(function(storageName) {" +
                "  const store = storageName === 'sessionStorage' ? sessionStorage : localStorage;" +
                "  const rows = [];" +
                "  for (let i = 0; i < store.length; i++) {" +
                "    const key = store.key(i);" +
                "    const value = store.getItem(key);" +
                "    if (!value) continue;" +
                "    const lower = key.toLowerCase() + ' ' + value.toLowerCase();" +
                "    if (lower.includes('purchase') || lower.includes('compra') || lower.includes('spc') || lower.includes('maintenance') || lower.includes('mantenimiento') || lower.includes('mnt')) {" +
                "      rows.push(JSON.stringify({ key: key, value: value }));" +
                "    }" +
                "  }" +
                "  return rows;" +
                "})(arguments[0]);";

            var rows = await JS.InvokeAsync<string[]>("eval", script, storageName);

            foreach (var row in rows)
            {
                using var rowDoc = JsonDocument.Parse(row);
                var key = GetString(rowDoc.RootElement, "key");
                var value = GetString(rowDoc.RootElement, "value");

                if (string.IsNullOrWhiteSpace(key) || string.IsNullOrWhiteSpace(value))
                {
                    continue;
                }

                try
                {
                    using var valueDoc = JsonDocument.Parse(value);
                    ExtractLocalItems(valueDoc.RootElement, $"{sourcePrefix}: {key}", key, result);
                }
                catch
                {
                    // Ignora claves que no sean JSON válido.
                }
            }
        }
        catch
        {
            // El almacenamiento local es apoyo, no debe romper la pantalla.
        }

        return result;
    }

    private void ExtractLocalItems(JsonElement element, string source, string storageKey, List<ConsultationItem> result)
    {
        if (element.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in element.EnumerateArray())
            {
                ExtractLocalItems(item, source, storageKey, result);
            }

            return;
        }

        if (element.ValueKind != JsonValueKind.Object)
        {
            return;
        }

        var kind = ResolveKind(element);

        if (kind is not null)
        {
            result.Add(MapLocalItem(element, kind.Value, source, storageKey));
        }

        foreach (var property in element.EnumerateObject())
        {
            if (property.Value.ValueKind is JsonValueKind.Object or JsonValueKind.Array)
            {
                ExtractLocalItems(property.Value, source, storageKey, result);
            }
        }
    }

    private RequestKind? ResolveKind(JsonElement element)
    {
        var text = element.GetRawText().ToLowerInvariant();

        if (text.Contains("purchase") || text.Contains("compra") || text.Contains("spc") || text.Contains("bor-comp") || text.Contains("solicitud de compra"))
        {
            return RequestKind.Purchase;
        }

        if (text.Contains("maintenance") || text.Contains("mantenimiento") || text.Contains("mnt") || text.Contains("mtto"))
        {
            return RequestKind.Maintenance;
        }

        return null;
    }

    private ConsultationItem MapApiItem(JsonElement element, RequestKind kind)
    {
        var number = GetString(element, "RequestNumber", "requestNumber", "Number", "number", "Code", "code");
        var id = GetString(element, "Id", "id");

        return new ConsultationItem
        {
            Id = id ?? number ?? Guid.NewGuid().ToString(),
            Number = number ?? id ?? "—",
            Kind = kind,
            Source = "API",
            SourceKind = SourceKind.Api,
            Type = kind == RequestKind.Purchase
                ? "Compra"
                : GetString(element, "RequestType", "requestType", "Type", "type") ?? "Mtto.",
            Priority = GetString(element, "Priority", "priority") ?? "Media",
            Status = NormalizeStatus(GetString(element, "Status", "status", "State", "state")),
            AssetName = kind == RequestKind.Purchase
                ? FirstText(element, "ItemName", "itemName", "ToolName", "toolName", "ItemCode", "itemCode")
                : FirstText(element, "Title", "title", "ToolName", "toolName", "ToolInternalCode", "toolInternalCode"),
            Description = kind == RequestKind.Purchase
                ? BuildPurchaseDescription(element)
                : BuildMaintenanceDescription(element),
            Provider = FirstText(element, "VendorSuggestion", "vendorSuggestion", "Provider", "provider"),
            EstimatedCostText = GetString(element, "EstimatedCostText", "estimatedCostText", "Cost", "cost"),
            EstimatedCost = ParseMoney(GetString(element, "EstimatedCostText", "estimatedCostText", "Cost", "cost")),
            CreatedAt = GetDate(element, "CreatedAt", "createdAt", "RequestedAt", "requestedAt"),
            UpdatedAt = GetDate(element, "UpdatedAt", "updatedAt"),
            ScheduledAt = GetDate(element, "ScheduledAt", "scheduledAt", "RequiredAt", "requiredAt"),
            ClosedAt = GetDate(element, "ClosedAt", "closedAt", "RejectedAt", "rejectedAt", "CanceledAt", "canceledAt"),
            RequestedBy = FirstText(element, "RequestedByUserName", "requestedByUserName", "RequestedByResponsiblePersonName", "requestedByResponsiblePersonName"),
            PreparedBy = FirstText(element, "PreparedBy", "preparedBy", "SubmittedBy", "submittedBy"),
            Technician = FirstText(element, "AssignedTechnician", "assignedTechnician", "ExecutionStartedBy", "executionStartedBy"),
            Branch = FirstText(element, "BranchCode", "branchCode", "BranchName", "branchName"),
            Notes = FirstText(element, "Notes", "notes", "ApprovalComment", "approvalComment", "RejectionReason", "rejectionReason", "ClosingComment", "closingComment"),
            RawText = element.GetRawText()
        };
    }

    private ConsultationItem MapLocalItem(JsonElement element, RequestKind kind, string source, string storageKey)
    {
        var number = GetString(element, "RequestNumber", "requestNumber", "Number", "number", "Code", "code", "requestCode", "RequestCode");
        var id = GetString(element, "Id", "id", "RequestId", "requestId", "rowId", "RowId");

        return new ConsultationItem
        {
            Id = id ?? number ?? Guid.NewGuid().ToString(),
            Number = number ?? id ?? "—",
            Kind = kind,
            Source = source,
            SourceKind = SourceKind.BrowserStorage,
            StorageKey = storageKey,
            Type = kind == RequestKind.Purchase
                ? "Compra"
                : FirstText(element, "RequestType", "requestType", "Type", "type") ?? "Mtto.",
            Priority = GetString(element, "Priority", "priority") ?? "Media",
            Status = NormalizeStatus(GetString(element, "Status", "status", "State", "state", "localStatus", "LocalStatus", "statusText", "StatusText", "statusLabel", "StatusLabel")),
            AssetName = FirstText(element, "ItemName", "itemName", "ToolName", "toolName", "Title", "title", "Name", "name", "assetName", "AssetName"),
            Description = FirstText(element, "Description", "description", "Details", "details", "ProblemDescription", "problemDescription", "Justification", "justification", "Need", "need"),
            Provider = FirstText(element, "VendorSuggestion", "vendorSuggestion", "Provider", "provider", "Supplier", "supplier"),
            EstimatedCostText = GetString(element, "EstimatedCostText", "estimatedCostText", "Cost", "cost", "Total", "total", "totalBeforeTax", "TotalBeforeTax"),
            EstimatedCost = ParseMoney(GetString(element, "EstimatedCostText", "estimatedCostText", "Cost", "cost", "Total", "total", "totalBeforeTax", "TotalBeforeTax")),
            CreatedAt = GetDate(element, "CreatedAt", "createdAt", "RequestedAt", "requestedAt", "date", "Date"),
            UpdatedAt = GetDate(element, "UpdatedAt", "updatedAt", "LastUpdatedAt", "lastUpdatedAt"),
            ScheduledAt = GetDate(element, "ScheduledAt", "scheduledAt", "RequiredAt", "requiredAt"),
            ClosedAt = GetDate(element, "ClosedAt", "closedAt", "RejectedAt", "rejectedAt", "CanceledAt", "canceledAt"),
            RequestedBy = FirstText(element, "RequestedByUserName", "requestedByUserName", "Requester", "requester", "Solicitante", "solicitante"),
            PreparedBy = FirstText(element, "PreparedBy", "preparedBy", "CreatedBy", "createdBy"),
            Technician = FirstText(element, "AssignedTechnician", "assignedTechnician", "Technician", "technician"),
            Branch = FirstText(element, "BranchCode", "branchCode", "BranchName", "branchName", "Sede", "sede"),
            Notes = FirstText(element, "Notes", "notes", "Observation", "observation", "Observations", "observations", "Comment", "comment"),
            RawText = element.GetRawText()
        };
    }

    private IEnumerable<ConsultationItem> Deduplicate(IEnumerable<ConsultationItem> source)
    {
        return source
            .GroupBy(x => $"{x.Kind}:{NormalizeKey(x.Number)}:{NormalizeKey(x.Id)}")
            .Select(group =>
                group.OrderByDescending(x => x.SourceKind == SourceKind.Api)
                     .ThenByDescending(x => x.UpdatedAt ?? x.CreatedAt ?? DateTime.MinValue)
                     .First())
            .Where(x => !string.IsNullOrWhiteSpace(x.Number) || !string.IsNullOrWhiteSpace(x.AssetName))
            .ToList();
    }

    private bool MatchesSearch(ConsultationItem item)
    {
        if (string.IsNullOrWhiteSpace(searchText))
        {
            return true;
        }

        var value = searchText.Trim();

        return Contains(item.Number, value)
            || Contains(item.AssetName, value)
            || Contains(item.Description, value)
            || Contains(item.Provider, value)
            || Contains(item.RequestedBy, value)
            || Contains(item.PreparedBy, value)
            || Contains(item.Technician, value)
            || Contains(item.Branch, value);
    }

