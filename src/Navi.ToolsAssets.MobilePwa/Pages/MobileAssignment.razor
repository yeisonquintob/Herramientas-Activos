    private LoanRequestItemLite? FindPendingRequestForTool(Guid toolId)
    {
        var request = PendingRequests.FirstOrDefault(x =>
            x.Items.Any(i => i.ToolAssetId == toolId && !i.Returned));

        if (request is null)
        {
            return null;
        }

        return new LoanRequestItemLite(request.Id, request.LoanNumber);
    }

    private bool RequestInVisibleScope(MobileLoanRequestDto request)
    {
        var visibleIds = ScopedTools.Select(x => x.Id).ToHashSet();

        return request.Items.Any(i => visibleIds.Contains(i.ToolAssetId));
    }

