        color: #657083;
        font-size: .68rem;
        font-weight: 900;
        text-transform: uppercase;
    }

    .kpi-card strong {
        display: block;
        color: #17111c;
        font-size: 1.45rem;
        font-weight: 950;
        line-height: 1.1;
    }

    .kpi-card small {
        color: #657083;
        font-size: .68rem;
    }

