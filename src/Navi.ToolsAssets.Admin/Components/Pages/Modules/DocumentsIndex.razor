@page "/documents"
@rendermode InteractiveServer
@inherits DocumentsIndexBase

@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Documentos - NAVI</PageTitle>

<section class="docs-hero">
    <div>
        <span class="docs-pill">DOCUMENTOS · ACTIVOS · EVIDENCIAS</span>
        <h2>Gestión documental</h2>
        <p>Consulta, carga y descarga documentos reales asociados a herramientas, activos y procesos de toma física existentes en NAVI.</p>
    </div>

    <div class="docs-hero-actions">
        <button type="button" class="docs-hero-btn" @onclick="LoadAsync" disabled="@isLoading">
            @(isLoading ? "Actualizando..." : "Actualizar")
        </button>
    </div>
</section>

<section class="docs-kpis">
    <article>
        <span>Total documentos</span>
        <strong>@documents.Count</strong>
        <small>Documentos reales</small>
    </article>

    <article class="success">
        <span>Activos con soporte</span>
        <strong>@documents.Select(x => x.ToolAssetId).Distinct().Count()</strong>
        <small>Asociados a inventario</small>
    </article>

    <article class="warning">
        <span>Clasificación actual</span>
        <strong>@CountByCategory(selectedCategory)</strong>
        <small>@selectedCategory</small>
    </article>

    <article class="purple">
        <span>Inventario</span>
        <strong>@assets.Count</strong>
        <small>Activos disponibles</small>
    </article>
</section>

<section class="docs-workspace">
    <aside class="docs-card docs-side-card docs-left-panel">
        <div class="docs-card-title compact">
            <div>
                <h3>Clasificación</h3>
                <p>Define el tipo documental a consultar o cargar.</p>
            </div>
        </div>

        <div class="docs-category-list">
            @foreach (var item in Categories)
            {
                <button type="button"
                        class="@GetCategoryClass(item.Name)"
                        title="@($"{item.Name}: {CountByCategory(item.Name)} registro(s)")"
                        @onclick="() => SelectCategory(item.Name)">
                    <span>@item.Icon</span>
                    <strong>@item.Name</strong>
                    <small>@CountByCategory(item.Name) registro(s)</small>
                </button>
            }
        </div>

        <div class="docs-left-separator"></div>

        <div class="docs-card-title compact manual-title">
            <div>
                <h3>Manual operativo</h3>
                <p>Manual operativo detallado por módulo, proceso, permisos, reglas y documentos relacionados.</p>
            </div>
        </div>

        <div class="docs-manual-list">
            @foreach (var item in ManualOptions)
            {
                <div class="@GetManualClass(item.Code)">
                    <span>@item.Icon</span>

                    <div>
                        <strong>@item.Title</strong>
                        <small>@item.Module</small>
                    </div>

                    <button type="button" @onclick="() => OpenManual(item.Code)">
                        Ver
                    </button>
                </div>
            }
        </div>
    </aside>

    <main class="docs-main">
        @if (selectedCategory == PhysicalCountCategory)
        {
            <article class="docs-card docs-physical-card">
                <div class="docs-card-title">
                    <div>
                        <h3>Documentación de toma física</h3>
                        <p>Esta clasificación no permite subir documentos. Muestra las tomas físicas reales y sus registros reportados para visualizar o descargar el consolidado.</p>
                    </div>

                    <span class="docs-selected-pill">@selectedCategory</span>
                </div>

                <div class="docs-form-grid physical-selector">
                    <div class="span-2">
                        <label>Toma física</label>
                        <select class="form-select" value="@selectedPhysicalCountId" @onchange="OnPhysicalCountSelected">
                            <option value="">Seleccione una toma física</option>

                            @foreach (var count in physicalCounts)
                            {
                                <option value="@count.Id.ToString()">
                                    @count.CountNumber - @Show(count.BranchCode) - @count.StatusLabel
                                </option>
                            }
                        </select>
                    </div>
                </div>

                <div class="docs-physical-summary">
                    <div>
                        <span>Tomas creadas</span>
                        <strong>@physicalCounts.Count</strong>
                        <small>Campañas reales</small>
                    </div>

                    <div>
                        <span>Participantes</span>
                        <strong>@SelectedBoardSummary.TotalParticipants</strong>
                        <small>De la toma seleccionada</small>
                    </div>

                    <div>
                        <span>Reportes</span>
                        <strong>@SelectedReportedSummary.Total</strong>
                        <small>Registros de usuario</small>
                    </div>

                    <div>
                        <span>Pendientes</span>
                        <strong>@PendingPhysicalDecisions</strong>
                        <small>Aclarar / crear / conciliar</small>
                    </div>
                </div>

                <div class="docs-physical-actions">
                    <button type="button" @onclick="OpenPhysicalModal" disabled="@(SelectedPhysicalCount is null)">
                        Visualizar consolidado
                    </button>

                    @if (CanDownloadDocuments)
                    {
                        <a href="@BuildPhysicalCountCsvDataUrl()" download="consolidado-toma-fisica.csv">
                            Descargar consolidado CSV
                        </a>
                    }
                    else
                    {
                        <button type="button" class="docs-disabled-action" disabled>
                            Descargar consolidado CSV
                        </button>
                    }
                </div>

                <div class="docs-table-wrapper">
                    <table class="docs-table">
                        <thead>
                            <tr>
                                <th>Toma</th>
                                <th>Sede</th>
                                <th>Estado</th>
                                <th>Fecha inicio</th>
                                <th>Fecha cierre</th>
                                <th>Responsable</th>
                                <th>Inventario</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var row in physicalCounts)
                            {
                                <tr class="@(row.Id.ToString() == selectedPhysicalCountId ? "selected-row" : "")">
                                    <td>
                                        <strong>@row.CountNumber</strong>
                                        <small>@Show(row.Notes)</small>
                                    </td>

                                    <td>
                                        <strong>@Show(row.BranchCode)</strong>
                                        <small>@Show(row.BranchName)</small>
                                    </td>

                                    <td>
                                        <span class="@GetPhysicalStatusClass(row.Status)">
                                            @row.StatusLabel
                                        </span>
                                    </td>

                                    <td>@row.StartedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(row.FinishedAt is null ? "—" : row.FinishedAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm"))</td>
                                    <td>@Show(row.ResponsibleBy)</td>

                                    <td>
                                        <strong>Total: @row.TotalItems</strong>
                                        <small>Encontradas: @row.FoundItems</small>
                                        <small>Faltantes: @row.MissingItems</small>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </article>

            <article class="docs-card docs-table-card">
                <div class="docs-card-title">
                    <div>
                        <h3>Registros reportados de la toma</h3>
                        <p>Detalle de lo reportado por los usuarios durante la toma física y lo que queda pendiente de aclarar, crear, conciliar o rechazar.</p>
                    </div>

                    <div class="docs-filters one">
                        <input class="form-control"
                               placeholder="Buscar código, nombre, usuario, estado, ubicación..."
                               @bind="physicalSearchText"
                               @bind:event="oninput" />
                    </div>
                </div>

                @if (SelectedPhysicalCount is null)
                {
                    <div class="docs-empty">Selecciona una toma física para visualizar sus registros.</div>
                }
                else if (!FilteredReportedItems.Any())
                {
                    <div class="docs-empty">Esta toma física no tiene registros reportados para los filtros seleccionados.</div>
                }
                else
                {
                    <div class="docs-table-wrapper">
                        <table class="docs-table">
                            <thead>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Código / nombre</th>
                                    <th>Usuario</th>
                                    <th>Ubicación</th>
                                    <th>Estado conciliación</th>
                                    <th>Datos mínimos</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in FilteredReportedItems)
                                {
                                    <tr>
                                        <td>
                                            <span class="docs-type-pill">@Show(item.ReportTypeLabel)</span>
                                            <small>@Show(item.ReportType)</small>
                                        </td>

                                        <td>
                                            <strong>@Show(item.ToolInternalCode)</strong>
                                            <small>@Show(item.ToolName)</small>
                                            <small>@Show(item.ReportedName)</small>
                                        </td>

                                        <td>
                                            <strong>@Show(item.ParticipantName)</strong>
                                            <small>@Show(item.ParticipantUserName)</small>
                                        </td>

                                        <td>
                                            <strong>@Show(item.FoundLocation)</strong>
                                            <small>@Show(item.ExpectedLocation)</small>
                                        </td>

                                        <td>
                                            <span class="@GetReconciliationClass(item)">
                                                @GetReconciliationLabel(item)
                                            </span>
                                        </td>

                                        <td>@(item.HasMinimumData ? "Completos" : "Incompletos")</td>
                                        <td>@item.ReportedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </article>
        }
        else
        {
            <article class="docs-card docs-upload-card">
                <div class="docs-card-title">
                    <div>
                        <h3>Cargar documento</h3>
                        <p>El documento se guarda sobre un activo real del inventario. La clasificación seleccionada define el tipo documental.</p>
                    </div>

                    <span class="docs-selected-pill">@selectedCategory</span>
                </div>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="@messageClass docs-inline-message">@message</div>
                }

                <div class="docs-form-grid">
                    <div>
                        <label>Clasificación</label>
                        <input class="form-control" value="@selectedCategory" readonly />
                    </div>

                    <div>
                        <label>Activo / herramienta existente</label>
                        <input class="form-control"
                               list="docs-assets-list"
                               placeholder="Escribe código, nombre, serial, sede o responsable"
                               @bind="assetSearchText"
                               @bind:event="oninput" />

                        <datalist id="docs-assets-list">
                            @foreach (var asset in FilteredAssets)
                            {
                                <option value="@FormatAssetOption(asset)"></option>
                            }
                        </datalist>

                        <small class="@GetAssetHintClass()">@GetAssetHint()</small>
                    </div>

                    <div>
                        <label>Nombre del documento</label>
                        <input class="form-control"
                               placeholder="Ej: factura compra kit scanner"
                               @bind="documentName" />
                    </div>

                    <div>
                        <label>Responsable de carga</label>
                        <input class="form-control"
                               placeholder="Usuario que carga el documento"
                               @bind="uploadedBy" />
                    </div>

                    <div class="span-2">
                        <label>Archivo</label>
                        <InputFile class="form-control" OnChange="OnFileSelected" />
                        <small class="docs-asset-hint ok">@(selectedFile is null ? "Seleccione PDF, imagen, Excel o Word." : $"Archivo seleccionado: {selectedFile.Name}")</small>
                    </div>

                    <div class="span-2">
                        <label>Descripción</label>
                        <textarea class="form-control"
                                  rows="3"
                                  placeholder="Detalle del soporte o evidencia cargada"
                                  @bind="description"></textarea>
                    </div>
                </div>

                <div class="docs-actions">
                    <button type="button" @onclick="UploadAsync" disabled="@(!CanSaveDocument || isSaving)">
                        @(isSaving ? "Guardando..." : "Guardar documento")
                    </button>

                    <button type="button" class="secondary" @onclick="ClearForm" disabled="@isSaving">
                        Limpiar
                    </button>
                </div>
            </article>

            <article class="docs-card docs-table-card">
                <div class="docs-card-title">
                    <div>
                        <h3>Documentos encontrados</h3>
                        <p>Documentos reales cargados desde hoja de vida, facturas, mantenimiento, actas o garantías del activo.</p>
                    </div>

                    <div class="docs-filters">
                        <input class="form-control"
                               placeholder="Buscar documento, activo, código, responsable..."
                               @bind="documentSearchText"
                               @bind:event="oninput" />

                        <select class="form-select" @bind="selectedToolFilter">
                            <option value="">Todos los activos</option>
                            @foreach (var asset in assets.OrderBy(x => x.InternalCode))
                            {
                                <option value="@asset.Id.ToString()">@asset.InternalCode</option>
                            }
                        </select>
                    </div>
                </div>

                @if (isLoading)
                {
                    <div class="docs-empty">Cargando documentos desde inventario...</div>
                }
                else if (!FilteredDocuments.Any())
                {
                    <div class="docs-empty">No hay documentos para la clasificación o filtros seleccionados.</div>
                }
                else
                {
                    <div class="docs-table-wrapper">
                        <table class="docs-table">
                            <thead>
                                <tr>
                                    <th>Documento</th>
                                    <th>Clasificación</th>
                                    <th>Activo / herramienta</th>
                                    <th>Responsable</th>
                                    <th>Fecha</th>
                                    <th>Tamaño</th>
                                    <th>Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in FilteredDocuments)
                                {
                                    <tr>
                                        <td>
                                            <strong>@GetDocumentDisplayName(item)</strong>
                                            <small>@item.FileName</small>
                                            <small>@Show(item.Description)</small>
                                        </td>

                                        <td>
                                            <span class="docs-type-pill">@GetDocumentCategory(item)</span>
                                        </td>

                                        <td>
                                            <strong>@item.ToolInternalCode</strong>
                                            <small>@item.ToolName</small>
                                            <small>@Show(item.BranchCode) · @Show(item.ResponsiblePersonName)</small>
                                        </td>

                                        <td>@Show(item.UploadedBy)</td>
                                        <td>@item.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@FormatBytes(item.SizeBytes)</td>

                                        <td>
                                            <div class="docs-row-actions">
                                                <button type="button" @onclick="() => OpenDocument(item)">
                                                    Ver
                                                </button>

                                                @if (CanDownloadDocuments)
                                                {
                                                    <a href="@BuildDownloadUrl(item.DownloadUrl)" target="_blank">
                                                        Descargar
                                                    </a>
                                                }
                                                else
                                                {
                                                    <button type="button" class="docs-disabled-action" disabled>
                                                        Descargar
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </article>
        }
    </main>
</section>

@if (showPhysicalModal)
{
    <div class="docs-modal-backdrop" @onclick="ClosePhysicalModal">
        <section class="docs-modal docs-document-modal" @onclick:stopPropagation="true">
            <header>
                <div class="docs-modal-title">
                    <span>📦</span>
                    <div>
                        <strong>@(SelectedPhysicalCount?.CountNumber ?? "Consolidado de toma física")</strong>
                        <small>@Show(SelectedPhysicalCount?.BranchCode) · @Show(SelectedPhysicalCount?.StatusLabel)</small>
                    </div>
                </div>

                <button type="button" @onclick="ClosePhysicalModal">Cerrar</button>
            </header>

            <div class="docs-modal-body">
                <article>
                    <h3>Resumen de toma</h3>
                    <p><strong>Toma:</strong> @Show(SelectedPhysicalCount?.CountNumber)</p>
                    <p><strong>Sede:</strong> @Show(SelectedPhysicalCount?.BranchCode) - @Show(SelectedPhysicalCount?.BranchName)</p>
                    <p><strong>Estado:</strong> @Show(SelectedPhysicalCount?.StatusLabel)</p>
                    <p><strong>Responsable:</strong> @Show(SelectedPhysicalCount?.ResponsibleBy)</p>
                </article>

                <article>
                    <h3>Avance</h3>
                    <p><strong>Participantes:</strong> @SelectedBoardSummary.TotalParticipants</p>
                    <p><strong>Esperados:</strong> @SelectedBoardSummary.TotalExpected</p>
                    <p><strong>Contados:</strong> @SelectedBoardSummary.TotalCounted</p>
                    <p><strong>Pendientes:</strong> @SelectedBoardSummary.TotalPending</p>
                </article>

                <article class="span-2">
                    <h3>Registros reportados</h3>

                    <div class="docs-table-wrapper">
                        <table class="docs-table">
                            <thead>
                                <tr>
                                    <th>Tipo</th>
                                    <th>Código / nombre</th>
                                    <th>Usuario</th>
                                    <th>Estado</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in FilteredReportedItems)
                                {
                                    <tr>
                                        <td>@Show(item.ReportTypeLabel)</td>
                                        <td>
                                            <strong>@Show(item.ToolInternalCode)</strong>
                                            <small>@Show(item.ToolName)</small>
                                            <small>@Show(item.ReportedName)</small>
                                        </td>
                                        <td>@Show(item.ParticipantName)</td>
                                        <td>@GetReconciliationLabel(item)</td>
                                        <td>@item.ReportedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </article>
            </div>
        </section>
    </div>
}

@if (showDocumentModal && selectedDocument is not null)
{
    <div class="docs-modal-backdrop" @onclick="CloseDocument">
        <section class="docs-modal docs-document-modal" @onclick:stopPropagation="true">
            <header>
                <div class="docs-modal-title">
                    <span>📄</span>
                    <div>
                        <strong>@GetDocumentDisplayName(selectedDocument)</strong>
                        <small>@selectedDocument.ToolInternalCode · @GetDocumentCategory(selectedDocument)</small>
                    </div>
                </div>

                <button type="button" @onclick="CloseDocument">Cerrar</button>
            </header>

            <div class="docs-modal-body">
                <article>
                    <h3>Información del documento</h3>
                    <p><strong>Archivo:</strong> @selectedDocument.FileName</p>
                    <p><strong>Clasificación:</strong> @GetDocumentCategory(selectedDocument)</p>
                    <p><strong>Tamaño:</strong> @FormatBytes(selectedDocument.SizeBytes)</p>
                    <p><strong>Responsable:</strong> @Show(selectedDocument.UploadedBy)</p>
                    <p><strong>Fecha:</strong> @selectedDocument.UploadedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                </article>

                <article>
                    <h3>Activo asociado</h3>
                    <p><strong>Código:</strong> @selectedDocument.ToolInternalCode</p>
                    <p><strong>Nombre:</strong> @selectedDocument.ToolName</p>
                    <p><strong>Sede:</strong> @Show(selectedDocument.BranchCode)</p>
                    <p><strong>Responsable activo:</strong> @Show(selectedDocument.ResponsiblePersonName)</p>
                </article>

                <article class="span-2">
                    <h3>Descripción</h3>
                    <p>@Show(selectedDocument.Description)</p>
                </article>

                <article class="span-2">
                    <h3>Acciones</h3>
                    <div class="docs-modal-actions">
                        @if (CanDownloadDocuments)
                        {
                            <a href="@BuildDownloadUrl(selectedDocument.DownloadUrl)" target="_blank">Descargar documento</a>
                        }
                        else
                        {
                            <button type="button" class="docs-disabled-action" disabled>Descarga restringida</button>
                        }
                    </div>
                </article>
            </div>
        </section>
    </div>
}

@if (showManualModal)
{
    <div class="docs-modal-backdrop" @onclick="CloseManual">
        <section class="docs-modal" @onclick:stopPropagation="true">
            <header>
                <div class="docs-modal-title">
                    <span>@SelectedManual.Icon</span>
                    <div>
                        <strong>@SelectedManual.Title</strong>
                        <small>@SelectedManual.Module</small>
                    </div>
                </div>

                <button type="button" @onclick="CloseManual">Cerrar</button>
            </header>

            <div class="docs-modal-body">
                <article>
                    <h3>Descripción general</h3>
                    <p>@SelectedManual.Description</p>
                </article>

                <article>
                    <h3>Objetivo</h3>
                    <p>@SelectedManual.Purpose</p>
                </article>

                <article class="span-2">
                    <h3>Proceso funcional</h3>
                    <ol>
                        @foreach (var step in SelectedManual.Steps)
                        {
                            <li>@step</li>
                        }
                    </ol>
                </article>

                <article class="span-2">
                    <h3>Reglas y validaciones</h3>
                    <ul>
                        @foreach (var rule in SelectedManual.Rules)
                        {
                            <li>@rule</li>
                        }
                    </ul>
                </article>

                <article class="span-2">
                    <h3>Documentos relacionados</h3>
                    <ul>
                        @foreach (var doc in SelectedManual.RelatedDocuments)
                        {
                            <li>@doc</li>
                        }
                    </ul>
                </article>
            </div>
        </section>
    </div>
}

<style>
    .docs-hero {
        margin-bottom: .7rem;
        padding: .95rem 1.1rem;
        border-radius: 1rem;
        background: linear-gradient(105deg, #050507 0%, #07070b 34%, #120017 58%, #350040 78%, #710083 100%);
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        box-shadow: 0 .55rem 1.2rem rgba(75,0,92,.18);
    }

    .docs-pill {
        display: inline-flex;
        padding: .18rem .62rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.35);
        background: rgba(255,255,255,.10);
        font-size: .68rem;
        font-weight: 950;
    }

    .docs-hero h2 {
        margin: .34rem 0 .14rem;
        font-size: 1.75rem;
        font-weight: 950;
        line-height: 1.05;
    }

    .docs-hero p {
        margin: 0;
        color: rgba(255,255,255,.88);
        font-size: .88rem;
    }

    .docs-hero-actions {
        width: 190px;
        display: grid;
        gap: .42rem;
    }

    .docs-hero-btn {
        width: 190px;
        min-height: 36px;
        border-radius: .6rem;
        border: 1px solid rgba(255,255,255,.70);
        background: rgba(255,255,255,.08);
        color: white;
        font-weight: 950;
        font-size: .76rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .docs-kpis {
        display: grid;
        grid-template-columns: repeat(4, minmax(130px, 1fr));
        gap: .45rem;
        margin-bottom: .65rem;
    }

    .docs-kpis article,
    .docs-card {
        background: #fff;
        border: 1px solid #eadff0;
        border-radius: .9rem;
        box-shadow: 0 .25rem .75rem rgba(75,0,92,.045);
    }

    .docs-kpis article {
        border-left: 4px solid #2186d9;
        padding: .55rem;
    }

    .docs-kpis article.success { border-left-color: #198754; }
    .docs-kpis article.warning { border-left-color: #ffc107; }
    .docs-kpis article.purple { border-left-color: #7b0d8e; }

    .docs-kpis span {
        display: block;
        color: #526071;
        font-size: .62rem;
        font-weight: 950;
        text-transform: uppercase;
    }

    .docs-kpis strong {
        display: block;
        color: #06111f;
        font-size: 1.35rem;
        font-weight: 950;
        line-height: 1;
    }

    .docs-kpis small {
        color: #657083;
        font-size: .62rem;
    }

    .docs-workspace {
        display: grid;
        grid-template-columns: 315px minmax(0, 1fr);
        gap: .65rem;
        align-items: start;
    }

    .docs-main {
        display: grid;
        gap: .65rem;
        min-width: 0;
