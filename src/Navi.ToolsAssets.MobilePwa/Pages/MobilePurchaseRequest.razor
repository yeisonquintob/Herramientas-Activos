    private async Task LoadLocalStateAsync()
    {
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", "navi-mobile-purchase-request-v1");
            storedRequests = string.IsNullOrWhiteSpace(json)
                ? new()
                : JsonSerializer.Deserialize<List<StoredPurchaseRequest>>(json, jsonOptions) ?? new();
        }
        catch
        {
            storedRequests = new();
        }
    }

    private async Task SaveLocalStateAsync()
    {
        var json = JsonSerializer.Serialize(storedRequests, jsonOptions);
        await JS.InvokeVoidAsync("localStorage.setItem", "navi-mobile-purchase-request-v1", json);
