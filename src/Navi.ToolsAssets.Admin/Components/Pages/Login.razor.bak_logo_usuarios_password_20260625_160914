@page "/login"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using System.Text.Json
@using Microsoft.JSInterop
@using Navi.ToolsAssets.Admin.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject WebAuthSessionService AuthSession
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Login - NAVI Herramientas</PageTitle>

<div class="login-shell">
    <section class="login-card">
        <div class="login-brand">
            <div class="login-logo">N</div>
            <div>
                <h1>NAVI Herramientas</h1>
                <p>Seguridad real por usuario, rol, sede y permisos</p>
            </div>
        </div>

        <EditForm Model="loginModel" OnValidSubmit="LoginAsync">
            <DataAnnotationsValidator />

            <div class="form-group mb-3">
                <label>Usuario</label>
                <InputText class="form-control"
                           @bind-Value="loginModel.UserName"
                           placeholder="admin, herramientero, tecnico..." />
                <ValidationMessage For="@(() => loginModel.UserName)" />
            </div>

            <div class="form-group mb-3">
                <label>Contraseña</label>
                <InputText type="password"
                           class="form-control"
                           @bind-Value="loginModel.Password"
                           placeholder="Por ahora cualquier contraseña no vacía" />
                <ValidationMessage For="@(() => loginModel.Password)" />
                <small class="text-muted">MVP: valida usuario activo en base de datos y contraseña no vacía.</small>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(infoMessage))
            {
                <div class="alert alert-info">@infoMessage</div>
            }

            <button type="submit" class="btn btn-primary w-100" disabled="@isLoading">
                @(isLoading ? "Ingresando..." : "Ingresar")
            </button>
        </EditForm>

        <div class="login-demo-users">
            <span>Usuarios demo:</span>
            <button type="button" @onclick='() => UseDemo("admin")'>Admin</button>
            <button type="button" @onclick='() => UseDemo("herramientero")'>Herramientero</button>
            <button type="button" @onclick='() => UseDemo("tecnico")'>Técnico</button>
            <button type="button" @onclick='() => UseDemo("auditor")'>Auditor</button>
            <button type="button" @onclick='() => UseDemo("gerencial")'>Gerencial</button>
            <button type="button" @onclick='() => UseDemo("sede")'>Sede</button>
        </div>
    </section>
</div>

<style>
