    private List<ToolItem> tools = new();
    private List<ResponsibleItem> responsibles = new();
    private List<BranchItem> branches = new();
    private List<LocationItem> locations = new();
    private List<LoanRequestItem> loanRequests = new();
    private List<UserItem> users = new();

    private AssignmentForm form = new();
    private AssignmentRequestForm requestForm = new();

    private string assignmentToolSearchText = string.Empty;
    private string assignmentResponsibleSearchText = string.Empty;
    private string assignmentBranchSearchText = string.Empty;
    private string assignmentLocationSearchText = string.Empty;
    private string historyResponsibleSearchText = string.Empty;
    private string selectedResponsibleSearchText = string.Empty;
    private string selectedBranchSearchText = string.Empty;
    private string selectedBranchCode = string.Empty;
    private bool branchFilterInitialized;

    private bool isLoading;
    private bool isSaving;
    private string search = string.Empty;
    private string selectedResponsibleId = string.Empty;
    private string historyResponsibleId = string.Empty;
    private string historySearch = string.Empty;
