@inherits LayoutComponentBase
@inject MobileAuthSessionService Auth
@inject NavigationManager Navigation

<div class="mobile-shell">
    <main class="mobile-main">
        @if (!isReady)
        {
            <section class="mobile-page">
                <div class="mobile-empty">
                    <strong>Validando permisos</strong>
                    <span>Estamos verificando tu acceso móvil.</span>
                </div>
            </section>
        }
        else if (IsRouteDenied)
        {
            <section class="mobile-page">
                <div class="mobile-empty">
                    <strong>Acceso restringido</strong>
                    <span>No tienes permiso para visualizar esta pantalla en la app móvil.</span>
                    <button class="mobile-primary-button" type="button" @onclick="GoHome">Volver al inicio</button>
                </div>
            </section>
        }
        else
        {
            @Body
        }
    </main>

    <NavMenu />
</div>

@code {
    private bool isReady;

    protected override async Task OnParametersSetAsync()
    {
        await Auth.InitializeAsync();
        isReady = true;
    }

    private bool IsRouteDenied
    {
        get
        {
            if (!Auth.IsAuthenticated)
            {
                return false;
            }

            var path = Navigation.ToBaseRelativePath(Navigation.Uri)
                .Split('?', '#')[0]
                .Trim('/')
                .ToLowerInvariant();

            if (string.IsNullOrWhiteSpace(path) || path == "login")
            {
                return false;
            }

            return !CanAccessRoute(path);
        }
    }

    private bool CanAccessRoute(string path)
    {
        
        
        
        
        // NAVI LIFE RECORD INTERNAL VALIDATION START
        // Hoja de vida móvil valida permisos y alcance dentro de sus componentes.
        if (path == "mobile/life-records" ||
            (path.StartsWith("tools/") &&
             (path.Contains("/life-record") || path.Contains("/technical-life-record"))))
        {
            return true;
        }
        // NAVI LIFE RECORD INTERNAL VALIDATION END

// NAVI HISTORY INTERNAL VALIDATION START
        // El historial valida AssetAssignment.History dentro de MobileHistory.razor.
        if (path == "mobile/history")
        {
            return true;
        }
        // NAVI HISTORY INTERNAL VALIDATION END

// NAVI INVENTORY INTERNAL VALIDATION START
        // Inventario AF valida Tools.View dentro de MyTools.razor.
        // Mis activos queda como función base.
        if (path == "all-tools" || path.StartsWith("all-tools/"))
        {
            return true;
        }
        // NAVI INVENTORY INTERNAL VALIDATION END

// NAVI DASHBOARD INTERNAL VALIDATION START
        // El dashboard móvil valida Dashboard.View dentro de MobileDashboard.razor.
        // No debe quedar bloqueado por Mobile.Access global.
        if (path == "mobile/dashboard")
        {
            return true;
        }
        // NAVI DASHBOARD INTERNAL VALIDATION END

if (!Auth.CanAccessMobile())
        {
            return false;
        }

        if (string.IsNullOrWhiteSpace(path) || path == "login" || path == "logout")
        {
            return true;
        }

        if (path == "counter" || path == "weather")
        {
            return false;
        }

        // Funciones base móviles siempre disponibles para usuario autenticado.
        if (path == "my-tools" ||
            path.StartsWith("my-tools/") ||
            path == "report-damage" ||
            path.StartsWith("report-damage/"))
        {
            return true;
        }

        // Dashboard.
        if (path == "mobile/dashboard")
        {
            // Validación interna en MobileDashboard.razor.
            return true;
        }

        // Inventario general.
        if (path == "all-tools" || path.StartsWith("all-tools/"))
        {
            return Auth.HasPermission("Tools.View");
        }

        // Disponible y ubicación.
        if (path == "asset-availability" ||
            path == "mobile/availability" ||
            path == "availability-location" ||
            path == "available-location" ||
            path == "disponible-ubicacion")
        {
            return Auth.HasAnyPermission(
                "AssetAvailability.View",
                "AssetAvailability.Update",
                "AssetAvailability.Manage",
                "Tools.View");
        }

        // Detalle, hoja de vida y rutas relacionadas a un activo.
        if (path.StartsWith("tools/") &&
            (path.Contains("/life-record") ||
             path.Contains("/technical-life-record") ||
             path.Contains("/life-record-view") ||
             path.Contains("/technical-life-record-view")))
        {
            return Auth.HasAnyPermission(
                "TechnicalLifeRecord.View",
                "TechnicalLifeRecord.Export",
                "ToolDetail.LifeRecord.Open",
                "ToolDetail.View",
                "Tools.View",
                "Mobile.Tools.View");
        }

        if (path == "mobile/life-records")
        {
            return Auth.HasAnyPermission(
                "TechnicalLifeRecord.View",
                "TechnicalLifeRecord.Export",
                "ToolDetail.LifeRecord.Open",
                "ToolDetail.View",
                "Tools.View",
                "Mobile.Tools.View");
        }

        if (path.StartsWith("tools/"))
        {
            return Auth.HasAnyPermission(
                "ToolDetail.View",
                "Tools.View",
                "Mobile.Tools.View",
                "TechnicalLifeRecord.View",
                "ToolDetail.LifeRecord.Open");
        }

        // Asignación, préstamos, devolución y movimientos.
        if (path == "mobile/assignment")
        {
            return Auth.HasAnyPermission(
                "AssetAssignment.View",
                "AssetAssignment.Request",
                "Mobile.Loans.Request",
                "AssetAssignment.Assign",
                "AssetAssignment.Return",
                "AssetAssignment.Approve",
                "AssetAssignment.Deny",
                "AssetAssignment.History",
                "Loans.View",
                "Loans.Request",
                "Returns.View");
        }

        if (path == "mobile/history")
        {
            return Auth.HasAnyPermission(
                "AssetAssignment.History",
                "AssetAssignment.View",
                "Loans.View",
                "Returns.View");
        }

        // Documentos y evidencias.
        if (path == "mobile/documents")
        {
            return Auth.HasAnyPermission(
                "Documents.View",
                "Documents.Upload",
                "Documents.Download",
                "Documents.Delete",
                "ToolDetail.Documents.View",
                "ToolDetail.Documents.Upload");
        }

        // Tomas físicas móviles: consultar, reportar y cargar evidencia.
        if (path == "mobile/physical-counts" ||
            path.StartsWith("mobile/physical-counts/"))
        {
            return Auth.HasAnyPermission(
                "PhysicalCounts.View",
                "PhysicalCounts.Report",
                "PhysicalCounts.Evidence.Upload");
        }

        // Reportes.
        if (path == "mobile/reports")
        {
            return Auth.HasAnyPermission(
                "Reports.View",
                "Reports.Export");
        }

        // Compras / suministros.
        if (path == "mobile/purchases")
        {
            return Auth.HasAnyPermission(
                "Purchases.View",
                "Purchases.Request",
                "Purchases.Quote",
                "Purchases.Generate",
                "Purchases.Approve",
                "Purchases.Reject",
                "Supplies.View",
                "Supplies.Request",
                "Supplies.Manage");
        }

        // Mantenimiento.
        if (path == "mobile/maintenance-request")
        {
            return Auth.HasAnyPermission(
                "Maintenance.View",
                "Maintenance.Request",
                "Maintenance.Quote",
                "Maintenance.Generate",
                "Maintenance.Execute",
                "Maintenance.Close",
                "Maintenance.Reject",
                "Maintenance.Manage");
        }

        if (path == "mobile/maintenance-plans")
        {
            return Auth.HasAnyPermission(
                "MaintenancePlans.View",
                "MaintenancePlans.Create",
                "MaintenancePlans.Edit",
                "MaintenancePlans.Delete",
                "MaintenancePlans.Manage",
                "Maintenance.View");
        }

        // Conciliación.
        if (path == "mobile/reconciliation")
        {
            return Auth.HasAnyPermission(
                "Reconciliation.View",
                "Reconciliation.Clarify",
                "Reconciliation.ApproveCreation",
                "Reconciliation.Manage");
        }

        // Preoperacional.
        if (path == "mobile/preoperational")
        {
            return Auth.HasAnyPermission(
                "Mobile.PreOperational.Report",
                "PreOperational.View",
                "PreOperational.Report");
        }

        // Control interno / vencimientos / recepción.
        if (path == "mobile/internal-control")
        {
            return Auth.HasAnyPermission(
                "InternalControl.View",
                "InternalControl.Manage",
                "Tools.View",
                "Reports.View",
                "Settings.View");
        }

        if (path == "mobile/expirations")
        {
            return Auth.HasAnyPermission(
                "Expirations.View",
                "MaintenancePlans.View",
                "Maintenance.View",
                "Reports.View",
                "Tools.View");
        }

        if (path == "mobile/reception")
        {
            return Auth.HasAnyPermission(
                "Reception.View",
                "Reception.Manage",
                "Purchases.View",
                "Tools.View");
        }

        // Configuración.
        if (path == "mobile/settings")
        {
            return Auth.HasAnyPermission(
                "Settings.View",
                "Settings.Manage",
                "Security.Users",
                "Security.Roles");
        }

        // Si en adelante se agregan estas rutas, quedan preparadas por permiso.
        if (path == "mobile/disposals")
        {
            return Auth.HasAnyPermission(
                "Disposals.View",
                "Disposals.Request",
                "Disposals.Approve",
                "Disposals.Manage");
        }

        if (path == "mobile/returns")
        {
            return Auth.HasAnyPermission(
                "AssetAssignment.Return",
                "Returns.View",
                "Returns.Manage");
        }

        if (path == "mobile/supplies")
        {
            return Auth.HasAnyPermission(
                "Supplies.View",
                "Supplies.Request",
                "Supplies.Manage",
                "Purchases.View",
                "Purchases.Request");
        }


        // Consulta compras y mantenimiento.
        if (path == "mobile/maintenance")
        {
            return Auth.HasAnyPermission(
                "Purchases.View",
                "Purchases.Request",
                "Purchases.Quote",
                "Purchases.Generate",
                "Purchases.Approve",
                "Purchases.Reject",
                "Maintenance.View",
                "Maintenance.Request",
                "Maintenance.Quote",
                "Maintenance.Generate",
                "Maintenance.Execute",
                "Maintenance.Close",
                "Maintenance.Reject");
        }

        // Toda ruta mobile no mapeada queda bloqueada.
        if (path.StartsWith("mobile/"))
        {
            return false;
        }

        return true;
    }



    private void GoHome()
    {
        Navigation.NavigateTo("/", forceLoad: false);
    }
}
