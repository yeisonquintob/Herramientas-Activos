    private async Task GenerateAsync()
    {

        if (!CanGenerateFinalRequest)
        {
            return;
        }

        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            if (!CanGenerateRequest)
            {
                errorMessage = "Debes tener la solicitud en cotización y mínimo una cotización seleccionada.";
                return;
            }

            var selectedLines = SelectedLines.ToList();
            var selectedQuotes = SelectedQuotes.ToList();

            if (IsPurchase)
            {
                await GeneratePurchaseAsync(selectedLines, selectedQuotes);
            }
            else
            {
                await GenerateMaintenanceAsync(selectedLines, selectedQuotes);
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error generando solicitud: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task GeneratePurchaseAsync(List<RequestLineItem> selectedLines, List<QuotationItem> selectedQuotes)
    {

        if (!CanGenerateFinalRequest)
        {
            return;
        }

        var summary = BuildSummary(selectedLines, selectedQuotes);
        var total = selectedQuotes.Sum(x => x.PriceBeforeVat ?? 0);
        var firstLine = selectedLines.First();

        var request = new CreatePurchaseRequestRequest
        {
            ItemCode = firstLine.TechnicalOrSerial,
            ItemName = string.IsNullOrWhiteSpace(header.RequestName) ? $"SPC - {firstLine.ToolName}" : header.RequestName.Trim(),
            ItemDescription = summary,
            Quantity = selectedLines.Sum(x => x.Quantity),
            Unit = "Und",
            PurchasePurpose = header.RequestType,
            Justification = string.IsNullOrWhiteSpace(header.NeedDescription) ? summary : header.NeedDescription,
            Priority = header.Priority,
            BranchId = TryGuid(header.BranchIdText),
            RequiredAt = header.RequiredAt,
            ProjectId = "SPC-MRO",
            VendorSuggestion = string.Join(" | ", selectedQuotes.Select(x => x.Provider).Distinct()),
            EstimatedCostText = total > 0 ? total.ToString("N0") : null,
            Notes = summary,
            SendToReview = true
        };

        var api = CreateApiClient();
        var response = await api.PostAsJsonAsync("api/purchase-requests", request);

        if (!response.IsSuccessStatusCode)
        {
            var error = await response.Content.ReadFromJsonAsync<ApiError>();
            errorMessage = error?.Message ?? "No se pudo generar la solicitud de compra.";
            return;
        }

        await RemoveActiveAfterGeneratedAsync();
        successMessage = "Solicitud de compra generada correctamente.";
        await LoadAsync();
    }

    private async Task GenerateMaintenanceAsync(List<RequestLineItem> selectedLines, List<QuotationItem> selectedQuotes)
    {

        if (!CanGenerateFinalRequest)
        {
            return;
        }

        var summary = BuildSummary(selectedLines, selectedQuotes);
        var total = selectedQuotes.Sum(x => x.PriceBeforeVat ?? 0);
        var firstLine = selectedLines.First();

        var request = new CreateMaintenanceRequestRequest
        {
            BranchId = TryGuid(header.BranchIdText),
            RequestType = header.RequestType,
            Priority = header.Priority,
            Title = string.IsNullOrWhiteSpace(header.RequestName) ? $"Mantenimiento - {firstLine.ToolName}" : header.RequestName.Trim(),
            ProblemDescription = summary,
            WorkDescription = header.NeedDescription,
            FailureCause = string.Join(" | ", selectedLines.Select(x => x.Novelty).Where(x => !string.IsNullOrWhiteSpace(x))),
            RequiresStop = selectedLines.Any(x => x.Criticality == "Crítica"),
            IsSafetyRisk = selectedLines.Any(x => x.Criticality == "Crítica"),
            EstimatedCostText = total > 0 ? total.ToString("N0") : null,
            VendorSuggestion = string.Join(" | ", selectedQuotes.Select(x => x.Provider).Distinct()),
            Notes = summary,
            SendToReview = true
        };

        var api = CreateApiClient();
        var response = await api.PostAsJsonAsync("api/maintenance-requests", request);

        if (!response.IsSuccessStatusCode)
        {
            var error = await response.Content.ReadFromJsonAsync<ApiError>();
            errorMessage = error?.Message ?? "No se pudo generar la solicitud de mantenimiento.";
            return;
        }

        await RemoveActiveAfterGeneratedAsync();
        successMessage = "Solicitud de mantenimiento generada correctamente.";
        await LoadAsync();
    }

    private async Task RemoveActiveAfterGeneratedAsync()
    {

        if (!CanGenerateFinalRequest)
        {
            return;
        }

        if (activeStoredRequestId.HasValue)
        {
            storedRequests.RemoveAll(x => x.Id == activeStoredRequestId.Value);
            await SaveLocalStateAsync();
        }

        ClearWorkspace();
    }

    private string BuildSummary(List<RequestLineItem> lines, List<QuotationItem> quotes)
    {
        var sb = new StringBuilder();

        sb.AppendLine("ENCABEZADO");
        sb.AppendLine($"Solicitud: {Display(header.RequestName)}");
        sb.AppendLine($"Tipo: {Display(header.RequestType)}");
        sb.AppendLine($"Sede: {SelectedBranchLabel}");
        sb.AppendLine($"Solicitante: {Display(header.RequestedBy)}");
        sb.AppendLine($"Responsable aprueba: {Display(header.Approver)}");
        sb.AppendLine($"Prioridad: {Display(header.Priority)}");
        sb.AppendLine($"Fecha requerida: {FormatDate(header.RequiredAt)}");
        sb.AppendLine($"Ubicación/área: {Display(header.Location)}");
        sb.AppendLine($"Necesidad: {Display(header.NeedDescription)}");
        sb.AppendLine();

        sb.AppendLine("HERRAMIENTAS / KIT");
        foreach (var line in lines)
        {
            sb.AppendLine($"- {line.ToolName} | Cantidad: {line.Quantity} | Técnico/Serial: {Display(line.TechnicalOrSerial)} | Criticidad: {Display(line.Criticality)}");
            sb.AppendLine($"  Foto/evidencia: {Display(line.ImageReference)}");
            sb.AppendLine($"  Detalles: {Display(line.Details)}");
            sb.AppendLine($"  Novedades: {Display(line.Novelty)}");
        }

        sb.AppendLine();
        sb.AppendLine("COTIZACIONES");
        foreach (var quote in quotes)
        {
            sb.AppendLine($"- Proveedor: {quote.Provider} | Herramienta: {GetLineName(quote.LineId)} | Fecha: {FormatDate(quote.QuotationDate)} | Entrega: {Display(quote.DeliveryTime)} | Precio sin IVA: {FormatMoney(quote.PriceBeforeVat)}");
            sb.AppendLine($"  Detalles: {Display(quote.AdditionalDetails)}");
        }

        return sb.ToString();
    }

    private void ClearWorkspace()
    {
        activeStoredRequestId = null;
        editingLineId = null;
        editingQuoteId = null;
        currentStatus = "New";
        currentLines = new();
        currentQuotes = new();
        ClearLine();
        ClearQuotation();

        var currentRequester = header.RequestedBy;
        var currentBranch = header.BranchIdText;

        header.Clear();
        ResetHeaderDefaults();

        if (!string.IsNullOrWhiteSpace(currentRequester))
        {
            header.RequestedBy = currentRequester;
        }

        if (!string.IsNullOrWhiteSpace(currentBranch))
        {
            header.BranchIdText = currentBranch;
        }
    }

    private string GetLineName(Guid? id)
    {
        if (!id.HasValue)
        {
            return "Toda la solicitud / kit";
        }

        return currentLines.FirstOrDefault(x => x.Id == id.Value)?.ToolName ?? "Herramienta no encontrada";
    }

    private string BuildLocalNumber(string status, DateTime date)
    {
        var prefix = IsPurchase ? "BOR-COMP" : "BOR-MANT";
        var suffix = status == LocalStatusConfirmed ? "CONF" : "DRAFT";
        return $"{prefix}-{suffix}-{date:yyyyMMddHHmmss}";
    }

    private string GetStoredStatusLabel(string status)
    {
        return status switch
        {
            LocalStatusDraft => "Borrador",
            LocalStatusConfirmed => "Confirmada / pendiente por cotizar",
            LocalStatusQuoting => "Cotizando",
            _ => status
        };
    }

    private string GetStoredStatusClass(string status)
    {
        return status switch
        {
            LocalStatusDraft => "status-pill draft",
            LocalStatusConfirmed => "status-pill confirmed",
            LocalStatusQuoting => "status-pill quoting",
            _ => "status-pill"
        };
    }

    private string GetStoredRowClass(StoredRequest item)
    {
        return item.Status switch
        {
            LocalStatusDraft => "draft-row",
            LocalStatusConfirmed => "confirmed-row",
            LocalStatusQuoting => "quoting-row",
            _ => string.Empty
        };
    }

    private static Guid? TryGuid(string? value)
    {
        return Guid.TryParse(value, out var id) ? id : null;
    }

    private static string Display(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "—" : value;
    }

    private static string FormatDate(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("dd/MM/yyyy") : "—";
    }

    private static string FormatDateTime(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("dd/MM/yyyy HH:mm") : "—";
    }

    private static string FormatMoney(decimal? value)
    {
        return value.HasValue ? $"${value.Value:N0}" : "—";
    }

    private static string GetStatusLabel(string status)
    {
        return status switch
        {
            "Draft" => "Borrador",
            "InReview" => "En revisión",
            "Approved" => "Aprobado",
            "Scheduled" => "Programado",
            "InExecution" => "En ejecución",
            "Closed" => "Cerrado",
            "Rejected" => "Rechazado",
            "Canceled" => "Cancelado",
            _ => status
        };
    }

    private sealed class StoredRequest
    {
        public Guid Id { get; set; }
        public string LocalNumber { get; set; } = string.Empty;
        public string Status { get; set; } = LocalStatusDraft;
        public RequestHeader Header { get; set; } = new();
        public List<RequestLineItem> Lines { get; set; } = new();
