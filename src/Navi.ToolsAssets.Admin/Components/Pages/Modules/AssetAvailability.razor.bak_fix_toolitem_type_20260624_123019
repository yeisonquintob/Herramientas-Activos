        font-weight: 900;
        margin-bottom: .6rem;
    }

    .af-banner h2 {
        color: #fff;
        font-weight: 950;
        margin: 0;
    }

    .af-banner p {
        color: rgba(255,255,255,.78);
        margin: .35rem 0 0;
        font-size: .9rem;
    }

    .af-banner-side {
        min-width: 185px;
        display: grid;
        gap: .65rem;
    }

    .af-status-box {
        background: rgba(255,255,255,.12);
        border-radius: .65rem;
        padding: .55rem .75rem;
        text-align: right;
    }

    .af-status-box span {
        color: #ffdd57;
        display: block;
        font-size: .75rem;
        font-weight: 900;
    }

    .af-grid {
        display: grid;
        grid-template-columns: 360px minmax(0, 1fr);
        gap: 1rem;
    }

    .af-card {
        background: #fff;
        border: 1px solid #dfe3e8;
        border-radius: .85rem;
        padding: 1rem;
        box-shadow: 0 .3rem .75rem rgba(0,0,0,.045);
    }

