    private void BuildAccessoryValidationForms()
    {
        accessoryValidations = new();

        if (lifeRecord?.Accessories is null || lifeRecord.Accessories.Count == 0)
        {
            return;
        }

        foreach (var accessory in lifeRecord.Accessories.OrderBy(x => x.Name))
        {
            accessoryValidations.Add(new AccessoryValidationForm
            {
                Name = accessory.Name,
                QuantityExpected = accessory.Quantity,
                QuantityFound = accessory.Quantity,
                IsPresent = true,
                Status = "Good",
                Observation = string.IsNullOrWhiteSpace(accessory.Observation)
                    ? "Accesorio verificado durante toma física."
                    : accessory.Observation
            });
        }
    }

    private string BuildFinalObservation()
    {
        var baseObservation = form.Observation?.Trim() ?? string.Empty;
        const string marker = "VALIDACIÓN DE ACCESORIOS:";

        var existingIndex = baseObservation.IndexOf(marker, StringComparison.OrdinalIgnoreCase);
        if (existingIndex >= 0)
        {
            baseObservation = baseObservation[..existingIndex].Trim();
        }

        if (accessoryValidations.Count == 0)
        {
            return baseObservation;
        }

        var lines = new List<string>
        {
            marker
        };

        foreach (var accessory in accessoryValidations)
        {
            var presentText = accessory.IsPresent ? "Sí" : "No";

            lines.Add(
                $"- {accessory.Name}: Presente={presentText}; Cantidad esperada={accessory.QuantityExpected:N2}; Cantidad encontrada={accessory.QuantityFound:N2}; Estado={accessory.Status}; Observación={Display(accessory.Observation)}");
        }

        var accessoryText = string.Join(Environment.NewLine, lines);

        return string.IsNullOrWhiteSpace(baseObservation)
            ? accessoryText
            : baseObservation + Environment.NewLine + Environment.NewLine + accessoryText;
    }
    private async Task ConfirmToolAsync()
    {
        await SendReportAsync("Confirmed");
    }

    private async Task RejectToolAsync()
    {
        if (string.IsNullOrWhiteSpace(form.Observation))
        {
            errorMessage = "Debes ingresar un comentario indicando por qué rechazas la herramienta.";
            return;
        }

        await SendReportAsync("Rejected");
    }

    private async Task SendReportAsync(string action)
    {
        isSaving = true;
        errorMessage = null;
        successMessage = null;

        try
        {
            var api = HttpClientFactory.CreateClient("NaviApi");

            var finalObservation = BuildFinalObservation();
            form.Observation = finalObservation;

            if (action.Equals("Confirmed", StringComparison.OrdinalIgnoreCase))
            {
                await UpdateAllowedToolFieldsAsync(api);
            }

            if (selectedEvidence is not null)
            {
                await UploadEvidenceAsync(api);
            }

            var response = await api.PostAsJsonAsync(
                $"api/physical-counts/participants/{ParticipantId}/report-assigned-tool",
                new
                {
                    ToolAssetId,
                    ReportAction = action,
                    form.PhysicalStatus,
                    FoundLocation = GetSelectedLocationName(),
                    form.Observation,
                    ActionBy = "admin"
                });

            if (!response.IsSuccessStatusCode)
            {
                var detail = await response.Content.ReadAsStringAsync();
                errorMessage = $"No se pudo guardar el reporte. {detail}";
                return;
            }

            successMessage = action == "Confirmed"
                ? "Herramienta reportada correctamente como completa."
                : "Herramienta rechazada y enviada a pendiente de conciliación.";

            await Task.Delay(650);
            GoBack();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error guardando validación: {ex.Message}";
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task UpdateAllowedToolFieldsAsync(HttpClient api)
    {
        var masterResponse = await api.PatchAsJsonAsync(
            $"api/tools/{ToolAssetId}/master-data",
            new
            {
                OperationalStatus = form.OperationalStatus,
                PhysicalStatus = form.PhysicalStatus,
                UpdatedBy = "admin"
            });

        if (!masterResponse.IsSuccessStatusCode)
        {
            var detail = await masterResponse.Content.ReadAsStringAsync();
            throw new InvalidOperationException($"No se pudieron actualizar estados permitidos. {detail}");
        }

        if (form.LocationId.HasValue && form.LocationId.Value != Guid.Empty)
        {
            var selectedLocation = locations.FirstOrDefault(x => x.Id == form.LocationId.Value);

            var locationResponse = await api.PatchAsJsonAsync(
                $"api/tools/{ToolAssetId}/availability-location",
                new
                {
                    BranchId = tool?.BranchId ?? selectedLocation?.BranchId ?? Guid.Empty,
                    LocationId = form.LocationId,
                    OperationalStatus = form.OperationalStatus,
                    Observation = form.Observation,
                    ChangedBy = "admin"
                });

            if (!locationResponse.IsSuccessStatusCode)
            {
                var detail = await locationResponse.Content.ReadAsStringAsync();
                throw new InvalidOperationException($"No se pudo actualizar la ubicación permitida. {detail}");
            }
        }
    }

    private async Task UploadEvidenceAsync(HttpClient api)
    {
        if (selectedEvidence is null)
        {
            return;
        }

        using var formData = new MultipartFormDataContent();

        var stream = selectedEvidence.OpenReadStream(50_000_000);
        var fileContent = new StreamContent(stream);
        fileContent.Headers.ContentType = new MediaTypeHeaderValue(
            string.IsNullOrWhiteSpace(selectedEvidence.ContentType)
                ? "application/octet-stream"
                : selectedEvidence.ContentType);

        formData.Add(fileContent, "file", selectedEvidence.Name);
        formData.Add(new StringContent("PhysicalCountEvidence"), "documentType");
        formData.Add(new StringContent(form.EvidenceDescription ?? "Evidencia de toma física"), "description");
        formData.Add(new StringContent("admin"), "uploadedBy");

        var response = await api.PostAsync($"api/tools/{ToolAssetId}/documents", formData);

        if (!response.IsSuccessStatusCode)
        {
            var detail = await response.Content.ReadAsStringAsync();
            throw new InvalidOperationException($"No se pudo cargar la evidencia. {detail}");
        }
    }

