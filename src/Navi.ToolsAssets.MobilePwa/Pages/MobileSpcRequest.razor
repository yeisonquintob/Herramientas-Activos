
@using System.Text.Json
@using System.Net.Http
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@using Navi.ToolsAssets.MobilePwa.Models

@inject NaviMobileApiClient Api
@inject MobileAuthSessionService Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@PageTitleText - NAVI Herramientas y AF</PageTitle>

<section class="mobile-page navi-mobile-spc-v1">
    @if (isLoading && !initialized)
    {
        <div class="mobile-loading">Cargando módulo...</div>
    }
    else if (!Auth.IsAuthenticated)
    {
        <div class="mobile-empty">
            <strong>Sesión requerida</strong>
            <span>Debes iniciar sesión para continuar.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoLogin">Ir al login</button>
        </div>
    }
    else if (!CanAccessModule)
    {
        <div class="mobile-empty">
            <strong>Sin permiso</strong>
            <span>No tienes permisos para visualizar este módulo.</span>
            <button class="mobile-primary-button" type="button" @onclick="GoHome">Volver al inicio</button>
        </div>
    }
    else
    {
        <header class="mspc-hero">
            <div>
                <span>@HeroPill</span>
                <h1>@PageTitleText</h1>
                <p>@PageSubtitle</p>
            </div>

            <div class="mspc-hero-actions">
                <button type="button" @onclick="GoHome">Inicio</button>
                <button type="button" @onclick="RefreshAsync" disabled="@isLoading">
                    @(isLoading ? "Cargando..." : "Actualizar")
                </button>
            </div>
        </header>

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="mobile-alert success">@successMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="mobile-alert error">@errorMessage</div>
        }

        <section class="mspc-kpis">
            <article>
                <span>Locales</span>
                <strong>@LocalVisibleRequests.Count()</strong>
                <small>Borrador/cotización</small>
            </article>

            <article>
                <span>Generadas</span>
                <strong>@FilteredRegistered.Count()</strong>
                <small>API</small>
            </article>

            <article>
                <span>Pendientes</span>
                <strong>@FilteredRegistered.Count(x => IsOpenStatus(x.Status))</strong>
                <small>En proceso</small>
            </article>

            <article>
                <span>Permiso</span>
                <strong>@PermissionMode</strong>
                <small>Matriz</small>
            </article>
        </section>

        <section class="mspc-filter-card">
            <label>
                <span>Buscar</span>
                <input value="@searchText"
                       @oninput="OnSearchChanged"
                       placeholder="Número, herramienta, solicitante, estado..." />
            </label>

            @if (UserCanSeeAllBranches())
            {
                <label>
                    <span>Sede</span>
                    <select value="@selectedBranchCode" @onchange="OnBranchFilterChanged">
                        <option value="">Todas las sedes</option>
                        @foreach (var branch in VisibleBranches)
                        {
                            <option value="@branch.Code">@branch.Code - @branch.Name</option>
                        }
                    </select>
                </label>
            }
            else
            {
                <label>
                    <span>Sede</span>
                    <input value="@ScopeLabel" disabled />
                </label>
            }

            <div class="mspc-status-head">
                <strong>Estados</strong>
                <button type="button" @onclick="ClearFilters">Limpiar filtros</button>
            </div>

            <div class="mspc-status-chips">
                @foreach (var status in StatusOptions)
                {
                    <button type="button"
                            class="@(selectedStatuses.Contains(status.Value) ? "selected" : "")"
                            @onclick="() => ToggleStatus(status.Value)">
                        @status.Text
                    </button>
                }
            </div>
        </section>

        @if (CanCreateOrConfirmRequest)
        {
            <details class="mspc-card" open>
                <summary>
                    <span>Nueva solicitud</span>
                    <em>@RequestVisualState</em>
                </summary>

                <div class="mspc-form-grid">
                    <label>
                        <span>Nombre solicitud</span>
                        <InputText @bind-Value="header.RequestName" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Sede</span>
                        <InputSelect @bind-Value="header.BranchIdText" disabled="@(!CanEditRequest)">
                            <option value="">Seleccione sede</option>
                            @foreach (var branch in VisibleBranches)
                            {
                                <option value="@branch.Id">@branch.Code - @branch.Name</option>
                            }
                        </InputSelect>
                    </label>

                    <label>
                        <span>Solicitante</span>
                        <InputText @bind-Value="header.RequestedBy" disabled />
                    </label>

                    <label>
                        <span>@(IsPurchase ? "Tipo solicitud" : "Tipo mantenimiento")</span>
                        <InputSelect @bind-Value="header.RequestType" disabled="@(!CanEditRequest)">
                            @if (IsPurchase)
                            {
                                <option value="SPC">SPC</option>
                                <option value="Activo fijo">Activo fijo</option>
                                <option value="Herramienta">Herramienta</option>
                                <option value="Equipo">Equipo</option>
                                <option value="Kit de herramientas">Kit de herramientas</option>
                            }
                            else
                            {
                                <option value="Correctivo">Correctivo</option>
                                <option value="Preventivo">Preventivo</option>
                                <option value="Calibración">Calibración</option>
                                <option value="Garantía">Garantía</option>
                                <option value="Seguridad/SSTA">Seguridad/SSTA</option>
                            }
                        </InputSelect>
                    </label>

                    <label>
                        <span>Prioridad</span>
                        <InputSelect @bind-Value="header.Priority" disabled="@(!CanEditRequest)">
                            <option value="Baja">Baja</option>
                            <option value="Media">Media</option>
                            <option value="Alta">Alta</option>
                            <option value="Crítica">Crítica</option>
                        </InputSelect>
                    </label>

                    <label>
                        <span>Fecha requerida</span>
                        <InputDate @bind-Value="header.RequiredAt" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Ubicación / área</span>
                        <InputText @bind-Value="header.Location" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Responsable que aprueba</span>
                        <InputText @bind-Value="header.Approver" disabled="@(!CanEditRequest)" />
                    </label>
                </div>

                <label class="mspc-full">
                    <span>Descripción general de la necesidad</span>
                    <InputTextArea @bind-Value="header.NeedDescription" disabled="@(!CanEditRequest)" />
                </label>

                <div class="mspc-subtitle">
                    <strong>@LinesTitle</strong>
                    <span>Agrega una o varias herramientas, equipos o repuestos.</span>
                </div>

                <div class="mspc-form-grid">
                    <label>
                        <span>Herramienta / equipo</span>
                        <InputText @bind-Value="lineForm.ToolName" disabled="@(!CanEditRequest)" />
                    </label>

                    <label>
                        <span>Serial / referencia técnica</span>
                        <InputText @bind-Value="lineForm.TechnicalOrSerial" disabled="@(!CanEditRequest)" />
                    </label>

                    @if (IsPurchase)
                    {
                        <label>
                            <span>Cantidad</span>
                            <InputNumber @bind-Value="lineForm.Quantity" disabled="@(!CanEditRequest)" />
                        </label>
                    }
                    else
                    {
                        <label>
                            <span>Criticidad</span>
                            <InputSelect @bind-Value="lineForm.Criticality" disabled="@(!CanEditRequest)">
                                <option value="Normal">Normal</option>
                                <option value="Alta">Alta</option>
                                <option value="Crítica">Crítica</option>
                            </InputSelect>
                        </label>
                    }
                </div>

                <label class="mspc-full">
                    <span>Detalle</span>
                    <InputTextArea @bind-Value="lineForm.Details" disabled="@(!CanEditRequest)" />
                </label>

                <label class="mspc-full">
                    <span>Novedad / falla / observación</span>
                    <InputTextArea @bind-Value="lineForm.Novelty" disabled="@(!CanEditRequest)" />
                </label>

                <div class="mspc-action-row">
                    <button type="button" class="primary" @onclick="AddLine" disabled="@(!CanEditRequest)">
                        @(editingLineId.HasValue ? "Actualizar línea" : "Agregar línea")
                    </button>

                    <button type="button" @onclick="ClearLine">
                        Limpiar línea
                    </button>
                </div>

                @if (!currentLines.Any())
                {
                    <div class="mobile-empty compact">No hay herramientas agregadas.</div>
                }
                else
                {
                    <div class="mspc-list">
                        @foreach (var item in currentLines)
                        {
                            <article>
                                <div>
                                    <strong>@item.ToolName</strong>
                                    <span>@item.TechnicalOrSerial</span>
                                    <small>@(IsPurchase ? $"Cantidad: {item.Quantity}" : $"Criticidad: {item.Criticality}")</small>
                                    <small>@item.Details</small>
                                    <small>@item.Novelty</small>
                                </div>

                                <div class="mspc-row-actions">
                                    <label>
                                        <InputCheckbox @bind-Value="item.Selected" disabled="@(!CanEditRequest)" />
                                        Usar
                                    </label>

                                    <button type="button" @onclick="() => EditLine(item.Id)" disabled="@(!CanEditRequest)">Editar</button>
                                    <button type="button" class="danger" @onclick="() => RemoveLine(item.Id)" disabled="@(!CanEditRequest)">Quitar</button>
                                </div>
                            </article>
                        }
                    </div>
                }

                <div class="mspc-action-row footer">
                    <button type="button" @onclick="SaveDraftAsync" disabled="@(!CanSaveAsDraft)">
                        Guardar borrador
                    </button>

                    <button type="button" class="primary" @onclick="ConfirmRequestAsync" disabled="@(!CanConfirmRequest)">
                        Confirmar solicitud
                    </button>

                    <button type="button" class="danger" @onclick="NewRequest">
                        Nueva
                    </button>
                </div>
            </details>
        }

        @if (CanRegisterQuotation)
        {
            <details class="mspc-card" open="@CanQuote">
                <summary>
                    <span>@QuotationTitle</span>
                    <em>@(CanQuote ? "Habilitada" : "Selecciona una solicitud confirmada")</em>
                </summary>

                @if (!CanQuote)
                {
                    <div class="mobile-empty compact">
                        Selecciona una solicitud confirmada y presiona <strong>Realizar cotización</strong>.
                    </div>
                }

                <div class="mspc-form-grid">
                    <label>
                        <span>Proveedor</span>
                        <InputText @bind-Value="quoteForm.Provider" disabled="@(!CanQuote)" />
                    </label>

                    <label>
                        <span>Herramienta cotizada</span>
                        <InputSelect @bind-Value="quoteForm.LineIdText" disabled="@(!CanQuote)">
                            <option value="">Toda la solicitud / kit</option>
                            @foreach (var line in currentLines)
                            {
                                <option value="@line.Id">@line.ToolName</option>
                            }
                        </InputSelect>
                    </label>

                    <label>
                        <span>Fecha cotización</span>
                        <InputDate @bind-Value="quoteForm.QuotationDate" disabled="@(!CanQuote)" />
                    </label>

                    <label>
                        <span>Tiempo entrega / reparación</span>
                        <InputText @bind-Value="quoteForm.DeliveryTime" disabled="@(!CanQuote)" />
                    </label>

                    <label>
                        <span>Precio antes de IVA</span>
                        <InputNumber @bind-Value="quoteForm.PriceBeforeVat" disabled="@(!CanQuote)" />
                    </label>
                </div>

                <label class="mspc-full">
                    <span>Detalle cotización</span>
                    <InputTextArea @bind-Value="quoteForm.AdditionalDetails" disabled="@(!CanQuote)" />
                </label>

                <div class="mspc-action-row">
                    <button type="button" class="primary" @onclick="AddQuotationAsync" disabled="@(!CanQuote)">
                        @(editingQuoteId.HasValue ? "Actualizar cotización" : "Agregar cotización")
                    </button>

                    <button type="button" @onclick="ClearQuotation">
                        Limpiar
                    </button>
                </div>

                @if (!currentQuotes.Any())
                {
                    <div class="mobile-empty compact">No hay cotizaciones agregadas.</div>
                }
                else
                {
                    <div class="mspc-list">
                        @foreach (var quote in currentQuotes)
                        {
                            <article>
                                <div>
                                    <strong>@quote.Provider</strong>
                                    <span>@GetLineName(quote.LineId)</span>
                                    <small>@DateLabel(quote.QuotationDate) · @quote.DeliveryTime</small>
                                    <small>@MoneyLabel(quote.PriceBeforeVat)</small>
                                    <small>@quote.AdditionalDetails</small>
                                </div>

                                <div class="mspc-row-actions">
                                    <label>
                                        <InputCheckbox @bind-Value="quote.Selected" disabled="@(!CanQuote)" />
                                        Usar
                                    </label>

                                    <button type="button" @onclick="() => EditQuotation(quote.Id)" disabled="@(!CanQuote)">Editar</button>
                                    <button type="button" class="danger" @onclick="() => RemoveQuotationAsync(quote.Id)" disabled="@(!CanQuote)">Quitar</button>
                                </div>
                            </article>
                        }
                    </div>
                }
            </details>
        }

        @if (CanGenerateFinalRequest)
        {
            <details class="mspc-card" open>
                <summary>
                    <span>@GenerateTitle</span>
                    <em>@SelectedQuotes.Count() cotización(es)</em>
                </summary>

                <section class="mspc-summary-grid">
                    <article>
                        <span>Líneas seleccionadas</span>
                        <strong>@SelectedLines.Count()</strong>
                    </article>

                    <article>
                        <span>Cotizaciones seleccionadas</span>
                        <strong>@SelectedQuotes.Count()</strong>
                    </article>

                    <article>
                        <span>Total antes de IVA</span>
                        <strong>@MoneyLabel(SelectedQuotes.Sum(x => x.PriceBeforeVat ?? 0))</strong>
                    </article>
                </section>

                <button type="button" class="mspc-generate" @onclick="GenerateAsync" disabled="@(!CanGenerateRequest || isSaving)">
                    @(isSaving ? "Generando..." : GenerateButtonText)
                </button>

                @if (CanQuote && !SelectedQuotes.Any())
                {
                    <div class="mobile-empty compact">Agrega y selecciona al menos una cotización para generar la solicitud.</div>
                }
            </details>
        }

        <details class="mspc-card" open>
            <summary>
                <span>Solicitudes locales</span>
                <em>@LocalVisibleRequests.Count()</em>
            </summary>

            @if (!LocalVisibleRequests.Any())
            {
                <div class="mobile-empty compact">No hay borradores ni solicitudes locales.</div>
            }
            else
            {
                <div class="mspc-list">
                    @foreach (var item in LocalVisibleRequests)
                    {
                        <article>
                            <div>
                                <strong>@item.LocalNumber</strong>
                                <span>@Display(item.Header.RequestName)</span>
                                <small>@Display(item.Header.RequestType) · @Display(item.Header.Priority)</small>
                                <small>@StatusLabel(item.Status) · @DateTimeLabel(item.UpdatedAt)</small>
                            </div>

                            <div class="mspc-row-actions">
                                @if (item.Status == LocalStatusDraft && CanCreateOrConfirmRequest)
                                {
                                    <button type="button" @onclick="() => LoadDraftForEdit(item.Id)">Editar</button>
                                    <button type="button" class="primary" @onclick="() => ConfirmStoredRequestAsync(item.Id)">Confirmar</button>
                                }
                                else if (item.Status == LocalStatusConfirmed && CanRegisterQuotation)
                                {
                                    <button type="button" class="warning" @onclick="() => StartQuotationAsync(item.Id)">Realizar cotización</button>
                                }
                                else if (item.Status == LocalStatusQuoting && CanRegisterQuotation)
                                {
                                    <button type="button" class="warning" @onclick="() => ContinueQuotation(item.Id)">Continuar cotización</button>
                                }

                                <button type="button" class="danger" @onclick="() => DeleteLocalRequestAsync(item.Id)">Eliminar</button>
                            </div>
                        </article>
                    }
                </div>
            }
        </details>

        @if (CanViewGeneratedRequests)
        {
            <details class="mspc-card" open>
                <summary>
                    <span>Solicitudes generadas</span>
                    <em>@FilteredRegistered.Count()</em>
                </summary>

                @if (isLoading)
                {
                    <div class="mobile-empty compact">Cargando solicitudes generadas...</div>
                }
                else if (!FilteredRegistered.Any())
                {
                    <div class="mobile-empty compact">No hay solicitudes generadas visibles para tus filtros.</div>
                }
                else
                {
                    <div class="mspc-list generated">
                        @foreach (var item in FilteredRegistered.Take(80))
                        {
                            <article>
                                <div>
                                    <strong>@item.RequestNumber</strong>
                                    <span>@item.Title</span>
                                    <small>@Display(item.BranchCode) · @Display(item.Priority) · @StatusLabel(item.Status)</small>
                                    <small>@Display(item.RequestedBy) · @DateTimeLabel(item.CreatedAt)</small>
                                </div>

                                <div class="mspc-row-actions">
                                    @if (CanApproveRequest && item.Status == "InReview")
                                    {
                                        <button type="button" class="approve" @onclick="() => ApproveAsync(item)">Aprobar</button>
                                    }

                                    @if (CanRejectRequest && item.Status == "InReview")
                                    {
                                        <button type="button" class="danger" @onclick="() => RejectAsync(item)">Rechazar</button>
                                    }

                                    @if (IsPurchase && CanApproveRequest && item.Status == "Approved")
                                    {
                                        <button type="button" class="primary" @onclick="() => ClosePurchaseAsync(item)">Cerrar</button>
                                    }

                                    @if (IsMaintenance && CanApproveRequest && item.Status == "Approved")
                                    {
                                        <button type="button" class="warning" @onclick="() => ScheduleMaintenanceAsync(item)">Programar</button>
                                    }

                                    @if (IsMaintenance && CanExecuteMaintenance && (item.Status == "Approved" || item.Status == "Scheduled"))
                                    {
                                        <button type="button" class="primary" @onclick="() => StartMaintenanceAsync(item)">Iniciar</button>
                                    }

                                    @if (IsMaintenance && CanExecuteMaintenance && (item.Status == "Approved" || item.Status == "Scheduled" || item.Status == "InExecution"))
                                    {
                                        <button type="button" class="approve" @onclick="() => CloseMaintenanceAsync(item)">Cerrar</button>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                }
            </details>
        }
    }
</section>

@code {
    private const string LocalStatusDraft = "Draft";
    private const string LocalStatusConfirmed = "Confirmed";
    private const string LocalStatusQuoting = "Quoting";
    private const string LocalStatusGenerated = "Generated";

    private readonly JsonSerializerOptions jsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = false
    };

    private bool initialized;
    private bool isLoading = true;
    private bool isSaving;
    private string? successMessage;
    private string? errorMessage;

    private string searchText = string.Empty;
    private string selectedBranchCode = string.Empty;
    private HashSet<string> selectedStatuses = new(StringComparer.OrdinalIgnoreCase);

    private readonly RequestHeader header = new();
    private readonly RequestLineForm lineForm = new();
    private readonly QuotationForm quoteForm = new();

    private List<RequestLineItem> currentLines = new();
    private List<QuotationItem> currentQuotes = new();
    private List<StoredRequest> storedRequests = new();
    private List<ApiRegisteredItem> registeredItems = new();
    private List<MobileBranchDto> branches = new();

    private Guid? activeStoredRequestId;
    private Guid? editingLineId;
    private Guid? editingQuoteId;

    private string currentStatus = "New";

    private bool IsPurchase => new Uri(Navigation.Uri).AbsolutePath.Contains("/mobile/purchases", StringComparison.OrdinalIgnoreCase);
    private bool IsMaintenance => !IsPurchase;

    private string StorageKey => IsPurchase ? "navi-mobile-spc-purchase-v1" : "navi-mobile-spc-maintenance-v1";

    private string PageTitleText => IsPurchase ? "Solicitud de compra" : "Solicitud de mantenimiento";
    private string HeroPill => IsPurchase ? "SPC · COMPRA AF" : "MANTENIMIENTO · SOLICITUD";
    private string PageSubtitle => IsPurchase
        ? "Crea borrador, confirma, cotiza y genera solicitud final según permisos."
        : "Crea borrador, confirma, cotiza, programa y cierra mantenimiento según permisos.";
    private string LinesTitle => IsPurchase ? "Herramientas / activos solicitados" : "Herramientas / equipos a intervenir";
    private string QuotationTitle => IsPurchase ? "Cotización de compra" : "Cotización de mantenimiento";
    private string GenerateTitle => IsPurchase ? "Generar solicitud de compra" : "Generar solicitud de mantenimiento";
    private string GenerateButtonText => IsPurchase ? "Generar compra" : "Generar mantenimiento";

    private bool CanViewGeneratedRequests =>
        HasAny(IsPurchase ? "Purchases.View" : "Maintenance.View",
               IsPurchase ? "Purchases.Request" : "Maintenance.Request",
               IsPurchase ? "Purchases.Generate" : "Maintenance.Generate",
               IsPurchase ? "Purchases.Approve" : "Maintenance.Close",
               IsPurchase ? "Purchases.Reject" : "Maintenance.Reject");

    private bool CanCreateOrConfirmRequest => Has(IsPurchase ? "Purchases.Request" : "Maintenance.Request");
    private bool CanRegisterQuotation => Has(IsPurchase ? "Purchases.Quote" : "Maintenance.Quote");
    private bool CanGenerateFinalRequest => Has(IsPurchase ? "Purchases.Generate" : "Maintenance.Generate");
    private bool CanApproveRequest => Has(IsPurchase ? "Purchases.Approve" : "Maintenance.Close");
    private bool CanRejectRequest => Has(IsPurchase ? "Purchases.Reject" : "Maintenance.Reject");
    private bool CanExecuteMaintenance => IsMaintenance && Has("Maintenance.Execute");

    private bool CanAccessModule =>
        IsPurchase
            ? HasAny("Purchases.View", "Purchases.Request", "Purchases.Quote", "Purchases.Generate", "Purchases.Approve", "Purchases.Reject")
            : HasAny("Maintenance.View", "Maintenance.Request", "Maintenance.Quote", "Maintenance.Generate", "Maintenance.Execute", "Maintenance.Close", "Maintenance.Reject");

    private bool CanEditRequest => CanCreateOrConfirmRequest && (currentStatus == "New" || currentStatus == LocalStatusDraft);
    private bool CanQuote => CanRegisterQuotation && currentStatus == LocalStatusQuoting && activeStoredRequestId.HasValue;
    private bool CanSaveAsDraft => CanEditRequest && SelectedLines.Any();
    private bool CanConfirmRequest => CanEditRequest && SelectedLines.Any();
    private bool CanGenerateRequest => CanGenerateFinalRequest && currentStatus == LocalStatusQuoting && SelectedLines.Any() && SelectedQuotes.Any();

    private IEnumerable<RequestLineItem> SelectedLines => currentLines.Where(x => x.Selected);
    private IEnumerable<QuotationItem> SelectedQuotes => currentQuotes.Where(x => x.Selected);

    private IEnumerable<MobileBranchDto> VisibleBranches =>
        branches
            .Where(IsVisibleBranch)
            .OrderBy(x => x.Code);

    private IEnumerable<StoredRequest> LocalVisibleRequests =>
        storedRequests
            .Where(MatchesLocalScope)
            .Where(MatchesLocalSearch)
            .Where(MatchesLocalStatus)
            .OrderByDescending(x => x.UpdatedAt);

    private IEnumerable<ApiRegisteredItem> FilteredRegistered =>
        registeredItems
            .Where(MatchesApiScope)
            .Where(MatchesApiSearch)
            .Where(MatchesApiStatus)
            .OrderByDescending(x => x.CreatedAt);

    private string ScopeLabel =>
        UserCanSeeAllBranches()
            ? "Todas las sedes"
            : Display(Auth.CurrentUser?.BranchName ?? Auth.CurrentUser?.BranchCode);

    private string PermissionMode
    {
        get
        {
            if (CanGenerateFinalRequest)
            {
                return "Genera";
            }

            if (CanRegisterQuotation)
            {
                return "Cotiza";
            }

            if (CanCreateOrConfirmRequest)
            {
                return "Solicita";
            }

            if (CanViewGeneratedRequests)
            {
                return "Consulta";
            }

            return "Sin permiso";
        }
    }

    private string RequestVisualState => currentStatus switch
    {
        LocalStatusDraft => "Borrador",
        LocalStatusConfirmed => "Confirmada",
        LocalStatusQuoting => "Cotizando",
        LocalStatusGenerated => "Generada",
        _ => "Nueva"
    };

    private readonly (string Value, string Text)[] StatusOptions =
    {
        ("Draft", "Borrador"),
        ("Confirmed", "Confirmada"),
        ("Quoting", "Cotizando"),
        ("InReview", "En revisión"),
        ("Approved", "Aprobada"),
        ("Scheduled", "Programada"),
        ("InExecution", "En ejecución"),
        ("Closed", "Cerrada"),
        ("Rejected", "Rechazada")
    };

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();

        if (!Auth.IsAuthenticated)
        {
            isLoading = false;
            return;
        }

        var refreshedUser = await Api.RefreshCurrentSessionAsync();

        if (refreshedUser is null || !Auth.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", forceLoad: true);
            return;
        }

        ResetHeaderDefaults();
        await LoadStaticAsync();
        await RefreshAsync();

        initialized = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await LoadLocalStateAsync();
        StateHasChanged();
    }

    private async Task LoadStaticAsync()
    {
