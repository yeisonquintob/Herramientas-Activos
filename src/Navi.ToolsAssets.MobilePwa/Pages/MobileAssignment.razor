    private async Task SaveDirectAssignmentAsync()
    {
        if (assignmentForm.AssignmentType == "Responsible" && !CanDirectAssign)
        {
            ShowError("No tienes permiso para confirmar nuevas asignaciones.");
            return;
        }

        if (assignmentForm.AssignmentType == "Warehouse" && !CanReturnAssignment)
        {
            ShowError("No tienes permiso para regresar activos al almacén.");
            return;
        }

        if (assignmentForm.ToolId is null)
        {
            ShowError("Debe seleccionar un activo fijo.");
            return;
        }

        if (assignmentForm.AssignmentType == "Responsible" && assignmentForm.ResponsiblePersonId is null)
        {
            ShowError("Debe seleccionar un responsable.");
            return;
        }

        var selectedToolForMovement = selectedAssignmentTool;

        if (selectedToolForMovement is null)
        {
            ShowError("No se encontró el activo seleccionado o no está dentro de tu alcance.");
            return;
        }

        if (assignmentForm.AssignmentType == "Responsible" && !IsToolAvailableForLoan(selectedToolForMovement))
        {
            ShowError("El activo seleccionado no está disponible para asignación directa. Primero debe estar disponible en almacén/taller.");
            return;
        }

        if (assignmentForm.AssignmentType == "Warehouse" && (assignmentForm.BranchId is null || assignmentForm.LocationId is null))
        {
            ShowError("Debe seleccionar sede y almacén/taller destino.");
            return;
        }

        try
        {
            isSaving = true;

            await Api.AssignFixedAssetAsync(assignmentForm.ToolId.Value, new MobileDirectAssignmentRequest
            {
                AssignmentType = assignmentForm.AssignmentType,
                ResponsiblePersonId = assignmentForm.ResponsiblePersonId,
                BranchId = assignmentForm.BranchId,
                LocationId = assignmentForm.LocationId,
                AssignmentDate = assignmentForm.AssignmentDate,
                Observation = assignmentForm.Observation,
                ChangedBy = Auth.CurrentUser?.UserName ?? "mobile"
            });

            ShowSuccess(assignmentForm.AssignmentType == "Warehouse"
                ? "Activo regresado correctamente a almacén/taller."
                : "Asignación confirmada correctamente.");

            assignmentForm = new MobileDirectAssignmentForm();
            assignmentSearch = string.Empty;

            await LoadAsync();
        }
        catch (Exception ex)
        {
            ShowError($"No se pudo guardar el movimiento: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

