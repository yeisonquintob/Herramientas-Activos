@page "/mro-purchases"
@page "/purchases/mro"
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using System.Net.Http.Json
@using Navi.ToolsAssets.Admin.Services.Auth
@inject IHttpClientFactory HttpClientFactory
@inject WebAuthSessionService AuthSession

<PageTitle>Solicitar Compra AF</PageTitle>

<PermissionGuard Permission="Purchases.View" ModuleName="Solicitar Compra AF">

<section class="purchase-hero">
    <div>
        <span class="purchase-pill">ADQUISICIÓN Y ABASTECIMIENTO</span>
        <h2>Solicitudes de compra AF</h2>
        <p>Flujo interno estilo Dynamics: borrador, revisión, aprobación, rechazo, cierre y posterior envío a ERP.</p>
    </div>

    <div class="purchase-side">
        <div class="purchase-status-box">
            <span>Solicitudes</span>
            <strong>@requests.Count registradas</strong>
        </div>

        <button class="purchase-outline-btn" type="button" @onclick="LoadAsync">
            Actualizar
        </button>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">@successMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<section class="purchase-kpi-grid">
    <article class="purchase-kpi-card">
        <span>Total</span>
        <strong>@requests.Count</strong>
        <small>Solicitudes creadas</small>
    </article>

    <article class="purchase-kpi-card warning">
        <span>En revisión</span>
        <strong>@requests.Count(x => x.Status == "InReview")</strong>
        <small>Pendientes por aprobar</small>
    </article>

    <article class="purchase-kpi-card success">
        <span>Aprobadas</span>
        <strong>@requests.Count(x => x.Status == "Approved")</strong>
        <small>Listas para compras/ERP</small>
    </article>

    <article class="purchase-kpi-card danger">
        <span>Rechazadas</span>
        <strong>@requests.Count(x => x.Status == "Rejected")</strong>
        <small>Devueltas al solicitante</small>
    </article>

    <article class="purchase-kpi-card">
        <span>Dynamics</span>
        <strong>@requests.Count(x => x.SentToDynamics)</strong>
        <small>Marcadas como enviadas</small>
    </article>
</section>

<section class="purchase-layout">
    <article class="purchase-card purchase-form-card">
        <div class="purchase-card-title">
            <div>
                <h3>Nueva solicitud</h3>
                <p>Registra una necesidad de compra como en Dynamics 365.</p>
            </div>
        </div>

        @if (!CanRequest)
        {
            <div class="readonly-box">
                Tu rol puede consultar solicitudes, pero no crear nuevas solicitudes de compra.
            </div>
        }

        <EditForm Model="form" OnValidSubmit="CreateAsync">
            <DataAnnotationsValidator />

            <div class="form-grid">
                <div class="form-group full">
                    <label>Activo / herramienta relacionada</label>
                    <InputSelect class="form-select" @bind-Value="form.ToolAssetIdText" disabled="@(!CanRequest)">
                        <option value="">Solicitud sin activo existente</option>
                        @foreach (var tool in tools)
                        {
                            <option value="@tool.Id">@tool.InternalCode - @tool.Name</option>
                        }
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Código</label>
                    <InputText class="form-control" @bind-Value="form.ItemCode" placeholder="Ej: TALADRO-001" disabled="@(!CanRequest)" />
                </div>

                <div class="form-group">
                    <label>Nombre solicitado</label>
                    <InputText class="form-control" @bind-Value="form.ItemName" placeholder="Ej: Taladro percutor" disabled="@(!CanRequest)" />
                    <ValidationMessage For="@(() => form.ItemName)" />
                </div>

                <div class="form-group">
                    <label>Cantidad</label>
                    <InputNumber class="form-control" @bind-Value="form.Quantity" disabled="@(!CanRequest)" />
                </div>

                <div class="form-group">
                    <label>Unidad</label>
                    <InputText class="form-control" @bind-Value="form.Unit" disabled="@(!CanRequest)" />
                </div>

                <div class="form-group">
                    <label>Propósito de pedido</label>
                    <InputSelect class="form-select" @bind-Value="form.PurchasePurpose" disabled="@(!CanRequest)">
                        <option value="Consumo">Consumo</option>
                        <option value="Activo fijo">Activo fijo</option>
                        <option value="Reposición">Reposición</option>
                        <option value="Mantenimiento">Mantenimiento</option>
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Prioridad</label>
                    <InputSelect class="form-select" @bind-Value="form.Priority" disabled="@(!CanRequest)">
                        <option value="Baja">Baja</option>
                        <option value="Media">Media</option>
                        <option value="Alta">Alta</option>
                        <option value="Crítica">Crítica</option>
                    </InputSelect>
                </div>

                <div class="form-group">
                    <label>Fecha requerida</label>
                    <InputDate class="form-control" @bind-Value="form.RequiredAt" disabled="@(!CanRequest)" />
                </div>

                <div class="form-group">
                    <label>Proveedor sugerido</label>
                    <InputText class="form-control" @bind-Value="form.VendorSuggestion" disabled="@(!CanRequest)" />
                </div>

                <div class="form-group">
                    <label>Valor estimado</label>
                    <InputText class="form-control" @bind-Value="form.EstimatedCostText" placeholder="$0" disabled="@(!CanRequest)" />
                </div>

                <div class="form-group full">
                    <label>Descripción</label>
                    <InputTextArea class="form-control" @bind-Value="form.ItemDescription" rows="2" disabled="@(!CanRequest)" />
                </div>

                <div class="form-group full">
                    <label>Justificación</label>
                    <InputTextArea class="form-control" @bind-Value="form.Justification" rows="3" placeholder="Explica por qué se requiere la compra." disabled="@(!CanRequest)" />
                    <ValidationMessage For="@(() => form.Justification)" />
                </div>

                <div class="form-group full">
                    <label>Notas internas</label>
                    <InputTextArea class="form-control" @bind-Value="form.Notes" rows="2" disabled="@(!CanRequest)" />
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary" disabled="@(!CanRequest || isSaving)">
                    @(isSaving ? "Guardando..." : "Crear borrador")
                </button>

                <button type="button" class="btn btn-success" disabled="@(!CanRequest || isSaving)" @onclick="CreateAndSubmitAsync">
                    Crear y enviar a revisión
                </button>

                <button type="button" class="btn btn-outline-secondary" @onclick="ClearForm">
                    Limpiar
                </button>
            </div>
        </EditForm>
    </article>

    <article class="purchase-card purchase-list-card">
        <div class="purchase-card-title">
            <div>
                <h3>Solicitudes registradas</h3>
                <p>Vista tipo ERP con estado, preparador, fechas y propósito de pedido.</p>
            </div>

            <div class="purchase-filters">
                <select class="form-select" @bind="selectedStatus">
                    <option value="">Todos los estados</option>
                    <option value="Draft">Borrador</option>
                    <option value="InReview">En revisión</option>
                    <option value="Approved">Aprobado</option>
                    <option value="Rejected">Rechazado</option>
                    <option value="Closed">Cerrado</option>
                </select>

                <input class="form-control" placeholder="Buscar solicitud, activo, solicitante..."
                       @bind="searchText" @bind:event="oninput" />

                <button class="btn btn-outline-primary" type="button" @onclick="LoadAsync">
                    Filtrar
                </button>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="loading-box">Cargando solicitudes...</div>
        }
        else if (!FilteredRequests.Any())
        {
            <div class="empty-box">No hay solicitudes con los filtros aplicados.</div>
        }
        else
        {
            <div class="purchase-table-wrapper">
                <table class="purchase-table">
                    <thead>
                        <tr>
                            <th>Solicitud</th>
                            <th>Nombre</th>
                            <th>Preparador</th>
                            <th>Estado</th>
                            <th>Fecha creación</th>
                            <th>Fecha envío</th>
                            <th>Propósito</th>
                            <th>Dynamics</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in FilteredRequests)
                        {
                            <tr>
                                <td>
                                    <strong>@item.RequestNumber</strong>
                                    <small>@item.ItemCode</small>
                                </td>
                                <td>
                                    <strong>@item.ItemName</strong>
                                    <small>@item.Justification</small>
                                </td>
                                <td>@item.PreparedBy</td>
                                <td>
                                    <span class="@GetStatusClass(item.Status)">
                                        @GetStatusLabel(item.Status)
                                    </span>
                                </td>
                                <td>@FormatDate(item.CreatedAt)</td>
                                <td>@FormatDate(item.SubmittedAt)</td>
                                <td>@item.PurchasePurpose</td>
                                <td>
                                    @if (item.SentToDynamics)
                                    {
                                        <span class="status-pill sent">Enviado</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill pending">Pendiente</span>
                                    }
                                </td>
                                <td>
                                    <div class="row-actions">
                                        @if (item.Status == "Draft" && CanRequest)
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => SubmitAsync(item.Id)">
                                                Enviar
                                            </button>
                                        }

                                        @if (item.Status == "InReview" && CanApprove)
                                        {
                                            <button class="btn btn-sm btn-success" @onclick="() => ApproveAsync(item.Id)">
                                                Aprobar
                                            </button>
                                        }

                                        @if (item.Status == "InReview" && CanReject)
                                        {
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RejectAsync(item.Id)">
                                                Rechazar
                                            </button>
                                        }

                                        @if (item.Status == "Approved" && CanApprove)
                                        {
                                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => MarkSentDynamicsAsync(item.Id)">
                                                Marcar Dynamics
                                            </button>

                                            <button class="btn btn-sm btn-outline-dark" @onclick="() => CloseAsync(item.Id)">
                                                Cerrar
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>
</section>

</PermissionGuard>

